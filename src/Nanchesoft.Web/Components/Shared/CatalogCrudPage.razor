<div class="ns-catalog-page">
    @if (!string.IsNullOrWhiteSpace(_clientError))
    {
        <div style="margin-bottom:16px;padding:12px 16px;border-radius:12px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3;white-space:pre-wrap;">
            <strong>Error real:</strong>
            @_clientError
        </div>
    }

    @if (_definition is null)
    {
        @if (string.IsNullOrWhiteSpace(_clientError))
        {
            <div class="ns-catalog-loading">
                <div class="ns-loader"></div>
                <span>Cargando catálogo...</span>
            </div>
        }
        else
        {
            <div style="padding:16px;border-radius:16px;border:1px solid #fecaca;background:#fff7f7;color:#991b1b;">
                <h3 style="margin:0 0 8px 0;">No se pudo cargar el catálogo</h3>
                <div style="white-space:pre-wrap;">@_clientError</div>
            </div>
        }
    }
    else
    {
        <div class="ns-catalog-header">
            <div>
                <div class="ns-catalog-eyebrow">Nanchesoft ERP · Implementación actual</div>
                <h1 class="ns-catalog-title">@_definition.Title</h1>
                <p class="ns-catalog-subtitle">@_definition.Subtitle</p>
            </div>

            <div class="ns-catalog-badge">
                DevExtreme 25.6
            </div>
        </div>

        <div class="ns-kpi-grid">
            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Total</div>
                <div class="ns-kpi-value">@_definition.TotalCount</div>
            </div>

            <div class="ns-kpi-card ns-kpi-card-success">
                <div class="ns-kpi-label">Activos</div>
                <div class="ns-kpi-value">@_definition.ActiveCount</div>
            </div>

            <div class="ns-kpi-card ns-kpi-card-muted">
                <div class="ns-kpi-label">Inactivos</div>
                <div class="ns-kpi-value">@_definition.InactiveCount</div>
            </div>

            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Catálogo</div>
                <div class="ns-kpi-value ns-kpi-value-small">@_definition.CatalogKey</div>
            </div>
        </div>

        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin:18px 0 14px 0;">
            <button class="ns-primary-btn" @onclick="RefreshCatalogAsync">Recargar</button>
            <a class="ns-secondary-btn" href="@_csvHref" download="@GetExportFileName("csv")">Exportar CSV</a>
            <a class="ns-secondary-btn" href="@_jsonHref" download="@GetExportFileName("json")">Exportar JSON</a>
            <a class="ns-secondary-btn" href="@_printHref" target="_blank">Imprimir catálogo</a>
        </div>

        <div class="ns-grid-shell">
            <div id="@_containerId" class="ns-grid-host"></div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string CatalogKey { get; set; } = string.Empty;

    private readonly CatalogAppService _catalogService = CatalogAppService.Instance;

    private CatalogViewDefinition? _definition;
    private DotNetObjectReference<CatalogCrudPage>? _dotNetReference;
    private readonly string _containerId = $"ns-grid-{Guid.NewGuid():N}";
    private bool _gridRendered;
    private string? _clientError;
    private string _csvHref = "#";
    private string _jsonHref = "#";
    private string _printHref = "#";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _clientError = null;
            _definition = await GetDefinitionAsync();
            RebuildExportArtifacts();
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            _definition = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_definition is null)
            return;

        _dotNetReference ??= DotNetObjectReference.Create(this);

        if (firstRender || !_gridRendered)
        {
            try
            {
                _clientError = null;
                await JS.InvokeVoidAsync("nsCrudGrid.renderCrudGrid", _containerId, _definition, _dotNetReference);
                _gridRendered = true;
            }
            catch (Exception ex)
            {
                _clientError = ex.Message;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleInsert(JsonElement row)
    {
        _clientError = null;
        try
        {
            _definition = await ExecuteWriteAsync("insert", null, row);
            RebuildExportArtifacts();
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = true, Definition = _definition };
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            await InvokeAsync(StateHasChangeedSafe);
            return new CatalogCrudOperationResult { Success = false, Error = ex.Message, Definition = _definition ?? await GetDefinitionAsync() };
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleUpdate(string key, JsonElement changes)
    {
        _clientError = null;
        try
        {
            _definition = await ExecuteWriteAsync("update", key, changes);
