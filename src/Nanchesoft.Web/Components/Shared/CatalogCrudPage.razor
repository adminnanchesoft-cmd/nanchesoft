    private void RebuildExportArtifacts()
    {
        if (_definition is null)
        {
            _csvHref = _jsonHref = _printHref = _importTemplateHref = "#";
            return;
        }

        var visibleColumns = _definition.Columns.Where(x => x.Visible).ToList();
        var csv = new StringBuilder();
        csv.AppendLine(string.Join(",", visibleColumns.Select(x => EscapeCsv(x.Caption))));
        foreach (var row in _definition.Rows)
        {
            csv.AppendLine(string.Join(",", visibleColumns.Select(c => EscapeCsv(GetDisplayValue(c, row)))));
        }

        var json = JsonSerializer.Serialize(_definition.Rows, new JsonSerializerOptions { WriteIndented = true });
        var html = BuildPrintableHtml(_definition, visibleColumns);

        _csvHref = BuildDataUri("text/csv;charset=utf-8", csv.ToString());
        _jsonHref = BuildDataUri("application/json;charset=utf-8", json);
        _printHref = BuildDataUri("text/html;charset=utf-8", html);

        if (_definition.AllowImport)
            RebuildImportTemplate(visibleColumns);
    }

    private void RebuildImportTemplate(List<CatalogColumnDefinition> visibleColumns)
    {
        // Template: editable columns (skip ID key, company and IsActive — auto-handled)
        var importCols = visibleColumns
            .Where(x => x.AllowEditing && x.DataField != _definition!.KeyExpr
                     && !_importAutoExcludeFields.Contains(x.DataField))
            .ToList();

        var sb = new StringBuilder();
        sb.AppendLine(string.Join(",", importCols.Select(x => EscapeCsv(x.Caption))));

        // Add an example row with hints
        var exampleCells = importCols.Select(col =>
        {
            if (col.UseLookup && col.LookupItems.Count > 0)
                return EscapeCsv(col.LookupItems[0].Name);
            return col.DataType switch
            {
                "boolean" => "Sí",
                "number"  => "0",
                "date"    => DateTime.Today.ToString("dd/MM/yyyy"),
                _         => EscapeCsv($"Ejemplo {col.Caption}")
            };
        });
        sb.AppendLine(string.Join(",", exampleCells));
        _importTemplateHref = BuildDataUri("text/csv;charset=utf-8", sb.ToString());
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null || _definition is null) return;

        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        using var reader = new StreamReader(ms, Encoding.UTF8);
        var content = await reader.ReadToEndAsync();

        await ProcessCsvContent(content);
    }

    [JSInvokable]
    public async Task HandleDroppedCsv(string csvText)
    {
        if (_definition is null) return;
        await ProcessCsvContent(csvText);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ProcessCsvContent(string content)
    {
        _importRows.Clear();
        _importHeaders.Clear();
        _importStatuses.Clear();
        _importAutoCode.Clear();
        _importEditCodes.Clear();
        _importHasCodeCol = false;
        _importCsvCodeIdx = -1;
        _importCsvNameIdx = -1;
        _importCodeDisplayIdx = -1;
        _importDone = 0;
        _importOk = 0;
        _importMappings.Clear();

        var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries)
                           .Select(l => l.TrimEnd('\r'))
                           .Where(l => !string.IsNullOrWhiteSpace(l))
                           .ToList();

        if (lines.Count < 2) return;

        var rawHeaders = ParseCsvLine(lines[0]);

        var importCols = _definition.Columns
            .Where(x => x.AllowEditing && x.DataField != _definition.KeyExpr && x.Visible
                     && !_importAutoExcludeFields.Contains(x.DataField))
            .ToList();

        var codeColDef = importCols.FirstOrDefault(x => x.DataField == "Code");
        var nameColDef = importCols.FirstOrDefault(x => x.DataField == "Name");

        // Match each CSV header to a column definition by name/alias
        for (int h = 0; h < rawHeaders.Count; h++)
        {
            var col = FindImportColDef(rawHeaders[h], importCols);
            if (col?.DataField == "Code") _importCsvCodeIdx = h;
            if (col?.DataField == "Name") _importCsvNameIdx = h;
            _importMappings.Add(new ImportHeaderMapping
            {
                SourceHeader = rawHeaders[h],
                TargetField = col?.DataField ?? string.Empty,
                TargetLabel = col?.Caption ?? string.Empty,
                Found = col is not null
            });
        }

        _importHasCodeCol = _importCsvCodeIdx >= 0;

        // Build display headers — prepend "Código (auto)" when Code is not in CSV
        if (!_importHasCodeCol && codeColDef is not null)
        {
            _importHeaders = new List<string> { $"{codeColDef.Caption} (auto)" }.Concat(rawHeaders).ToList();
            _importCodeDisplayIdx = 0;
        }
        else
        {
            _importHeaders = new List<string>(rawHeaders);
            _importCodeDisplayIdx = _importCsvCodeIdx;
        }

        // Parse data rows
        for (int i = 1; i < lines.Count; i++)
        {
            var rawCells = ParseCsvLine(lines[i]);
            while (rawCells.Count < rawHeaders.Count) rawCells.Add("");

            var nameValue = _importCsvNameIdx >= 0 && _importCsvNameIdx < rawCells.Count
                ? rawCells[_importCsvNameIdx].Trim()
                : "";

            var codeFromCsv = _importHasCodeCol && _importCsvCodeIdx < rawCells.Count
                ? rawCells[_importCsvCodeIdx].Trim()
                : "";

            var isAutoCode = string.IsNullOrWhiteSpace(codeFromCsv);
            var effectiveCode = isAutoCode ? nameValue : codeFromCsv;

            _importAutoCode.Add(isAutoCode);
            _importEditCodes.Add(effectiveCode);

            List<string> displayRow;
            if (!_importHasCodeCol && codeColDef is not null)
            {
                displayRow = new List<string> { effectiveCode };
                displayRow.AddRange(rawCells.Take(rawHeaders.Count));
            }
            else
            {
                displayRow = rawCells.Take(rawHeaders.Count).ToList();
                if (_importCsvCodeIdx >= 0 && isAutoCode && _importCsvCodeIdx < displayRow.Count)
                    displayRow[_importCsvCodeIdx] = effectiveCode;
            }

            _importRows.Add(displayRow);
        }
    }

    private async Task ExecuteImportAsync()
    {
        if (_definition is null || _importRows.Count == 0) return;

        _importing = true;
        _importDone = 0;
        _importOk = 0;
        _importStatuses = Enumerable.Repeat("", _importRows.Count).ToList();

        var importCols = _definition.Columns
            .Where(x => x.AllowEditing && x.DataField != _definition.KeyExpr
                     && !_importAutoExcludeFields.Contains(x.DataField))
            .ToList();

        var codeColDef = importCols.FirstOrDefault(x => x.DataField == "Code");

        // Pre-build duplicate sets from catalog's current state
        var existingCodes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var existingNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var r in _definition.Rows)
        {
            var c = GetRowString(r, "Code"); if (c is not null) existingCodes.Add(c.Trim());
            var n = GetRowString(r, "Name");  if (n is not null) existingNames.Add(n.Trim());
        }

        // Cache of quickCreateKey → ID for "POR IDENTIFICAR" records already created this session
        var porIdentificarCache = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        for (int i = 0; i < _importRows.Count; i++)
        {
            var cells = _importRows[i];
            var payload = new Dictionary<string, object?>();

            // Map cells by header name (not position)
            for (int j = 0; j < Math.Min(_importHeaders.Count, cells.Count); j++)
            {
                var col = FindImportColDef(_importHeaders[j], importCols);

                // Skip unrecognized headers (incl. "Código (auto)" virtual col) and Code (set separately)
                if (col is null || col.DataField == "Code") continue;

                var raw = cells[j].Trim();

                if (col.UseLookup && col.LookupItems.Count > 0)
                {
                    var match = col.LookupItems.FirstOrDefault(x =>
                        string.Equals(x.Name, raw, StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(x.Id, raw, StringComparison.OrdinalIgnoreCase));

                    if (match is null && !string.IsNullOrWhiteSpace(col.QuickCreateKey))
                    {
                        // FK missing — create "POR IDENTIFICAR" in the referenced catalog
                        var porId = await GetOrCreatePorIdentificarAsync(col.QuickCreateKey, col.LookupItems, porIdentificarCache);
                        payload[col.DataField] = porId;
                    }
                    else
                    {
                        payload[col.DataField] = match?.Id ?? (string.IsNullOrEmpty(raw) ? null : raw);
                    }
                }
                else if (col.DataType == "boolean")
                    payload[col.DataField] = raw is "Sí" or "Si" or "si" or "sí" or "true" or "True" or "1" or "yes" or "Yes";
                else if (col.DataType == "number" && decimal.TryParse(raw, out var num))
                    payload[col.DataField] = num;
                else if (col.DataType == "date" && DateTime.TryParse(raw, out var dt))
                    payload[col.DataField] = dt;
                else
                    payload[col.DataField] = raw;
            }

            // Set Code from editable codes (auto-generated or user-edited)
            if (codeColDef is not null)
                payload["Code"] = i < _importEditCodes.Count ? _importEditCodes[i].Trim() : "";

            // Always active on import; company auto-resolved by API from session context
            payload["IsActive"] = true;
            payload.Remove("CompanyId");

            // Duplicate check
            var codeVal = payload.TryGetValue("Code", out var cvObj) ? cvObj?.ToString()?.Trim() ?? "" : "";
            var nameVal = payload.TryGetValue("Name", out var nvObj) ? nvObj?.ToString()?.Trim() ?? "" : "";

            var isDuplicate = (!string.IsNullOrEmpty(codeVal) && codeColDef is not null && existingCodes.Contains(codeVal))
                           || (!string.IsNullOrEmpty(nameVal) && existingNames.Contains(nameVal));
            if (isDuplicate)
            {
                _importStatuses[i] = "Duplicado — omitido";
                _importDone = i + 1;
                StateHasChanged();
                continue;
            }

            try
            {
                var jsonElement = JsonSerializer.Deserialize<JsonElement>(JsonSerializer.Serialize(payload));
                await ExecuteWriteAsync("insert", null, jsonElement);
                _importStatuses[i] = "OK";
                _importOk++;
                if (!string.IsNullOrEmpty(codeVal)) existingCodes.Add(codeVal);
                if (!string.IsNullOrEmpty(nameVal)) existingNames.Add(nameVal);
            }
            catch (Exception ex)
            {
                _importStatuses[i] = $"Error: {ex.Message}";
            }

            _importDone = i + 1;
            StateHasChanged();
        }

        _importing = false;
        await RefreshCatalogAsync();
    }

    private async Task<string?> GetOrCreatePorIdentificarAsync(
        string quickCreateKey,
        List<CatalogLookupItem> currentItems,
        Dictionary<string, string> cache)
    {
        const string porNombre = "POR IDENTIFICAR";
        const string porCodigo = "POR-IDENTIFICAR";

        // Return from cache if already created this session
        if (cache.TryGetValue(quickCreateKey, out var cached)) return cached;

        // Check if already exists in current lookup items
        var existing = currentItems.FirstOrDefault(x =>
            x.Name.Equals(porNombre, StringComparison.OrdinalIgnoreCase) ||
            x.Name.Contains("POR IDENTIFICAR", StringComparison.OrdinalIgnoreCase));
        if (existing is not null)
        {
            cache[quickCreateKey] = existing.Id;
            return existing.Id;
        }

        // Create it
        try
        {
            var result = await HandleQuickCreate(quickCreateKey, porCodigo, porNombre);
            if (result.Success && !string.IsNullOrEmpty(result.NewId))
            {
                cache[quickCreateKey] = result.NewId;
                return result.NewId;
            }
        }
        catch { }

        return null;
    }

    // Fields always excluded from import: company is auto-resolved by API; IsActive always set to true
    private static readonly HashSet<string> _importAutoExcludeFields = new(StringComparer.OrdinalIgnoreCase)
    {
        "CompanyId", "IsActive",
    };

    private static readonly Dictionary<string, string> _importColumnAliases = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Nombre"] = "Name",
        ["Código"] = "Code",
        ["Codigo"] = "Code",
        ["Clave"] = "Code",
        ["Descripción"] = "Description",
        ["Descripcion"] = "Description",
        ["Activo"] = "IsActive",
        ["Active"] = "IsActive",
        ["Department"] = "DepartmentId",
        ["Departamento"] = "DepartmentId",
    };

    private static CatalogColumnDefinition? FindImportColDef(string header, List<CatalogColumnDefinition> importCols)
    {
        var h = header.Trim();
        if (string.IsNullOrEmpty(h)) return null;
        var canonical = _importColumnAliases.TryGetValue(h, out var alias) ? alias : h;
        return importCols.FirstOrDefault(c =>
            string.Equals(c.Caption, h, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(c.DataField, h, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(c.DataField, canonical, StringComparison.OrdinalIgnoreCase));
    }

    private static List<string> ParseCsvLine(string line)
    {
        var result = new List<string>();
        var sb = new StringBuilder();
        bool inQuote = false;

        for (int i = 0; i < line.Length; i++)
        {
            var c = line[i];
            if (c == '"')
            {
                if (inQuote && i + 1 < line.Length && line[i + 1] == '"')
                { sb.Append('"'); i++; }
                else inQuote = !inQuote;
            }
            else if ((c == ',' || c == ';') && !inQuote)
            { result.Add(sb.ToString()); sb.Clear(); }
            else
                sb.Append(c);
        }
        result.Add(sb.ToString());
        return result;
    }

    private sealed class ImportHeaderMapping
    {
        public string SourceHeader { get; set; } = string.Empty;
        public string TargetField { get; set; } = string.Empty;
        public string TargetLabel { get; set; } = string.Empty;
        public bool Found { get; set; }
    }

    private static string GetDisplayValue(CatalogColumnDefinition column, Dictionary<string, object?> row)
    {
        if (!row.TryGetValue(column.DataField, out var raw) || raw is null)
            return string.Empty;

        var value = raw.ToString() ?? string.Empty;
        if (!column.UseLookup || column.LookupItems.Count == 0)
            return value;

        var match = column.LookupItems.FirstOrDefault(x => string.Equals(x.Id, value, StringComparison.OrdinalIgnoreCase));
        return match?.Name ?? value;
    }

    private static string EscapeCsv(string? value)
    {
        var normalized = (value ?? string.Empty).Replace("\r", " ").Replace("\n", " ");
        if (normalized.Contains('"') || normalized.Contains(',') || normalized.Contains(';'))
            return $"\"{normalized.Replace("\"", "\"\"")}\"";
        return normalized;
    }

    private static string BuildDataUri(string mimeType, string content)
        => $"data:{mimeType},{Uri.EscapeDataString(content)}";

    private string GetExportFileName(string extension)
        => $"{SanitizeFileName(_definition?.CatalogKey ?? CatalogKey)}-{DateTime.Now:yyyyMMdd-HHmmss}.{extension}";

    private int GetMetadataInt(string key)
    {
        if (_definition?.Metadata is null || !_definition.Metadata.TryGetValue(key, out var value) || value is null)
            return 0;
        return value switch
        {
            int i => i,
            long l => (int)l,
            decimal d => (int)d,
            double dbl => (int)dbl,
            JsonElement e when e.ValueKind == JsonValueKind.Number && e.TryGetInt32(out var parsed) => parsed,
            _ when int.TryParse(value.ToString(), out var parsed) => parsed,
            _ => 0
        };
    }

    private static string SanitizeFileName(string value)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var cleaned = new string(value.Select(c => invalid.Contains(c) ? '-' : c).ToArray());
        return string.IsNullOrWhiteSpace(cleaned) ? "catalogo" : cleaned;
    }

    private static string BuildPrintableHtml(CatalogViewDefinition definition, List<CatalogColumnDefinition> columns)
    {
        var sb = new StringBuilder();
        sb.Append("<html><head><meta charset='utf-8'><title>");
        sb.Append(WebUtility.HtmlEncode(definition.Title));
        sb.Append("</title><style>");
        sb.Append("body{font-family:Segoe UI,Arial,sans-serif;margin:24px;color:#0f172a;} h1{margin:0 0 8px 0;} p{margin:0 0 18px 0;color:#475569;} table{width:100%;border-collapse:collapse;font-size:12px;} th,td{border:1px solid #cbd5e1;padding:8px;vertical-align:top;} th{background:#e2e8f0;text-align:left;} .meta{margin-bottom:16px;color:#475569;font-size:12px;} @media print{body{margin:12px;} button{display:none;}} </style></head><body onload='window.print()'>");
        sb.Append($"<h1>{WebUtility.HtmlEncode(definition.Title)}</h1>");
        sb.Append($"<p>{WebUtility.HtmlEncode(definition.Subtitle)}</p>");
        sb.Append($"<div class='meta'>Catálogo: {WebUtility.HtmlEncode(definition.CatalogKey)} · Total: {definition.TotalCount} · Fecha: {DateTime.Now:dd/MM/yyyy HH:mm}</div>");
        sb.Append("<table><thead><tr>");
        foreach (var c in columns)
            sb.Append($"<th>{WebUtility.HtmlEncode(c.Caption)}</th>");
        sb.Append("</tr></thead><tbody>");
        foreach (var row in definition.Rows)
        {
            sb.Append("<tr>");
            foreach (var c in columns)
                sb.Append($"<td>{WebUtility.HtmlEncode(GetDisplayValue(c, row))}</td>");
            sb.Append("</tr>");
        }
        sb.Append("</tbody></table></body></html>");
        return sb.ToString();
    }

    private Task StateHasChangeedSafe()
    {
        StateHasChanged();
        return Task.CompletedTask;
    }

