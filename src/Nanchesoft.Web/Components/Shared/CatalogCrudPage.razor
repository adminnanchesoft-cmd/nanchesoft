<div class="ns-catalog-page">
    @if (!string.IsNullOrWhiteSpace(_clientError))
    {
        <div style="margin-bottom:16px;padding:12px 16px;border-radius:12px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3;white-space:pre-wrap;">
            <strong>Error real:</strong>
            @_clientError
        </div>
    }

    @if (_definition is null)
    {
        @if (string.IsNullOrWhiteSpace(_clientError))
        {
            <div class="ns-catalog-loading">
                <div class="ns-loader"></div>
                <span>Cargando catálogo...</span>
            </div>
        }
        else
        {
            <div style="padding:16px;border-radius:16px;border:1px solid #fecaca;background:#fff7f7;color:#991b1b;">
                <h3 style="margin:0 0 8px 0;">No se pudo cargar el catálogo</h3>
                <div style="white-space:pre-wrap;">@_clientError</div>
            </div>
        }
    }
    else
    {
        <div class="ns-catalog-header">
            <div>
                <div class="ns-catalog-eyebrow">Nanchesoft ERP · Implementación actual</div>
                <h1 class="ns-catalog-title">@_definition.Title</h1>
                <p class="ns-catalog-subtitle">@_definition.Subtitle</p>
            </div>

            <div class="ns-catalog-badge">
                DevExtreme 25.6
            </div>
        </div>

        <div class="ns-kpi-grid">
            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Total</div>
                <div class="ns-kpi-value">@_definition.TotalCount</div>
            </div>

            <div class="ns-kpi-card ns-kpi-card-success">
                <div class="ns-kpi-label">Activos</div>
                <div class="ns-kpi-value">@_definition.ActiveCount</div>
            </div>

            <div class="ns-kpi-card ns-kpi-card-muted">
                <div class="ns-kpi-label">Inactivos</div>
                <div class="ns-kpi-value">@_definition.InactiveCount</div>
            </div>

            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Catálogo</div>
                <div class="ns-kpi-value ns-kpi-value-small">@_definition.CatalogKey</div>
            </div>
        </div>

        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin:18px 0 14px 0;">
            <button class="ns-primary-btn" @onclick="RefreshCatalogAsync">Recargar</button>
            <a class="ns-secondary-btn" href="@_csvHref" download="@GetExportFileName("csv")">Exportar CSV</a>
            <a class="ns-secondary-btn" href="@_jsonHref" download="@GetExportFileName("json")">Exportar JSON</a>
            <a class="ns-secondary-btn" href="@_printHref" target="_blank">Imprimir catálogo</a>
            @if (_definition.AllowImport)
            {
                <button class="ns-secondary-btn" @onclick="() => _showImport = !_showImport">
                    @(_showImport ? "Cerrar importación" : "Importar CSV")
                </button>
                <a class="ns-secondary-btn" href="@_importTemplateHref" download="@($"plantilla_{_definition.CatalogKey}.csv")">Descargar plantilla</a>
            }
        </div>

        @if (_definition.AllowImport && _showImport)
        {
            <div style="margin:0 0 18px 0;padding:20px;border-radius:14px;border:1px solid #dbeafe;background:#f0f7ff;">
                <h3 style="margin:0 0 12px 0;font-size:1rem;font-weight:600;color:#1d4ed8;">Importar desde CSV</h3>
                <p style="margin:0 0 14px 0;font-size:.875rem;color:#475569;">
                    Descarga la plantilla, llena los datos y sube el archivo. Las columnas deben mantenerse en el mismo orden.
                </p>

                <InputFile OnChange="OnImportFileSelected" accept=".csv" style="display:block;margin-bottom:12px;" />

                @if (_importRows.Count > 0)
                {
                    <div style="margin:12px 0;overflow-x:auto;max-height:260px;border:1px solid #bfdbfe;border-radius:8px;">
                        <table style="border-collapse:collapse;font-size:.8rem;width:100%;">
                            <thead>
                                <tr style="background:#eff6ff;position:sticky;top:0;">
                                    <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;">#</th>
                                    @foreach (var h in _importHeaders)
                                    {
                                        <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;white-space:nowrap;">@h</th>
                                    }
                                    <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _importRows.Count; i++)
                                {
                                    var row = _importRows[i];
                                    var status = i < _importStatuses.Count ? _importStatuses[i] : "";
                                    var bg = status == "OK" ? "#f0fdf4" : status.StartsWith("Error") ? "#fff1f2" : "white";
                                    <tr style="background:@bg;">
                                        <td style="padding:5px 10px;border-bottom:1px solid #e2e8f0;color:#64748b;">@(i + 1)</td>
                                        @foreach (var cell in row)
                                        {
                                            <td style="padding:5px 10px;border-bottom:1px solid #e2e8f0;">@cell</td>
                                        }
                                        <td style="padding:5px 10px;border-bottom:1px solid #e2e8f0;font-size:.75rem;color:@(status == "OK" ? "#16a34a" : status.StartsWith("Error") ? "#dc2626" : "#94a3b8");">
                                            @status
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p style="margin:8px 0 14px 0;font-size:.8rem;color:#64748b;">@_importRows.Count fila(s) detectada(s)</p>

                    @if (!_importing)
                    {
                        <button class="ns-primary-btn" @onclick="ExecuteImportAsync" disabled="@(_importRows.Count == 0)">
                            Importar @_importRows.Count registro(s)
                        </button>
                    }
                    else
                    {
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div class="ns-loader" style="width:20px;height:20px;border-width:2px;"></div>
                            <span style="font-size:.875rem;color:#475569;">Importando @_importDone de @_importRows.Count...</span>
                        </div>
                    }

                    @if (_importDone > 0 && !_importing)
                    {
                        <p style="margin:10px 0 0 0;font-size:.875rem;color:#16a34a;font-weight:600;">
                            ✓ @_importOk de @_importRows.Count registros importados correctamente.
                        </p>
                    }
                }
            </div>
        }

        <div class="ns-grid-shell">
            <div id="@_containerId" class="ns-grid-host"></div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string CatalogKey { get; set; } = string.Empty;

    private readonly CatalogAppService _catalogService = CatalogAppService.Instance;

    private CatalogViewDefinition? _definition;
    private DotNetObjectReference<CatalogCrudPage>? _dotNetReference;
    private readonly string _containerId = $"ns-grid-{Guid.NewGuid():N}";
    private bool _gridRendered;
    private string? _clientError;
    private string _csvHref = "#";
    private string _jsonHref = "#";
    private string _printHref = "#";
    private string _importTemplateHref = "#";

    // Import state
    private bool _showImport;
    private List<string> _importHeaders = [];
    private List<List<string>> _importRows = [];
    private List<string> _importStatuses = [];
    private bool _importing;
    private int _importDone;
    private int _importOk;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _clientError = null;
            _definition = await GetDefinitionAsync();
            RebuildExportArtifacts();
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            _definition = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_definition is null)
            return;

        _dotNetReference ??= DotNetObjectReference.Create(this);

        if (firstRender || !_gridRendered)
        {
            try
            {
                _clientError = null;
                await JS.InvokeVoidAsync("nsCrudGrid.renderCrudGrid", _containerId, _definition, _dotNetReference);
                _gridRendered = true;
            }
            catch (Exception ex)
            {
                _clientError = ex.Message;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleInsert(JsonElement row)
    {
        _clientError = null;
        try
        {
            _definition = await ExecuteWriteAsync("insert", null, row);
            RebuildExportArtifacts();
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = true, Definition = _definition };
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            await InvokeAsync(StateHasChangeedSafe);
            return new CatalogCrudOperationResult { Success = false, Error = ex.Message, Definition = _definition ?? await GetDefinitionAsync() };
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleUpdate(string key, JsonElement changes)
    {
        _clientError = null;
        try
        {
            _definition = await ExecuteWriteAsync("update", key, changes);
            RebuildExportArtifacts();
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = true, Definition = _definition };
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = false, Error = ex.Message, Definition = _definition ?? await GetDefinitionAsync() };
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleDelete(string key)
    {
        _clientError = null;
        try
        {
            _definition = CatalogKey.ToLowerInvariant() switch
            {
                "companies" => await CompanyApiService.DeleteAsync(key),
                "branches" => await BranchApiService.DeleteAsync(key),
                "warehouses" => await WarehouseApiService.DeleteAsync(key),
                "users" => await UserApiService.DeleteAsync(key),
                "roles" => await RoleApiService.DeleteAsync(key),
                "permissions" => await PermissionApiService.DeleteAsync(key),
                "sessions" => await SessionApiService.DeleteAsync(key),
                "accesslogs" => await AccessLogApiService.DeleteAsync(key),
                "currencies" or "exchange-rates" or "taxes" or "units" or "banks" or
                "countries" or "states" or "cities" or "document-series" or
                "document-folios" or "company-settings" => await MasterCatalogApiService.DeleteAsync(CatalogKey, key),
                "customers" or "suppliers" or "contacts" or "addresses" or "bank-accounts" or
                "categories" or "brands" or "models" or "items" or "price-lists" or "barcodes" => await ThirdPartiesProductsApiService.DeleteAsync(CatalogKey, key),
                "purchase-requisitions" or "purchase-orders" or "purchase-receipts" or "purchase-invoices" or "purchase-returns" => await PurchaseApiService.DeleteAsync(CatalogKey, key),
                "inventory-entries" or "inventory-exits" or "inventory-transfers" or "inventory-adjustments" or "physical-counts" => await InventoryApiService.DeleteAsync(CatalogKey, key),
                "sales-quotes" or "sales-orders" or "sales-shipments" or "sales-invoices" or "sales-returns" or "credit-notes" => await SalesApiService.DeleteAsync(CatalogKey, key),
                "service-catalog" or "customer-service-rates" or "service-notes" => await ServiceBillingApiService.DeleteAsync(CatalogKey, key),
                "tenants" => await TenantApiService.DeleteAsync(key),
                "plans" => await PlanApiService.DeleteAsync(key),
                "hr-departments" or "hr-positions" or "hr-employees" or "hr-incidents" or "employee-contracts" or "payroll-period-types" or "payroll-periods" or "payroll-concepts" or "payroll-runs" or "payroll-run-lines" or "payroll-run-line-details" => await HumanResourcesApiService.DeleteAsync(CatalogKey, key),
                "time-clock" or "attendance-daily-summaries" or "payroll-recurring-movements" or "prepayroll-adjustments" or "prepayroll-cutoffs" or "employee-loans" or "employee-loan-deductions" or
                "payroll-source-applications" or "payroll-receipt-control" or "payroll-run-closings" or "payroll-dispersion-batches" or "payroll-dispersion-lines" or
                "payroll-accounting-postings" or "payroll-tax-accumulators" or "payroll-employer-obligations" or "payroll-fiscal-reconciliations" => await PayrollOperationsApiService.DeleteAsync(CatalogKey, key),
                "hr-shifts" or "hr-work-schedules" or "hr-time-clock-devices" or "hr-leave-types" or "hr-vacation-requests" or
                "hr-employee-documents" or "hr-employee-movements" or "hr-employee-certifications" or "hr-recruitment-vacancies" or "hr-candidate-applications" or
                "hr-onboarding-checklists" or "hr-performance-reviews" or "hr-competency-assessments" or "hr-succession-plans" => await HumanResourcesEnterpriseApiService.DeleteAsync(CatalogKey, key),
                "cash-accounts" or "bank-accounts-own" or "treasury-incomes" or "treasury-expenses" or "treasury-receipts" or "treasury-payments" or "treasury-reconciliations" => await TreasuryApiService.DeleteAsync(CatalogKey, key),
                "colors" or "leather-types" or "soles" or "manufacturing-types" or "toe-caps" or "sole-colors" or "dies" or "quality-control-dies" or "folio-patterns" or "unit-conversions" or "size-runs" or "families" or "lasts" or "lines" or "styles" or "embroidery-patterns" or "item-engineering-profiles" or "material-characteristics" or "material-sizes" or "material-families" or "material-subfamilies" or "material-items" or "material-suppliers" or "material-supplier-cost-history" or "finished-products" or "product-components" or "finished-product-materials" or "product-consumption-profiles" or "production-phases" => await ProductEngineeringApiService.DeleteAsync(CatalogKey, key),
                "production-orders" or "piecework-rates" => await ProductionApiService.DeleteAsync(CatalogKey, key),
                _ => await _catalogService.DeleteAsync(CatalogKey, key)
            };
            RebuildExportArtifacts();
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = true, Definition = _definition };
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = false, Error = ex.Message, Definition = _definition ?? await GetDefinitionAsync() };
        }
    }

    [JSInvokable]
    public void HandleNavigateTo(string url) => Nav.NavigateTo(url);

    [JSInvokable]
    public async Task<QuickCreateResult> HandleQuickCreate(string quickCreateKey, string code, string name)
    {
        try
        {
            var payloadJson = JsonSerializer.Serialize(new { Code = code.Trim().ToUpperInvariant(), Name = name.Trim(), IsActive = true });
            using var doc = JsonDocument.Parse(payloadJson);
            var payload = doc.RootElement.Clone();

            var updatedDef = await RouteQuickInsertAsync(quickCreateKey.ToLowerInvariant(), payload);
            var keyExpr = updatedDef.KeyExpr;

            var allItems = updatedDef.Rows
                .Select(r =>
                {
                    var id = r.TryGetValue(keyExpr, out var idVal) ? idVal?.ToString() ?? "" : "";
                    var rowCode = GetRowString(r, "Code") ?? "";
                    var rowName = GetRowString(r, "Name") ?? rowCode;
                    var display = string.IsNullOrEmpty(rowCode) ? rowName : $"{rowCode} · {rowName}";
                    return new CatalogLookupItem { Id = id, Name = display };
                })
                .Where(x => !string.IsNullOrEmpty(x.Id))
                .OrderBy(x => x.Name)
                .ToList();

            var codeUpper = code.Trim().ToUpperInvariant();
            var newItem = allItems.FirstOrDefault(x => x.Name.StartsWith(codeUpper + " ·", StringComparison.OrdinalIgnoreCase))
                       ?? allItems.LastOrDefault(x => x.Name.Contains(codeUpper, StringComparison.OrdinalIgnoreCase));

            return new QuickCreateResult { Success = true, NewId = newItem?.Id ?? "", AllItems = allItems };
        }
        catch (Exception ex)
        {
            return new QuickCreateResult { Success = false, Error = ex.Message };
        }
    }

    private static string? GetRowString(Dictionary<string, object?> row, string key)
    {
        if (row.TryGetValue(key, out var val)) return val?.ToString();
        var kv = row.FirstOrDefault(x => string.Equals(x.Key, key, StringComparison.OrdinalIgnoreCase));
        return kv.Value?.ToString();
    }

    private Task<CatalogViewDefinition> RouteQuickInsertAsync(string catalogKey, JsonElement payload)
        => catalogKey switch
        {
            "hr-departments" or "hr-positions" or "hr-employees" or "hr-incidents" or "employee-contracts"
            or "payroll-period-types" or "payroll-periods" or "payroll-concepts" or "payroll-runs" or "payroll-run-lines" or "payroll-run-line-details"
                => HumanResourcesApiService.InsertAsync(catalogKey, payload),
            "time-clock" or "attendance-daily-summaries" or "payroll-recurring-movements" or "prepayroll-adjustments"
            or "prepayroll-cutoffs" or "employee-loans" or "employee-loan-deductions" or "payroll-source-applications"
            or "payroll-receipt-control" or "payroll-run-closings" or "payroll-dispersion-batches" or "payroll-dispersion-lines"
            or "payroll-accounting-postings" or "payroll-tax-accumulators" or "payroll-employer-obligations" or "payroll-fiscal-reconciliations"
                => PayrollOperationsApiService.InsertAsync(catalogKey, payload),
            "hr-shifts" or "hr-work-schedules" or "hr-time-clock-devices" or "hr-leave-types" or "hr-vacation-requests"
            or "hr-employee-documents" or "hr-employee-movements" or "hr-employee-certifications" or "hr-recruitment-vacancies"
            or "hr-candidate-applications" or "hr-onboarding-checklists" or "hr-performance-reviews"
            or "hr-competency-assessments" or "hr-succession-plans"
                => HumanResourcesEnterpriseApiService.InsertAsync(catalogKey, payload),
            "currencies" or "exchange-rates" or "taxes" or "units" or "banks" or "countries" or "states"
            or "cities" or "document-series" or "document-folios" or "company-settings"
                => MasterCatalogApiService.InsertAsync(catalogKey, payload),
            "customers" or "suppliers" or "contacts" or "addresses" or "bank-accounts" or "categories"
            or "brands" or "models" or "items" or "price-lists" or "barcodes"
                => ThirdPartiesProductsApiService.InsertAsync(catalogKey, payload),
            "colors" or "leather-types" or "soles" or "manufacturing-types" or "toe-caps" or "sole-colors"
            or "dies" or "quality-control-dies" or "folio-patterns" or "unit-conversions" or "size-runs"
            or "families" or "lasts" or "lines" or "styles" or "embroidery-patterns" or "item-engineering-profiles"
            or "material-characteristics" or "material-sizes" or "material-families" or "material-subfamilies"
            or "material-items" or "material-suppliers" or "material-supplier-cost-history" or "finished-products"
            or "product-components" or "finished-product-materials" or "product-consumption-profiles" or "production-phases"
                => ProductEngineeringApiService.InsertAsync(catalogKey, payload),
            "production-orders" or "production-vouchers" or "piecework-records" or "piecework-rates"
            or "production-cells" or "production-surplus"
                => ProductionApiService.InsertAsync(catalogKey, payload),
            _ => throw new InvalidOperationException($"Quick-create no soportado para el catálogo: '{catalogKey}'.")
        };

    public sealed class QuickCreateResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
        public string NewId { get; set; } = "";
        public List<CatalogLookupItem> AllItems { get; set; } = [];
    }

    [JSInvokable]
    public async Task<CatalogViewDefinition> HandleRefresh()
    {
        _clientError = null;
        _definition = await GetDefinitionAsync();
        RebuildExportArtifacts();
        await InvokeAsync(StateHasChanged);
        return _definition;
    }

    private async Task RefreshCatalogAsync()
    {
        _definition = await GetDefinitionAsync();
        RebuildExportArtifacts();
        _gridRendered = false;
        await JS.InvokeVoidAsync("nsCrudGrid.disposeCrudGrid", _containerId);
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("nsCrudGrid.disposeCrudGrid", _containerId); } catch { }
        _dotNetReference?.Dispose();
    }

    private async Task<CatalogViewDefinition> ExecuteWriteAsync(string action, string? key, JsonElement row)
    {
        return CatalogKey.ToLowerInvariant() switch
        {
            "companies" => action == "insert" ? await CompanyApiService.InsertAsync(row) : await CompanyApiService.UpdateAsync(key!, row),
            "branches" => action == "insert" ? await BranchApiService.InsertAsync(row) : await BranchApiService.UpdateAsync(key!, row),
            "warehouses" => action == "insert" ? await WarehouseApiService.InsertAsync(row) : await WarehouseApiService.UpdateAsync(key!, row),
            "users" => action == "insert" ? await UserApiService.InsertAsync(row) : await UserApiService.UpdateAsync(key!, row),
            "roles" => action == "insert" ? await RoleApiService.InsertAsync(row) : await RoleApiService.UpdateAsync(key!, row),
            "permissions" => action == "insert" ? await PermissionApiService.InsertAsync(row) : await PermissionApiService.UpdateAsync(key!, row),
            "sessions" => action == "insert" ? await SessionApiService.InsertAsync(row) : await SessionApiService.UpdateAsync(key!, row),
            "accesslogs" => action == "insert" ? await AccessLogApiService.InsertAsync(row) : await AccessLogApiService.UpdateAsync(key!, row),
            "currencies" or "exchange-rates" or "taxes" or "units" or "banks" or "countries" or "states" or "cities" or "document-series" or "document-folios" or "company-settings" => action == "insert" ? await MasterCatalogApiService.InsertAsync(CatalogKey, row) : await MasterCatalogApiService.UpdateAsync(CatalogKey, key!, row),
            "customers" or "suppliers" or "contacts" or "addresses" or "bank-accounts" or "categories" or "brands" or "models" or "items" or "price-lists" or "barcodes" => action == "insert" ? await ThirdPartiesProductsApiService.InsertAsync(CatalogKey, row) : await ThirdPartiesProductsApiService.UpdateAsync(CatalogKey, key!, row),
            "purchase-requisitions" or "purchase-orders" or "purchase-receipts" or "purchase-invoices" or "purchase-returns" => action == "insert" ? await PurchaseApiService.InsertAsync(CatalogKey, row) : await PurchaseApiService.UpdateAsync(CatalogKey, key!, row),
            "inventory-entries" or "inventory-exits" or "inventory-transfers" or "inventory-adjustments" or "physical-counts" => action == "insert" ? await InventoryApiService.InsertAsync(CatalogKey, row) : await InventoryApiService.UpdateAsync(CatalogKey, key!, row),
            "sales-quotes" or "sales-orders" or "sales-shipments" or "sales-invoices" or "sales-returns" or "credit-notes" => action == "insert" ? await SalesApiService.InsertAsync(CatalogKey, row) : await SalesApiService.UpdateAsync(CatalogKey, key!, row),
            "service-catalog" or "customer-service-rates" or "service-notes" => action == "insert" ? await ServiceBillingApiService.InsertAsync(CatalogKey, row) : await ServiceBillingApiService.UpdateAsync(CatalogKey, key!, row),
