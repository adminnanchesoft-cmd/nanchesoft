@using System.IO
@using System.Net
@using System.Text
@using System.Text.Json
@using Microsoft.JSInterop
@using Nanchesoft.Web.Services.Administration
@using Nanchesoft.Web.Services.Branches
@using Nanchesoft.Web.Services.Catalogs
@using Nanchesoft.Web.Services.Companies
@using Nanchesoft.Web.Services.Security
@using Nanchesoft.Web.Services.Warehouses
@using Nanchesoft.Web.Services.ThirdPartiesProducts
@using Nanchesoft.Web.Services.Purchases
@using Nanchesoft.Web.Services.Inventory
@using Nanchesoft.Web.Services.Sales
@using Nanchesoft.Web.Services.HumanResources
@using Nanchesoft.Web.Services.Products
@using Nanchesoft.Web.Services.ProfessionalServices
@using Nanchesoft.Web.Services.Platform
@using Nanchesoft.Web.Services.Treasury
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject CompanyApiService CompanyApiService
@inject BranchApiService BranchApiService
@inject WarehouseApiService WarehouseApiService
@inject UserApiService UserApiService
@inject RoleApiService RoleApiService
@inject PermissionApiService PermissionApiService
@inject SessionApiService SessionApiService
@inject AccessLogApiService AccessLogApiService
@inject MasterCatalogApiService MasterCatalogApiService
@inject ThirdPartiesProductsApiService ThirdPartiesProductsApiService
@inject PurchaseApiService PurchaseApiService
@inject InventoryApiService InventoryApiService
@inject SalesApiService SalesApiService
@inject HumanResourcesApiService HumanResourcesApiService
@inject PayrollOperationsApiService PayrollOperationsApiService
@inject HumanResourcesEnterpriseApiService HumanResourcesEnterpriseApiService
@inject ProductEngineeringApiService ProductEngineeringApiService
@inject ServiceBillingApiService ServiceBillingApiService
@inject TenantApiService TenantApiService
@inject PlanApiService PlanApiService
@inject Nanchesoft.Web.Services.Production.ProductionApiService ProductionApiService
@inject TreasuryApiService TreasuryApiService
@inject Nanchesoft.Web.Services.AuthService AuthService
@inject Nanchesoft.Web.State.AppState AppState
@inject Nanchesoft.Web.State.AuthState AuthState

<div class="ns-catalog-page">
    @if (!string.IsNullOrWhiteSpace(_clientError))
    {
        <div style="margin-bottom:16px;padding:12px 16px;border-radius:12px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3;white-space:pre-wrap;">
            <strong>Error real:</strong>
            @_clientError
        </div>
    }

    @if (_definition is null)
    {
        @if (string.IsNullOrWhiteSpace(_clientError))
        {
            <div class="ns-catalog-loading">
                <div class="ns-loader"></div>
                <span>Cargando catálogo...</span>
            </div>
        }
        else
        {
            <div style="padding:16px;border-radius:16px;border:1px solid #fecaca;background:#fff7f7;color:#991b1b;">
                <h3 style="margin:0 0 8px 0;">No se pudo cargar el catálogo</h3>
                <div style="white-space:pre-wrap;">@_clientError</div>
            </div>
        }
    }
    else
    {
        <div class="ns-catalog-header">
            <div>
                <div class="ns-catalog-eyebrow">Nanchesoft ERP · Implementación actual</div>
                <h1 class="ns-catalog-title">@_definition.Title</h1>
                <p class="ns-catalog-subtitle">@_definition.Subtitle</p>
            </div>

            <div class="ns-catalog-badge">
                DevExtreme 25.6
            </div>
        </div>

        <div class="ns-kpi-grid">
            <div class="ns-kpi-card ns-kpi-card-total">
                <div class="ns-kpi-label">Total</div>
                <div class="ns-kpi-value">@_definition.TotalCount</div>
            </div>

            <div class="ns-kpi-card ns-kpi-card-success">
                <div class="ns-kpi-label">Activos</div>
                <div class="ns-kpi-value">@_definition.ActiveCount</div>
            </div>

            <div class="ns-kpi-card ns-kpi-card-muted">
                <div class="ns-kpi-label">Inactivos</div>
                <div class="ns-kpi-value">@_definition.InactiveCount</div>
            </div>

            @if (IsIncidentCatalog)
            {
                <div class="ns-kpi-card ns-kpi-card-danger">
                    <div class="ns-kpi-label">Descuentos</div>
                    <div class="ns-kpi-value">@GetMetadataInt("DiscountCount")</div>
                </div>

                <div class="ns-kpi-card ns-kpi-card-info">
                    <div class="ns-kpi-label">Percepciones</div>
                    <div class="ns-kpi-value">@GetMetadataInt("PerceptionCount")</div>
                </div>
            }
            else
            {
                <div class="ns-kpi-card">
                    <div class="ns-kpi-label">Catálogo</div>
                    <div class="ns-kpi-value ns-kpi-value-small">@_definition.CatalogKey</div>
                </div>
            }
        </div>

        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin:18px 0 14px 0;">
            <button class="ns-primary-btn" @onclick="RefreshCatalogAsync">Recargar</button>
            <a class="ns-secondary-btn" href="@_csvHref" download="@GetExportFileName("csv")">Exportar CSV</a>
            <a class="ns-secondary-btn" href="@_jsonHref" download="@GetExportFileName("json")">Exportar JSON</a>
            <a class="ns-secondary-btn" href="@_printHref" target="_blank">Imprimir catálogo</a>
            @if (_definition.AllowImport)
            {
                @if (UsesUniversalImportPage)
                {
                    <button class="ns-secondary-btn" @onclick="OpenUniversalImportPage">Importar CSV</button>
                }
                else
                {
                    <button class="ns-secondary-btn" @onclick="() => { _showImport = !_showImport; _dropZoneReady = false; }">
                        @(_showImport ? "Cerrar importación" : "Importar CSV")
                    </button>
                    <a class="ns-secondary-btn" href="@_importTemplateHref" download="@($"plantilla_{_definition.CatalogKey}.csv")">Descargar plantilla</a>
                }
            }
        </div>

        @if (_definition.AllowImport && _showImport && !UsesUniversalImportPage)
        {
            var _importableCols = _definition.Columns
                .Where(x => x.AllowEditing && x.DataField != _definition.KeyExpr && x.Visible
                         && !_importAutoExcludeFields.Contains(x.DataField))
                .ToList();

            <div style="margin:0 0 18px 0;padding:20px;border-radius:14px;border:1px solid #dbeafe;background:#f0f7ff;">
                <h3 style="margin:0 0 12px 0;font-size:1rem;font-weight:600;color:#1d4ed8;">Importar desde CSV</h3>

                @* Campos del catálogo *@
                <details style="margin-bottom:14px;">
                    <summary style="cursor:pointer;font-size:.85rem;font-weight:600;color:#1e40af;user-select:none;">
                        Campos del catálogo (@_importableCols.Count campo(s))
                    </summary>
                    <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px;">
                        @foreach (var fc in _importableCols)
                        {
                            var fcBg = fc.Required ? "#dbeafe" : "#f1f5f9";
                            var fcColor = fc.Required ? "#1e40af" : "#475569";
                            <span style="font-size:.78rem;padding:3px 8px;border-radius:6px;background:@fcBg;color:@fcColor;border:1px solid @(fc.Required ? "#93c5fd" : "#e2e8f0");">
                                @fc.Caption
                                @if (fc.Required) { <strong> *</strong> }
                                @if (fc.UseLookup) { <span style="font-size:.7rem;opacity:.75;"> (lista)</span> }
                            </span>
                        }
                    </div>
                    <p style="margin:8px 0 0 0;font-size:.75rem;color:#64748b;">
                        * Requerido · Si falta un campo FK requerido se creará automáticamente "POR IDENTIFICAR" · Si falta Código, se usará el Nombre.
                    </p>
                </details>

                <p style="margin:0 0 14px 0;font-size:.875rem;color:#475569;">
                    Sube un CSV con las columnas que necesites. El sistema reconoce los encabezados por nombre — no necesitas todas las columnas ni en orden específico.
                </p>

                <div id="@_importDropZoneId"
                     style="position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;min-height:80px;border:2px dashed #93c5fd;border-radius:10px;background:#fff;cursor:pointer;margin-bottom:14px;transition:background .15s;padding:14px;"
                     onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='#fff'">
                    <span style="font-size:1.5rem;pointer-events:none;">📂</span>
                    <span style="font-size:.875rem;font-weight:600;color:#1d4ed8;pointer-events:none;">Arrastra tu CSV aquí o haz clic para seleccionar</span>
                    <span style="font-size:.75rem;color:#64748b;pointer-events:none;">Formatos admitidos: .csv · separador coma o punto y coma</span>
                    <InputFile OnChange="OnImportFileSelected" accept=".csv"
                               style="position:absolute;top:0;left:0;width:100%;height:100%;opacity:0;cursor:pointer;" />
                </div>

                @if (_importMappings.Count > 0)
                {
                    <div style="margin:12px 0;overflow-x:auto;border:1px solid #bfdbfe;border-radius:8px;background:#fff;">
                        <table style="border-collapse:collapse;font-size:.8rem;width:100%;">
                            <thead>
                                <tr style="background:#eff6ff;">
                                    <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;">Columna CSV</th>
                                    <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;">Campo Nanchesoft</th>
                                    <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mapping in _importMappings)
                                {
                                    var rowBg = mapping.Found ? "#f8fafc" : "#fff7ed";
                                    <tr style="background:@rowBg;">
                                        <td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;font-weight:600;">@mapping.SourceHeader</td>
                                        <td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">@(string.IsNullOrWhiteSpace(mapping.TargetLabel) ? "-" : mapping.TargetLabel)</td>
                                        <td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;color:@(mapping.Found ? "#166534" : "#b45309");">
                                            @(mapping.Found ? "Mapeado" : "Sin asignar")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (_importRows.Count > 0)
                {
                    <div style="margin:12px 0;overflow-x:auto;max-height:300px;border:1px solid #bfdbfe;border-radius:8px;">
                        <table style="border-collapse:collapse;font-size:.8rem;width:100%;">
                            <thead>
                                <tr style="background:#eff6ff;position:sticky;top:0;">
                                    <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;">#</th>
                                    @for (int hIdx = 0; hIdx < _importHeaders.Count; hIdx++)
                                    {
                                        var isAutoHdr = hIdx == _importCodeDisplayIdx && !_importHasCodeCol;
                                        <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;white-space:nowrap;@(isAutoHdr ? "background:#fffbeb;" : "")">
                                            @_importHeaders[hIdx]
                                            @if (isAutoHdr)
                                            {
                                                <span style="font-size:.65rem;background:#fef08a;color:#92400e;border-radius:3px;padding:1px 5px;margin-left:4px;vertical-align:middle;">generado</span>
                                            }
                                        </th>
                                    }
                                    <th style="padding:6px 10px;border-bottom:1px solid #bfdbfe;">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _importRows.Count; i++)
                                {
                                    var row = _importRows[i];
                                    var status = i < _importStatuses.Count ? _importStatuses[i] : "";
                                    var bg = status == "OK" ? "#f0fdf4"
                                           : status.StartsWith("Error") ? "#fff1f2"
                                           : status.StartsWith("Duplicado") ? "#fffbeb"
                                           : "white";
                                    <tr style="background:@bg;">
                                        <td style="padding:5px 10px;border-bottom:1px solid #e2e8f0;color:#64748b;">@(i + 1)</td>
                                        @for (int j = 0; j < row.Count && j < _importHeaders.Count; j++)
                                        {
                                            var isAutoCode = j == _importCodeDisplayIdx && i < _importAutoCode.Count && _importAutoCode[i];
                                            <td style="padding:5px 10px;border-bottom:1px solid #e2e8f0;@(isAutoCode ? "background:#fefce8;" : "")">
                                                @if (isAutoCode)
                                                {
                                                    var ci = i;
                                                    <div style="display:flex;align-items:center;gap:4px;">
                                                        <input style="border:1px solid #fbbf24;border-radius:4px;padding:2px 6px;font-size:.8rem;flex:1;min-width:70px;background:#fff;"
                                                               value="@_importEditCodes[ci]"
                                                               @oninput="(e) => _importEditCodes[ci] = e.Value?.ToString() ?? string.Empty" />
                                                        <span style="font-size:.65rem;background:#fef08a;color:#92400e;border-radius:3px;padding:1px 4px;white-space:nowrap;">auto</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @row[j]
                                                }
                                            </td>
                                        }
                                        <td style="padding:5px 10px;border-bottom:1px solid #e2e8f0;font-size:.75rem;color:@(status == "OK" ? "#16a34a" : status.StartsWith("Error") ? "#dc2626" : status.StartsWith("Duplicado") ? "#d97706" : "#94a3b8");">
                                            @status
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p style="margin:8px 0 14px 0;font-size:.8rem;color:#64748b;">
                        @_importRows.Count fila(s) detectada(s)
                        @if (_importAutoCode.Count(x => x) > 0)
                        {
                            <span style="margin-left:8px;background:#fef08a;color:#92400e;border-radius:4px;padding:1px 7px;font-size:.75rem;">
                                @_importAutoCode.Count(x => x) código(s) auto-generado(s) — puedes editarlos antes de importar
                            </span>
                        }
                    </p>

                    @if (!_importing)
                    {
                        <button class="ns-primary-btn" @onclick="ExecuteImportAsync" disabled="@(_importRows.Count == 0)">
                            Importar @_importRows.Count registro(s)
                        </button>
                    }
                    else
                    {
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div class="ns-loader" style="width:20px;height:20px;border-width:2px;"></div>
                            <span style="font-size:.875rem;color:#475569;">Importando @_importDone de @_importRows.Count...</span>
                        </div>
                    }

                    @if (_importDone > 0 && !_importing)
                    {
                        <p style="margin:10px 0 0 0;font-size:.875rem;color:#16a34a;font-weight:600;">
                            ✓ @_importOk importado(s) · @(_importStatuses.Count(s => s.StartsWith("Duplicado"))) omitido(s) por duplicado · @(_importStatuses.Count(s => s.StartsWith("Error"))) error(es).
                        </p>
                    }
                }
            </div>
        }

        <div class="ns-grid-shell">
            <div id="@_containerId" class="ns-grid-host"></div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string CatalogKey { get; set; } = string.Empty;

    private readonly CatalogAppService _catalogService = CatalogAppService.Instance;

    private CatalogViewDefinition? _definition;
    private DotNetObjectReference<CatalogCrudPage>? _dotNetReference;
    private readonly string _containerId = $"ns-grid-{Guid.NewGuid():N}";
    private string _importDropZoneId => $"ns-dz-{_containerId}";
    private bool _gridRendered;
    private string? _clientError;
    private string _csvHref = "#";
    private string _jsonHref = "#";
    private string _printHref = "#";
    private string _importTemplateHref = "#";
    private bool IsIncidentCatalog => string.Equals(_definition?.CatalogKey, "hr-incidents", StringComparison.OrdinalIgnoreCase);

    // Import state
    private bool _showImport;
    private bool _dropZoneReady;
    private List<string> _importHeaders = [];
    private List<List<string>> _importRows = [];
    private List<string> _importStatuses = [];
    private bool _importing;
    private int _importDone;
    private int _importOk;
    private bool _importHasCodeCol;
    private int _importCsvCodeIdx = -1;
    private int _importCsvNameIdx = -1;
    private int _importCodeDisplayIdx = -1;
    private List<bool> _importAutoCode = [];
    private List<string> _importEditCodes = [];
    private List<ImportHeaderMapping> _importMappings = [];
    private bool UsesUniversalImportPage => string.Equals(CatalogKey, "hr-employees", StringComparison.OrdinalIgnoreCase);

    protected override Task OnInitializedAsync()
    {
        // La carga real se posterga a OnAfterRenderAsync para que MainLayout pueda
        // restaurar la sesión desde localStorage (JS interop) y AppState/AuthState
        // tengan el TenantId antes de hacer las llamadas a la API.
        return Task.CompletedTask;
    }

    private async Task LoadDefinitionAsync()
    {
        try
        {
            _clientError = null;
            Console.WriteLine($"[CatalogCrudPage] LoadDefinitionAsync key={CatalogKey} appStateHash={AppState.GetHashCode()} authStateHash={AuthState.GetHashCode()} tenant={AppState.CurrentTenantId ?? AuthState.TenantId} company={AppState.CurrentCompanyId ?? AuthState.CompanyId}");
            _definition = await GetDefinitionAsync();
            RebuildExportArtifacts();
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            _definition = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Asegurar que la sesión está restaurada antes de cargar el catálogo.
            try { await AuthService.RestoreSessionAsync(); } catch (Exception ex) { Console.WriteLine($"[CatalogCrudPage] RestoreSession failed: {ex.Message}"); }
            Console.WriteLine($"[CatalogCrudPage] after restore key={CatalogKey} tenant={AppState.CurrentTenantId ?? AuthState.TenantId} authenticated={AuthState.IsAuthenticated}");
            await LoadDefinitionAsync();
        }

        if (_definition is null)
            return;

        _dotNetReference ??= DotNetObjectReference.Create(this);

        if (firstRender || !_gridRendered)
        {
            try
            {
                _clientError = null;
                await JS.InvokeVoidAsync("nsCrudGrid.renderCrudGrid", _containerId, _definition, _dotNetReference);
                _gridRendered = true;
            }
            catch (Exception ex)
            {
                _clientError = ex.Message;
                await InvokeAsync(StateHasChanged);
            }
        }

        if (_definition.AllowImport && _showImport && !_dropZoneReady)
        {
            try
            {
                await JS.InvokeVoidAsync("nsImport.initDropZone", _importDropZoneId, _dotNetReference);
                _dropZoneReady = true;
            }
            catch { }
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleInsert(JsonElement row)
    {
        _clientError = null;
        try
        {
            _definition = await ExecuteWriteAsync("insert", null, row);
            RebuildExportArtifacts();
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = true, Definition = _definition };
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            await InvokeAsync(StateHasChangeedSafe);
            return new CatalogCrudOperationResult { Success = false, Error = ex.Message, Definition = _definition ?? await GetDefinitionAsync() };
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleUpdate(string key, JsonElement changes)
    {
        _clientError = null;
        try
        {
            _definition = await ExecuteWriteAsync("update", key, changes);
            RebuildExportArtifacts();
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = true, Definition = _definition };
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = false, Error = ex.Message, Definition = _definition ?? await GetDefinitionAsync() };
        }
    }

    [JSInvokable]
    public async Task<CatalogCrudOperationResult> HandleDelete(string key)
    {
        _clientError = null;
        try
        {
            _definition = CatalogKey.ToLowerInvariant() switch
            {
                "companies" => await CompanyApiService.DeleteAsync(key),
                "branches" => await BranchApiService.DeleteAsync(key),
                "warehouses" => await WarehouseApiService.DeleteAsync(key),
                "users" => await UserApiService.DeleteAsync(key),
                "roles" => await RoleApiService.DeleteAsync(key),
                "permissions" => await PermissionApiService.DeleteAsync(key),
                "sessions" => await SessionApiService.DeleteAsync(key),
                "accesslogs" => await AccessLogApiService.DeleteAsync(key),
                "currencies" or "exchange-rates" or "taxes" or "units" or "banks" or
                "countries" or "states" or "cities" or "document-series" or
                "document-folios" or "company-settings" => await MasterCatalogApiService.DeleteAsync(CatalogKey, key),
                "customers" or "suppliers" or "contacts" or "addresses" or "bank-accounts" or
                "categories" or "brands" or "models" or "items" or "price-lists" or "barcodes" => await ThirdPartiesProductsApiService.DeleteAsync(CatalogKey, key),
                "purchase-requisitions" or "purchase-orders" or "purchase-receipts" or "purchase-invoices" or "purchase-returns" => await PurchaseApiService.DeleteAsync(CatalogKey, key),
                "inventory-entries" or "inventory-exits" or "inventory-transfers" or "inventory-adjustments" or "physical-counts" => await InventoryApiService.DeleteAsync(CatalogKey, key),
                "sales-quotes" or "sales-orders" or "sales-shipments" or "sales-invoices" or "sales-returns" or "credit-notes" => await SalesApiService.DeleteAsync(CatalogKey, key),
                "service-catalog" or "customer-service-rates" or "service-notes" => await ServiceBillingApiService.DeleteAsync(CatalogKey, key),
                "tenants" => await TenantApiService.DeleteAsync(key),
                "plans" => await PlanApiService.DeleteAsync(key),
                "hr-departments" or "hr-positions" or "hr-employees" or "hr-incidents" or "hr-recurring-incidents" or "employee-contracts" or "payroll-incident-types" or "payroll-period-types" or "payroll-periods" or "payroll-concepts" or "payroll-runs" or "payroll-run-lines" or "payroll-run-line-details" => await HumanResourcesApiService.DeleteAsync(CatalogKey, key),
                "time-clock" or "attendance-daily-summaries" or "payroll-recurring-movements" or "prepayroll-adjustments" or "prepayroll-cutoffs" or "employee-loans" or "employee-loan-deductions" or
                "payroll-source-applications" or "payroll-receipt-control" or "payroll-run-closings" or "payroll-dispersion-batches" or "payroll-dispersion-lines" or
                "payroll-accounting-postings" or "payroll-tax-accumulators" or "payroll-employer-obligations" or "payroll-fiscal-reconciliations" => await PayrollOperationsApiService.DeleteAsync(CatalogKey, key),
                "hr-shifts" or "hr-work-schedules" or "hr-time-clock-devices" or "hr-leave-types" or "hr-vacation-requests" or
                "hr-employee-documents" or "hr-employee-movements" or "hr-employee-certifications" or "hr-recruitment-vacancies" or "hr-candidate-applications" or
                "hr-onboarding-checklists" or "hr-performance-reviews" or "hr-competency-assessments" or "hr-succession-plans" => await HumanResourcesEnterpriseApiService.DeleteAsync(CatalogKey, key),
                "cash-accounts" or "bank-accounts-own" or "treasury-incomes" or "treasury-expenses" or "treasury-receipts" or "treasury-payments" or "treasury-reconciliations" => await TreasuryApiService.DeleteAsync(CatalogKey, key),
                "colors" or "leather-types" or "soles" or "manufacturing-types" or "toe-caps" or "sole-colors" or "dies" or "quality-control-dies" or "folio-patterns" or "unit-conversions" or "size-runs" or "families" or "lasts" or "lines" or "styles" or "embroidery-patterns" or "item-engineering-profiles" or "material-characteristics" or "material-sizes" or "material-families" or "material-subfamilies" or "material-items" or "material-suppliers" or "material-supplier-cost-history" or "finished-products" or "product-components" or "finished-product-materials" or "product-consumption-profiles" or "production-phases" => await ProductEngineeringApiService.DeleteAsync(CatalogKey, key),
                "production-orders" or "piecework-rates" => await ProductionApiService.DeleteAsync(CatalogKey, key),
                _ => await _catalogService.DeleteAsync(CatalogKey, key)
            };
            RebuildExportArtifacts();
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = true, Definition = _definition };
        }
        catch (Exception ex)
        {
            _clientError = ex.Message;
            await InvokeAsync(StateHasChanged);
            return new CatalogCrudOperationResult { Success = false, Error = ex.Message, Definition = _definition ?? await GetDefinitionAsync() };
        }
    }

    [JSInvokable]
