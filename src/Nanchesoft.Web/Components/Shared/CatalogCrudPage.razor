    [JSInvokable]
    public async Task<QuickCreateResult> HandleQuickCreate(string quickCreateKey, string code, string name)
    {
        try
        {
            var payloadJson = JsonSerializer.Serialize(new { Code = code.Trim().ToUpperInvariant(), Name = name.Trim(), IsActive = true });
            using var doc = JsonDocument.Parse(payloadJson);
            var payload = doc.RootElement.Clone();

            var updatedDef = await RouteQuickInsertAsync(quickCreateKey.ToLowerInvariant(), payload);
            var keyExpr = updatedDef.KeyExpr;

            var allItems = updatedDef.Rows
                .Select(r =>
                {
                    var id = r.TryGetValue(keyExpr, out var idVal) ? idVal?.ToString() ?? "" : "";
                    var rowCode = GetRowString(r, "Code") ?? "";
                    var rowName = GetRowString(r, "Name") ?? rowCode;
                    var display = string.IsNullOrEmpty(rowCode) ? rowName : $"{rowCode} · {rowName}";
                    return new CatalogLookupItem
                    {
                        Id = id,
                        Name = display,
                        Group = GetRowString(r, "IncidentCategory") ?? GetRowString(r, "Group") ?? "",
                        Color = GetRowString(r, "Color") ?? "",
                        Icon = GetRowString(r, "Icon") ?? "",
                        Description = GetRowString(r, "Description") ?? "",
                        Code = GetRowString(r, "Code") ?? "",
                        AffectType = GetRowString(r, "AffectType") ?? "",
                        IsActive = !bool.TryParse(GetRowString(r, "IsActive"), out var active) || active
                    };
                })
                .Where(x => !string.IsNullOrEmpty(x.Id))
                .OrderBy(x => x.Name)
                .ToList();

            var codeUpper = code.Trim().ToUpperInvariant();
            var newItem = allItems.FirstOrDefault(x => x.Name.StartsWith(codeUpper + " ·", StringComparison.OrdinalIgnoreCase))
                       ?? allItems.LastOrDefault(x => x.Name.Contains(codeUpper, StringComparison.OrdinalIgnoreCase));

            return new QuickCreateResult { Success = true, NewId = newItem?.Id ?? "", AllItems = allItems };
        }
        catch (Exception ex)
        {
            return new QuickCreateResult { Success = false, Error = ex.Message };
        }
    }

    private static string? GetRowString(Dictionary<string, object?> row, string key)
    {
        if (row.TryGetValue(key, out var val)) return val?.ToString();
        var kv = row.FirstOrDefault(x => string.Equals(x.Key, key, StringComparison.OrdinalIgnoreCase));
        return kv.Value?.ToString();
    }

