@inherits LayoutComponentBase
@inject Nanchesoft.Web.State.AuthState AuthState
@inject Nanchesoft.Web.Services.AuthService AuthService
@inject NavigationManager NavigationManager

@if (!_sessionReady)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100vh;background:#f3f6fb;color:#1f3b63;font-size:18px;font-weight:600;">
        Cargando sesión segura...
    </div>
}
else if (AuthState.IsAuthenticated)
{
    <div class="ns-shell2 ns-shell2--azure-topbar ns-shell-v3 ns-shell-enterprise">
        <TopBar />

        <ShellCommandPalette />

        <div class="ns-shell2__body ns-shell2__body--nav ns-shell-enterprise-body">
            <aside class="ns-shell2__left ns-shell-enterprise-sidebar">
                <SideMenu />
            </aside>

            <main class="ns-shell2__main ns-shell-enterprise-main">
                <Breadcrumb />
                <ModuleHero />

                <section class="ns-shell2__pageframe ns-shell2__pageframe--wide ns-shell-enterprise-content">
                    @Body
                </section>
            </main>
        </div>
    </div>
}

@code {
    private bool _sessionReady;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var restored = await AuthService.RestoreSessionAsync();
        _sessionReady = true;

        if (!restored && !AuthState.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }
}
