@page "/products/consumption-templates"
@using System.Net.Http.Json
@using System.Text.Json
@using System.Globalization
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<PageTitle>Plantillas de consumo | Nanchesoft</PageTitle>

<div class="page-header">
    <h1 class="page-title">Plantillas de consumo</h1>
    <p class="page-subtitle">Consumos por estilo y corrida de tallas. Independiente del producto terminado.</p>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}
@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}

<div class="filter-bar d-flex gap-2 mb-3 flex-wrap">
    <select class="form-select w-auto" @onchange="OnStyleChanged">
        <option value="">— Todos los estilos —</option>
        @foreach (var s in _styles)
        {
            <option value="@s.ProductStyleId">@s.Code</option>
        }
    </select>
    <select class="form-select w-auto" @onchange="OnRunChanged">
        <option value="">— Todas las corridas —</option>
        @foreach (var r in _runs)
        {
            <option value="@r.ProductSizeRunId">@r.Name</option>
        }
    </select>
    <button class="btn btn-primary" @onclick="LoadTemplatesAsync">Buscar</button>
    <button class="btn btn-success ms-auto" @onclick="ShowInitializeModal">+ Inicializar plantilla</button>
</div>

@if (_loading)
{
    <p>Cargando...</p>
}
else if (_templates.Count == 0)
{
    <p class="text-muted">No hay plantillas. Usa «+ Inicializar plantilla» para crear una.</p>
}
else
{
    <div class="list-group mb-3">
        @foreach (var t in _templates)
        {
            <div class="list-group-item list-group-item-action @(t.Id == _selectedTemplate?.Id ? "active" : "")"
                 @onclick="() => SelectTemplate(t)" style="cursor:pointer;">
                <div class="d-flex justify-content-between align-items-center">
                    <span>
                        <strong>@t.ProductStyleCode</strong> / @t.ProductSizeRunName
                    </span>
                    <span class="badge @StatusBadgeClass(t.Status)">@StatusLabel(t.Status)</span>
                </div>
                <small class="text-muted">Creado: @t.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
            </div>
        }
    </div>
}

@if (_selectedTemplate is not null)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <strong>@_selectedTemplate.ProductStyleCode</strong> / @_selectedTemplate.ProductSizeRunName
                <span class="badge @StatusBadgeClass(_selectedTemplate.Status) ms-2">@StatusLabel(_selectedTemplate.Status)</span>
            </span>
            <div class="d-flex gap-2">
                @if (!_selectedTemplate.IsAuthorized)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ShowCopyFromModal">Copiar desde</button>
                    <button class="btn btn-sm btn-primary" @onclick="SaveChangesAsync" disabled="@_saving">
                        @(_saving ? "Guardando..." : "Guardar")
                    </button>
                    <button class="btn btn-sm btn-success" @onclick="AuthorizeAsync" disabled="@_authorizing">
                        @(_authorizing ? "Autorizando..." : "Autorizar")
                    </button>
                }
            </div>
        </div>
        <div class="card-body p-0" style="overflow-x:auto;">
            <table class="table table-sm table-bordered mb-0 consumption-matrix">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th class="sticky-col" style="min-width:180px">Componente</th>
                        <th style="min-width:90px">Unidad</th>
                        <th style="min-width:60px">Activo</th>
                        <th style="min-width:70px">Piezas</th>
                        @foreach (var size in GetSizeHeaders())
                        {
                            <th style="min-width:75px">@size</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in _selectedTemplate.Details)
                    {
                        bool isDcm2 = detail.UnitCode.Equals("DCM2", StringComparison.OrdinalIgnoreCase);
                        <tr class="@(!detail.IsActive ? "table-secondary" : "")">
                            <td class="sticky-col">
                                <span title="@detail.ProductComponentCode">@detail.ProductComponentName</span>
                                @if (_rowNotice.TryGetValue(detail.Id, out var notice))
                                {
                                    <br /><small class="text-info fst-italic">@notice</small>
                                }
                            </td>
                            <td class="text-center align-middle">
                                @if (!string.IsNullOrEmpty(detail.UnitAbbreviation))
                                {
                                    <span class="badge bg-light text-dark border">@detail.UnitAbbreviation</span>
                                }
                                @if (isDcm2 && !_selectedTemplate.IsAuthorized)
                                {
                                    <br />
                                    <select class="form-select form-select-sm mt-1 dispersion-select"
                                            value="@detail.DispersionMode"
                                            @onchange="e => OnDispersionModeChanged(detail, e.Value?.ToString())">
                                        <option value="paired">Por pares</option>
                                        <option value="linear">Lineal</option>
                                    </select>
                                }
                            </td>
                            <td class="text-center align-middle">
                                @if (!_selectedTemplate.IsAuthorized)
                                {
                                    <input type="checkbox" checked="@detail.IsActive"
                                           @onchange="e => detail.IsActive = (bool)(e.Value ?? false)" />
                                }
                                else
                                {
                                    <input type="checkbox" checked="@detail.IsActive" disabled />
                                }
                            </td>
                            <td class="align-middle">
                                @if (!_selectedTemplate.IsAuthorized)
                                {
                                    <input type="number" class="form-control form-control-sm" min="1"
                                           value="@detail.Pieces"
                                           @onchange="e => detail.Pieces = int.TryParse(e.Value?.ToString(), out var v) ? v : 1" />
                                }
                                else
                                {
                                    <span>@detail.Pieces</span>
                                }
                            </td>
                            @foreach (var sz in detail.Sizes)
                            {
                                <td class="align-middle">
                                    @if (!_selectedTemplate.IsAuthorized && detail.IsActive)
                                    {
                                        <input type="number" class="form-control form-control-sm" step="0.0001" min="0"
                                               value="@sz.Consumption.ToString("G", CultureInfo.InvariantCulture)"
                                               @onchange="async e => await OnSizeChanged(detail, sz, e.Value?.ToString() ?? string.Empty)" />
                                    }
                                    else
                                    {
                                        <span class="@(sz.Consumption <= 0 && detail.IsActive ? "text-danger" : "")">@sz.Consumption</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showInitModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Inicializar plantilla de consumo</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Estilo *</label>
                        <select class="form-select" @bind="_initStyleId">
                            <option value="">— Selecciona —</option>
                            @foreach (var s in _styles)
                            {
                                <option value="@s.ProductStyleId">@s.Code</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Corrida *</label>
                        <select class="form-select" @bind="_initRunId">
                            <option value="">— Selecciona —</option>
                            @foreach (var r in _runs)
                            {
                                <option value="@r.ProductSizeRunId">@r.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notas</label>
                        <textarea class="form-control" @bind="_initNotes" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancelar</button>
                    <button class="btn btn-primary" @onclick="InitializeAsync" disabled="@_initializing">
                        @(_initializing ? "Inicializando..." : "Inicializar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showCopyModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Copiar consumos desde otra plantilla</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">Los consumos de la plantilla origen se copiarán a la plantilla actual, emparejando por secuencia de talla.</p>
                    <div class="mb-3">
                        <label class="form-label">Plantilla origen *</label>
                        <select class="form-select" @bind="_copySourceId">
                            <option value="">— Selecciona —</option>
                            @foreach (var t in _templates.Where(x => x.Id != _selectedTemplate?.Id && x.IsActive))
                            {
                                <option value="@t.Id">@t.ProductStyleCode / @t.ProductSizeRunName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancelar</button>
                    <button class="btn btn-primary" @onclick="CopyFromAsync" disabled="@_copying">
                        @(_copying ? "Copiando..." : "Copiar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .consumption-matrix .sticky-col {
        position: sticky;
        left: 0;
        background: white;
        z-index: 1;
        border-right: 2px solid #dee2e6;
    }
    .consumption-matrix thead th.sticky-col {
        background: #212529;
    }
    .dispersion-select {
        font-size: 0.7rem;
        padding: 1px 4px;
        width: auto;
        min-width: 80px;
    }
</style>

@code {
    private List<StyleOptionDto> _styles = [];
    private List<RunOptionDto> _runs = [];
    private List<ConsumptionTemplateDto> _templates = [];
    private ConsumptionTemplateDto? _selectedTemplate;

    private string _filterStyleId = string.Empty;
    private string _filterRunId = string.Empty;

    private bool _loading;
    private bool _saving;
    private bool _authorizing;
    private bool _initializing;
    private bool _copying;

    private bool _showInitModal;
    private bool _showCopyModal;

    private string _initStyleId = string.Empty;
    private string _initRunId = string.Empty;
    private string _initNotes = string.Empty;
    private string _copySourceId = string.Empty;

    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    private readonly Dictionary<Guid, string> _rowNotice = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
        await LoadTemplatesAsync();
    }

    private HttpClient Client => HttpClientFactory.CreateClient("Nanchesoft.Api");

    private async Task LoadLookupsAsync()
    {
        _styles = await Client.GetFromJsonAsync<List<StyleOptionDto>>("/api/products/styles/options") ?? [];
        _runs = await Client.GetFromJsonAsync<List<RunOptionDto>>("/api/products/size-runs/options") ?? [];
    }

    private async Task LoadTemplatesAsync()
    {
        _loading = true;
        _errorMessage = string.Empty;
        _selectedTemplate = null;
        _rowNotice.Clear();
        try
        {
            var url = "/api/consumption-templates?";
            if (!string.IsNullOrEmpty(_filterStyleId)) url += $"productStyleId={_filterStyleId}&";
            if (!string.IsNullOrEmpty(_filterRunId)) url += $"productSizeRunId={_filterRunId}&";
            _templates = await Client.GetFromJsonAsync<List<ConsumptionTemplateDto>>(url) ?? [];
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al cargar plantillas: {ex.Message}";
        }
        finally { _loading = false; }
    }

    private void SelectTemplate(ConsumptionTemplateDto t)
    {
        _selectedTemplate = t;
        _rowNotice.Clear();
    }

    private IEnumerable<string> GetSizeHeaders()
        => _selectedTemplate?.Details.FirstOrDefault()?.Sizes
            .OrderBy(s => s.Sequence)
            .Select(s => string.IsNullOrEmpty(s.DisplayLabel) ? s.SizeCode : s.DisplayLabel)
            ?? Enumerable.Empty<string>();

    // Called when any size input changes. Applies copy-first or DCM2 spread as needed.
    private async Task OnSizeChanged(ConsumptionTemplateDetailDto detail, ConsumptionTemplateSizeDto size, string rawValue)
    {
        if (!decimal.TryParse(rawValue, NumberStyles.Any, CultureInfo.InvariantCulture, out var value))
            value = 0m;
        size.Consumption = value;

        var sizes = detail.Sizes;
        if (sizes.Count == 0) return;

        bool isFirst = sizes[0].Id == size.Id;
        bool isLast = sizes[^1].Id == size.Id;
        bool isDcm2 = detail.UnitCode.Equals("DCM2", StringComparison.OrdinalIgnoreCase);

        if (isFirst && sizes.Count > 1)
        {
            foreach (var s in sizes)
                s.Consumption = value;
            _ = ShowRowNotice(detail.Id, "Se copió el consumo a todas las tallas.");
        }
        else if (isDcm2 && isLast && sizes.Count > 1 && sizes[0].Consumption > 0)
        {
            ApplyClientSpread(sizes, detail.DispersionMode);
            _ = ShowRowNotice(detail.Id, "Se aplicó dispersión DCM2.");
        }

        await Task.CompletedTask;
    }

    // Client-side spread mirrors the backend logic for immediate visual feedback.
    private static void ApplyClientSpread(List<ConsumptionTemplateSizeDto> sizes, string mode)
    {
        if (sizes.Count < 2) return;
        decimal first = sizes[0].Consumption;
        decimal last = sizes[^1].Consumption;

        if (mode == "paired")
        {
            int pairCount = (sizes.Count + 1) / 2;
            if (pairCount < 2) return;
            decimal z = (last - first) / (pairCount - 1);
            for (int i = 0; i < sizes.Count; i++)
                sizes[i].Consumption = Math.Round(first + z * (i / 2), 4, MidpointRounding.AwayFromZero);
            sizes[^1].Consumption = last;
        }
        else // linear
        {
            decimal z = (last - first) / (sizes.Count - 1);
            for (int i = 0; i < sizes.Count; i++)
                sizes[i].Consumption = Math.Round(first + z * i, 4, MidpointRounding.AwayFromZero);
        }
    }

    private async Task ShowRowNotice(Guid detailId, string msg)
    {
        _rowNotice[detailId] = msg;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(3500);
        _rowNotice.Remove(detailId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveChangesAsync()
    {
        if (_selectedTemplate is null) return;
        _saving = true; _errorMessage = string.Empty; _successMessage = string.Empty;
        try
        {
            var payload = new
            {
                notes = _selectedTemplate.Notes,
                details = _selectedTemplate.Details.Select(d => new
                {
                    detailId = d.Id,
                    pieces = d.Pieces,
                    isActive = d.IsActive,
                    dispersionMode = d.DispersionMode,
                    notes = d.Notes,
                    sizes = d.Sizes.Select(s => new { sizeId = s.Id, consumption = s.Consumption })
                })
            };
            var resp = await Client.PutAsJsonAsync($"/api/consumption-templates/{_selectedTemplate.Id}", payload);
            if (resp.IsSuccessStatusCode)
            {
                _successMessage = "Cambios guardados.";
                // Reload to reflect backend-applied DCM2 spread values
                var refreshed = await Client.GetFromJsonAsync<ConsumptionTemplateDto>(
                    $"/api/consumption-templates/{_selectedTemplate.Id}");
                if (refreshed is not null)
                {
                    var idx = _templates.FindIndex(x => x.Id == refreshed.Id);
                    if (idx >= 0) _templates[idx] = refreshed;
                    _selectedTemplate = refreshed;
                }
            }
            else
            {
                var err = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _errorMessage = err.TryGetProperty("message", out var m) ? m.GetString() ?? "Error al guardar." : "Error al guardar.";
            }
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }

    private async Task AuthorizeAsync()
    {
        if (_selectedTemplate is null) return;
        _authorizing = true; _errorMessage = string.Empty; _successMessage = string.Empty;
        try
        {
            var resp = await Client.PostAsync($"/api/consumption-templates/{_selectedTemplate.Id}/authorize", null);
            if (resp.IsSuccessStatusCode)
            {
                _successMessage = "Plantilla autorizada.";
                await LoadTemplatesAsync();
            }
            else
            {
                var err = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _errorMessage = err.TryGetProperty("message", out var m) ? m.GetString() ?? "Error." : "Error.";
            }
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _authorizing = false; }
    }

    private async Task InitializeAsync()
    {
        if (string.IsNullOrEmpty(_initStyleId) || string.IsNullOrEmpty(_initRunId))
        {
            _errorMessage = "Selecciona estilo y corrida."; return;
        }
        _initializing = true; _errorMessage = string.Empty;
        try
        {
            var payload = new { productStyleId = Guid.Parse(_initStyleId), productSizeRunId = Guid.Parse(_initRunId), notes = _initNotes };
            var resp = await Client.PostAsJsonAsync("/api/consumption-templates/initialize", payload);
            if (resp.IsSuccessStatusCode)
            {
                CloseModals();
                _successMessage = "Plantilla inicializada.";
                await LoadTemplatesAsync();
            }
            else
            {
                var err = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _errorMessage = err.TryGetProperty("message", out var m) ? m.GetString() ?? "Error." : "Error.";
            }
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _initializing = false; }
    }

    private async Task CopyFromAsync()
    {
        if (_selectedTemplate is null || string.IsNullOrEmpty(_copySourceId)) return;
        _copying = true; _errorMessage = string.Empty;
        try
        {
            var payload = new { sourceTemplateId = Guid.Parse(_copySourceId) };
            var resp = await Client.PostAsJsonAsync($"/api/consumption-templates/{_selectedTemplate.Id}/copy-from", payload);
            if (resp.IsSuccessStatusCode)
            {
                CloseModals();
                _successMessage = "Consumos copiados. Cargando plantilla actualizada...";
                await LoadTemplatesAsync();
            }
            else
            {
                var err = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _errorMessage = err.TryGetProperty("message", out var m) ? m.GetString() ?? "Error." : "Error.";
            }
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _copying = false; }
    }

    private static void OnDispersionModeChanged(ConsumptionTemplateDetailDto detail, string? value)
        => detail.DispersionMode = string.IsNullOrEmpty(value) ? "paired" : value;

    private void OnStyleChanged(ChangeEventArgs e) => _filterStyleId = e.Value?.ToString() ?? string.Empty;
    private void OnRunChanged(ChangeEventArgs e) => _filterRunId = e.Value?.ToString() ?? string.Empty;
    private void ShowInitializeModal() { _initStyleId = string.Empty; _initRunId = string.Empty; _initNotes = string.Empty; _showInitModal = true; }
    private void ShowCopyFromModal() { _copySourceId = string.Empty; _showCopyModal = true; }
    private void CloseModals() { _showInitModal = false; _showCopyModal = false; }

    private static string StatusBadgeClass(string status) => status switch
    {
        "authorized" => "bg-success",
        "incomplete" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
    private static string StatusLabel(string status) => status switch
    {
        "authorized" => "Autorizado",
        "incomplete" => "Incompleto",
        _ => "Pendiente"
    };

    private sealed class StyleOptionDto { public Guid ProductStyleId { get; set; } public string Code { get; set; } = string.Empty; }
    private sealed class RunOptionDto { public Guid ProductSizeRunId { get; set; } public string Code { get; set; } = string.Empty; public string Name { get; set; } = string.Empty; }

    private sealed class ConsumptionTemplateDto
    {
        public Guid Id { get; set; }
        public Guid CompanyId { get; set; }
        public Guid ProductStyleId { get; set; }
        public string ProductStyleCode { get; set; } = string.Empty;
        public Guid ProductSizeRunId { get; set; }
        public string ProductSizeRunName { get; set; } = string.Empty;
        public bool IsActive { get; set; }
        public bool IsAuthorized { get; set; }
        public DateTime? AuthorizedAt { get; set; }
        public string? AuthorizedBy { get; set; }
        public string Notes { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public string? CreatedBy { get; set; }
        public string Status { get; set; } = "pending";
        public List<ConsumptionTemplateDetailDto> Details { get; set; } = [];
    }

    private sealed class ConsumptionTemplateDetailDto
    {
        public Guid Id { get; set; }
        public Guid ConsumptionTemplateId { get; set; }
        public Guid ProductComponentId { get; set; }
        public string ProductComponentCode { get; set; } = string.Empty;
        public string ProductComponentName { get; set; } = string.Empty;
        public string UnitCode { get; set; } = string.Empty;
        public string UnitAbbreviation { get; set; } = string.Empty;
        public int Pieces { get; set; }
        public bool IsActive { get; set; }
        public string DispersionMode { get; set; } = "paired";
        public string Notes { get; set; } = string.Empty;
        public List<ConsumptionTemplateSizeDto> Sizes { get; set; } = [];
    }

    private sealed class ConsumptionTemplateSizeDto
    {
        public Guid Id { get; set; }
        public Guid ConsumptionTemplateDetailId { get; set; }
        public Guid ProductSizeRunSizeId { get; set; }
        public string SizeCode { get; set; } = string.Empty;
        public string DisplayLabel { get; set; } = string.Empty;
        public int Sequence { get; set; }
        public decimal Consumption { get; set; }
        public bool IsActive { get; set; }
    }
}
