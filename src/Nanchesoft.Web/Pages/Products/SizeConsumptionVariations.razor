@page "/products/size-consumption-variations"
@using System.Net.Http.Json
@using Nanchesoft.Web.Services.Products
@inject HttpClient Http

<PageTitle>Variaciones de consumo por talla | Nanchesoft</PageTitle>

<h3>Variaciones de consumo por talla</h3>

@if (_items is null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Talla base</th>
                <th>Talla destino</th>
                <th>Variación %</th>
                <th>Diferencia cantidad</th>
                <th>Aplica a costo</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in _items)
        {
            <tr>
                <td>@item.BaseSizeCode</td>
                <td>@item.TargetSizeCode</td>
                <td>@item.VariationPercent</td>
                <td>@item.QuantityDelta</td>
                <td>@(item.AppliesToCosting ? "Sí" : "No")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<ProductSizeConsumptionVariationDto>? _items;

    protected override async Task OnInitializedAsync()
    {
        _items = await Http.GetFromJsonAsync<List<ProductSizeConsumptionVariationDto>>("/api/products/size-consumption-variations") ?? new();
    }
}
