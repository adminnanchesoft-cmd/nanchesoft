@page "/products/engineering-readiness"
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Estado de ingeniería</PageTitle>

<h3>Estado de ingeniería</h3>
<p class="text-muted">Panel de preparación para productos terminados, consumos, materiales, ficha técnica y autorización.</p>

@if (_loading)
{
    <p>Cargando...</p>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(4,minmax(180px,1fr));gap:12px;margin-bottom:16px;">
        <div class="card"><div class="card-body"><div class="text-muted">Productos</div><div style="font-size:28px;font-weight:700;">@_rows.Count</div></div></div>
        <div class="card"><div class="card-body"><div class="text-muted">Listos para explotar</div><div style="font-size:28px;font-weight:700;">@_readyCount</div></div></div>
        <div class="card"><div class="card-body"><div class="text-muted">Con atención</div><div style="font-size:28px;font-weight:700;">@_attentionCount</div></div></div>
        <div class="card"><div class="card-body"><div class="text-muted">Promedio avance</div><div style="font-size:28px;font-weight:700;">@_averageReadiness%</div></div></div>
    </div>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Código</th>
                <th>Producto</th>
                <th>Estilo</th>
                <th>Corrida</th>
                <th>Material principal</th>
                <th>Foto</th>
                <th>Materiales</th>
                <th>Consumos</th>
                <th>Ficha</th>
                <th>Costeo</th>
                <th>Autorización</th>
                <th>Avance</th>
                <th>Faltantes</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in _rows)
        {
            <tr>
                <td>@row.Code</td>
                <td>@row.Name</td>
                <td>@EmptyValue(row.ProductStyleName)</td>
                <td>@EmptyValue(row.ProductSizeRunName)</td>
                <td>@EmptyValue(row.MainMaterialItemName)</td>
                <td>@YesNo(row.HasPhoto)</td>
                <td>@row.MaterialAssignmentsCount</td>
                <td>@row.ConsumptionProfilesCount</td>
                <td>@row.TechnicalSheetsCount</td>
                <td>@row.CostSheetsCount</td>
                <td>@row.AuthorizationRecordsCount</td>
                <td>
                    <div style="min-width:140px;">
                        <div style="font-weight:600;">@row.ReadinessPercent%</div>
                        <div style="height:8px;background:#e5e7eb;border-radius:999px;overflow:hidden;">
                            <div style="height:8px;width:@($"{row.ReadinessPercent}%");background:@BarColor(row.ReadinessPercent);"></div>
                        </div>
                    </div>
                </td>
                <td>@EmptyValue(row.MissingSteps)</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private List<EngineeringReadinessRow> _rows = new();
    private int _readyCount;
    private int _attentionCount;
    private int _averageReadiness;

    protected override async Task OnInitializedAsync()
    {
        _rows = await Http.GetFromJsonAsync<List<EngineeringReadinessRow>>("/api/products/engineering-readiness") ?? new();
        _readyCount = _rows.Count(x => x.IsReadyForExplosion);
        _attentionCount = _rows.Count - _readyCount;
        _averageReadiness = _rows.Count == 0 ? 0 : (int)Math.Round(_rows.Average(x => x.ReadinessPercent));
        _loading = false;
    }

    private static string YesNo(bool value) => value ? "Sí" : "No";
    private static string EmptyValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    private static string BarColor(int value) => value >= 100 ? "#16a34a" : value >= 70 ? "#f59e0b" : "#dc2626";

    private sealed class EngineeringReadinessRow
    {
        public Guid FinishedProductId { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ProductStyleName { get; set; } = string.Empty;
        public string ProductSizeRunName { get; set; } = string.Empty;
        public string MainMaterialItemName { get; set; } = string.Empty;
        public bool HasPhoto { get; set; }
        public bool HeaderHasConsumptionDefinition { get; set; }
        public bool HeaderHasMaterialAssignments { get; set; }
        public bool IsAuthorizedForExplosion { get; set; }
        public bool IsActive { get; set; }
        public int MaterialAssignmentsCount { get; set; }
        public int ConsumptionProfilesCount { get; set; }
        public int TechnicalSheetsCount { get; set; }
        public int CostSheetsCount { get; set; }
        public int AuthorizationRecordsCount { get; set; }
        public int ReadinessPercent { get; set; }
        public string MissingSteps { get; set; } = string.Empty;
        public bool IsReadyForExplosion { get; set; }
    }
}
