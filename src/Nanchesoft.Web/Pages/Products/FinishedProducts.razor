    private void CloseModal() { _showModal = false; _modalError = null; }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Code)) { _modalError = "El código es obligatorio."; return; }
        _saving = true;
        _modalError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var body = new
            {
                Code            = _form.Code.Trim().ToUpperInvariant(),
                Name            = string.IsNullOrWhiteSpace(_form.Name) ? (string?)null : _form.Name.Trim(),
                BillingName     = _form.BillingName ?? string.Empty,
                ProductStyleId          = ParseGuid(_form.ProductStyleId),
                ProductLineId           = ParseGuid(_form.ProductLineId),
                ProductLastId           = ParseGuid(_form.ProductLastId),
                ItemBrandId             = ParseGuid(_form.ItemBrandId),
                ItemModelId             = ParseGuid(_form.ItemModelId),
                ProductSizeRunId        = ParseGuid(_form.ProductSizeRunId),
                ProductLeatherTypeId    = ParseGuid(_form.ProductLeatherTypeId),
                ProductColorId          = ParseGuid(_form.ProductColorId),
                ProductToeCapId         = ParseGuid(_form.ProductToeCapId),
                ProductSoleId           = ParseGuid(_form.ProductSoleId),
                ProductSoleColorId      = ParseGuid(_form.ProductSoleColorId),
                ProductFolioPatternId   = ParseGuid(_form.ProductFolioPatternId),
                ProductManufacturingTypeId = ParseGuid(_form.ProductManufacturingTypeId),
                MainMaterialItemId      = (Guid?)null,
                Notes    = _form.Notes ?? string.Empty,
                IsActive = _form.IsActive,
                HasPhoto = false,
                HasConsumptionDefinition = false,
                HasMaterialAssignments   = false,
                IsAuthorizedForExplosion = false
            };

            HttpResponseMessage resp;
            if (_editingId.HasValue)
                resp = await client.PutAsJsonAsync($"/api/products/finished-products/{_editingId}", body);
            else
                resp = await client.PostAsJsonAsync("/api/products/finished-products", body);

            if (!resp.IsSuccessStatusCode)
            {
                _modalError = await ParseErrorAsync(resp);
                return;
            }
            _showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task DeleteItemAsync()
    {
        if (!_editingId.HasValue) return;
        var confirmed = await JS.InvokeAsync<bool>("confirm", "¿Eliminar este producto terminado?");
        if (!confirmed) return;
        _saving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var resp = await client.DeleteAsync($"/api/products/finished-products/{_editingId}");
            if (!resp.IsSuccessStatusCode) { _modalError = await ParseErrorAsync(resp); return; }
            _showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

