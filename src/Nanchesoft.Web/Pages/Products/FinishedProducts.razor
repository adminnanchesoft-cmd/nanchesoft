    private void OpenQuickCreate(string type)
    {
        _qcType = type;
        _quickCreateTitle = type switch
        {
            "style"         => "Nuevo estilo",
            "line"          => "Nueva línea",
            "last"          => "Nueva horma (last)",
            "brand"         => "Nueva marca",
            "model"         => "Nuevo modelo",
            "leather"       => "Nuevo tipo de piel",
            "color"         => "Nuevo color",
            "toecap"        => "Nuevo casco / horma (toecap)",
            "sole"          => "Nueva suela",
            "solecolor"     => "Nuevo color de suela",
            "folio"         => "Nuevo patrón de foliado",
            "manufacturing" => "Nuevo tipo de manufactura",
            _               => "Nuevo"
        };
        _qcCode = _qcName = string.Empty;
        _quickCreateError = null;
        _showQuickCreate = true;
    }

    private void CloseQuickCreate() { _showQuickCreate = false; _quickCreateError = null; }

    private async Task SaveQuickCreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_qcCode) || string.IsNullOrWhiteSpace(_qcName))
        {
            _quickCreateError = "Código y nombre son obligatorios.";
            return;
        }
        _qcSaving = true;
        _quickCreateError = null;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var code = _qcCode.Trim().ToUpperInvariant();
            var name = _qcName.Trim();

            // Orange catalog types use OrangeSimpleCatalogRequest (Code+Name+IsActive)
            // Standard catalog types use specific request bodies
            string apiUrl, optUrl, idField;
            Action<string> selector;

            switch (_qcType)
            {
                case "style":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/styles", "/api/products/styles/options", "productStyleId", v => _form.ProductStyleId = v);
                    break;
                case "line":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/lines", "/api/products/lines/options", "productLineId", v => _form.ProductLineId = v);
                    break;
                case "last":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/lasts", "/api/products/lasts/options", "productLastId", v => _form.ProductLastId = v);
                    break;
                case "brand":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/brands", "/api/products/brands/options", "brandId", v => _form.ItemBrandId = v);
                    break;
                case "model":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/models", "/api/products/models/options", "modelId", v => _form.ItemModelId = v);
                    break;
                case "leather":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/leather-types", "/api/products/leather-types/options", "id", v => _form.ProductLeatherTypeId = v);
                    break;
                case "color":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/colors", "/api/products/colors/options", "id", v => _form.ProductColorId = v);
                    break;
                case "toecap":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/toe-caps", "/api/products/toe-caps/options", "id", v => _form.ProductToeCapId = v);
                    break;
                case "sole":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/soles", "/api/products/soles/options", "id", v => _form.ProductSoleId = v);
                    break;
                case "solecolor":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/sole-colors", "/api/products/sole-colors/options", "id", v => _form.ProductSoleColorId = v);
                    break;
                case "folio":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/folio-patterns", "/api/products/folio-patterns/options", "id", v => _form.ProductFolioPatternId = v);
                    break;
                case "manufacturing":
                    (apiUrl, optUrl, idField, selector) = ("/api/products/manufacturing-types", "/api/products/manufacturing-types/options", "id", v => _form.ProductManufacturingTypeId = v);
                    break;
                default:
                    throw new InvalidOperationException($"Unknown quick-create type: {_qcType}");
            }

            // POST to create
            var resp = await client.PostAsJsonAsync(apiUrl, new { Code = code, Name = name, IsActive = true });
            if (!resp.IsSuccessStatusCode) { _quickCreateError = await ParseErrorAsync(resp); return; }

            // Extract new id from response
            var resultTxt = await resp.Content.ReadAsStringAsync();
            var newId = string.Empty;
            try
            {
                using var doc = JsonDocument.Parse(resultTxt);
                // Orange catalog returns plain guid string; others may return { id: "..." } or just a guid string
                if (doc.RootElement.ValueKind == JsonValueKind.String)
                    newId = doc.RootElement.GetString() ?? string.Empty;
                else if (doc.RootElement.TryGetProperty("id", out var p))
                    newId = p.ValueKind == JsonValueKind.String ? (p.GetString() ?? string.Empty) : p.ToString();
            }
            catch { /* ignore parse error */ }

            // Reload options list
            var fresh = await FetchOpts(client, optUrl, idField);
            switch (_qcType)
            {
                case "style":   _styleOptions        = fresh; break;
                case "line":    _lineOptions         = fresh; break;
                case "last":    _lastOptions         = fresh; break;
                case "brand":   _brandOptions        = fresh; break;
                case "model":   _modelOptions        = fresh; break;
                case "leather": _leatherOptions      = fresh; break;
                case "color":   _colorOptions        = fresh; break;
                case "toecap":  _toeCapOptions       = fresh; break;
                case "sole":    _soleOptions         = fresh; break;
                case "solecolor": _soleColorOptions  = fresh; break;
                case "folio":   _folioOptions        = fresh; break;
                case "manufacturing": _manufacturingOptions = fresh; break;
            }

            if (!string.IsNullOrEmpty(newId)) selector(newId);
            _showQuickCreate = false;
        }
        catch (Exception ex) { _quickCreateError = ex.Message; }
        finally { _qcSaving = false; }
    }

    private static Guid? ParseGuid(string? value)
        => Guid.TryParse(value, out var g) ? g : (Guid?)null;

    private static async Task<string> ParseErrorAsync(HttpResponseMessage resp)
    {
        var txt = await resp.Content.ReadAsStringAsync();
        try
        {
            using var doc = JsonDocument.Parse(txt);
            if (doc.RootElement.TryGetProperty("message", out var m)) return m.GetString() ?? txt;
        }
        catch { /* ignore */ }
        return txt;
    }

