@page "/accounting/auto-policies"
@using Nanchesoft.Web.Services.Accounting
@inject AccountingApiService Api

<PageTitle>Pólizas automáticas | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Contabilidad · Pólizas automáticas</h1>

<div class="alert alert-secondary">
    Esta etapa genera <strong>pólizas automáticas base</strong> en borrador usando cuentas semilla:
    <strong>1000 Caja</strong>, <strong>1010 Bancos</strong>, <strong>1050 Clientes</strong>, <strong>2000 Proveedores</strong>, <strong>4000 Ventas</strong> y <strong>6000 Gastos generales</strong>.
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Tipo de origen</label>
                <select class="form-select" @bind="_sourceType">
                    <option value="all">Todos</option>
                    <option value="sales_invoice">Facturas de venta</option>
                    <option value="credit_note">Notas de crédito</option>
                    <option value="purchase_invoice">Facturas de proveedor</option>
                    <option value="receipt">Recibos</option>
                    <option value="payment">Pagos</option>
                </select>
            </div>
            <div class="col-md-3 form-check mt-4 pt-2">
                <input class="form-check-input" id="includeGenerated" type="checkbox" @bind="_includeGenerated" />
                <label class="form-check-label" for="includeGenerated">Incluir ya generadas</label>
            </div>
            <div class="col-md-5 d-flex gap-2 justify-content-md-end">
                <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_busy">Actualizar</button>
                <button class="btn btn-primary" @onclick="GenerateFilteredAsync" disabled="@_busy || _rows.Count == 0">Generar pendientes filtradas</button>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Pendientes</div><div class="fs-4 fw-bold text-danger">@_summary.PendingTotal</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Venta</div><div class="fs-4 fw-bold">@_summary.PendingSalesInvoices</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Compra</div><div class="fs-4 fw-bold">@_summary.PendingPurchaseInvoices</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Recibos</div><div class="fs-4 fw-bold">@_summary.PendingReceipts</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Pagos</div><div class="fs-4 fw-bold">@_summary.PendingPayments</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Borrador auto</div><div class="fs-4 fw-bold text-secondary">@_summary.DraftAutomaticEntries</div></div></div></div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando pólizas automáticas...</div>
}
else if (_rows.Count == 0)
{
    <div class="alert alert-light border">No hay documentos disponibles con el filtro actual.</div>
}
else
{
    <div class="card shadow-sm mb-3">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tipo</th>
                        <th>Fecha</th>
                        <th>Folio</th>
                        <th>Tercero</th>
                        <th class="text-end">Total</th>
                        <th>Cargo</th>
                        <th>Abono</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in _rows)
                {
                    <tr class="@(row.SourceId == _selectedSourceId ? "table-primary" : null)">
                        <td>@GetSourceLabel(row.SourceType)</td>
                        <td>@row.DocumentDate.ToString("yyyy-MM-dd")</td>
                        <td>@row.Folio</td>
                        <td>@row.ThirdPartyName</td>
                        <td class="text-end">@row.Total.ToString("N2")</td>
                        <td>@row.DebitAccountCode @row.DebitAccountName</td>
                        <td>@row.CreditAccountCode @row.CreditAccountName</td>
                        <td>
                            @if (row.ExistingJournalEntryId.HasValue)
                            {
                                <span class="badge text-bg-success">@($"{row.ExistingJournalFolio} · {row.ExistingJournalStatus}")</span>
                            }
                            else if (row.IsReady)
                            {
                                <span class="badge text-bg-warning">Pendiente</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger">No lista</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-secondary" @onclick="() => PreviewAsync(row.SourceType, row.SourceId)">Vista previa</button>
                                <button class="btn btn-outline-primary" @onclick="() => GenerateOneAsync(row.SourceType, row.SourceId)" disabled="@(_busy || !row.IsReady || row.ExistingJournalEntryId.HasValue)">Generar</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_preview is not null)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Vista previa · @GetSourceLabel(_preview.SourceType) · @_preview.Folio</span>
            <span class="text-muted small">@_preview.EntryDate.ToString("yyyy-MM-dd")</span>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-4"><div class="text-muted small">Tercero</div><div>@_preview.ThirdPartyName</div></div>
                <div class="col-md-4"><div class="text-muted small">Concepto</div><div>@_preview.Concept</div></div>
                <div class="col-md-4"><div class="text-muted small">Referencia</div><div>@_preview.ReferenceKey</div></div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_preview.Message))
            {
                <div class="alert alert-warning">@_preview.Message</div>
            }

            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Cuenta</th>
                            <th>Descripción</th>
                            <th class="text-end">Cargo</th>
                            <th class="text-end">Abono</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var line in _preview.Lines)
                    {
                        <tr>
                            <td>@line.AccountCode · @line.AccountName</td>
                            <td>@line.Description</td>
                            <td class="text-end">@line.Debit.ToString("N2")</td>
                            <td class="text-end">@line.Credit.ToString("N2")</td>
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr class="fw-semibold">
                            <td colspan="2" class="text-end">Totales</td>
                            <td class="text-end">@_preview.Lines.Sum(x => x.Debit).ToString("N2")</td>
                            <td class="text-end">@_preview.Lines.Sum(x => x.Credit).ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _message;
    private string _sourceType = "all";
    private bool _includeGenerated;
    private Guid? _selectedSourceId;
    private AccountingAutoPolicySummaryDto _summary = new();
    private List<AccountingAutoPolicySourceDto> _rows = new();
    private AccountingAutoPolicyPreviewDto? _preview;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _busy = true;
        _error = null;
        _message = null;

        try
        {
            _summary = await Api.GetAutoPolicySummaryAsync();
            _rows = await Api.GetAutoPolicySourcesAsync(_sourceType, _includeGenerated);
            _preview = null;
            _selectedSourceId = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            _busy = false;
        }
    }

    private async Task PreviewAsync(string sourceType, Guid sourceId)
    {
        _busy = true;
        _error = null;
        _message = null;

        try
        {
            _preview = await Api.GetAutoPolicyPreviewAsync(sourceType, sourceId);
            _selectedSourceId = sourceId;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task GenerateOneAsync(string sourceType, Guid sourceId)
    {
        _busy = true;
        _error = null;
        _message = null;

        try
        {
            var result = await Api.GenerateAutoPolicyAsync(new AccountingAutoPolicyGenerateRequest { SourceType = sourceType, SourceId = sourceId });
            _message = result.Message;
            await ReloadAsync();
            await PreviewAsync(sourceType, sourceId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task GenerateFilteredAsync()
    {
        _busy = true;
        _error = null;
        _message = null;

        try
        {
            var result = await Api.GeneratePendingAutoPoliciesAsync(_sourceType);
            _message = result.Message;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static string GetSourceLabel(string sourceType)
    {
        return sourceType switch
        {
            "sales_invoice" => "Factura venta",
            "credit_note" => "Nota crédito",
            "purchase_invoice" => "Factura proveedor",
            "receipt" => "Recibo",
            "payment" => "Pago",
            _ => sourceType
        };
    }
}
