@page "/accounting/document-posting"
@using Microsoft.AspNetCore.Components
@using Nanchesoft.Web.Services.Accounting
@inject AccountingApiService Api
@inject NavigationManager Navigation

<PageTitle>Contabilizar documentos | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Contabilidad · Contabilizar documentos</h1>

<div class="alert alert-secondary">
    Usa esta pantalla para <strong>previsualizar</strong> y <strong>generar</strong> la póliza automática de un documento puntual.
    La póliza se crea en <strong>borrador</strong> para que la revises antes de aprobar y postear.
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Tipo de documento</label>
                <select class="form-select" @bind="_sourceTypeFilter">
                    <option value="all">Todos</option>
                    <option value="sales_invoice">Facturas de venta</option>
                    <option value="credit_note">Notas de crédito</option>
                    <option value="purchase_invoice">Facturas de proveedor</option>
                    <option value="receipt">Recibos</option>
                    <option value="payment">Pagos</option>
                </select>
            </div>
            <div class="col-md-8 d-flex gap-2 justify-content-md-end">
                <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_busy">Actualizar</button>
                <a class="btn btn-outline-secondary" href="/accounting/auto-policies">Pólizas automáticas</a>
                <a class="btn btn-outline-secondary" href="/accounting/journal-entries">Ir a pólizas</a>
            </div>
        </div>
    </div>
</div>

@if (SourceId.HasValue)
{
    <div class="card shadow-sm mb-3 border-primary">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <div class="text-muted small">Documento actual</div>
                <div class="fw-semibold">@GetSourceLabel(EffectiveSourceType) · @SourceId.Value</div>
                <div class="small text-muted">Abriste esta pantalla desde el documento origen.</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @if (!string.IsNullOrWhiteSpace(GetSourceDocumentUrl(EffectiveSourceType, SourceId.Value)))
                {
                    <a class="btn btn-outline-primary" href="@GetSourceDocumentUrl(EffectiveSourceType, SourceId.Value)">Volver al documento</a>
                }
                <button class="btn btn-primary" @onclick="LoadCurrentPreviewAsync" disabled="@_busy">Recargar vista previa</button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="alert alert-info">Cargando documentos contables...</div>
}
else if (_rows.Count == 0)
{
    <div class="alert alert-light border">No hay documentos disponibles con el filtro actual.</div>
}
else
{
    <div class="card shadow-sm mb-3">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tipo</th>
                        <th>Fecha</th>
                        <th>Folio</th>
                        <th>Tercero</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in _rows)
                {
                    <tr class="@(row.SourceId == _selectedSourceId ? "table-primary" : null)">
                        <td>@GetSourceLabel(row.SourceType)</td>
                        <td>@row.DocumentDate.ToString("yyyy-MM-dd")</td>
                        <td>@row.Folio</td>
                        <td>@row.ThirdPartyName</td>
                        <td class="text-end">@row.Total.ToString("N2")</td>
                        <td>
                            @if (row.ExistingJournalEntryId.HasValue)
                            {
                                <span class="badge text-bg-success">@($"{row.ExistingJournalFolio} · {row.ExistingJournalStatus}")</span>
                            }
                            else if (row.IsReady)
                            {
                                <span class="badge text-bg-warning">Pendiente</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger">No lista</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-secondary" @onclick="() => PreviewAsync(row.SourceType, row.SourceId)">Vista previa</button>
                                <button class="btn btn-outline-primary" @onclick="() => GenerateAsync(row.SourceType, row.SourceId)" disabled="@(_busy || !row.IsReady || row.ExistingJournalEntryId.HasValue)">Generar</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_preview is not null)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Vista previa · @GetSourceLabel(_preview.SourceType) · @_preview.Folio</span>
            <span class="text-muted small">@_preview.EntryDate.ToString("yyyy-MM-dd")</span>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-lg-4">
                    <div class="text-muted small">Tercero</div>
                    <div>@_preview.ThirdPartyName</div>
                </div>
                <div class="col-lg-4">
                    <div class="text-muted small">Concepto</div>
                    <div>@_preview.Concept</div>
                </div>
                <div class="col-lg-4">
                    <div class="text-muted small">Referencia</div>
                    <div>@_preview.ReferenceKey</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_preview.Message))
            {
                <div class="alert @(_preview.IsReady ? "alert-info" : "alert-warning")">@_preview.Message</div>
            }

            @if (_preview.ExistingJournalEntryId.HasValue)
            {
                <div class="alert alert-success d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <span>Este documento ya tiene la póliza <strong>@_preview.ExistingJournalFolio</strong> con estatus <strong>@_preview.ExistingJournalStatus</strong>.</span>
                    <a class="btn btn-outline-success btn-sm" href="/accounting/journal-entries">Revisar pólizas</a>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Cuenta</th>
                            <th>Descripción</th>
                            <th class="text-end">Cargo</th>
                            <th class="text-end">Abono</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var line in _preview.Lines)
                    {
                        <tr>
                            <td>@line.AccountCode · @line.AccountName</td>
                            <td>@line.Description</td>
                            <td class="text-end">@line.Debit.ToString("N2")</td>
                            <td class="text-end">@line.Credit.ToString("N2")</td>
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr class="fw-semibold">
                            <td colspan="2" class="text-end">Totales</td>
                            <td class="text-end">@_preview.Lines.Sum(x => x.Debit).ToString("N2")</td>
                            <td class="text-end">@_preview.Lines.Sum(x => x.Credit).ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex gap-2 flex-wrap mt-3">
                @if (_preview.SourceId != Guid.Empty)
                {
                    <button class="btn btn-primary" @onclick="() => GenerateAsync(_preview.SourceType, _preview.SourceId)" disabled="@(_busy || !_preview.IsReady || _preview.ExistingJournalEntryId.HasValue)">Generar póliza en borrador</button>
                }
                @if (!string.IsNullOrWhiteSpace(GetSourceDocumentUrl(_preview.SourceType, _preview.SourceId)))
                {
                    <a class="btn btn-outline-secondary" href="@GetSourceDocumentUrl(_preview.SourceType, _preview.SourceId)">Volver al documento</a>
                }
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "sourceType")]
    public string? SourceType { get; set; }

    [SupplyParameterFromQuery(Name = "sourceId")]
    public Guid? SourceId { get; set; }

    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _message;
    private string _sourceTypeFilter = "all";
    private Guid? _selectedSourceId;
    private string _lastQueryKey = string.Empty;
    private List<AccountingAutoPolicySourceDto> _rows = new();
    private AccountingAutoPolicyPreviewDto? _preview;

    private string EffectiveSourceType => NormalizeSourceType(SourceType);

    protected override async Task OnParametersSetAsync()
    {
        var key = $"{NormalizeSourceType(SourceType)}|{SourceId}";
        if (_lastQueryKey == key)
        {
            return;
        }

        _lastQueryKey = key;
        _sourceTypeFilter = NormalizeSourceType(SourceType);
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _busy = true;
        _error = null;
        _message = null;

        try
        {
            _rows = await Api.GetAutoPolicySourcesAsync(_sourceTypeFilter, includeGenerated: true);

            if (SourceId.HasValue && !string.Equals(_sourceTypeFilter, "all", StringComparison.OrdinalIgnoreCase))
            {
                await LoadPreviewInternalAsync(EffectiveSourceType, SourceId.Value, updateUrl: false);
            }
            else
            {
                _preview = null;
                _selectedSourceId = null;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            _busy = false;
        }
    }

    private async Task LoadCurrentPreviewAsync()
    {
        if (SourceId.HasValue)
        {
            await LoadPreviewInternalAsync(EffectiveSourceType, SourceId.Value, updateUrl: false);
        }
    }

    private async Task PreviewAsync(string sourceType, Guid sourceId)
        => await LoadPreviewInternalAsync(sourceType, sourceId, updateUrl: true);

    private async Task LoadPreviewInternalAsync(string sourceType, Guid sourceId, bool updateUrl)
    {
        _busy = true;
        _error = null;
        _message = null;

        try
        {
            _selectedSourceId = sourceId;
            _preview = await Api.GetAutoPolicyPreviewAsync(sourceType, sourceId);

            if (updateUrl)
            {
                Navigation.NavigateTo($"/accounting/document-posting?sourceType={Uri.EscapeDataString(sourceType)}&sourceId={sourceId}", false);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task GenerateAsync(string sourceType, Guid sourceId)
    {
        _busy = true;
        _error = null;
        _message = null;

        try
        {
            var result = await Api.GenerateAutoPolicyAsync(new AccountingAutoPolicyGenerateRequest
            {
                SourceType = sourceType,
                SourceId = sourceId
            });

            if (!result.Success)
            {
                _error = result.Message;
                return;
            }

            _message = result.Message;
            _sourceTypeFilter = NormalizeSourceType(sourceType);
            SourceType = sourceType;
            SourceId = sourceId;
            _lastQueryKey = string.Empty;
            await ReloadAsync();
            await LoadPreviewInternalAsync(sourceType, sourceId, updateUrl: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static string NormalizeSourceType(string? sourceType)
    {
        var value = (sourceType ?? "all").Trim().ToLowerInvariant();
        return value switch
        {
            "sales_invoice" or "credit_note" or "purchase_invoice" or "receipt" or "payment" => value,
            _ => "all"
        };
    }

    private static string GetSourceLabel(string sourceType)
        => sourceType switch
        {
            "sales_invoice" => "Factura de venta",
            "credit_note" => "Nota de crédito",
            "purchase_invoice" => "Factura de proveedor",
            "receipt" => "Recibo",
            "payment" => "Pago",
            _ => sourceType
        };

    private static string GetSourceDocumentUrl(string sourceType, Guid sourceId)
        => sourceType switch
        {
            "sales_invoice" => $"/sales/invoices/detail/{sourceId}",
            "credit_note" => $"/sales/credit-notes/detail/{sourceId}",
            "purchase_invoice" => $"/purchases/invoices/detail/{sourceId}",
            "receipt" => $"/treasury/receipts/detail/{sourceId}",
            "payment" => $"/treasury/payments/detail/{sourceId}",
            _ => string.Empty
        };
}
