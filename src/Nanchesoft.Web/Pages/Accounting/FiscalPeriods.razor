@page "/accounting/fiscal-periods"
@using Nanchesoft.Web.Services.Accounting
@inject AccountingApiService Api

<PageTitle>Periodos fiscales | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Contabilidad · Periodos fiscales</h1>

<div class="card shadow-sm mb-3">
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label">Año</label>
            <input class="form-control" type="number" @bind="_year" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary" @onclick="LoadAsync">Consultar</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}
@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Mes</th>
                    <th>Inicio</th>
                    <th>Fin</th>
                    <th>Estatus</th>
                    <th>Activo</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Sin periodos fiscales.</td></tr>
                }
                else
                {
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>@row.Month.ToString("D2") - @MonthName(row.Month)</td>
                            <td>@row.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@row.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>@row.Status</td>
                            <td>@(row.IsActive ? "Sí" : "No")</td>
                            <td class="text-end">
                                @if (row.Status == "open")
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => CloseAsync(row.Id)">Cerrar</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => ReopenAsync(row.Id)">Reabrir</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private int _year = DateTime.Today.Year;
    private List<FiscalPeriodRowDto> _rows = new();
    private string? _message;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var lookups = await Api.GetLookupsAsync();
        if (lookups.CurrentYear > 0)
        {
            _year = lookups.CurrentYear;
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _message = null;
        _error = null;
        try
        {
            _rows = await Api.GetFiscalPeriodsAsync(_year);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CloseAsync(Guid periodId)
    {
        _message = null;
        _error = null;
        try
        {
            await Api.CloseFiscalPeriodAsync(periodId);
            _message = "Periodo cerrado correctamente.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ReopenAsync(Guid periodId)
    {
        _message = null;
        _error = null;
        try
        {
            await Api.ReopenFiscalPeriodAsync(periodId);
            _message = "Periodo reabierto correctamente.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string MonthName(int month) => month switch
    {
        1 => "Enero",
        2 => "Febrero",
        3 => "Marzo",
        4 => "Abril",
        5 => "Mayo",
        6 => "Junio",
        7 => "Julio",
        8 => "Agosto",
        9 => "Septiembre",
        10 => "Octubre",
        11 => "Noviembre",
        12 => "Diciembre",
        _ => "Mes"
    };
}
