@page "/sales/invoices"
@using Nanchesoft.Web.Services.Cfdi
@inject CfdiApiService CfdiApiService
@inject NavigationManager Navigation
<PageTitle>Facturas | Nanchesoft</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase small text-secondary fw-semibold">Ventas · facturas</div>
            <h2 class="mb-1">Facturas de venta</h2>
            <div class="text-secondary">Captura, timbra y contabiliza directo las facturas desde la operación comercial.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/sales/dashboard")'>Dashboard ventas</button>
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/cfdi/documents")'>Documentos CFDI</button>
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/accounting/document-posting?sourceType=sales_invoice")'>Contabilizar documentos</button>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/sales/invoices/detail")'>Nueva factura</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success">@_message</div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (_loading)
    {
        <div class="alert alert-info">Cargando facturas...</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Venta</th>
                            <th>CFDI</th>
                            <th>UUID</th>
                            <th style="width: 380px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>@row.Folio</td>
                                <td>@row.CustomerName</td>
                                <td>@row.DocumentDate.ToString("yyyy-MM-dd")</td>
                                <td>@row.Total.ToString("N2")</td>
                                <td>@row.BusinessStatus</td>
                                <td>@row.CfdiStatus</td>
                                <td>@(string.IsNullOrWhiteSpace(row.Uuid) ? "-" : row.Uuid)</td>
                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a class="btn btn-sm btn-outline-secondary" href="@row.EditRoute">Editar</a>
                                        <button class="btn btn-sm btn-outline-primary" @onclick='() => OpenAccounting(row.Id)'>Contabilizar</button>
                                        <button class="btn btn-sm btn-success" disabled="@(row.BusinessStatus is not ("approved" or "posted") || row.CfdiStatus is not ("pending" or "not-generated"))" @onclick='() => StampAsync(row.Id)'>Timbrar</button>
                                        <button class="btn btn-sm btn-warning" disabled="@(row.CfdiStatus != "stamped")" @onclick='() => CancelAsync(row.Id)'>Cancelar</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _message;
    private string? _error;
    private List<CfdiSalesSourceDto> _rows = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _message = null;
        _error = null;
        _rows = await CfdiApiService.GetSalesInvoicesAsync();
        _loading = false;
    }

    private void OpenAccounting(Guid id)
    {
        Navigation.NavigateTo($"/accounting/document-posting?sourceType=sales_invoice&sourceId={id}");
    }

    private async Task StampAsync(Guid id)
    {
        _message = null;
        _error = null;
        try
        {
            await CfdiApiService.StampSalesInvoiceAsync(id);
            _message = "Factura timbrada correctamente en modo demo.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CancelAsync(Guid id)
    {
        _message = null;
        _error = null;
        try
        {
            await CfdiApiService.CancelSalesInvoiceAsync(id);
            _message = "Factura cancelada correctamente en modo demo.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
