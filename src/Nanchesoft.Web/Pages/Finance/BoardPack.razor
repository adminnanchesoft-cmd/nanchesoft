@page "/finance/board-pack"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Paquete directivo | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Paquete directivo</h1>
<p class="text-muted">Resumen ejecutivo del mes con tendencia de seis meses, capital de trabajo y cumplimiento financiero.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-8 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
        <a class="btn btn-outline-secondary" href="/finance/liquidity-radar">Radar liquidez</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando paquete directivo...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Ventas del mes</div><div class="fs-4 fw-bold text-primary">@_dto.SalesCurrentMonth.ToString("N2")</div><div class="small text-muted">Compras @_dto.PurchasesCurrentMonth.ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Flujo neto del mes</div><div class="fs-4 fw-bold @GetSignedClass(_dto.NetCashCurrentMonth)">@_dto.NetCashCurrentMonth.ToString("N2")</div><div class="small text-muted">Cobros @_dto.ReceiptsCurrentMonth.ToString("N2") / pagos @_dto.PaymentsCurrentMonth.ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Capital de trabajo</div><div class="fs-4 fw-bold @GetSignedClass(_dto.WorkingCapital)">@_dto.WorkingCapital.ToString("N2")</div><div class="small text-muted">CxC @_dto.OpenReceivables.ToString("N2") / CxP @_dto.OpenPayables.ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Presupuesto y meta</div><div class="fs-4 fw-bold @GetComplianceClass(_dto.BudgetCompliancePercent)">@_dto.BudgetCompliancePercent.ToString("N2")%</div><div class="small text-muted">Meta @_dto.GoalCompliancePercent.ToString("N2")%</div></div></div></div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="h5 mb-3">Resumen del mes</div>
                    <table class="table table-sm align-middle mb-0">
                        <tbody>
                            <tr><th>Mes</th><td class="text-end">@_dto.MonthLabel</td></tr>
                            <tr><th>Inventario valorizado</th><td class="text-end">@_dto.InventoryValue.ToString("N2")</td></tr>
                            <tr><th>Presupuesto</th><td class="text-end">@_dto.BudgetCurrentMonth.ToString("N2")</td></tr>
                            <tr><th>Real</th><td class="text-end">@_dto.ActualCurrentMonth.ToString("N2")</td></tr>
                            <tr><th>Meta</th><td class="text-end">@_dto.GoalCurrentMonth.ToString("N2")</td></tr>
                            <tr><th>Real meta</th><td class="text-end">@_dto.GoalActualCurrentMonth.ToString("N2")</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="h5 mb-3">Lectura ejecutiva</div>
                    <ul class="mb-0">
                        <li>El flujo neto del mes es <strong class="@GetSignedClass(_dto.NetCashCurrentMonth)">@_dto.NetCashCurrentMonth.ToString("N2")</strong>.</li>
                        <li>La liquidez disponible soporta un capital de trabajo de <strong>@_dto.WorkingCapital.ToString("N2")</strong>.</li>
                        <li>El cumplimiento contra presupuesto va en <strong>@_dto.BudgetCompliancePercent.ToString("N2")%</strong>.</li>
                        <li>El cumplimiento contra meta va en <strong>@_dto.GoalCompliancePercent.ToString("N2")%</strong>.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="h5 mb-3">Tendencia últimos 6 meses</div>
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Periodo</th>
                            <th class="text-end">Ventas</th>
                            <th class="text-end">Compras</th>
                            <th class="text-end">Cobros</th>
                            <th class="text-end">Pagos</th>
                            <th class="text-end">Flujo neto</th>
                            <th class="text-end">Presupuesto</th>
                            <th class="text-end">Real</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _dto.MonthlyRows)
                        {
                            <tr>
                                <td>@row.Label</td>
                                <td class="text-end">@row.Sales.ToString("N2")</td>
                                <td class="text-end">@row.Purchases.ToString("N2")</td>
                                <td class="text-end">@row.Receipts.ToString("N2")</td>
                                <td class="text-end">@row.Payments.ToString("N2")</td>
                                <td class="text-end @GetSignedClass(row.NetCash)">@row.NetCash.ToString("N2")</td>
                                <td class="text-end">@row.Budget.ToString("N2")</td>
                                <td class="text-end">@row.Actual.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private FinanceBoardPackDto _dto = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _dto = await FinanceApiService.GetBoardPackAsync(_year, _month);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetSignedClass(decimal value) => value >= 0m ? "text-success" : "text-danger";
    private static string GetComplianceClass(decimal value) => value >= 100m ? "text-success" : value >= 90m ? "text-warning" : "text-danger";
}
