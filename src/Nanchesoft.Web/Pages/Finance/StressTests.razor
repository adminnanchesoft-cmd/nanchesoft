@page "/finance/stress-tests"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Pruebas de estrés | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Pruebas de estrés</h1>
<p class="text-muted">Evalúa la resistencia de caja frente a cambios en cobros y pagos del mes seleccionado.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-8 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/liquidity-radar">Radar liquidez</a>
        <a class="btn btn-outline-secondary" href="/finance/scenarios">Escenarios financieros</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando pruebas de estrés...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Liquidez base</div><div class="fs-4 fw-bold">@_dto.BaseLiquidity.ToString("N2")</div><div class="small text-muted">Caja + bancos activos</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Cobros base</div><div class="fs-4 fw-bold text-success">@_dto.BaseInflows.ToString("N2")</div><div class="small text-muted">Entradas del mes</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Pagos base</div><div class="fs-4 fw-bold text-danger">@_dto.BaseOutflows.ToString("N2")</div><div class="small text-muted">Salidas del mes</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Cierre base</div><div class="fs-4 fw-bold @GetSignedClass(_dto.BaseClosingCash)">@_dto.BaseClosingCash.ToString("N2")</div><div class="small text-muted">Antes de escenarios</div></div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Escenario</th>
                    <th class="text-end">Delta cobros</th>
                    <th class="text-end">Delta pagos</th>
                    <th class="text-end">Cierre proyectado</th>
                    <th class="text-end">Variación vs base</th>
                    <th>Impacto</th>
                    <th>Notas</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _dto.Rows)
                {
                    <tr>
                        <td>@row.Scenario</td>
                        <td class="text-end @GetSignedClass(row.InflowDelta)">@row.InflowDelta.ToString("N2")</td>
                        <td class="text-end @(row.OutflowDelta > 0 ? "text-danger" : "text-success")">@row.OutflowDelta.ToString("N2")</td>
                        <td class="text-end @GetSignedClass(row.ClosingCash)">@row.ClosingCash.ToString("N2")</td>
                        <td class="text-end @GetSignedClass(row.VarianceVsBase)">@row.VarianceVsBase.ToString("N2")</td>
                        <td><span class="badge @GetImpactBadge(row.ImpactLevel)">@row.ImpactLevel</span></td>
                        <td>@row.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private FinanceStressTestDto _dto = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _dto = await FinanceApiService.GetStressTestsAsync(_year, _month);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetSignedClass(decimal value) => value >= 0m ? "text-success" : "text-danger";
    private static string GetImpactBadge(string value) => value == "Crítico" ? "bg-danger" : value == "Presión" ? "bg-warning text-dark" : "bg-success";
}
