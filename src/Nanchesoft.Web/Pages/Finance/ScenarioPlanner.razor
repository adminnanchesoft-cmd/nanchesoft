@page "/finance/scenarios"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Escenarios financieros | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Escenarios financieros</h1>
<p class="text-muted">Simula cambios en cobranza, pagos, crecimiento y movimientos extraordinarios para medir el impacto en liquidez semanal.</p>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Escenarios guardados</h2>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadAsync">Recargar</button>
                </div>
                @if (_loading)
                {
                    <div class="alert alert-info mb-0">Cargando escenarios...</div>
                }
                else if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger mb-0">@_error</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var row in _rows.OrderBy(x => x.Name))
                        {
                            <button type="button" class="list-group-item list-group-item-action @(row.Id == _edit.Id ? "active" : string.Empty)" @onclick="() => EditRow(row)">
                                <div class="fw-semibold">@row.Name</div>
                                <div class="small">Cobranza @row.CollectionShiftDays días · Pagos @row.PaymentShiftDays días · Horizonte @row.HorizonWeeks semanas</div>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Editor</h2>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="_edit.Name" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Mover cobranza (días)</label>
                        <input class="form-control" type="number" @bind="_edit.CollectionShiftDays" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Mover pagos (días)</label>
                        <input class="form-control" type="number" @bind="_edit.PaymentShiftDays" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Crec. ventas %</label>
                        <input class="form-control" type="number" step="0.01" @bind="_edit.SalesGrowthPercent" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Crec. compras %</label>
                        <input class="form-control" type="number" step="0.01" @bind="_edit.PurchaseGrowthPercent" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Red. gastos %</label>
                        <input class="form-control" type="number" step="0.01" @bind="_edit.ExpenseReductionPercent" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Ingreso extra</label>
                        <input class="form-control" type="number" step="0.01" @bind="_edit.ExtraInflow" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Salida extra</label>
                        <input class="form-control" type="number" step="0.01" @bind="_edit.ExtraOutflow" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Horizonte (semanas)</label>
                        <input class="form-control" type="number" min="1" max="26" @bind="_edit.HorizonWeeks" />
                    </div>
                    <div class="col-6 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="_edit.IsDefault" />
                            <label class="form-check-label">Escenario favorito</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notas</label>
                        <textarea class="form-control" rows="3" @bind="_edit.Notes"></textarea>
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <button class="btn btn-success" @onclick="AddOrUpdateAsync">Agregar / actualizar</button>
                    <button class="btn btn-outline-primary" @onclick="EvaluateAsync">Evaluar</button>
                    <button class="btn btn-outline-secondary" @onclick="ResetForm">Limpiar</button>
                    <button class="btn btn-primary" @onclick="SaveAllAsync" disabled="@_saving">Guardar todo</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        @if (_evaluation is not null)
        {
            <div class="row g-3 mb-3">
                <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Liquidez inicial</div><div class="fs-4 fw-bold">@_evaluation.OpeningBalance.ToString("N2")</div></div></div></div>
                <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Cierre base</div><div class="fs-4 fw-bold text-secondary">@_evaluation.BaselineClosingBalance.ToString("N2")</div></div></div></div>
                <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Cierre escenario</div><div class="fs-4 fw-bold @( _evaluation.ImpactAmount >= 0 ? "text-success" : "text-danger")">@_evaluation.ScenarioClosingBalance.ToString("N2")</div><div class="small text-muted">Impacto @_evaluation.ImpactAmount.ToString("N2")</div></div></div></div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Resultado por semana</h2>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Semana</th>
                                    <th class="text-end">Base cierre</th>
                                    <th class="text-end">Escenario cierre</th>
                                    <th class="text-end">Impacto</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _evaluation.Rows)
                                {
                                    <tr>
                                        <td>@row.PeriodStart.ToString("dd/MM") - @row.PeriodEnd.ToString("dd/MM")</td>
                                        <td class="text-end">@row.BaselineClosing.ToString("N2")</td>
                                        <td class="text-end">@row.ScenarioClosing.ToString("N2")</td>
                                        <td class="text-end @(row.ImpactAmount >= 0 ? "text-success" : "text-danger")">@row.ImpactAmount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-secondary">Captura o selecciona un escenario y luego presiona <strong>Evaluar</strong>.</div>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private List<FinanceScenarioRowDto> _rows = new();
    private FinanceScenarioRowDto _edit = NewRow();
    private FinanceScenarioEvaluationDto? _evaluation;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetScenariosAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task AddOrUpdateAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_edit.Name))
        {
            _error = "Captura un nombre para el escenario.";
            return Task.CompletedTask;
        }

        _edit.HorizonWeeks = _edit.HorizonWeeks <= 0 ? 8 : Math.Min(26, _edit.HorizonWeeks);
        _edit.UpdatedAt = DateTime.UtcNow;
        var existing = _rows.FirstOrDefault(x => x.Id == _edit.Id);
        if (existing is null)
        {
            _rows.Add(Clone(_edit));
        }
        else
        {
            Copy(_edit, existing);
        }
        return Task.CompletedTask;
    }

    private async Task EvaluateAsync()
    {
        _error = null;
        try
        {
            _evaluation = await FinanceApiService.EvaluateScenarioAsync(_edit);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SaveAllAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            await FinanceApiService.SaveScenariosAsync(_rows);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void EditRow(FinanceScenarioRowDto row)
    {
        _edit = Clone(row);
    }

    private void ResetForm()
    {
        _edit = NewRow();
    }

    private static FinanceScenarioRowDto NewRow() => new()
    {
        HorizonWeeks = 8
    };

    private static FinanceScenarioRowDto Clone(FinanceScenarioRowDto source) => new()
    {
        Id = source.Id,
        Name = source.Name,
        Notes = source.Notes,
        CollectionShiftDays = source.CollectionShiftDays,
        PaymentShiftDays = source.PaymentShiftDays,
        SalesGrowthPercent = source.SalesGrowthPercent,
        PurchaseGrowthPercent = source.PurchaseGrowthPercent,
        ExpenseReductionPercent = source.ExpenseReductionPercent,
        ExtraInflow = source.ExtraInflow,
        ExtraOutflow = source.ExtraOutflow,
        HorizonWeeks = source.HorizonWeeks,
        IsDefault = source.IsDefault,
        UpdatedAt = source.UpdatedAt
    };

    private static void Copy(FinanceScenarioRowDto source, FinanceScenarioRowDto target)
    {
        target.Name = source.Name;
        target.Notes = source.Notes;
        target.CollectionShiftDays = source.CollectionShiftDays;
        target.PaymentShiftDays = source.PaymentShiftDays;
        target.SalesGrowthPercent = source.SalesGrowthPercent;
        target.PurchaseGrowthPercent = source.PurchaseGrowthPercent;
        target.ExpenseReductionPercent = source.ExpenseReductionPercent;
        target.ExtraInflow = source.ExtraInflow;
        target.ExtraOutflow = source.ExtraOutflow;
        target.HorizonWeeks = source.HorizonWeeks;
        target.IsDefault = source.IsDefault;
        target.UpdatedAt = source.UpdatedAt;
    }
}
