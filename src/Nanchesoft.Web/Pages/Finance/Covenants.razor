@page "/finance/covenants"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Covenants | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Covenants y coberturas</h1>
<p class="text-muted">Monitorea límites internos de liquidez, presión de pagos, concentración de cartera y cobertura de capital de trabajo.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2"><label class="form-label">Año</label><input class="form-control" type="number" min="2020" max="2100" @bind="_year" /></div>
    <div class="col-md-2"><label class="form-label">Mes</label><select class="form-select" @bind="_month">@for (var month = 1; month <= 12; month++) { <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option> }</select></div>
    <div class="col-md-8 d-flex gap-2"><button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button><a class="btn btn-outline-secondary" href="/finance/liquidity-radar">Radar liquidez</a></div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando covenants...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">OK</div><div class="fs-4 fw-bold text-success">@_rows.Count(x => x.Status == "ok")</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Warning</div><div class="fs-4 fw-bold text-warning">@_rows.Count(x => x.Status == "warning")</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Críticos</div><div class="fs-4 fw-bold text-danger">@_rows.Count(x => x.Status == "critical")</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle mb-0">
                    <thead><tr><th>Código</th><th>Covenant</th><th class="text-end">Actual</th><th>Condición</th><th class="text-end">Umbral</th><th class="text-end">Holgura</th><th>Estatus</th><th>Notas</th></tr></thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>@row.CovenantCode</td>
                                <td>@row.CovenantName</td>
                                <td class="text-end">@row.CurrentValue.ToString("N4")</td>
                                <td>@row.ThresholdOperator</td>
                                <td class="text-end">@row.ThresholdValue.ToString("N4")</td>
                                <td class="text-end @GetHeadroomClass(row.Headroom)">@row.Headroom.ToString("N4")</td>
                                <td><span class="badge @GetStatusBadge(row.Status)">@row.Status</span></td>
                                <td>@row.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private List<FinanceCovenantRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try { _rows = await FinanceApiService.GetCovenantsAsync(_year, _month); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private static string GetStatusBadge(string value) => value switch { "critical" => "text-bg-danger", "warning" => "text-bg-warning", _ => "text-bg-success" };
    private static string GetHeadroomClass(decimal value) => value >= 0m ? "text-success" : "text-danger";
}
