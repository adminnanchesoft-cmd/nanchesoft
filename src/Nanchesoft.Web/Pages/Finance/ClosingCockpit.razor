@page "/finance/closing-cockpit"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Cockpit de cierre | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Cockpit de cierre</h1>
<p class="text-muted">Checklist mensual para saber qué falta por cerrar en Contabilidad, Tesorería, Ventas, Compras, CxC y CxP.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2"><label class="form-label">Año</label><input class="form-control" type="number" min="2020" max="2100" @bind="_year" /></div>
    <div class="col-md-2"><label class="form-label">Mes</label><select class="form-select" @bind="_month">@for (var month = 1; month <= 12; month++) { <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option> }</select></div>
    <div class="col-md-8 d-flex gap-2"><button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button><a class="btn btn-outline-secondary" href="/accounting/fiscal-periods">Periodos</a></div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando cockpit...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Checks críticos</div><div class="fs-4 fw-bold text-danger">@_rows.Count(x => x.Status == "critical")</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Checks en warning</div><div class="fs-4 fw-bold text-warning">@_rows.Count(x => x.Status == "warning")</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Importe bajo revisión</div><div class="fs-4 fw-bold text-primary">@_rows.Sum(x => x.Amount).ToString("N2")</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle mb-0">
                    <thead><tr><th>Área</th><th>Check</th><th class="text-end">Pendientes</th><th class="text-end">Monto</th><th>Estatus</th><th>Detalle</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>@row.Area</td>
                                <td>@row.CheckName</td>
                                <td class="text-end">@row.PendingCount</td>
                                <td class="text-end">@row.Amount.ToString("N2")</td>
                                <td><span class="badge @GetStatusBadge(row.Status)">@row.Status</span></td>
                                <td>@row.Detail</td>
                                <td>@if (!string.IsNullOrWhiteSpace(row.Route)) { <a class="btn btn-sm btn-outline-primary" href="@row.Route">Abrir</a> }</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private List<FinanceClosingCockpitRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try { _rows = await FinanceApiService.GetClosingCockpitAsync(_year, _month); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private static string GetStatusBadge(string value) => value switch { "critical" => "text-bg-danger", "warning" => "text-bg-warning", _ => "text-bg-success" };
}
