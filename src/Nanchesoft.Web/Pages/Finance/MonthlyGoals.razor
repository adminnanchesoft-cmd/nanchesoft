@page "/finance/monthly-goals"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Metas mensuales | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Metas mensuales</h1>
<p class="text-muted">Controla metas operativas por mes para ventas, compras, cobros y pagos.</p>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" @bind="_year" />
    </div>
    <div class="col-md-2 d-flex align-items-end gap-2">
        <button class="btn btn-outline-secondary" @onclick="ReloadAsync">Cargar</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">Guardar</button>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando metas...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Metas</div><div class="display-6 fw-bold">@_rows.Count</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Objetivo total</div><div class="fs-4 fw-bold text-info">@_rows.Sum(x => x.TargetAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Actual total</div><div class="fs-4 fw-bold text-primary">@_progress.Sum(x => x.ActualAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Cumplimiento promedio</div><div class="fs-4 fw-bold">@(_progress.Any() ? _progress.Average(x => x.CompliancePercent).ToString("N2") : "0.00")%</div></div></div></div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h2 class="h5 mb-3">Captura / edición</h2>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Métrica</label>
                    <select class="form-select" value="@_selectedMetricCode" @onchange="OnMetricChanged">
                        <option value="">Selecciona...</option>
                        @foreach (var item in _metrics)
                        {
                            <option value="@item.MetricCode">@item.MetricName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Mes</label>
                    <select class="form-select" @bind="_edit.Month">
                        @for (var month = 1; month <= 12; month++)
                        {
                            <option value="@month">@MonthName(month)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Meta</label>
                    <input class="form-control" type="number" step="0.01" @bind="_edit.TargetAmount" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Notas</label>
                    <input class="form-control" @bind="_edit.Notes" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="AddOrUpdateAsync">@(string.IsNullOrEmpty(_editModeLabel) ? "Agregar meta" : $"Actualizar {_editModeLabel}")</button>
                <button class="btn btn-outline-secondary" @onclick="ResetForm">Limpiar</button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Mes</th>
                            <th>Métrica</th>
                            <th class="text-end">Meta</th>
                            <th>Notas</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows.OrderBy(x => x.Month).ThenBy(x => x.MetricName))
                        {
                            <tr>
                                <td>@MonthName(row.Month)</td>
                                <td>@row.MetricName</td>
                                <td class="text-end">@row.TargetAmount.ToString("N2")</td>
                                <td>@row.Notes</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditRow(row)">Editar</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRow(row.Id)">Quitar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Seguimiento real vs meta</h2>
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Mes</th>
                            <th>Métrica</th>
                            <th class="text-end">Meta</th>
                            <th class="text-end">Real</th>
                            <th class="text-end">Variación</th>
                            <th class="text-end">Cumplimiento</th>
                            <th>Notas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _progress.OrderBy(x => x.Month).ThenBy(x => x.MetricName))
                        {
                            <tr>
                                <td>@MonthName(row.Month)</td>
                                <td>@row.MetricName</td>
                                <td class="text-end">@row.TargetAmount.ToString("N2")</td>
                                <td class="text-end">@row.ActualAmount.ToString("N2")</td>
                                <td class="text-end @(row.VarianceAmount >= 0m ? "text-success" : "text-danger")">@row.VarianceAmount.ToString("N2")</td>
                                <td class="text-end">@row.CompliancePercent.ToString("N2")%</td>
                                <td>@row.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private int _year = DateTime.UtcNow.Year;
    private List<FinanceGoalMetricItemDto> _metrics = new();
    private List<FinanceGoalRowDto> _rows = new();
    private List<FinanceGoalProgressRowDto> _progress = new();
    private FinanceGoalRowDto _edit = NewRow();
    private string _selectedMetricCode = string.Empty;
    private string _editModeLabel = string.Empty;

    protected override async Task OnInitializedAsync()
        => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _metrics = await FinanceApiService.GetGoalMetricsAsync();
            _rows = await FinanceApiService.GetGoalsAsync(_year);
            _progress = await FinanceApiService.GetGoalProgressAsync(_year);
            ResetForm();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            foreach (var row in _rows)
            {
                row.Year = _year;
            }

            await FinanceApiService.SaveGoalsAsync(_year, _rows);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private Task AddOrUpdateAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_edit.MetricCode))
        {
            _error = "Selecciona una métrica.";
            return Task.CompletedTask;
        }

        _edit.Year = _year;
        var existing = _rows.FirstOrDefault(x => x.Id == _edit.Id);
        if (existing is null)
        {
            _rows.Add(Clone(_edit));
        }
        else
        {
            Copy(_edit, existing);
        }

        ResetForm();
        return Task.CompletedTask;
    }

    private void EditRow(FinanceGoalRowDto row)
    {
        _edit = Clone(row);
        _selectedMetricCode = row.MetricCode;
        _editModeLabel = row.MetricName;
    }

    private void DeleteRow(Guid id)
    {
        _rows.RemoveAll(x => x.Id == id);
        if (_edit.Id == id)
        {
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _edit = NewRow();
        _selectedMetricCode = string.Empty;
        _editModeLabel = string.Empty;
    }

    private void OnMetricChanged(ChangeEventArgs args)
    {
        _selectedMetricCode = args.Value?.ToString() ?? string.Empty;
        var metric = _metrics.FirstOrDefault(x => string.Equals(x.MetricCode, _selectedMetricCode, StringComparison.OrdinalIgnoreCase));
        if (metric is null)
        {
            return;
        }

        _edit.MetricCode = metric.MetricCode;
        _edit.MetricName = metric.MetricName;
    }

    private static FinanceGoalRowDto NewRow() => new()
    {
        Id = Guid.NewGuid(),
        Year = DateTime.UtcNow.Year,
        Month = DateTime.UtcNow.Month
    };

    private static FinanceGoalRowDto Clone(FinanceGoalRowDto row) => new()
    {
        Id = row.Id,
        Year = row.Year,
        Month = row.Month,
        MetricCode = row.MetricCode,
        MetricName = row.MetricName,
        TargetAmount = row.TargetAmount,
        Notes = row.Notes
    };

    private static void Copy(FinanceGoalRowDto source, FinanceGoalRowDto target)
    {
        target.Year = source.Year;
        target.Month = source.Month;
        target.MetricCode = source.MetricCode;
        target.MetricName = source.MetricName;
        target.TargetAmount = source.TargetAmount;
        target.Notes = source.Notes;
    }

    private static string MonthName(int month)
        => new DateTime(DateTime.UtcNow.Year, month, 1).ToString("MMMM");
}
