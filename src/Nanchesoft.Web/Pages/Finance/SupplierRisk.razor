
@page "/finance/supplier-risk"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Riesgo proveedores | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Riesgo proveedores</h1>
<p class="text-muted">Evalúa presión de pago, dependencia por proveedor y acciones sugeridas para priorizar la operación.</p>

@if (_loading)
{
    <div class="alert alert-info">Cargando riesgo proveedores...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Proveedores monitoreados</div><div class="fs-4 fw-bold">@_rows.Count</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Saldo abierto</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.OpenAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Vencido</div><div class="fs-4 fw-bold text-warning">@_rows.Sum(x => x.OverdueAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Críticos</div><div class="fs-4 fw-bold text-danger">@_rows.Count(x => x.Status == "Crítico")</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Proveedor</th>
                            <th class="text-end">Abierto</th>
                            <th class="text-end">Vencido</th>
                            <th class="text-end">Programado</th>
                            <th class="text-end">Pagado</th>
                            <th class="text-end">Cumplimiento %</th>
                            <th class="text-end">Concentración %</th>
                            <th class="text-end">Autorizaciones</th>
                            <th class="text-end">Plazo</th>
                            <th>Estatus</th>
                            <th>Acción sugerida</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>@row.SupplierName</td>
                                <td class="text-end">@row.OpenAmount.ToString("N2")</td>
                                <td class="text-end">@row.OverdueAmount.ToString("N2")</td>
                                <td class="text-end">@row.ScheduledAmount.ToString("N2")</td>
                                <td class="text-end">@row.PaidAmount.ToString("N2")</td>
                                <td class="text-end">@row.CompliancePercent.ToString("N2")%</td>
                                <td class="text-end">@row.ConcentrationPercent.ToString("N2")%</td>
                                <td class="text-end">@row.RequiresAuthorizationCount</td>
                                <td class="text-end">@row.PaymentTermDays</td>
                                <td><span class="badge @GetStatusBadge(row.Status)">@row.Status</span></td>
                                <td>@row.SuggestedAction</td>
                                <td><a class="btn btn-sm btn-outline-primary" href="@row.Route">Abrir</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<FinanceSupplierRiskRowDto> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _rows = await FinanceApiService.GetSupplierRiskAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetStatusBadge(string value) => value switch { "Crítico" => "text-bg-danger", "Alerta" => "text-bg-warning", _ => "text-bg-success" };
}
