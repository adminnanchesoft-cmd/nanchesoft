@page "/finance/monthly-liquidity-bridge"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Puente liquidez mensual | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Puente liquidez mensual</h1>
<p class="text-muted">Apertura, cobros, pagos, cierre y capital de trabajo por mes.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-10 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/rolling-forecast">Forecast rolling</a>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando puente de liquidez...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Apertura año</div><div class="fs-4 fw-bold">@(_rows.FirstOrDefault()?.OpeningLiquidity.ToString("N2") ?? "0.00")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Cobros año</div><div class="fs-4 fw-bold text-success">@_rows.Sum(x => x.Receipts).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Pagos año</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.Payments).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Cierre año</div><div class="fs-4 fw-bold @GetSignedClass(_rows.LastOrDefault()?.ClosingLiquidity ?? 0m)">@(_rows.LastOrDefault()?.ClosingLiquidity.ToString("N2") ?? "0.00")</div></div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Mes</th>
                    <th class="text-end">Apertura</th>
                    <th class="text-end">Cobros</th>
                    <th class="text-end">Pagos</th>
                    <th class="text-end">Flujo neto</th>
                    <th class="text-end">Cierre</th>
                    <th class="text-end">CxC abierta</th>
                    <th class="text-end">CxP abierta</th>
                    <th class="text-end">Capital trabajo</th>
                    <th class="text-end">Cobertura %</th>
                    <th>Estatus</th>
                </tr>
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="11" class="text-center text-muted py-4">No hay información.</td></tr>
                }
                else
                {
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>@row.Label</td>
                            <td class="text-end">@row.OpeningLiquidity.ToString("N2")</td>
                            <td class="text-end">@row.Receipts.ToString("N2")</td>
                            <td class="text-end">@row.Payments.ToString("N2")</td>
                            <td class="text-end @GetSignedClass(row.NetMovement)">@row.NetMovement.ToString("N2")</td>
                            <td class="text-end @GetSignedClass(row.ClosingLiquidity)">@row.ClosingLiquidity.ToString("N2")</td>
                            <td class="text-end">@row.OpenReceivables.ToString("N2")</td>
                            <td class="text-end">@row.OpenPayables.ToString("N2")</td>
                            <td class="text-end @GetSignedClass(row.WorkingCapital)">@row.WorkingCapital.ToString("N2")</td>
                            <td class="text-end">@row.CoveragePercent.ToString("N2")%</td>
                            <td><span class="badge @GetBadge(row.Status)">@row.Status</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private bool _loading = true;
    private string? _error;
    private List<FinanceMonthlyLiquidityBridgeRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetMonthlyLiquidityBridgeAsync(_year);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetSignedClass(decimal value) => value >= 0m ? "text-success" : "text-danger";
    private static string GetBadge(string value) => value switch { "Crítico" => "text-bg-danger", "Alerta" => "text-bg-warning", _ => "text-bg-success" };
}
