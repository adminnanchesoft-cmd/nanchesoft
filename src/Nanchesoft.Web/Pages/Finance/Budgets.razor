@page "/finance/budgets"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Presupuestos | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Presupuestos financieros</h1>
<p class="text-muted">Captura presupuesto mensual por cuenta contable. Esta versión guarda la planeación sin migraciones nuevas.</p>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" @bind="_year" />
    </div>
    <div class="col-md-2 d-flex align-items-end gap-2">
        <button class="btn btn-outline-secondary" @onclick="ReloadAsync">Cargar</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">Guardar</button>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando presupuestos...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Renglones</div><div class="display-6 fw-bold">@_rows.Count</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Total anual</div><div class="fs-4 fw-bold text-primary">@_rows.Sum(x => x.BudgetAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Mes seleccionado</div><div class="fs-4 fw-bold">@_editMonthName</div><div class="small text-muted">Total @_rows.Where(x => x.Month == _edit.Month).Sum(x => x.BudgetAmount).ToString("N2")</div></div></div></div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h2 class="h5 mb-3">Captura / edición</h2>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Cuenta</label>
                    <select class="form-select" value="@_selectedAccountIdString" @onchange="OnAccountChanged">
                        <option value="">Selecciona...</option>
                        @foreach (var item in _lookups)
                        {
                            <option value="@item.AccountId">@item.AccountCode - @item.AccountName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Mes</label>
                    <select class="form-select" @bind="_edit.Month">
                        @for (var month = 1; month <= 12; month++)
                        {
                            <option value="@month">@MonthName(month)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Importe</label>
                    <input class="form-control" type="number" step="0.01" @bind="_edit.BudgetAmount" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Notas</label>
                    <input class="form-control" @bind="_edit.Notes" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="AddOrUpdateAsync">@(string.IsNullOrEmpty(_editModeLabel) ? "Agregar renglón" : $"Actualizar {_editModeLabel}")</button>
                <button class="btn btn-outline-secondary" @onclick="ResetForm">Limpiar</button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Mes</th>
                            <th>Cuenta</th>
                            <th>Tipo</th>
                            <th class="text-end">Presupuesto</th>
                            <th>Notas</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows.OrderBy(x => x.Month).ThenBy(x => x.AccountCode))
                        {
                            <tr>
                                <td>@MonthName(row.Month)</td>
                                <td>@row.AccountCode - @row.AccountName</td>
                                <td>@row.AccountType</td>
                                <td class="text-end">@row.BudgetAmount.ToString("N2")</td>
                                <td>@row.Notes</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditRow(row)">Editar</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRow(row.Id)">Quitar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private int _year = DateTime.UtcNow.Year;
    private List<FinanceBudgetLookupItemDto> _lookups = new();
    private List<FinanceBudgetRowDto> _rows = new();
    private FinanceBudgetRowDto _edit = NewRow();
    private string _selectedAccountIdString = string.Empty;
    private string _editModeLabel = string.Empty;

    private string _editMonthName => MonthName(_edit.Month == 0 ? 1 : _edit.Month);

    protected override async Task OnInitializedAsync()
        => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _lookups = await FinanceApiService.GetBudgetLookupsAsync();
            _rows = await FinanceApiService.GetBudgetsAsync(_year);
            ResetForm();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            foreach (var row in _rows)
            {
                row.Year = _year;
            }

            await FinanceApiService.SaveBudgetsAsync(_year, _rows);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private Task AddOrUpdateAsync()
    {
        _error = null;
        if (_edit.AccountId == Guid.Empty)
        {
            _error = "Selecciona una cuenta contable.";
            return Task.CompletedTask;
        }

        _edit.Year = _year;
        var existing = _rows.FirstOrDefault(x => x.Id == _edit.Id);
        if (existing is null)
        {
            _rows.Add(Clone(_edit));
        }
        else
        {
            Copy(_edit, existing);
        }

        ResetForm();
        return Task.CompletedTask;
    }

    private void EditRow(FinanceBudgetRowDto row)
    {
        _edit = Clone(row);
        _selectedAccountIdString = row.AccountId.ToString();
        _editModeLabel = row.AccountCode;
    }

    private void DeleteRow(Guid id)
    {
        _rows.RemoveAll(x => x.Id == id);
        if (_edit.Id == id)
        {
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _edit = NewRow();
        _selectedAccountIdString = string.Empty;
        _editModeLabel = string.Empty;
    }

    private void OnAccountChanged(ChangeEventArgs args)
    {
        _selectedAccountIdString = args.Value?.ToString() ?? string.Empty;
        if (!Guid.TryParse(_selectedAccountIdString, out var accountId))
        {
            return;
        }

        var account = _lookups.FirstOrDefault(x => x.AccountId == accountId);
        if (account is null)
        {
            return;
        }

        _edit.AccountId = account.AccountId;
        _edit.AccountCode = account.AccountCode;
        _edit.AccountName = account.AccountName;
        _edit.AccountType = account.AccountType;
        _edit.Nature = account.Nature;
    }

    private static FinanceBudgetRowDto NewRow() => new()
    {
        Id = Guid.NewGuid(),
        Year = DateTime.UtcNow.Year,
        Month = DateTime.UtcNow.Month
    };

    private static FinanceBudgetRowDto Clone(FinanceBudgetRowDto row) => new()
    {
        Id = row.Id,
        Year = row.Year,
        Month = row.Month,
        AccountId = row.AccountId,
        AccountCode = row.AccountCode,
        AccountName = row.AccountName,
        AccountType = row.AccountType,
        Nature = row.Nature,
        BudgetAmount = row.BudgetAmount,
        Notes = row.Notes
    };

    private static void Copy(FinanceBudgetRowDto source, FinanceBudgetRowDto target)
    {
        target.Year = source.Year;
        target.Month = source.Month;
        target.AccountId = source.AccountId;
        target.AccountCode = source.AccountCode;
        target.AccountName = source.AccountName;
        target.AccountType = source.AccountType;
        target.Nature = source.Nature;
        target.BudgetAmount = source.BudgetAmount;
        target.Notes = source.Notes;
    }

    private static string MonthName(int month)
        => new DateTime(DateTime.UtcNow.Year, month, 1).ToString("MMMM");
}
