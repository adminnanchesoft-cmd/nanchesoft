@page "/finance/concentration-analysis"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Concentración de cartera | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Concentración de cartera</h1>
<p class="text-muted">Mide dependencia comercial sobre clientes y proveedores: participación, saldo abierto y concentración.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Top</label>
        <input class="form-control" type="number" min="5" max="25" @bind="_top" />
    </div>
    <div class="col-md-8 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando concentración de cartera...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Ventas netas</div><div class="fs-4 fw-bold text-primary">@_dto.TotalSales.ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Compras</div><div class="fs-4 fw-bold text-secondary">@_dto.TotalPurchases.ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Top 3 clientes</div><div class="fs-4 fw-bold text-warning">@_dto.Top3CustomerSharePercent.ToString("N2")%</div><div class="small text-muted">HHI @(_dto.CustomerHhi.ToString("N2"))</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Top 3 proveedores</div><div class="fs-4 fw-bold text-warning">@_dto.Top3SupplierSharePercent.ToString("N2")%</div><div class="small text-muted">HHI @(_dto.SupplierHhi.ToString("N2"))</div></div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Top clientes</h2>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th class="text-end">Venta neta</th>
                                    <th class="text-end">Saldo abierto</th>
                                    <th class="text-end">Docs</th>
                                    <th class="text-end">Participación</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_dto.Customers.Count == 0)
                                {
                                    <tr><td colspan="6" class="text-center text-muted py-4">Sin datos.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _dto.Customers)
                                    {
                                        <tr>
                                            <td>@row.PartyName</td>
                                            <td class="text-end fw-semibold">@row.Amount.ToString("N2")</td>
                                            <td class="text-end">@row.OpenAmount.ToString("N2")</td>
                                            <td class="text-end">@row.Documents</td>
                                            <td class="text-end">@row.SharePercent.ToString("N2")%</td>
                                            <td>@if (!string.IsNullOrWhiteSpace(row.Route)) { <a class="btn btn-sm btn-outline-primary" href="@row.Route">Ver</a> }</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Top proveedores</h2>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Proveedor</th>
                                    <th class="text-end">Compra</th>
                                    <th class="text-end">Saldo abierto</th>
                                    <th class="text-end">Docs</th>
                                    <th class="text-end">Participación</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_dto.Suppliers.Count == 0)
                                {
                                    <tr><td colspan="6" class="text-center text-muted py-4">Sin datos.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _dto.Suppliers)
                                    {
                                        <tr>
                                            <td>@row.PartyName</td>
                                            <td class="text-end fw-semibold">@row.Amount.ToString("N2")</td>
                                            <td class="text-end">@row.OpenAmount.ToString("N2")</td>
                                            <td class="text-end">@row.Documents</td>
                                            <td class="text-end">@row.SharePercent.ToString("N2")%</td>
                                            <td>@if (!string.IsNullOrWhiteSpace(row.Route)) { <a class="btn btn-sm btn-outline-primary" href="@row.Route">Ver</a> }</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _top = 10;
    private bool _loading = true;
    private string? _error;
    private FinanceConcentrationAnalysisDto _dto = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _dto = await FinanceApiService.GetConcentrationAnalysisAsync(_year, _top);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
