@page "/finance/year-over-year"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Comparativo anual | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Comparativo anual</h1>
<p class="text-muted">Compara ventas, compras, cobros y pagos del año actual contra el año anterior mes por mes.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-10 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
        <a class="btn btn-outline-secondary" href="/finance/monthly-profitability">Rentabilidad mensual</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando comparativo anual...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Ventas actual</div><div class="fs-4 fw-bold text-primary">@_rows.Sum(x => x.SalesCurrent).ToString("N2")</div><div class="small text-muted">Anterior @_rows.Sum(x => x.SalesPrevious).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Compras actual</div><div class="fs-4 fw-bold text-secondary">@_rows.Sum(x => x.PurchasesCurrent).ToString("N2")</div><div class="small text-muted">Anterior @_rows.Sum(x => x.PurchasesPrevious).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Cobros actual</div><div class="fs-4 fw-bold text-success">@_rows.Sum(x => x.ReceiptsCurrent).ToString("N2")</div><div class="small text-muted">Anterior @_rows.Sum(x => x.ReceiptsPrevious).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Pagos actual</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.PaymentsCurrent).ToString("N2")</div><div class="small text-muted">Anterior @_rows.Sum(x => x.PaymentsPrevious).ToString("N2")</div></div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Mes</th>
                    <th class="text-end">Ventas actual</th>
                    <th class="text-end">Ventas anterior</th>
                    <th class="text-end">% ventas</th>
                    <th class="text-end">Compras actual</th>
                    <th class="text-end">Compras anterior</th>
                    <th class="text-end">% compras</th>
                    <th class="text-end">Cobros actual</th>
                    <th class="text-end">Pagos actual</th>
                </tr>
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No hay datos para el año seleccionado.</td></tr>
                }
                else
                {
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>@row.Label</td>
                            <td class="text-end">@row.SalesCurrent.ToString("N2")</td>
                            <td class="text-end">@row.SalesPrevious.ToString("N2")</td>
                            <td class="text-end @GetPercentClass(row.SalesGrowthPercent)">@row.SalesGrowthPercent.ToString("N2")%</td>
                            <td class="text-end">@row.PurchasesCurrent.ToString("N2")</td>
                            <td class="text-end">@row.PurchasesPrevious.ToString("N2")</td>
                            <td class="text-end @GetPercentClass(row.PurchasesGrowthPercent)">@row.PurchasesGrowthPercent.ToString("N2")%</td>
                            <td class="text-end">@row.ReceiptsCurrent.ToString("N2")</td>
                            <td class="text-end">@row.PaymentsCurrent.ToString("N2")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private bool _loading = true;
    private string? _error;
    private List<FinanceYearOverYearRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetYearOverYearAsync(_year);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetPercentClass(decimal value) => value >= 0m ? "text-success" : "text-danger";
}
