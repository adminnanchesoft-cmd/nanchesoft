@page "/finance/supplier-radar"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Radar proveedores | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Radar proveedores</h1>
<p class="text-muted">Compras, pagos, abierto y riesgo por proveedor para el mes seleccionado.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-8 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/supplier-risk">Riesgo proveedores</a>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando radar proveedores...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Compras netas</div><div class="fs-4 fw-bold text-primary">@_rows.Sum(x => x.NetPurchases).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Pagos</div><div class="fs-4 fw-bold text-success">@_rows.Sum(x => x.PaymentsAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Abierto</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.OpenAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Críticos</div><div class="fs-4 fw-bold text-danger">@_rows.Count(x => x.RiskLevel == "Crítico")</div></div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Proveedor</th>
                    <th class="text-end">Compras</th>
                    <th class="text-end">Devoluciones</th>
                    <th class="text-end">Compras netas</th>
                    <th class="text-end">Pagos</th>
                    <th class="text-end">Abierto</th>
                    <th class="text-end">Vencido</th>
                    <th class="text-end">Participación %</th>
                    <th class="text-end">Cobertura %</th>
                    <th class="text-end">Plazo</th>
                    <th>Riesgo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="12" class="text-center text-muted py-4">No hay información.</td></tr>
                }
                else
                {
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>@row.SupplierCode · @row.SupplierName</td>
                            <td class="text-end">@row.PurchasesAmount.ToString("N2")</td>
                            <td class="text-end">@row.ReturnAmount.ToString("N2")</td>
                            <td class="text-end fw-semibold">@row.NetPurchases.ToString("N2")</td>
                            <td class="text-end">@row.PaymentsAmount.ToString("N2")</td>
                            <td class="text-end">@row.OpenAmount.ToString("N2")</td>
                            <td class="text-end">@row.OverdueAmount.ToString("N2")</td>
                            <td class="text-end">@row.ParticipationPercent.ToString("N2")%</td>
                            <td class="text-end">@row.PaymentCoveragePercent.ToString("N2")%</td>
                            <td class="text-end">@row.PaymentTermDays</td>
                            <td><span class="badge @GetBadge(row.RiskLevel)">@row.RiskLevel</span></td>
                            <td><a class="btn btn-sm btn-outline-primary" href="@row.Route">Abrir</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private List<FinanceSupplierRadarRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetSupplierRadarAsync(_year, _month);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetBadge(string value) => value switch
    {
        "Crítico" => "text-bg-danger",
        "Alerta" => "text-bg-warning",
        _ => "text-bg-success"
    };
}
