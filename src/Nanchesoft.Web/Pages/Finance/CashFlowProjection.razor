@page "/finance/cash-flow"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Flujo proyectado | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Flujo proyectado</h1>
<p class="text-muted">Proyección financiera base por semanas usando cuentas por cobrar y cuentas por pagar abiertas.</p>

<div class="card shadow-sm mb-3">
    <div class="card-body d-flex flex-wrap gap-3 align-items-end">
        <div>
            <label class="form-label">Semanas</label>
            <select class="form-select" @bind="_weeks">
                <option value="4">4</option>
                <option value="8">8</option>
                <option value="12">12</option>
                <option value="26">26</option>
            </select>
        </div>
        <button class="btn btn-primary" @onclick="LoadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Calculando flujo proyectado...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Entradas proyectadas</div><div class="fs-4 fw-bold text-success">@_rows.Sum(x => x.ExpectedInflows).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Salidas proyectadas</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.ExpectedOutflows).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Flujo neto</div><div class="fs-4 fw-bold @(GetNetClass(_rows.Sum(x => x.NetFlow)))">@_rows.Sum(x => x.NetFlow).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Cierre final</div><div class="fs-4 fw-bold @(GetNetClass(_rows.LastOrDefault()?.ProjectedClosing ?? 0m))">@((_rows.LastOrDefault()?.ProjectedClosing ?? 0m).ToString("N2"))</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Periodo</th>
                        <th class="text-end">Apertura</th>
                        <th class="text-end">Entradas</th>
                        <th class="text-end">Salidas</th>
                        <th class="text-end">Neto</th>
                        <th class="text-end">Cierre</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_rows.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">Sin datos para proyectar.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>@row.PeriodStart.ToString("dd/MM/yyyy") - @row.PeriodEnd.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">@row.OpeningBalance.ToString("N2")</td>
                                <td class="text-end text-success">@row.ExpectedInflows.ToString("N2")</td>
                                <td class="text-end text-danger">@row.ExpectedOutflows.ToString("N2")</td>
                                <td class="text-end @(GetNetClass(row.NetFlow))">@row.NetFlow.ToString("N2")</td>
                                <td class="text-end fw-bold @(GetNetClass(row.ProjectedClosing))">@row.ProjectedClosing.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _weeks = 12;
    private List<FinanceCashFlowRowDto> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetCashFlowAsync(_weeks);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetNetClass(decimal value)
        => value >= 0m ? "text-success" : "text-danger";
}
