@page "/finance/payments-performance"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Desempeño de pagos | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Desempeño de pagos</h1>
<p class="text-muted">Seguimiento por proveedor a pagos programados, vencidos, pagados y autorizaciones requeridas.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-8 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/payment-schedule">Ver programación</a>
        <a class="btn btn-outline-secondary" href="/accounts-payable/balances">Ir a CxP</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando desempeño de pagos...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Pasivo abierto</div><div class="fs-4 fw-bold text-primary">@_rows.Sum(x => x.OpenAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Vencido</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.OverdueAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Programado</div><div class="fs-4 fw-bold text-warning">@_rows.Sum(x => x.ScheduledAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Pagado en el mes</div><div class="fs-4 fw-bold text-success">@_rows.Sum(x => x.PaidAmount).ToString("N2")</div></div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Proveedor</th>
                    <th class="text-end">Facturas pendientes</th>
                    <th class="text-end">Pasivo</th>
                    <th class="text-end">Vencido</th>
                    <th class="text-end">Programado</th>
                    <th class="text-end">Pagado</th>
                    <th class="text-end">Cumplimiento</th>
                    <th class="text-end">Autorizaciones</th>
                    <th>Riesgo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="10" class="text-center text-muted py-4">No hay información para el periodo seleccionado.</td></tr>
                }
                else
                {
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>@row.SupplierName</td>
                            <td class="text-end">@row.PendingInvoices</td>
                            <td class="text-end fw-semibold">@row.OpenAmount.ToString("N2")</td>
                            <td class="text-end text-danger">@row.OverdueAmount.ToString("N2")</td>
                            <td class="text-end text-warning">@row.ScheduledAmount.ToString("N2")</td>
                            <td class="text-end text-success">@row.PaidAmount.ToString("N2")</td>
                            <td class="text-end">@row.CompliancePercent.ToString("N2")%</td>
                            <td class="text-end">@row.RequiresAuthorizationCount</td>
                            <td><span class="badge @GetRiskClass(row.RiskLevel)">@row.RiskLevel</span></td>
                            <td>@if (!string.IsNullOrWhiteSpace(row.Route)) { <a class="btn btn-sm btn-outline-primary" href="@row.Route">Ver</a> }</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private List<FinancePaymentPerformanceRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetPaymentsPerformanceAsync(_year, _month);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetRiskClass(string risk) => risk switch
    {
        "Alta" => "bg-danger",
        "Media" => "bg-warning text-dark",
        _ => "bg-success"
    };
}
