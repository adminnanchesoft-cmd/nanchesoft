@page "/finance/payment-schedule"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Programación de pagos | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Programación de pagos</h1>
<p class="text-muted">Agenda de pagos operable con prioridad, responsable y necesidad de autorización.</p>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3"><label class="form-label">Desde</label><input type="date" class="form-control" value="@FromDateText" @onchange="OnFromChanged" /></div>
            <div class="col-md-3"><label class="form-label">Hasta</label><input type="date" class="form-control" value="@ToDateText" @onchange="OnToChanged" /></div>
            <div class="col-md-3"><label class="form-label">Filtro</label><input class="form-control" @bind="_filter" placeholder="Proveedor o folio" /></div>
            <div class="col-md-3 d-flex gap-2"><button class="btn btn-primary" @onclick="LoadAsync">Consultar</button><button class="btn btn-success" @onclick="SaveAsync" disabled="@_saving">Guardar</button></div>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando programación...</div>
}
else if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Proveedor</th>
                        <th>Folio</th>
                        <th>Vence</th>
                        <th>Abierto</th>
                        <th>Fecha pago</th>
                        <th>Estatus</th>
                        <th>Responsable</th>
                        <th>Prioridad</th>
                        <th>Notas</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in FilteredRows)
                {
                    <tr class="@(row.NeedsAuthorization ? "table-warning" : string.Empty)">
                        <td><div class="fw-semibold">@row.SupplierName</div><div class="small text-muted">@(row.NeedsAuthorization ? "Requiere autorización" : $"{row.DaysToDue} días")</div></td>
                        <td><a href="@row.Route">@row.Folio</a></td>
                        <td>@row.DueDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">@row.OpenAmount.ToString("N2")</td>
                        <td><input type="date" class="form-control form-control-sm" value="@ToInputDate(row.PlannedPaymentDate ?? row.DueDate)" @onchange="@(e => OnPlannedDateChanged(row, e))" /></td>
                        <td>
                            <select class="form-select form-select-sm" value="@row.ScheduleStatus" @onchange="@(e => row.ScheduleStatus = e.Value?.ToString() ?? "Sin programar")">
                                <option>Sin programar</option>
                                <option>Programado</option>
                                <option>Autorizado</option>
                                <option>Reagendado</option>
                                <option>Pagado</option>
                            </select>
                        </td>
                        <td><input class="form-control form-control-sm" @bind="row.Responsible" /></td>
                        <td>
                            <select class="form-select form-select-sm" value="@row.Priority" @onchange="@(e => row.Priority = e.Value?.ToString() ?? "Media")">
                                <option>Alta</option>
                                <option>Media</option>
                                <option>Baja</option>
                            </select>
                        </td>
                        <td><input class="form-control form-control-sm" @bind="row.Notes" /></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _message;
    private string _filter = string.Empty;
    private DateTime _from = DateTime.Today.AddDays(-7);
    private DateTime _to = DateTime.Today.AddDays(45);
    private List<FinancePaymentScheduleRowDto> _rows = new();

    private IEnumerable<FinancePaymentScheduleRowDto> FilteredRows => _rows.Where(x => string.IsNullOrWhiteSpace(_filter) || x.SupplierName.Contains(_filter, StringComparison.OrdinalIgnoreCase) || x.Folio.Contains(_filter, StringComparison.OrdinalIgnoreCase));
    private string FromDateText => _from.ToString("yyyy-MM-dd");
    private string ToDateText => _to.ToString("yyyy-MM-dd");

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _message = null;
        try { _rows = await FinanceApiService.GetPaymentScheduleAsync(_from, _to); }
        finally { _loading = false; }
    }

    private async Task SaveAsync()
    {
        _saving = true; _message = null;
        try { await FinanceApiService.SavePaymentScheduleAsync(_rows); _message = "Programación guardada."; }
        finally { _saving = false; }
    }

    private void OnFromChanged(ChangeEventArgs e) { if (DateTime.TryParse(e.Value?.ToString(), out var value)) _from = value.Date; }
    private void OnToChanged(ChangeEventArgs e) { if (DateTime.TryParse(e.Value?.ToString(), out var value)) _to = value.Date; }
    private void OnPlannedDateChanged(FinancePaymentScheduleRowDto row, ChangeEventArgs e) { if (DateTime.TryParse(e.Value?.ToString(), out var value)) row.PlannedPaymentDate = value.Date; }
    private static string ToInputDate(DateTime value) => value.ToString("yyyy-MM-dd");
}
