@page "/finance/supplier-control-tower"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Proveedor 360 financiero | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Proveedor 360 financiero</h1>
<p class="text-muted">Consolida desempeño de pagos, radar de proveedores, riesgo operativo y programación de pagos.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Desde</label>
        <input class="form-control" type="date" value="@FormatDateInput(_from)" @onchange="OnFromChanged" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Hasta</label>
        <input class="form-control" type="date" value="@FormatDateInput(_to)" @onchange="OnToChanged" />
    </div>
    <div class="col-md-4 d-flex gap-2 flex-wrap">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/payments-performance">Desempeño de pagos</a>
        <a class="btn btn-outline-secondary" href="/finance/supplier-risk">Riesgo proveedores</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando proveedor 360...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Pasivo abierto</div><div class="fs-4 fw-bold text-primary">@_payments.Sum(x => x.OpenAmount).ToString("N2")</div><div class="small text-muted">@_payments.Sum(x => x.PendingInvoices) facturas abiertas</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Vencido</div><div class="fs-4 fw-bold text-danger">@_payments.Sum(x => x.OverdueAmount).ToString("N2")</div><div class="small text-muted">Riesgo alto @_risk.Count(x => IsRisk(x.Status)) proveedores</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Programado</div><div class="fs-4 fw-bold text-warning">@_schedule.Where(x => x.PlannedPaymentDate.HasValue).Sum(x => x.OpenAmount).ToString("N2")</div><div class="small text-muted">Pagos programados @_schedule.Count(x => x.PlannedPaymentDate.HasValue)</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Autorizaciones requeridas</div><div class="fs-4 fw-bold text-success">@_risk.Sum(x => x.RequiresAuthorizationCount)</div><div class="small text-muted">Control de pagos sensibles</div></div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Desempeño de pagos</div>
                            <div class="small text-muted">Top proveedores por pasivo abierto en el periodo.</div>
                        </div>
                        <span class="badge bg-secondary">@_payments.Count filas</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Proveedor</th>
                                    <th class="text-end">Abierto</th>
                                    <th class="text-end">Vencido</th>
                                    <th class="text-end">Pagado</th>
                                    <th class="text-end">Cumplimiento</th>
                                    <th>Riesgo</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_payments.Count == 0)
                                {
                                    <tr><td colspan="7" class="text-center text-muted py-4">No hay desempeño de pagos.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _payments.OrderByDescending(x => x.OpenAmount).Take(10))
                                    {
                                        <tr>
                                            <td>@row.SupplierName</td>
                                            <td class="text-end fw-semibold">@row.OpenAmount.ToString("N2")</td>
                                            <td class="text-end text-danger">@row.OverdueAmount.ToString("N2")</td>
                                            <td class="text-end text-success">@row.PaidAmount.ToString("N2")</td>
                                            <td class="text-end">@row.CompliancePercent.ToString("N2")%</td>
                                            <td><span class="badge @GetRiskClass(row.RiskLevel)">@row.RiskLevel</span></td>
                                            <td>@if (!string.IsNullOrWhiteSpace(row.Route)) { <a class="btn btn-sm btn-outline-primary" href="@row.Route">Ver</a> }</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="h5 mb-2">Riesgo por proveedor</div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Proveedor</th>
                                    <th class="text-end">Concentración</th>
                                    <th class="text-end">Cobertura</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_risk.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-3">No hay riesgo calculado.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _risk.OrderByDescending(x => x.OpenAmount).Take(8))
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.SupplierName</div>
                                                <div class="small text-muted">@row.SuggestedAction</div>
                                            </td>
                                            <td class="text-end">@row.ConcentrationPercent.ToString("N2")%</td>
                                            <td class="text-end">@row.CompliancePercent.ToString("N2")%</td>
                                            <td><span class="badge @GetStatusClass(row.Status)">@row.Status</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="h5 mb-2">Concentración top proveedores</div>
                    <div class="small text-muted mb-2">HHI @_concentration.SupplierHhi.ToString("N2") · participación top 3 @_concentration.Top3SupplierSharePercent.ToString("N2")%</div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Proveedor</th>
                                    <th class="text-end">Saldo</th>
                                    <th class="text-end">Participación</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_concentration.Suppliers.Count == 0)
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-3">No hay concentración disponible.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _concentration.Suppliers.Take(8))
                                    {
                                        <tr>
                                            <td>@row.PartyName</td>
                                            <td class="text-end">@row.OpenAmount.ToString("N2")</td>
                                            <td class="text-end">@row.SharePercent.ToString("N2")%</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Radar operativo por proveedor</div>
                            <div class="small text-muted">Compras netas, pagos, vencido y cobertura.</div>
                        </div>
                        <span class="badge bg-secondary">@_supplierRadar.Count filas</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Proveedor</th>
                                    <th class="text-end">Compras netas</th>
                                    <th class="text-end">Pagos</th>
                                    <th class="text-end">Vencido</th>
                                    <th class="text-end">Participación</th>
                                    <th>Riesgo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_supplierRadar.Count == 0)
                                {
                                    <tr><td colspan="6" class="text-center text-muted py-3">No hay radar de proveedores.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _supplierRadar.OrderByDescending(x => x.NetPurchases).Take(10))
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.SupplierName</div>
                                                <div class="small text-muted">@row.SupplierCode</div>
                                            </td>
                                            <td class="text-end">@row.NetPurchases.ToString("N2")</td>
                                            <td class="text-end text-success">@row.PaymentsAmount.ToString("N2")</td>
                                            <td class="text-end text-danger">@row.OverdueAmount.ToString("N2")</td>
                                            <td class="text-end">@row.ParticipationPercent.ToString("N2")%</td>
                                            <td><span class="badge @GetRiskClass(row.RiskLevel)">@row.RiskLevel</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Programación de pagos</div>
                            <div class="small text-muted">Vencimiento, responsable y autorización.</div>
                        </div>
                        <span class="badge bg-secondary">@_schedule.Count filas</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Proveedor</th>
                                    <th>Folio</th>
                                    <th>Programado</th>
                                    <th class="text-end">Monto</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_schedule.Count == 0)
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-3">No hay programación registrada.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _schedule.OrderBy(x => x.PlannedPaymentDate ?? x.DueDate).Take(10))
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.SupplierName</div>
                                                <div class="small text-muted">@row.Responsible</div>
                                            </td>
                                            <td>@row.Folio</td>
                                            <td>
                                                <div>@FormatDate(row.PlannedPaymentDate ?? row.DueDate)</div>
                                                <div class="small text-muted">@row.ScheduleStatus · @row.Priority</div>
                                            </td>
                                            <td class="text-end">@row.OpenAmount.ToString("N2")</td>
                                            <td>@if (!string.IsNullOrWhiteSpace(row.Route)) { <a class="btn btn-sm btn-outline-primary" href="@row.Route">Abrir</a> }</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private DateTime _from = new(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private DateTime _to = new(DateTime.UtcNow.Year, DateTime.UtcNow.Month, DateTime.DaysInMonth(DateTime.UtcNow.Year, DateTime.UtcNow.Month));
    private bool _loading = true;
    private string? _error;
    private List<FinancePaymentPerformanceRowDto> _payments = new();
    private List<FinanceSupplierRiskRowDto> _risk = new();
    private List<FinanceSupplierRadarRowDto> _supplierRadar = new();
    private FinanceConcentrationAnalysisDto _concentration = new();
    private List<FinancePaymentScheduleRowDto> _schedule = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _payments = await FinanceApiService.GetPaymentsPerformanceAsync(_year, _month);
            _risk = await FinanceApiService.GetSupplierRiskAsync();
            _supplierRadar = await FinanceApiService.GetSupplierRadarAsync(_year, _month);
            _concentration = await FinanceApiService.GetConcentrationAnalysisAsync(_year, 10);
            _schedule = await FinanceApiService.GetPaymentScheduleAsync(_from, _to);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnFromChanged(ChangeEventArgs args)
    {
        if (DateTime.TryParse(args.Value?.ToString(), out var value))
        {
            _from = value;
        }
        return Task.CompletedTask;
    }

    private Task OnToChanged(ChangeEventArgs args)
    {
        if (DateTime.TryParse(args.Value?.ToString(), out var value))
        {
            _to = value;
        }
        return Task.CompletedTask;
    }

    private static string FormatDateInput(DateTime value) => value.ToString("yyyy-MM-dd");
    private static string FormatDate(DateTime value) => value.ToString("yyyy-MM-dd");
    private static bool IsRisk(string? value) => string.Equals(value, "Alta", StringComparison.OrdinalIgnoreCase) || string.Equals(value, "Crítica", StringComparison.OrdinalIgnoreCase);
    private static string GetRiskClass(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "alta" or "crítica" or "critica" => "bg-danger",
        "media" => "bg-warning text-dark",
        _ => "bg-success"
    };
    private static string GetStatusClass(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "bloqueado" or "tensión" or "tension" => "bg-danger",
        "warning" or "alerta" => "bg-warning text-dark",
        _ => "bg-success"
    };
}
