@page "/finance/cash-conversion-cycle"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Ciclo conversión efectivo | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Ciclo de conversión de efectivo</h1>
<p class="text-muted">Mide días de cobranza, inventario y pago para evaluar la velocidad de recuperación de caja.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-10 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/liquidity-radar">Radar liquidez</a>
        <a class="btn btn-outline-secondary" href="/finance/working-capital-bridge">Puente capital trabajo</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando ciclo de conversión...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">DSO promedio</div><div class="fs-4 fw-bold">@Average(x => x.DsoDays).ToString("N2")</div><div class="small text-muted">Días de cobranza</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">DIO promedio</div><div class="fs-4 fw-bold">@Average(x => x.DioDays).ToString("N2")</div><div class="small text-muted">Días de inventario</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">DPO promedio</div><div class="fs-4 fw-bold">@Average(x => x.DpoDays).ToString("N2")</div><div class="small text-muted">Días de pago</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">CCC promedio</div><div class="fs-4 fw-bold @GetCycleClass(Average(x => x.CashConversionCycleDays))">@Average(x => x.CashConversionCycleDays).ToString("N2")</div><div class="small text-muted">DSO + DIO - DPO</div></div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Mes</th>
                    <th class="text-end">Ventas</th>
                    <th class="text-end">Compras</th>
                    <th class="text-end">Inventario</th>
                    <th class="text-end">CxC abiertas</th>
                    <th class="text-end">CxP abiertas</th>
                    <th class="text-end">DSO</th>
                    <th class="text-end">DIO</th>
                    <th class="text-end">DPO</th>
                    <th class="text-end">CCC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td>@row.Label</td>
                        <td class="text-end">@row.Sales.ToString("N2")</td>
                        <td class="text-end">@row.Purchases.ToString("N2")</td>
                        <td class="text-end">@row.InventoryValue.ToString("N2")</td>
                        <td class="text-end">@row.OpenReceivables.ToString("N2")</td>
                        <td class="text-end">@row.OpenPayables.ToString("N2")</td>
                        <td class="text-end">@row.DsoDays.ToString("N2")</td>
                        <td class="text-end">@row.DioDays.ToString("N2")</td>
                        <td class="text-end">@row.DpoDays.ToString("N2")</td>
                        <td class="text-end @GetCycleClass(row.CashConversionCycleDays)">@row.CashConversionCycleDays.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private bool _loading = true;
    private string? _error;
    private List<FinanceCashConversionCycleRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetCashConversionCycleAsync(_year);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private decimal Average(Func<FinanceCashConversionCycleRowDto, decimal> selector)
        => _rows.Count == 0 ? 0m : Math.Round(_rows.Average(selector), 2);

    private static string GetCycleClass(decimal value) => value <= 0m ? "text-success" : value <= 45m ? "text-warning" : "text-danger";
}
