@page "/finance/branch-command-center"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Centro de mando por sucursal | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Centro de mando por sucursal</h1>
<p class="text-muted">Cruza pulso operativo por sucursal, plan semanal de tesorería y puente mensual de liquidez.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Semanas plan</label>
        <input class="form-control" type="number" min="4" max="16" @bind="_weeks" />
    </div>
    <div class="col-md-6 d-flex gap-2 flex-wrap">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/branch-pulse">Pulso sucursales</a>
        <a class="btn btn-outline-secondary" href="/finance/monthly-liquidity-bridge">Puente liquidez mensual</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando centro de mando por sucursal...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Caja actual sucursales</div><div class="fs-4 fw-bold text-success">@_branchPulse.Sum(x => x.CashBalance).ToString("N2")</div><div class="small text-muted">Flujo neto @_branchPulse.Sum(x => x.NetCashMovement).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Capital de trabajo</div><div class="fs-4 fw-bold @GetSignedClass(_branchPulse.Sum(x => x.WorkingCapital))">@_branchPulse.Sum(x => x.WorkingCapital).ToString("N2")</div><div class="small text-muted">CxC @_branchPulse.Sum(x => x.OpenReceivables).ToString("N2") · CxP @_branchPulse.Sum(x => x.OpenPayables).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Plan semanal cierre</div><div class="fs-4 fw-bold @GetSignedClass(_weeklyPlan.LastOrDefault()?.ProjectedClosing ?? 0m)">@((_weeklyPlan.LastOrDefault()?.ProjectedClosing ?? 0m).ToString("N2"))</div><div class="small text-muted">Horizonte @_weeks semanas</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Cobertura promedio</div><div class="fs-4 fw-bold text-primary">@(_monthlyBridge.Count == 0 ? "0.00" : _monthlyBridge.Average(x => x.CoveragePercent).ToString("N2"))%</div><div class="small text-muted">Puente mensual anualizado</div></div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Pulso por sucursal</div>
                            <div class="small text-muted">Ventas, compras, cobros, pagos, caja y capital de trabajo.</div>
                        </div>
                        <span class="badge bg-secondary">@_branchPulse.Count sucursales</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Sucursal</th>
                                    <th class="text-end">Ventas</th>
                                    <th class="text-end">Cobros</th>
                                    <th class="text-end">Pagos</th>
                                    <th class="text-end">Caja</th>
                                    <th class="text-end">Capital trabajo</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_branchPulse.Count == 0)
                                {
                                    <tr><td colspan="7" class="text-center text-muted py-4">No hay sucursales para el periodo.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _branchPulse.OrderByDescending(x => x.CashBalance).ThenByDescending(x => x.WorkingCapital))
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.BranchName</div>
                                                <div class="small text-muted">@row.BranchCode</div>
                                            </td>
                                            <td class="text-end">@row.SalesAmount.ToString("N2")</td>
                                            <td class="text-end text-success">@row.ReceiptsAmount.ToString("N2")</td>
                                            <td class="text-end text-danger">@row.PaymentsAmount.ToString("N2")</td>
                                            <td class="text-end">@row.CashBalance.ToString("N2")</td>
                                            <td class="text-end @GetSignedClass(row.WorkingCapital)">@row.WorkingCapital.ToString("N2")</td>
                                            <td><span class="badge @GetStatusClass(row.Status)">@row.Status</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Plan semanal tesorería</div>
                            <div class="small text-muted">Proyección de cierre con carryover vencido.</div>
                        </div>
                        <span class="badge bg-secondary">@_weeklyPlan.Count semanas</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Semana</th>
                                    <th class="text-end">Cobros</th>
                                    <th class="text-end">Pagos</th>
                                    <th class="text-end">Cierre</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_weeklyPlan.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-4">No hay plan semanal.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _weeklyPlan)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.WeekStart.ToString("yyyy-MM-dd")</div>
                                                <div class="small text-muted">a @row.WeekEnd.ToString("yyyy-MM-dd")</div>
                                            </td>
                                            <td class="text-end text-success">@row.PlannedCollections.ToString("N2")</td>
                                            <td class="text-end text-danger">@row.PlannedPayments.ToString("N2")</td>
                                            <td class="text-end @GetSignedClass(row.ProjectedClosing)">@row.ProjectedClosing.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Puente mensual de liquidez</div>
                            <div class="small text-muted">Apertura, cobros, pagos, cierre y cobertura por mes.</div>
                        </div>
                        <span class="badge bg-secondary">@_monthlyBridge.Count meses</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Mes</th>
                                    <th class="text-end">Apertura</th>
                                    <th class="text-end">Cobros</th>
                                    <th class="text-end">Pagos</th>
                                    <th class="text-end">Cierre</th>
                                    <th class="text-end">Cobertura</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_monthlyBridge.Count == 0)
                                {
                                    <tr><td colspan="7" class="text-center text-muted py-4">No hay puente de liquidez disponible.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _monthlyBridge)
                                    {
                                        <tr>
                                            <td>@row.Label</td>
                                            <td class="text-end">@row.OpeningLiquidity.ToString("N2")</td>
                                            <td class="text-end text-success">@row.Receipts.ToString("N2")</td>
                                            <td class="text-end text-danger">@row.Payments.ToString("N2")</td>
                                            <td class="text-end @GetSignedClass(row.ClosingLiquidity)">@row.ClosingLiquidity.ToString("N2")</td>
                                            <td class="text-end">@row.CoveragePercent.ToString("N2")%</td>
                                            <td><span class="badge @GetStatusClass(row.Status)">@row.Status</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="h5 mb-2">Puente capital de trabajo</div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Concepto</th>
                                    <th class="text-end">Monto</th>
                                    <th>Impacto</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_workingCapital.Count == 0)
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-3">No hay puente disponible.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _workingCapital)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.Label</div>
                                                <div class="small text-muted">@row.Commentary</div>
                                            </td>
                                            <td class="text-end @GetSignedClass(row.Amount)">@row.Amount.ToString("N2")</td>
                                            <td><span class="badge @GetImpactClass(row.Impact)">@row.Impact</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private int _weeks = 8;
    private bool _loading = true;
    private string? _error;
    private List<FinanceBranchPulseRowDto> _branchPulse = new();
    private List<FinanceTreasuryWeeklyPlanRowDto> _weeklyPlan = new();
    private List<FinanceMonthlyLiquidityBridgeRowDto> _monthlyBridge = new();
    private List<FinanceWorkingCapitalBridgeRowDto> _workingCapital = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _branchPulse = await FinanceApiService.GetBranchPulseAsync(_year, _month);
            _weeklyPlan = await FinanceApiService.GetWeeklyTreasuryPlanAsync(_weeks);
            _monthlyBridge = await FinanceApiService.GetMonthlyLiquidityBridgeAsync(_year);
            _workingCapital = await FinanceApiService.GetWorkingCapitalBridgeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetSignedClass(decimal value) => value >= 0m ? "text-success" : "text-danger";
    private static string GetStatusClass(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "rojo" or "crítico" or "critico" or "débil" or "debil" => "bg-danger",
        "warning" or "alerta" or "tensión" or "tension" => "bg-warning text-dark",
        _ => "bg-success"
    };
    private static string GetImpactClass(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "negativo" => "bg-danger",
        "mixto" or "neutral" => "bg-warning text-dark",
        _ => "bg-success"
    };
}
