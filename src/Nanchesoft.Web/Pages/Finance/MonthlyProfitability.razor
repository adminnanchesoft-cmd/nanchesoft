@page "/finance/monthly-profitability"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Rentabilidad mensual | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Rentabilidad mensual</h1>
<p class="text-muted">Comparativo mensual entre ventas netas, compras, margen bruto y margen de caja.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-10 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/budget-vs-actual">Ver real vs presupuesto</a>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando rentabilidad mensual...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Ventas netas</div><div class="fs-4 fw-bold text-primary">@_rows.Sum(x => x.NetSales).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Margen bruto</div><div class="fs-4 fw-bold @GetAmountClass(_rows.Sum(x => x.GrossMargin))">@_rows.Sum(x => x.GrossMargin).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Cobros</div><div class="fs-4 fw-bold text-success">@_rows.Sum(x => x.Receipts).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Margen de caja</div><div class="fs-4 fw-bold @GetAmountClass(_rows.Sum(x => x.CashMargin))">@_rows.Sum(x => x.CashMargin).ToString("N2")</div></div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Mes</th>
                    <th class="text-end">Ventas brutas</th>
                    <th class="text-end">Notas crédito</th>
                    <th class="text-end">Ventas netas</th>
                    <th class="text-end">Compras</th>
                    <th class="text-end">Margen bruto</th>
                    <th class="text-end">% margen</th>
                    <th class="text-end">Cobros</th>
                    <th class="text-end">Pagos</th>
                    <th class="text-end">Margen caja</th>
                    <th class="text-end">Acum. bruto</th>
                </tr>
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="11" class="text-center text-muted py-4">No hay información para el año seleccionado.</td></tr>
                }
                else
                {
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>@row.Label</td>
                            <td class="text-end">@row.GrossSales.ToString("N2")</td>
                            <td class="text-end">@row.CreditNotes.ToString("N2")</td>
                            <td class="text-end fw-semibold">@row.NetSales.ToString("N2")</td>
                            <td class="text-end">@row.Purchases.ToString("N2")</td>
                            <td class="text-end @GetAmountClass(row.GrossMargin)">@row.GrossMargin.ToString("N2")</td>
                            <td class="text-end">@row.GrossMarginPercent.ToString("N2")%</td>
                            <td class="text-end">@row.Receipts.ToString("N2")</td>
                            <td class="text-end">@row.Payments.ToString("N2")</td>
                            <td class="text-end @GetAmountClass(row.CashMargin)">@row.CashMargin.ToString("N2")</td>
                            <td class="text-end fw-semibold">@row.CumulativeGrossMargin.ToString("N2")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private bool _loading = true;
    private string? _error;
    private List<FinanceMonthlyProfitabilityRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetMonthlyProfitabilityAsync(_year);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetAmountClass(decimal value) => value >= 0m ? "text-success" : "text-danger";
}
