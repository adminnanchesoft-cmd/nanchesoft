@page "/finance/bank-movements"
@using Nanchesoft.Web.Services.Finance
@using Nanchesoft.Web.Services.Treasury
@inject FinancePhase1ApiService Phase1
@inject TreasuryApiService TreasuryApi
@inject IJSRuntime JS

<PageTitle>Movimientos bancarios | Nanchesoft</PageTitle>

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
        <div class="text-muted small">Nanchesoft ERP · Finanzas · Bancos</div>
        <h1 class="h3 mb-1">Movimientos bancarios</h1>
        <div class="text-muted">Captura manual de depósitos, retiros, comisiones, intereses y cargos automáticos por cuenta.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="/treasury/bank-accounts">Cuentas bancarias</a>
        <a class="btn btn-outline-secondary" href="/finance/bank-transfers">Transferencias</a>
        <a class="btn btn-outline-secondary" href="/finance/bank-statements">Estados de cuenta</a>
        <a class="btn btn-outline-secondary" href="/treasury/reconciliations">Conciliaciones</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando movimientos...</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success">@_message</div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Cuenta bancaria</label>
                    <select class="form-select" @bind="_selectedAccountIdText" @bind:after="ReloadAsync">
                        <option value="">Todas las cuentas</option>
                        @foreach (var account in _accounts)
                        {
                            <option value="@account.Id">@account.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Desde</label>
                    <input type="date" class="form-control" @bind="_fromDate" @bind:after="ReloadAsync" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Hasta</label>
                    <input type="date" class="form-control" @bind="_toDate" @bind:after="ReloadAsync" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" @onclick="OpenNewMovement">Nuevo movimiento</button>
                </div>
            </div>
        </div>
    </div>

    @if (_selectedAccountId.HasValue && _statement is not null)
    {
        <div class="row g-3 mb-3">
            <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Saldo inicial</div><div class="fs-4 fw-bold">@_statement.InitialBalance.ToString("C")</div></div></div></div>
            <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Saldo actual</div><div class="fs-4 fw-bold">@_statement.CurrentBalance.ToString("C")</div></div></div></div>
            <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Saldo conciliado</div><div class="fs-4 fw-bold text-success">@_statement.ReconciledBalance.ToString("C")</div></div></div></div>
            <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Flujo del periodo</div><div class="fs-5 fw-bold">+@_statement.TotalIn.ToString("N2") / -@_statement.TotalOut.ToString("N2")</div></div></div></div>
        </div>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Documento</th>
                        <th>Referencia</th>
                        <th class="text-end">Entrada</th>
                        <th class="text-end">Salida</th>
                        <th class="text-end">Saldo</th>
                        <th>Conciliado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_movements.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">Sin movimientos en el rango seleccionado.</td></tr>
                    }
                    else
                    {
                        @foreach (var movement in _movements)
                        {
                            <tr>
                                <td>@movement.MovementDate.ToString("dd/MM/yyyy")</td>
                                <td>@MovementTypeLabel(movement.MovementType)</td>
                                <td><span class="badge bg-light text-dark border">@movement.DocumentType</span></td>
                                <td>@movement.Reference</td>
                                <td class="text-end text-success">@(movement.AmountIn > 0 ? movement.AmountIn.ToString("N2") : "")</td>
                                <td class="text-end text-danger">@(movement.AmountOut > 0 ? movement.AmountOut.ToString("N2") : "")</td>
                                <td class="text-end">@movement.BalanceAfter.ToString("N2")</td>
                                <td>@(movement.IsReconciled ? "Sí" : "No")</td>
                                <td>
                                    @if (string.Equals(movement.DocumentType, "manual", StringComparison.OrdinalIgnoreCase) && !movement.IsReconciled)
                                    {
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditMovement(movement)">Editar</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMovementAsync(movement.BankMovementId)">Eliminar</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (_editing is not null)
    {
        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(_editing.BankMovementId.HasValue ? "Editar movimiento" : "Nuevo movimiento")</h5>
                        <button class="btn-close" @onclick="CloseEditor"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Cuenta bancaria</label>
                                <select class="form-select" @bind="_editAccountIdText" disabled="@_editing.BankMovementId.HasValue">
                                    <option value="">Selecciona...</option>
                                    @foreach (var account in _accounts)
                                    {
                                        <option value="@account.Id">@account.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Fecha</label>
                                <input type="date" class="form-control" @bind="_editing.MovementDate" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tipo</label>
                                <select class="form-select" @bind="_editing.MovementType">
                                    <option value="deposit">Depósito</option>
                                    <option value="withdrawal">Retiro</option>
                                    <option value="fee">Comisión</option>
                                    <option value="interest">Intereses</option>
                                    <option value="charge">Cargo</option>
                                    <option value="adjustment">Ajuste</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Referencia</label>
                                <input class="form-control" @bind="_editing.Reference" placeholder="Folio o concepto" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Entrada</label>
                                <input type="number" step="0.01" class="form-control text-end" @bind="_editing.AmountIn" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Salida</label>
                                <input type="number" step="0.01" class="form-control text-end" @bind="_editing.AmountOut" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseEditor">Cancelar</button>
                        <button class="btn btn-primary" @onclick="SaveMovementAsync">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _message;
    private List<BankMovementListRow> _movements = new();
    private List<TreasuryLookupItem> _accounts = new();
    private BankAccountStatement? _statement;
    private Guid? _selectedAccountId;
    private string _selectedAccountIdText = string.Empty;
    private DateTime? _fromDate = DateTime.Today.AddDays(-30);
    private DateTime? _toDate = DateTime.Today;
    private BankMovementRequest? _editing;
    private string _editAccountIdText = string.Empty;

    private Guid? SelectedAccountId
    {
        get => string.IsNullOrEmpty(_selectedAccountIdText) ? null : Guid.Parse(_selectedAccountIdText);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAccountsAsync();
        await ReloadAsync();
    }

    private async Task LoadAccountsAsync()
    {
        try
        {
            var lookups = await TreasuryApi.GetLookupsAsync();
            _accounts = lookups.BankAccounts.Select(x => new TreasuryLookupItem(Guid.Parse(x.Id), x.Name)).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _selectedAccountId = string.IsNullOrEmpty(_selectedAccountIdText) ? null : Guid.Parse(_selectedAccountIdText);
            _movements = await Phase1.GetMovementsAsync(_selectedAccountId, _fromDate, _toDate);
            _statement = _selectedAccountId.HasValue
                ? await Phase1.GetAccountStatementAsync(_selectedAccountId.Value, _fromDate, _toDate)
                : null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenNewMovement()
    {
        _editing = new BankMovementRequest
        {
            BankAccountId = _selectedAccountId ?? (_accounts.FirstOrDefault()?.IdGuid ?? Guid.Empty),
            MovementDate = DateTime.Today,
            MovementType = "deposit"
        };
        _editAccountIdText = _editing.BankAccountId.ToString();
    }

    private void EditMovement(BankMovementListRow row)
    {
        _editing = new BankMovementRequest
        {
            BankMovementId = row.BankMovementId,
            BankAccountId = row.BankAccountId,
            MovementDate = row.MovementDate,
            MovementType = row.MovementType,
            DocumentType = row.DocumentType,
            Reference = row.Reference,
            AmountIn = row.AmountIn,
            AmountOut = row.AmountOut,
            IsReconciled = row.IsReconciled,
            IsActive = row.IsActive
        };
        _editAccountIdText = row.BankAccountId.ToString();
    }

    private void CloseEditor()
    {
        _editing = null;
    }

    private async Task SaveMovementAsync()
    {
        if (_editing is null) return;
        _error = null;
        _message = null;
        if (Guid.TryParse(_editAccountIdText, out var accountId)) _editing.BankAccountId = accountId;
        if (_editing.BankAccountId == Guid.Empty)
        {
            _error = "Selecciona una cuenta bancaria.";
            return;
        }
        try
        {
            var response = await Phase1.SaveMovementAsync(_editing);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }
            _message = "Movimiento guardado correctamente.";
            _editing = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task DeleteMovementAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar el movimiento? Esta acción reversa el efecto en el saldo.")) return;
        try
        {
            var response = await Phase1.DeleteMovementAsync(id);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }
            _message = "Movimiento eliminado.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string MovementTypeLabel(string type) => type switch
    {
        "deposit" => "Depósito",
        "withdrawal" => "Retiro",
        "fee" => "Comisión",
        "interest" => "Intereses",
        "charge" => "Cargo",
        "adjustment" => "Ajuste",
        "transfer_in" => "Transferencia (entrada)",
        "transfer_out" => "Transferencia (salida)",
        "income" => "Ingreso",
        "expense" => "Egreso",
        "receipt" => "Recibo",
        "payment" => "Pago",
        _ => type
    };

    public sealed class TreasuryLookupItem
    {
        public string Id { get; set; } = string.Empty;
        public Guid IdGuid { get; set; }
        public string Name { get; set; } = string.Empty;

        public TreasuryLookupItem() { }
        public TreasuryLookupItem(Guid id, string name)
        {
            Id = id.ToString();
            IdGuid = id;
            Name = name;
        }
    }
}
