@page "/finance/kpi-scorecard"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Scorecard KPI | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Scorecard KPI</h1>
<p class="text-muted">Cumplimiento mensual contra metas financieras y KPIs de liquidez.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-8 d-flex gap-2">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/monthly-goals">Metas mensuales</a>
        <a class="btn btn-outline-secondary" href="/finance/executive-dashboard">Centro financiero</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando scorecard...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3">
        @foreach (var row in _rows)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-@GetBorder(row.Status)">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <div class="text-muted small">@row.MetricCode</div>
                                <div class="h5 mb-0">@row.MetricLabel</div>
                            </div>
                            <span class="badge text-bg-@GetBadge(row.Status)">@GetStatusLabel(row.Status)</span>
                        </div>
                        <div class="fs-4 fw-bold">@row.ActualAmount.ToString("N2")</div>
                        <div class="small text-muted">Meta @row.TargetAmount.ToString("N2")</div>
                        <div class="small @GetText(row.VarianceAmount)">Variación @row.VarianceAmount.ToString("N2")</div>
                        <div class="small text-muted">Cumplimiento @row.CompliancePercent.ToString("N2")%</div>
                        <hr />
                        <div class="small text-muted">@row.Commentary</div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private List<FinanceKpiScorecardRowDto> _rows = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetKpiScorecardAsync(_year, _month);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetBadge(string status) => status switch { "success" => "success", "warning" => "warning", "danger" => "danger", _ => "secondary" };
    private static string GetBorder(string status) => status switch { "success" => "success", "warning" => "warning", "danger" => "danger", _ => "secondary" };
    private static string GetStatusLabel(string status) => status switch { "success" => "En meta", "warning" => "Cerca", "danger" => "Desviado", _ => "Informativo" };
    private static string GetText(decimal amount) => amount >= 0m ? "text-success" : "text-danger";
}
