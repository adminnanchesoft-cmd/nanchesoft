@page "/finance/budget-vs-actual"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Real vs presupuesto | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Real vs presupuesto</h1>
<p class="text-muted">Comparativo mensual por cuenta contable contra pólizas posteadas.</p>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" @bind="_year" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Buscar cuenta</label>
        <input class="form-control" @bind="_search" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-outline-secondary" @onclick="ReloadAsync">Actualizar</button>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando comparativo...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Presupuesto</div><div class="fs-4 fw-bold text-info">@FilteredRows.Sum(x => x.BudgetAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Real</div><div class="fs-4 fw-bold text-primary">@FilteredRows.Sum(x => x.ActualAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Variación</div><div class="fs-4 fw-bold @(FilteredRows.Sum(x => x.VarianceAmount) >= 0m ? "text-success" : "text-danger")">@FilteredRows.Sum(x => x.VarianceAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Cumplimiento promedio</div><div class="fs-4 fw-bold">@AverageCompliance.ToString("N2")%</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Mes</th>
                            <th>Cuenta</th>
                            <th>Tipo</th>
                            <th class="text-end">Presupuesto</th>
                            <th class="text-end">Real</th>
                            <th class="text-end">Variación</th>
                            <th class="text-end">Cumplimiento</th>
                            <th>Notas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in FilteredRows)
                        {
                            <tr>
                                <td>@MonthName(row.Month)</td>
                                <td>@row.AccountCode - @row.AccountName</td>
                                <td>@row.AccountType</td>
                                <td class="text-end">@row.BudgetAmount.ToString("N2")</td>
                                <td class="text-end">@row.ActualAmount.ToString("N2")</td>
                                <td class="text-end @(row.VarianceAmount >= 0m ? "text-success" : "text-danger")">@row.VarianceAmount.ToString("N2")</td>
                                <td class="text-end">@row.CompliancePercent.ToString("N2")%</td>
                                <td>@row.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _year = DateTime.UtcNow.Year;
    private string _search = string.Empty;
    private List<FinanceBudgetVsActualRowDto> _rows = new();

    private IEnumerable<FinanceBudgetVsActualRowDto> FilteredRows => _rows
        .Where(x => string.IsNullOrWhiteSpace(_search)
            || x.AccountCode.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || x.AccountName.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .OrderBy(x => x.Month)
        .ThenBy(x => x.AccountCode);

    private decimal AverageCompliance => FilteredRows.Any() ? FilteredRows.Average(x => x.CompliancePercent) : 0m;

    protected override async Task OnInitializedAsync()
        => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetBudgetVsActualAsync(_year);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string MonthName(int month)
        => new DateTime(DateTime.UtcNow.Year, month, 1).ToString("MMMM");
}
