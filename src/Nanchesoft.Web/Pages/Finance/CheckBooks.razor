@page "/finance/check-books"
@using Nanchesoft.Web.Services.Finance
@using Nanchesoft.Web.Services.Treasury
@inject FinancePhase2ApiService Api
@inject TreasuryApiService TreasuryApi
@inject IJSRuntime JS

<PageTitle>Chequeras | Nanchesoft</PageTitle>

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
        <div class="text-muted small">Nanchesoft ERP · Finanzas · Bancos</div>
        <h1 class="h3 mb-1">Chequeras</h1>
        <div class="text-muted">Controla los talonarios de cheques por cuenta bancaria, con rangos de folio y series.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/finance/checks">Cheques</a>
        <button class="btn btn-primary" @onclick="OpenNew">+ Nueva chequera</button>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando...</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success">@_message</div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Cuenta</th>
                        <th>Serie</th>
                        <th class="text-end">Folio inicial</th>
                        <th class="text-end">Folio final</th>
                        <th class="text-end">Próximo folio</th>
                        <th>Activa</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_rows.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">Sin chequeras registradas.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td><code>@row.Code</code></td>
                                <td>@row.Name</td>
                                <td>@AccountName(row.BankAccountId)</td>
                                <td>@row.Series</td>
                                <td class="text-end">@row.FolioStart</td>
                                <td class="text-end">@row.FolioEnd</td>
                                <td class="text-end fw-bold">@row.NextFolio</td>
                                <td>@(row.IsActive ? "Sí" : "No")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(row)">Editar</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(row.Id)">Eliminar</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing.Id == Guid.Empty ? "Nueva chequera" : "Editar chequera")</h5>
                    <button class="btn-close" @onclick="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label">Cuenta bancaria</label>
                            <select class="form-select" @bind="_editAccountIdText">
                                <option value="">Selecciona...</option>
                                @foreach (var account in _accounts)
                                {
                                    <option value="@account.IdGuid">@account.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Código</label>
                            <input class="form-control" @bind="_editing.Code" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Serie</label>
                            <input class="form-control" @bind="_editing.Series" placeholder="A, B, 2026..." />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Nombre</label>
                            <input class="form-control" @bind="_editing.Name" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Folio inicial</label>
                            <input type="number" class="form-control text-end" @bind="_editing.FolioStart" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Folio final</label>
                            <input type="number" class="form-control text-end" @bind="_editing.FolioEnd" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Próximo folio</label>
                            <input type="number" class="form-control text-end" @bind="_editing.NextFolio" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="ckb" @bind="_editing.IsActive" />
                                <label class="form-check-label" for="ckb">Activa</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <textarea class="form-control" rows="2" @bind="_editing.Notes"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Close">Cancelar</button>
                    <button class="btn btn-primary" @onclick="SaveAsync">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _message;
    private string? _error;
    private List<CheckBookRow> _rows = new();
    private List<BankAccountLookup> _accounts = new();
    private CheckBookRow? _editing;
    private string _editAccountIdText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
        await ReloadAsync();
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            var lookups = await TreasuryApi.GetLookupsAsync();
            _accounts = lookups.BankAccounts.Select(x => new BankAccountLookup(Guid.Parse(x.Id), x.Name)).ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        try { _rows = await Api.GetCheckBooksAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private string AccountName(Guid id) => _accounts.FirstOrDefault(x => x.IdGuid == id)?.Name ?? "—";

    private void OpenNew()
    {
        _editing = new CheckBookRow
        {
            Id = Guid.Empty,
            BankAccountId = _accounts.FirstOrDefault()?.IdGuid ?? Guid.Empty,
            FolioStart = 1,
            FolioEnd = 100,
            NextFolio = 1,
            IsActive = true
        };
        _editAccountIdText = _editing.BankAccountId.ToString();
    }

    private void Edit(CheckBookRow row)
    {
        _editing = new CheckBookRow
        {
            Id = row.Id,
            CompanyId = row.CompanyId,
            BankAccountId = row.BankAccountId,
            Code = row.Code,
            Name = row.Name,
            Series = row.Series,
            FolioStart = row.FolioStart,
            FolioEnd = row.FolioEnd,
            NextFolio = row.NextFolio,
            Notes = row.Notes,
            IsActive = row.IsActive
        };
        _editAccountIdText = row.BankAccountId.ToString();
    }

    private void Close() => _editing = null;

    private async Task SaveAsync()
    {
        if (_editing is null) return;
        _message = null; _error = null;
        if (Guid.TryParse(_editAccountIdText, out var accountId)) _editing.BankAccountId = accountId;
        if (_editing.BankAccountId == Guid.Empty)
        {
            _error = "Selecciona una cuenta bancaria.";
            return;
        }
        try
        {
            var response = await Api.SaveCheckBookAsync(_editing);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }
            _message = "Chequera guardada.";
            _editing = null;
            await ReloadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar la chequera?")) return;
        try
        {
            var response = await Api.DeleteCheckBookAsync(id);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }
            _message = "Chequera eliminada.";
            await ReloadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private sealed record BankAccountLookup(Guid IdGuid, string Name);
}
