@page "/finance/document-control"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Control documental financiero | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Control documental financiero</h1>
<p class="text-muted">Cruza ventas, compras y tesorería con estatus operativo, saldo abierto y contabilización detectada.</p>

<div class="card shadow-sm mb-3">
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Módulo</label>
            <select class="form-select" @bind="_moduleFilter">
                <option value="">Todos</option>
                <option value="Ventas">Ventas</option>
                <option value="Compras">Compras</option>
                <option value="Tesorería">Tesorería</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Buscar</label>
            <input class="form-control" @bind="_search" placeholder="Folio, tercero o referencia" />
        </div>
        <div class="col-md-3 form-check mt-4 pt-2">
            <input class="form-check-input" type="checkbox" id="pendingAccounting" @bind="_onlyPendingAccounting" />
            <label class="form-check-label" for="pendingAccounting">Solo pendientes de contabilizar</label>
        </div>
        <div class="col-md-3 text-md-end">
            <button class="btn btn-primary me-2" @onclick="LoadAsync">Actualizar</button>
            <a class="btn btn-outline-secondary" href="/finance/exceptions">Ver excepciones</a>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando control documental...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Documentos visibles</div><div class="fs-4 fw-bold">@FilteredRows.Count</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Pendientes de contabilizar</div><div class="fs-4 fw-bold text-danger">@FilteredRows.Count(x => !x.IsAccounted && x.Status == "posted")</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Saldo abierto visible</div><div class="fs-4 fw-bold text-warning">@FilteredRows.Sum(x => x.OpenAmount).ToString("N2")</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Módulo</th>
                        <th>Tipo</th>
                        <th>Folio</th>
                        <th>Tercero</th>
                        <th>Fecha</th>
                        <th>Vence</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Abierto</th>
                        <th>Estatus</th>
                        <th>Contabilidad</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredRows.Count == 0)
                    {
                        <tr><td colspan="11" class="text-center text-muted py-4">Sin registros.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in FilteredRows)
                        {
                            <tr>
                                <td>@row.Module</td>
                                <td>@FormatDocumentType(row.DocumentType)</td>
                                <td>
                                    <div class="fw-semibold">@row.Folio</div>
                                    <div class="small text-muted">@row.Reference</div>
                                </td>
                                <td>@row.PartnerName</td>
                                <td>@row.DocumentDate.ToString("dd/MM/yyyy")</td>
                                <td>@(row.DueDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td class="text-end">@row.Total.ToString("N2")</td>
                                <td class="text-end @(row.OpenAmount > 0 ? "text-warning fw-bold" : "text-muted")">@row.OpenAmount.ToString("N2")</td>
                                <td><span class="badge @GetStatusBadge(row.Status)">@row.Status</span></td>
                                <td>
                                    @if (row.IsAccounted)
                                    {
                                        <span class="badge bg-success">@row.AccountingStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">pendiente</span>
                                    }
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary" href="@GetAccountingRoute(row)">Contabilizar</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string _moduleFilter = string.Empty;
    private string _search = string.Empty;
    private bool _onlyPendingAccounting;
    private List<FinanceDocumentControlRowDto> _rows = new();

    private List<FinanceDocumentControlRowDto> FilteredRows => _rows
        .Where(x => string.IsNullOrWhiteSpace(_moduleFilter) || x.Module == _moduleFilter)
        .Where(x => !_onlyPendingAccounting || !x.IsAccounted)
        .Where(x => string.IsNullOrWhiteSpace(_search)
            || x.Folio.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || x.PartnerName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || x.Reference.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(x => x.DocumentDate)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await FinanceApiService.GetDocumentControlAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatDocumentType(string value)
        => value switch
        {
            "sales_invoice" => "Factura venta",
            "purchase_invoice" => "Factura compra",
            "receipt" => "Recibo",
            "payment" => "Pago",
            _ => value
        };

    private static string GetStatusBadge(string status)
        => status switch
        {
            "posted" => "bg-success",
            "approved" => "bg-primary",
            "draft" => "bg-secondary",
            "cancelled" => "bg-danger",
            _ => "bg-light text-dark"
        };

    private static string GetAccountingRoute(FinanceDocumentControlRowDto row)
        => $"/accounting/document-posting?sourceType={row.DocumentType}&sourceId={row.DocumentId}";
}
