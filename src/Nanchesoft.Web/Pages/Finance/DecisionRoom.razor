@page "/finance/decision-room"
@using Nanchesoft.Web.Services.Finance
@inject FinanceApiService FinanceApiService

<PageTitle>Sala de decisión financiera | Nanchesoft</PageTitle>

<h1 class="h3 mb-3">Sala de decisión financiera</h1>
<p class="text-muted">Concentra alertas, covenants, acciones prioritarias y tareas de cierre para la reunión ejecutiva.</p>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label">Año</label>
        <input class="form-control" type="number" min="2020" max="2100" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Mes</label>
        <select class="form-select" @bind="_month">
            @for (var month = 1; month <= 12; month++)
            {
                <option value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="col-md-8 d-flex gap-2 flex-wrap">
        <button class="btn btn-primary" @onclick="ReloadAsync">Actualizar</button>
        <a class="btn btn-outline-secondary" href="/finance/action-center">Centro de acciones</a>
        <a class="btn btn-outline-secondary" href="/finance/closing-cockpit">Cockpit de cierre</a>
        <a class="btn btn-outline-secondary" href="/finance/covenants">Covenants</a>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando sala de decisión financiera...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Liquidez total</div><div class="fs-4 fw-bold text-success">@_dashboard.TotalLiquidity.ToString("N2")</div><div class="small text-muted">Capital trabajo @_dashboard.WorkingCapital.ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Alertas activas</div><div class="fs-4 fw-bold text-danger">@_alerts.Count</div><div class="small text-muted">Rojas @_semaphores.Count(x => IsStatus(x.Semaphore, "Rojo")) · acciones @_actions.Count</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Autorizaciones pendientes</div><div class="fs-4 fw-bold text-warning">@_dashboard.PendingApprovals</div><div class="small text-muted">Cierre pendiente @_closing.Where(x => !IsStatus(x.Status, "Ok") && !IsStatus(x.Status, "Completado")).Count()</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small">Covenants en riesgo</div><div class="fs-4 fw-bold @GetStatusTextClass(_covenants.Any(x => IsRiskStatus(x.Status)) ? "Crítico" : "Ok")">@_covenants.Count(x => IsRiskStatus(x.Status))</div><div class="small text-muted">Thresholds monitoreados @_covenants.Count</div></div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Cola priorizada de acciones</div>
                            <div class="small text-muted">Ordenada por prioridad, vencimiento y monto.</div>
                        </div>
                        <span class="badge bg-secondary">@_actions.Count registros</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Origen</th>
                                    <th>Documento</th>
                                    <th>Parte</th>
                                    <th>Vence</th>
                                    <th class="text-end">Monto</th>
                                    <th>Prioridad</th>
                                    <th>Estatus</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_actions.Count == 0)
                                {
                                    <tr><td colspan="8" class="text-center text-muted py-4">No hay acciones registradas.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _actions.Take(12))
                                    {
                                        <tr>
                                            <td>@row.Source</td>
                                            <td>
                                                <div class="fw-semibold">@row.DocumentNumber</div>
                                                <div class="small text-muted">@row.Category</div>
                                            </td>
                                            <td>@row.PartyName</td>
                                            <td>@FormatDate(row.DueDate)</td>
                                            <td class="text-end">@row.Amount.ToString("N2")</td>
                                            <td><span class="badge @GetPriorityClass(row.Priority)">@row.Priority</span></td>
                                            <td><span class="badge @GetStatusClass(row.Status)">@row.Status</span></td>
                                            <td>@if (!string.IsNullOrWhiteSpace(row.Route)) { <a class="btn btn-sm btn-outline-primary" href="@row.Route">Abrir</a> }</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="h5 mb-2">Alertas críticas</div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th class="text-end">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_alerts.Count == 0)
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-3">Sin alertas activas.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _alerts.Take(8))
                                    {
                                        <tr>
                                            <td><span class="badge @GetStatusClass(row.Severity)">@row.Severity</span></td>
                                            <td>
                                                <div class="fw-semibold">@row.Title</div>
                                                <div class="small text-muted">@row.Message</div>
                                            </td>
                                            <td class="text-end">@row.Amount.GetValueOrDefault().ToString("N2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="h5 mb-2">Semáforos ejecutivos</div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Métrica</th>
                                    <th class="text-end">Valor</th>
                                    <th>Semáforo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_semaphores.Count == 0)
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-3">Sin semáforos calculados.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _semaphores.Take(8))
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.Label</div>
                                                <div class="small text-muted">@row.SuggestedAction</div>
                                            </td>
                                            <td class="text-end">@row.CurrentValue.ToString("N2")</td>
                                            <td><span class="badge @GetSemaphoreClass(row.Semaphore)">@row.Semaphore</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Checklist de cierre</div>
                            <div class="small text-muted">Qué áreas siguen bloqueando el cierre del mes.</div>
                        </div>
                        <span class="badge bg-secondary">@_closing.Count filas</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Área</th>
                                    <th>Check</th>
                                    <th class="text-end">Pendientes</th>
                                    <th class="text-end">Monto</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_closing.Count == 0)
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-3">No hay checklist de cierre.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _closing)
                                    {
                                        <tr>
                                            <td>@row.Area</td>
                                            <td>
                                                <div class="fw-semibold">@row.CheckName</div>
                                                <div class="small text-muted">@row.Detail</div>
                                            </td>
                                            <td class="text-end">@row.PendingCount</td>
                                            <td class="text-end">@row.Amount.ToString("N2")</td>
                                            <td><span class="badge @GetStatusClass(row.Status)">@row.Status</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <div class="h5 mb-0">Covenants y umbrales</div>
                            <div class="small text-muted">Seguimiento a holgura y presión financiera.</div>
                        </div>
                        <span class="badge bg-secondary">@_covenants.Count indicadores</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Indicador</th>
                                    <th class="text-end">Actual</th>
                                    <th class="text-end">Umbral</th>
                                    <th class="text-end">Holgura</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_covenants.Count == 0)
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-3">No hay covenants configurados.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in _covenants)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@row.CovenantName</div>
                                                <div class="small text-muted">@row.Notes</div>
                                            </td>
                                            <td class="text-end">@row.CurrentValue.ToString("N2")</td>
                                            <td class="text-end">@row.ThresholdOperator @row.ThresholdValue.ToString("N2")</td>
                                            <td class="text-end">@row.Headroom.ToString("N2")</td>
                                            <td><span class="badge @GetStatusClass(row.Status)">@row.Status</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;
    private bool _loading = true;
    private string? _error;
    private FinanceDashboardDto _dashboard = new();
    private List<FinanceAlertRowDto> _alerts = new();
    private List<FinanceSemaphoreRowDto> _semaphores = new();
    private List<FinanceActionCenterRowDto> _actions = new();
    private List<FinanceClosingCockpitRowDto> _closing = new();
    private List<FinanceCovenantRowDto> _covenants = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _dashboard = await FinanceApiService.GetDashboardAsync();
            _alerts = await FinanceApiService.GetAlertsAsync();
            _semaphores = await FinanceApiService.GetSemaphoresAsync();
            _actions = await FinanceApiService.GetActionCenterAsync();
            _closing = await FinanceApiService.GetClosingCockpitAsync(_year, _month);
            _covenants = await FinanceApiService.GetCovenantsAsync(_year, _month);

            _actions = _actions
                .OrderBy(x => PriorityRank(x.Priority))
                .ThenBy(x => x.DueDate ?? DateTime.MaxValue)
                .ThenByDescending(x => x.Amount)
                .ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static int PriorityRank(string? priority)
    {
        return (priority ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "alta" => 0,
            "media" => 1,
            "baja" => 2,
            _ => 3
        };
    }

    private static bool IsStatus(string? value, string expected)
        => string.Equals(value?.Trim(), expected, StringComparison.OrdinalIgnoreCase);

    private static bool IsRiskStatus(string? status)
        => IsStatus(status, "Crítico") || IsStatus(status, "Warning") || IsStatus(status, "Alerta") || IsStatus(status, "Incumplimiento");

    private static string FormatDate(DateTime? value)
        => value.HasValue ? value.Value.ToString("yyyy-MM-dd") : "-";

    private static string GetPriorityClass(string? priority) => (priority ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "alta" => "bg-danger",
        "media" => "bg-warning text-dark",
        "baja" => "bg-success",
        _ => "bg-secondary"
    };

    private static string GetSemaphoreClass(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "rojo" => "bg-danger",
        "amarillo" => "bg-warning text-dark",
        _ => "bg-success"
    };

    private static string GetStatusClass(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "pending" or "pendiente" => "bg-warning text-dark",
        "critical" or "crítico" or "critico" or "rojo" => "bg-danger",
        "warning" or "alerta" or "en riesgo" => "bg-warning text-dark",
        "ok" or "completado" or "cerrado" or "green" or "verde" => "bg-success",
        "rejected" or "rechazado" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetStatusTextClass(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "crítico" or "critico" => "text-danger",
        "warning" => "text-warning",
        _ => "text-success"
    };
}
