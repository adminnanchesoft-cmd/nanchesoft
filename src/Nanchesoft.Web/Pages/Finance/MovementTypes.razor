@page "/finance/movement-types"
@using Nanchesoft.Web.Services.Finance
@inject FinancePhase2ApiService Api
@inject IJSRuntime JS

<PageTitle>Tipos de movimiento | Nanchesoft</PageTitle>

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
        <div class="text-muted small">Nanchesoft ERP · Finanzas · Catálogos</div>
        <h1 class="h3 mb-1">Tipos de movimiento</h1>
        <div class="text-muted">Catálogo parametrizable: Cargo, Abono, Transferencia, Comisión, Interés, Ajuste, Traspaso.</div>
    </div>
    <button class="btn btn-primary" @onclick="OpenNew">+ Nuevo tipo</button>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando tipos de movimiento...</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success">@_message</div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Dirección</th>
                        <th>Naturaleza</th>
                        <th>Afecta saldo</th>
                        <th>Sistema</th>
                        <th>Activo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_rows.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Sin registros.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td><code>@row.Code</code></td>
                                <td>@row.Name</td>
                                <td><span class="badge bg-light text-dark border">@DirectionLabel(row.Direction)</span></td>
                                <td>@NatureLabel(row.Nature)</td>
                                <td>@(row.AffectsBalance ? "Sí" : "No")</td>
                                <td>@(row.IsSystem ? "Sí" : "No")</td>
                                <td>@(row.IsActive ? "Sí" : "No")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(row)">Editar</button>
                                    @if (!row.IsSystem)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(row.Id)">Eliminar</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing.Id == Guid.Empty ? "Nuevo tipo" : "Editar tipo")</h5>
                    <button class="btn-close" @onclick="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Código</label>
                            <input class="form-control" @bind="_editing.Code" placeholder="CHRG, CREDIT..." />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Nombre</label>
                            <input class="form-control" @bind="_editing.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Dirección</label>
                            <select class="form-select" @bind="_editing.Direction">
                                <option value="in">Entrada (abono)</option>
                                <option value="out">Salida (cargo)</option>
                                <option value="neutral">Neutral / traspaso</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Naturaleza</label>
                            <select class="form-select" @bind="_editing.Nature">
                                <option value="">(libre)</option>
                                <option value="bank">Bancario</option>
                                <option value="cash">Caja</option>
                                <option value="transfer">Transferencia</option>
                                <option value="fee">Comisión</option>
                                <option value="interest">Interés</option>
                                <option value="adjustment">Ajuste</option>
                                <option value="charge">Cargo</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" id="ab" @bind="_editing.AffectsBalance" />
                                <label class="form-check-label" for="ab">Afecta saldo</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" id="ia" @bind="_editing.IsActive" />
                                <label class="form-check-label" for="ia">Activo</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <textarea class="form-control" rows="2" @bind="_editing.Notes"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Close">Cancelar</button>
                    <button class="btn btn-primary" @onclick="SaveAsync">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _message;
    private string? _error;
    private List<FinanceMovementTypeRow> _rows = new();
    private FinanceMovementTypeRow? _editing;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        try { _rows = await Api.GetMovementTypesAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private void OpenNew()
    {
        _editing = new FinanceMovementTypeRow
        {
            Id = Guid.Empty,
            Direction = "neutral",
            AffectsBalance = true,
            IsActive = true
        };
    }

    private void Edit(FinanceMovementTypeRow row)
    {
        _editing = new FinanceMovementTypeRow
        {
            Id = row.Id,
            TenantId = row.TenantId,
            CompanyId = row.CompanyId,
            Code = row.Code,
            Name = row.Name,
            Direction = row.Direction,
            Nature = row.Nature,
            AffectsBalance = row.AffectsBalance,
            IsSystem = row.IsSystem,
            AccountingAccountId = row.AccountingAccountId,
            Notes = row.Notes,
            IsActive = row.IsActive
        };
    }

    private void Close() => _editing = null;

    private async Task SaveAsync()
    {
        if (_editing is null) return;
        _message = null; _error = null;
        try
        {
            var response = await Api.SaveMovementTypeAsync(_editing);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }
            _message = "Tipo de movimiento guardado.";
            _editing = null;
            await ReloadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar este tipo de movimiento?")) return;
        try
        {
            var response = await Api.DeleteMovementTypeAsync(id);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }
            _message = "Eliminado.";
            await ReloadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string DirectionLabel(string d) => d switch
    {
        "in" => "Entrada",
        "out" => "Salida",
        _ => "Neutral"
    };

    private static string NatureLabel(string n) => n switch
    {
        "bank" => "Bancario",
        "cash" => "Caja",
        "transfer" => "Transferencia",
        "fee" => "Comisión",
        "interest" => "Interés",
        "adjustment" => "Ajuste",
        "charge" => "Cargo",
        _ => string.IsNullOrWhiteSpace(n) ? "—" : n
    };
}
