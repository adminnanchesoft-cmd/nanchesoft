@page "/finance/bank-statements"
@using Nanchesoft.Web.Services.Finance
@using Nanchesoft.Web.Services.Treasury
@inject FinancePhase1ApiService Phase1
@inject TreasuryApiService TreasuryApi
@inject IJSRuntime JS

<PageTitle>Estados de cuenta | Nanchesoft</PageTitle>

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
        <div class="text-muted small">Nanchesoft ERP · Finanzas · Bancos</div>
        <h1 class="h3 mb-1">Estados de cuenta</h1>
        <div class="text-muted">Captura manual o importación CSV de los estados de cuenta bancarios para conciliación posterior.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="/finance/bank-movements">Movimientos bancarios</a>
        <a class="btn btn-outline-secondary" href="/finance/reconciliation-suggestions">Conciliación asistida</a>
        <button class="btn btn-outline-primary" @onclick="OpenManual">Captura manual</button>
        <button class="btn btn-primary" @onclick="OpenImport">Importar CSV</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}
@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Cuenta bancaria</label>
                <select class="form-select" @bind="_filterAccountText" @bind:after="ReloadAsync">
                    <option value="">Todas las cuentas</option>
                    @foreach (var account in _accounts)
                    {
                        <option value="@account.Id">@account.Name</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Cuenta</th>
                    <th>Origen</th>
                    <th>Periodo</th>
                    <th class="text-end">Saldo inicial</th>
                    <th class="text-end">Saldo final</th>
                    <th class="text-end">Partidas</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (_statements.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No hay estados de cuenta capturados.</td></tr>
                }
                else
                {
                    @foreach (var item in _statements)
                    {
                        <tr>
                            <td>@item.StatementDate.ToString("dd/MM/yyyy")</td>
                            <td>@(_accountLabels.TryGetValue(item.BankAccountId, out var label) ? label : item.BankAccountId.ToString())</td>
                            <td><span class="badge bg-light text-dark border">@item.Source</span></td>
                            <td>@(item.PeriodStart?.ToString("dd/MM/yyyy") ?? "-") · @(item.PeriodEnd?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="text-end">@item.OpeningBalance.ToString("N2")</td>
                            <td class="text-end">@item.ClosingBalance.ToString("N2")</td>
                            <td class="text-end">@item.EntryCount</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ViewDetailAsync(item.BankStatementId)">Ver</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.BankStatementId)">Eliminar</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (_detail is not null)
{
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Partidas del estado de cuenta · @_detail.StatementDate.ToString("dd/MM/yyyy")</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _detail = null">Cerrar</button>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>Fecha</th><th>Descripción</th><th>Referencia</th><th class="text-end">Entrada</th><th class="text-end">Salida</th><th>Conciliado</th></tr></thead>
                <tbody>
                    @foreach (var entry in _detail.Entries)
                    {
                        <tr>
                            <td>@entry.EntryDate.ToString("dd/MM/yyyy")</td>
                            <td>@entry.Description</td>
                            <td>@entry.Reference</td>
                            <td class="text-end text-success">@(entry.AmountIn > 0 ? entry.AmountIn.ToString("N2") : "")</td>
                            <td class="text-end text-danger">@(entry.AmountOut > 0 ? entry.AmountOut.ToString("N2") : "")</td>
                            <td>@(entry.IsMatched ? "Sí" : "No")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_manual is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Captura manual de estado de cuenta</h5><button class="btn-close" @onclick="() => _manual = null"></button></div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Cuenta bancaria</label>
                            <select class="form-select" @bind="_manualAccountText">
                                <option value="">Selecciona...</option>
                                @foreach (var account in _accounts)
                                {
                                    <option value="@account.Id">@account.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control" @bind="_manual.StatementDate" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Saldo inicial</label>
                            <input type="number" step="0.01" class="form-control text-end" @bind="_manual.OpeningBalance" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Saldo final</label>
                            <input type="number" step="0.01" class="form-control text-end" @bind="_manual.ClosingBalance" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Referencia / Notas</label>
                            <input class="form-control" @bind="_manual.Reference" placeholder="Ej. Estado del mes" />
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Partidas</strong>
                        <button class="btn btn-sm btn-outline-primary" @onclick="AddEntry">Agregar partida</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead><tr><th>Fecha</th><th>Descripción</th><th>Referencia</th><th class="text-end">Entrada</th><th class="text-end">Salida</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var entry in _manual.Entries)
                                {
                                    <tr>
                                        <td><input type="date" class="form-control form-control-sm" @bind="entry.EntryDate" /></td>
                                        <td><input class="form-control form-control-sm" @bind="entry.Description" /></td>
                                        <td><input class="form-control form-control-sm" @bind="entry.Reference" /></td>
                                        <td><input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="entry.AmountIn" /></td>
                                        <td><input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="entry.AmountOut" /></td>
                                        <td><button class="btn btn-sm btn-link text-danger" @onclick="() => _manual.Entries.Remove(entry)">Quitar</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _manual = null">Cancelar</button>
                    <button class="btn btn-primary" @onclick="SaveManualAsync">Guardar estado</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_import is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Importar estado de cuenta (CSV)</h5><button class="btn-close" @onclick="() => _import = null"></button></div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        Formato esperado por línea (separador configurable): <code>fecha,descripcion,referencia,entrada,salida</code>.
                        Soporta encabezado en la primera fila. Las fechas se aceptan en dd/MM/yyyy, yyyy-MM-dd o MM/dd/yyyy.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Cuenta bancaria</label>
                            <select class="form-select" @bind="_importAccountText">
                                <option value="">Selecciona...</option>
                                @foreach (var account in _accounts)
                                {
                                    <option value="@account.Id">@account.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control" @bind="_import.StatementDate" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Saldo inicial</label>
                            <input type="number" step="0.01" class="form-control text-end" @bind="_import.OpeningBalance" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Saldo final</label>
                            <input type="number" step="0.01" class="form-control text-end" @bind="_import.ClosingBalance" />
                        </div>
                        <div class="col-md-1">
                            <label class="form-label">Sep.</label>
                            <input class="form-control" @bind="_import.Delimiter" maxlength="2" />
                        </div>
                        <div class="col-md-1 form-check pt-4 ms-2">
                            <input class="form-check-input" type="checkbox" @bind="_import.HasHeader" />
                            <label class="form-check-label small">Encabezado</label>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Contenido CSV</label>
                            <textarea class="form-control" rows="10" @bind="_import.CsvText" placeholder="fecha,descripcion,referencia,entrada,salida"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _import = null">Cancelar</button>
                    <button class="btn btn-primary" @onclick="ImportAsync">Importar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<BankStatementListRow> _statements = new();
    private List<TreasuryListItem> _accounts = new();
    private Dictionary<Guid, string> _accountLabels = new();
    private BankStatementDetail? _detail;
    private BankStatementSaveRequest? _manual;
    private BankStatementCsvImportRequest? _import;
    private string _filterAccountText = string.Empty;
    private string _manualAccountText = string.Empty;
    private string _importAccountText = string.Empty;
    private string? _message;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccountsAsync();
        await ReloadAsync();
    }

    private async Task LoadAccountsAsync()
    {
        var lookups = await TreasuryApi.GetLookupsAsync();
        _accounts = lookups.BankAccounts.Select(x => new TreasuryListItem(Guid.Parse(x.Id), x.Name)).ToList();
        _accountLabels = _accounts.ToDictionary(x => x.Id, x => x.Name);
    }

    private async Task ReloadAsync()
    {
        try
        {
            var accountId = string.IsNullOrEmpty(_filterAccountText) ? (Guid?)null : Guid.Parse(_filterAccountText);
            _statements = await Phase1.GetStatementsAsync(accountId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ViewDetailAsync(Guid id)
    {
        _detail = await Phase1.GetStatementAsync(id);
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar el estado de cuenta y sus partidas?")) return;
        var response = await Phase1.DeleteStatementAsync(id);
        if (!response.IsSuccessStatusCode)
        {
            _error = await response.Content.ReadAsStringAsync();
            return;
        }
        _message = "Estado de cuenta eliminado.";
        if (_detail?.BankStatementId == id) _detail = null;
        await ReloadAsync();
    }

    private void OpenManual()
    {
        _manual = new BankStatementSaveRequest
        {
            StatementDate = DateTime.Today,
            Source = "manual",
            Entries = new List<BankStatementEntryRow> { new() { EntryDate = DateTime.Today } }
        };
        _manualAccountText = _filterAccountText;
    }

    private void OpenImport()
    {
        _import = new BankStatementCsvImportRequest
        {
            StatementDate = DateTime.Today,
            Delimiter = ",",
            HasHeader = true
        };
        _importAccountText = _filterAccountText;
    }

    private void AddEntry()
    {
        if (_manual is null) return;
        _manual.Entries.Add(new BankStatementEntryRow { EntryDate = DateTime.Today });
    }

    private async Task SaveManualAsync()
    {
        if (_manual is null) return;
        if (!Guid.TryParse(_manualAccountText, out var accountId))
        {
            _error = "Selecciona una cuenta bancaria.";
            return;
        }
        _manual.BankAccountId = accountId;
        var response = await Phase1.CreateStatementAsync(_manual);
        if (!response.IsSuccessStatusCode)
        {
            _error = await response.Content.ReadAsStringAsync();
            return;
        }
        _message = "Estado de cuenta guardado.";
        _manual = null;
        await ReloadAsync();
    }

    private async Task ImportAsync()
    {
        if (_import is null) return;
        if (!Guid.TryParse(_importAccountText, out var accountId))
        {
            _error = "Selecciona una cuenta bancaria.";
            return;
        }
        _import.BankAccountId = accountId;
        try
        {
            var response = await Phase1.ImportCsvAsync(_import);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }
            _message = "Estado de cuenta importado.";
            _import = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    public sealed record TreasuryListItem(Guid Id, string Name);
}
