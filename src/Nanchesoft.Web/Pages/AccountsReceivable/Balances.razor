@page "/accounts-receivable/balances"
@using Nanchesoft.Web.Services.AccountsReceivable
@inject AccountsReceivableApiService Api

<PageTitle>Saldos CxC | Nanchesoft</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <div class="text-uppercase text-muted small fw-semibold">CxC · Saldos</div>
        <h1 class="h3 mb-1">Saldos por cliente</h1>
        <div class="text-muted">Consulta el saldo abierto, créditos y último movimiento por cliente.</div>
    </div>
    <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_loading">Actualizar</button>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando saldos...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Clientes con saldo</div><div class="fs-4 fw-bold">@_rows.Count(x => x.CurrentBalance > 0m)</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Saldo abierto</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.CurrentBalance).ToString("N2")</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Créditos / pagos</div><div class="fs-4 fw-bold text-success">@_rows.Sum(x => x.TotalCredits).ToString("N2")</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Cliente</th>
                        <th class="text-end">Límite</th>
                        <th class="text-end">Cargos</th>
                        <th class="text-end">Créditos/Pagos</th>
                        <th class="text-end">Saldo</th>
                        <th>Último movimiento</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_rows.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Sin registros.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>@row.CustomerCode</td>
                                <td>@row.CustomerName</td>
                                <td class="text-end">@row.CreditLimit.ToString("N2")</td>
                                <td class="text-end">@row.TotalCharges.ToString("N2")</td>
                                <td class="text-end">@row.TotalCredits.ToString("N2")</td>
                                <td class="text-end fw-bold">@row.CurrentBalance.ToString("N2")</td>
                                <td>@(row.LastMovementAt?.ToString("dd/MM/yyyy") ?? string.Empty)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<ArBalanceRowDto> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _rows = await Api.GetBalancesAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
