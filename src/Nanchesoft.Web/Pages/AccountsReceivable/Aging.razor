@page "/accounts-receivable/aging"
@using Nanchesoft.Web.Services.AccountsReceivable
@inject AccountsReceivableApiService Api

<PageTitle>Antigüedad CxC | Nanchesoft</PageTitle>

<div class="mb-3">
    <div class="text-uppercase text-muted small fw-semibold">CxC · Antigüedad</div>
    <h1 class="h3 mb-1">Antigüedad de saldos</h1>
    <div class="text-muted">Consulta facturas abiertas por rango de antigüedad.</div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Cliente</label>
            <select class="form-select" @bind="_selectedCustomerIdString">
                <option value="">Todos</option>
                @foreach (var customer in _lookups.Customers)
                {
                    <option value="@customer.Id">@customer.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button class="btn btn-primary" @onclick="ReloadAsync">Consultar</button>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info">Cargando antigüedad...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Saldo abierto</div><div class="fs-4 fw-bold text-danger">@_rows.Sum(x => x.OpenAmount).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">0-30</div><div class="fs-4 fw-bold">@_rows.Sum(x => x.BucketCurrent).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">31-60</div><div class="fs-4 fw-bold text-warning">@_rows.Sum(x => x.Bucket31To60).ToString("N2")</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">61+</div><div class="fs-4 fw-bold text-danger">@(_rows.Sum(x => x.Bucket61To90 + x.BucketOver90).ToString("N2"))</div></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Factura</th>
                        <th>Fecha</th>
                        <th class="text-end">Saldo abierto</th>
                        <th class="text-end">0-30</th>
                        <th class="text-end">31-60</th>
                        <th class="text-end">61-90</th>
                        <th class="text-end">90+</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_rows.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Sin registros.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>@row.CustomerName</td>
                                <td>@row.Folio</td>
                                <td>@row.InvoiceDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-end fw-bold">@row.OpenAmount.ToString("N2")</td>
                                <td class="text-end">@row.BucketCurrent.ToString("N2")</td>
                                <td class="text-end">@row.Bucket31To60.ToString("N2")</td>
                                <td class="text-end">@row.Bucket61To90.ToString("N2")</td>
                                <td class="text-end">@row.BucketOver90.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _selectedCustomerIdString;
    private ArLookupsDto _lookups = new();
    private List<ArAgingRowDto> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        _lookups = await Api.GetLookupsAsync();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            Guid? customerId = Guid.TryParse(_selectedCustomerIdString, out var parsed) ? parsed : null;
            _rows = await Api.GetAgingAsync(customerId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
