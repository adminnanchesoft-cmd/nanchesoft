@page "/integration/silvasoft/composicion"
@rendermode InteractiveServer
@using Nanchesoft.Web.Services.SilvaSoft
@inject SilvaSoftApiService SilvaSoft

<PageTitle>Composición SilvaSoft</PageTitle>

<div class="ns-page-header">
    <div class="ns-page-header__left">
        <div class="ns-page-header__breadcrumb">Integración › SilvaSoft</div>
        <h1 class="ns-page-header__title">Importar composición</h1>
        <p class="ns-page-header__subtitle">
            Consulta la tabla <code>dbo.composicion</code> de SilvaSoft e importa los materiales por estilo
            a la relación <em>Materiales por producto</em> de Nanchesoft.
        </p>
    </div>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @_msgClass mt-3">@((MarkupString)_message)</div>
}

<div class="ns-section mt-3" style="max-width:540px">
    <div class="ns-form-grid">
        <div class="ns-field">
            <label class="ns-field-label">Filtrar por estilo <span class="text-muted">(opcional)</span></label>
            <input class="ns-input" type="text" placeholder="Ej: C-100 o déjalo vacío para todos"
                   @bind="_styleFilter" />
        </div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <button class="ns-btn ns-btn--outline" @onclick="PreviewAsync" disabled="@_loading">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Previsualizar
        </button>
        <button class="ns-btn ns-btn--primary" @onclick="ImportAsync" disabled="@_importing">
            @if (_importing) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Importar
        </button>
    </div>
</div>

@if (_rows.Count > 0)
{
    <div class="ns-section mt-3">
        <div class="text-muted small mb-2">Mostrando @_rows.Count registros (máx. 200 por página)</div>
        <div class="ns-table-wrap">
            <table class="ns-table">
                <thead>
                    <tr>
                        <th>Estilo</th>
                        <th>Material</th>
                        <th class="text-end">Cantidad</th>
                        <th>Notas</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td><code>@r.StyleCode</code></td>
                            <td><code>@r.MaterialCode</code></td>
                            <td class="text-end">@r.Quantity.ToString("N4")</td>
                            <td class="text-muted small">@r.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (!_loading && _consulted)
{
    <div class="ns-empty-state mt-4">
        <p>No se encontraron registros en <code>dbo.composicion</code> con ese filtro.</p>
    </div>
}

@code {
    private List<SilvaSoftCompositionRow> _rows = [];
    private string? _styleFilter;
    private bool _loading;
    private bool _importing;
    private bool _consulted;
    private string? _message;
    private string _msgClass = "alert-info";

    private async Task PreviewAsync()
    {
        _loading = true;
        _message = null;
        try
        {
            _rows = await SilvaSoft.GetCompositionAsync(_styleFilter, page: 1);
            _consulted = true;
        }
        catch (Exception ex)
        {
            _message = $"Error: {ex.Message}";
            _msgClass = "alert-danger";
        }
        finally { _loading = false; }
    }

    private async Task ImportAsync()
    {
        _importing = true;
        _message = null;
        try
        {
            var r = await SilvaSoft.ImportCompositionAsync(_styleFilter);
            if (r is null)
            {
                _message = "La importación no devolvió resultado. Revise los logs.";
                _msgClass = "alert-warning";
            }
            else
            {
                _msgClass = r.Success ? "alert-success" : "alert-warning";
                _message = $"<strong>Importación completada:</strong> {r.Imported} importados, " +
                           $"{r.Skipped} omitidos, {r.Total} leídos de SilvaSoft.";
            }
        }
        catch (Exception ex)
        {
            _message = $"Error al importar: {ex.Message}";
            _msgClass = "alert-danger";
        }
        finally { _importing = false; }
    }
}
