@page "/integraciones/silvasoft/subfamilias"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Microsoft.JSInterop
@using System.Text.Json
@using Nanchesoft.Web.Services.SilvaSoft
@inject SilvaSoftApiService SilvaSoft
@inject IJSRuntime JS

<PageTitle>SilvaSoft — Subfamilias de materiales</PageTitle>

<div class="ns-catalog-page">

    <div class="ns-catalog-header">
        <div>
            <div class="ns-catalog-eyebrow">Nanchesoft ERP · Integración SilvaSoft</div>
            <h1 class="ns-catalog-title">Subfamilias de materiales</h1>
            <p class="ns-catalog-subtitle">
                Vista previa de la tabla <code>clase</code> de SilvaSoft SQL Server.
                Requiere que las <a href="/integraciones/silvasoft/familias-materiales">familias</a>
                ya estén importadas para vincular la familia padre.
            </p>
        </div>
        <div class="ns-catalog-badge">SilvaSoft · clase → MaterialSubfamily</div>
    </div>

    @if (_resultado is not null && _resultado.Exitoso)
    {
        <div class="ns-kpi-grid" style="margin-bottom:16px">
            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Registros leídos</div>
                <div class="ns-kpi-value">@_resultado.Total</div>
            </div>
            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Columnas detectadas</div>
                <div class="ns-kpi-value">@_resultado.Columnas.Count</div>
            </div>
            <div class="ns-kpi-card ns-kpi-card-success">
                <div class="ns-kpi-label">Tabla SQL Server</div>
                <div class="ns-kpi-value" style="font-size:1rem">@_resultado.NombreTabla</div>
            </div>
            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Base de datos</div>
                <div class="ns-kpi-value" style="font-size:1rem">@_resultado.BaseDatos</div>
            </div>
            <div class="ns-kpi-card">
                <div class="ns-kpi-label">Tiempo respuesta</div>
                <div class="ns-kpi-value">@_resultado.TiempoMs ms</div>
            </div>
        </div>
    }

    <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center">
        <button class="ns-btn ns-btn--primary" @onclick="ConsultarAsync" disabled="@_cargando">
            @if (_cargando) { <span class="spinner-border spinner-border-sm me-1"></span> }
            @(_resultado is null ? "Consultar SilvaSoft" : "Actualizar datos")
        </button>

        @if (_resultado is not null && _resultado.Exitoso)
        {
            <button class="ns-btn ns-btn--outline" @onclick="MostrarVistaAsync" disabled="@_cargandoVista">
                @if (_cargandoVista) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Importar subfamilias
            </button>
        }
    </div>

    @if (_resultado is not null && !_resultado.Exitoso)
    {
        <div style="padding:16px;border-radius:12px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3;margin-bottom:16px">
            <strong>Error al conectar con SilvaSoft:</strong><br />
            @_resultado.Error
            <div style="margin-top:8px;font-size:.85rem">
                Verifique la <a href="/integraciones/silvasoft/config">configuración de conexión</a>.
            </div>
        </div>
    }

    @if (_resultado is not null && _resultado.Exitoso)
    {
        <div id="@_gridId"></div>
    }
    else if (!_cargando && _resultado is null)
    {
        <div class="ns-empty-state" style="padding:48px 24px;text-align:center;color:#64748b">
            <svg viewBox="0 0 64 64" width="56" height="56" fill="none" style="margin-bottom:16px;opacity:.4">
                <rect x="8" y="16" width="48" height="36" rx="4" stroke="#94a3b8" stroke-width="2.5"/>
                <path d="M8 24h48" stroke="#94a3b8" stroke-width="2.5"/>
                <path d="M20 32h24M20 40h16" stroke="#94a3b8" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <div style="font-size:1.1rem;font-weight:600;margin-bottom:6px">Sin datos cargados</div>
            <div style="font-size:.9rem">
                Haz clic en <strong>Consultar SilvaSoft</strong> para leer la tabla
                <code>clase</code> desde el servidor SQL Server.
            </div>
        </div>
    }

</div>

@if (_mostrandoVista && _vista is not null)
{
    <div class="ns-modal-overlay" @onclick="CerrarVista"
         style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;display:flex;align-items:center;justify-content:center">
        <div class="ns-modal" @onclick:stopPropagation
             style="background:#fff;border-radius:16px;max-width:860px;width:95%;max-height:90vh;overflow:auto;padding:32px;box-shadow:0 20px 60px rgba(0,0,0,.25)">

            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px">
                <div>
                    <h2 style="margin:0 0 4px 0;font-size:1.25rem">Vista previa — Subfamilias</h2>
                    <p style="margin:0;color:#64748b;font-size:.9rem">
                        Análisis de @_vista.TotalEnSilvaSoft registros de la tabla <code>clase</code>
                        contra las subfamilias existentes en Nanchesoft.
                    </p>
                </div>
                <button class="ns-btn ns-btn--outline ns-btn--sm" @onclick="CerrarVista">✕ Cerrar</button>
            </div>

            <div class="ns-kpi-grid" style="margin-bottom:24px">
                <div class="ns-kpi-card ns-kpi-card-success">
                    <div class="ns-kpi-label">Nuevas para importar</div>
                    <div class="ns-kpi-value" style="color:#059669">@_vista.NuevosParaImportar</div>
                </div>
                <div class="ns-kpi-card">
                    <div class="ns-kpi-label">Ya existen (duplicados)</div>
                    <div class="ns-kpi-value" style="color:#d97706">@_vista.YaExistentesEnNanchesoft</div>
                </div>
                <div class="ns-kpi-card">
                    <div class="ns-kpi-label">Sin familia padre</div>
                    <div class="ns-kpi-value" style="color:#dc2626">@_vista.SinFamiliaPadre</div>
                </div>
                <div class="ns-kpi-card">
                    <div class="ns-kpi-label">Total en SilvaSoft</div>
                    <div class="ns-kpi-value">@_vista.TotalEnSilvaSoft</div>
                </div>
            </div>

            @if (_vista.SinFamiliaPadre > 0)
            {
                <div style="margin-bottom:16px;padding:12px 16px;background:#fef3c7;border:1px solid #fde68a;border-radius:8px;color:#92400e;font-size:.88rem">
                    <strong>Atención:</strong> @_vista.SinFamiliaPadre subfamilias no tienen su familia padre importada en Nanchesoft.
                    <a href="/integraciones/silvasoft/familias-materiales" style="color:#92400e;text-decoration:underline">
                        Importa las familias primero
                    </a> para que el vínculo funcione correctamente.
                </div>
            }

            <h3 style="font-size:1rem;margin-bottom:10px">Mapeo de columnas</h3>
            <div class="ns-table-wrap" style="margin-bottom:24px;max-height:180px;overflow:auto">
                <table class="ns-table" style="font-size:.85rem">
                    <thead>
                        <tr>
                            <th>Columna SilvaSoft</th>
                            <th>Tipo SQL</th>
                            <th>Campo Nanchesoft</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _vista.Mapeo)
                        {
                            <tr>
                                <td><code>@m.ColumnaOrigen</code></td>
                                <td class="text-muted">@m.TipoDato</td>
                                <td>
                                    @if (m.Mapeado)
                                    { <span style="color:#059669;font-weight:600">@m.CampoDestino</span> }
                                    else
                                    { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    @if (m.Mapeado)
                                    { <span class="ns-badge ns-badge--green">mapeado</span> }
                                    else
                                    { <span class="ns-badge">sin mapeo</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <h3 style="font-size:1rem;margin-bottom:10px">Vista previa (primeros 50 registros)</h3>
            <div class="ns-table-wrap" style="max-height:240px;overflow:auto">
                <table class="ns-table" style="font-size:.85rem">
                    <thead>
                        <tr>
                            <th>claseId</th>
                            <th>composicionId</th>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Familia padre</th>
                            <th>Estado</th>
                            <th>Razón</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _vista.VistaPrevia)
                        {
                            <tr>
                                <td class="text-muted small">@r.ClaseId</td>
                                <td class="text-muted small">@r.ComposicionId</td>
                                <td><code>@r.Codigo</code></td>
                                <td>@r.Nombre</td>
                                <td>
                                    @if (r.FamiliaPadre is not null)
                                    { <span style="color:#059669">@r.FamiliaPadre</span> }
                                    else
                                    { <span class="text-danger small">no importada</span> }
                                </td>
                                <td>
                                    @switch (r.Estado)
                                    {
                                        case "nuevo":
                                            <span class="ns-badge ns-badge--green">nuevo</span>
                                            break;
                                        case "duplicado":
                                            <span class="ns-badge" style="background:#fef3c7;color:#92400e">duplicado</span>
                                            break;
                                        default:
                                            <span class="ns-badge" style="background:#fee2e2;color:#991b1b">inválido</span>
                                            break;
                                    }
                                </td>
                                <td class="text-muted small">@r.Razon</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_importando)
            {
                <div style="margin-top:24px;padding:16px;background:#eff6ff;border-radius:10px;border:1px solid #bfdbfe;color:#1e40af;text-align:center">
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    Importando subfamilias desde SilvaSoft…
                </div>
            }
            else if (_resultadoImport is not null)
            {
                <div style="margin-top:24px;padding:16px;border-radius:10px;
                            border:1px solid @(_resultadoImport.Exitoso ? "#bbf7d0" : "#fecdd3");
                            background:@(_resultadoImport.Exitoso ? "#f0fdf4" : "#fff1f2");
                            color:@(_resultadoImport.Exitoso ? "#166534" : "#991b1b")">
                    <strong>@(_resultadoImport.Exitoso ? "Importación completada" : "Error en importación")</strong>
                    @if (_resultadoImport.Exitoso)
                    {
                        <div class="ns-kpi-grid" style="margin-top:12px">
                            <div class="ns-kpi-card ns-kpi-card-success">
                                <div class="ns-kpi-label">Importadas</div>
                                <div class="ns-kpi-value" style="color:#059669">@_resultadoImport.RegistrosImportados</div>
                            </div>
                            <div class="ns-kpi-card">
                                <div class="ns-kpi-label">Omitidas (dup.)</div>
                                <div class="ns-kpi-value" style="color:#d97706">@_resultadoImport.RegistrosOmitidos</div>
                            </div>
                            <div class="ns-kpi-card">
                                <div class="ns-kpi-label">Sin padre</div>
                                <div class="ns-kpi-value" style="color:#dc2626">@_resultadoImport.SinFamiliaPadre</div>
                            </div>
                            <div class="ns-kpi-card">
                                <div class="ns-kpi-label">Tiempo</div>
                                <div class="ns-kpi-value">@_resultadoImport.TiempoMs ms</div>
                            </div>
                        </div>
                        @foreach (var d in _resultadoImport.Detalles)
                        {
                            <div style="margin-top:6px;font-size:.88rem">· @d</div>
                        }
                    }
                    else
                    {
                        <div style="margin-top:8px">@_resultadoImport.Error</div>
                    }
                </div>
            }
            else
            {
                <div style="margin-top:24px;display:flex;gap:12px;align-items:center;flex-wrap:wrap">
                    <button class="ns-btn ns-btn--primary" @onclick="ConfirmarImportacionAsync" disabled="@(_importando || _vista.NuevosParaImportar == 0)">
                        Confirmar importación de subfamilias
                    </button>
                    <span class="text-muted small">
                        Se importarán <strong>@_vista.NuevosParaImportar</strong> subfamilias nuevas,
                        omitiendo <strong>@_vista.YaExistentesEnNanchesoft</strong> duplicados.
                    </span>
                </div>
            }
        </div>
    </div>
}

@code {
    private readonly string _gridId = $"ss-sf-grid-{Guid.NewGuid():N}";
    private SilvaSoftTablaResultado? _resultado;
    private SilvaSoftVistaImportacionSubfamiliasDto? _vista;
    private SilvaSoftImportSubfamiliasResultadoDto? _resultadoImport;
    private bool _cargando;
    private bool _cargandoVista;
    private bool _mostrandoVista;
    private bool _importando;
    private DotNetObjectReference<SilvaSoftSubfamilias>? _ref;

    protected override void OnInitialized() => _ref = DotNetObjectReference.Create(this);

    private async Task ConsultarAsync()
    {
        _cargando = true;
        StateHasChanged();
        try { _resultado = await SilvaSoft.ObtenerClaseAsync(top: 200); }
        finally { _cargando = false; }

        if (_resultado?.Exitoso == true)
        {
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
            await RenderizarGridAsync();
        }
        else await InvokeAsync(StateHasChanged);
    }

    private async Task RenderizarGridAsync()
    {
        if (_resultado is null || !_resultado.Exitoso) return;
        try
        {
            var columns = _resultado.Columnas.Select(c => new
            {
                dataField = c.NombreColumna, caption = c.NombreColumna,
                dataType = c.TipoDevExtreme, allowEditing = false,
                allowFiltering = true, allowSorting = true, visible = true, showInGrid = true,
                width = c.TipoDevExtreme == "number" ? 120 : 160
            }).ToList();

            var rows = _resultado.Registros.Select((reg, idx) =>
            {
                var dict = new Dictionary<string, object?> { ["_rowIdx"] = idx };
                foreach (var kv in reg.Campos)
                    dict[kv.Key] = kv.Value.ValueKind == System.Text.Json.JsonValueKind.Null ? null
                        : kv.Value.ValueKind == System.Text.Json.JsonValueKind.Number ? kv.Value.GetDouble()
                        : (object?)kv.Value.GetString();
                return dict;
            }).ToList();

            var definition = new
            {
                catalogKey = "silvasoft-clase",
                title = $"SilvaSoft · {_resultado.NombreTabla} ({_resultado.BaseDatos})",
                subtitle = $"{_resultado.Total} registros · {_resultado.TiempoMs}ms",
                keyExpr = "_rowIdx", allowCreate = false, allowUpdate = false,
                allowDelete = false, allowImport = false,
                totalCount = _resultado.Total, columns, rows
            };
            await JS.InvokeVoidAsync("nsCrudGrid.renderCrudGrid", _gridId, definition, _ref);
        }
        catch (Exception ex) { Console.Error.WriteLine($"[SilvaSoft/clase] Grid error: {ex.Message}"); }
    }

    private async Task MostrarVistaAsync()
    {
        _cargandoVista = true;
        try
        {
            _vista = await SilvaSoft.ObtenerVistaImportacionSubfamiliasAsync();
            if (_vista is not null) _mostrandoVista = true;
        }
        finally { _cargandoVista = false; }
    }

    private void CerrarVista() => _mostrandoVista = false;

    private async Task ConfirmarImportacionAsync()
    {
        _importando = true; _resultadoImport = null;
        StateHasChanged();
        try
        {
            var (ok, resultado, error) = await SilvaSoft.ImportarSubfamiliasAsync();
            _resultadoImport = resultado ?? new SilvaSoftImportSubfamiliasResultadoDto
            {
                Exitoso = false, Error = error
            };
        }
        finally { _importando = false; _mostrandoVista = false; }
    }

    [JSInvokable]
    public void OnGridEvent(string eventName, string payload) { }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("nsCrudGrid.disposeCrudGrid", _gridId); } catch { }
        _ref?.Dispose();
    }
}
