@page "/integraciones/silvasoft/config"
@rendermode InteractiveServer
@using Nanchesoft.Web.Services.SilvaSoft
@inject SilvaSoftApiService SilvaSoft

<PageTitle>SilvaSoft — Configuración de conexión</PageTitle>

<div class="ns-page-header">
    <div class="ns-page-header__left">
        <div class="ns-page-header__breadcrumb">Integraciones › SilvaSoft</div>
        <h1 class="ns-page-header__title">Configuración de conexión</h1>
        <p class="ns-page-header__subtitle">
            Configura el servidor SQL Server de SilvaSoft para esta empresa.
            Los datos se almacenan en la tabla <code>integraciones.silvasoft_conexiones</code>.
        </p>
    </div>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @_claseAlerta mt-3">@_mensaje</div>
}

@if (_testResult is not null)
{
    <div class="alert @(_testResult.Exitoso ? "alert-success" : "alert-warning") mt-3">
        <strong>@(_testResult.Exitoso ? "✓ Conexión exitosa" : "✗ Error de conexión"):</strong>
        @_testResult.Mensaje
        <span class="text-muted ms-2 small">(@_testResult.TiempoMs ms)</span>
    </div>
}

<div class="ns-section mt-3" style="max-width:660px">
    <div class="ns-form-grid">
        <div class="ns-field">
            <label class="ns-field-label">
                Servidor SQL Server
                <span class="text-muted small ms-1">Formato: HOST\INSTANCIA, IP o FQDN</span>
            </label>
            <input class="ns-input" type="text"
                   placeholder='Ej: SERVIDOR\RETRYVER  ó  192.168.1.100'
                   @bind="_req.NombreServidor" />
            <div class="ns-field-hint">
                Soporta instancias nombradas (SERVIDOR\INSTANCIA) y puertos implícitos.
            </div>
        </div>
        <div class="ns-field">
            <label class="ns-field-label">Base de datos</label>
            <input class="ns-input" type="text"
                   placeholder="Nombre de la BD SilvaSoft"
                   @bind="_req.BaseDatos" />
        </div>
        <div class="ns-field">
            <label class="ns-field-label">Usuario SQL</label>
            <input class="ns-input" type="text"
                   placeholder="Ej: Leonel"
                   @bind="_req.Usuario" />
        </div>
        <div class="ns-field">
            <label class="ns-field-label">
                Contraseña
                <span class="text-muted small ms-1">(dejar vacío para no modificar)</span>
            </label>
            <input class="ns-input" type="password"
                   placeholder="Vacío = sin contraseña o sin cambios"
                   @bind="_req.Password" />
            <div class="ns-field-hint text-warning small">
                ⚠ Fase 1: almacenada en texto. Fase 2 implementará encriptación IDataProtectionProvider.
            </div>
        </div>
        <div class="ns-field">
            <label class="ns-field-label">Notas <span class="text-muted small">(opcional)</span></label>
            <input class="ns-input" type="text" placeholder="Descripción libre" @bind="_req.Notas" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button class="ns-btn ns-btn--primary" @onclick="GuardarAsync" disabled="@_guardando">
            @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Guardar
        </button>
        <button class="ns-btn ns-btn--outline" @onclick="ProbarAsync" disabled="@_probando">
            @if (_probando) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Probar conexión
        </button>
    </div>

    @if (_cfg is not null)
    {
        <div class="text-muted small mt-4" style="padding:10px;background:#f8fafc;border-radius:8px">
            <strong>Estado actual:</strong>
            @if (_cfg.FechaUltimaSincronizacion.HasValue)
            {
                <span> Última sincronización: @_cfg.FechaUltimaSincronizacion.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            }
            else
            {
                <span> Sin sincronizaciones previas</span>
            }
            · Servidor: <code>@_cfg.NombreServidor</code> · BD: <code>@_cfg.BaseDatos</code>
        </div>
    }
</div>

@code {
    private SilvaSoftConexionRequest _req = new();
    private SilvaSoftConexionDto? _cfg;
    private SilvaSoftConexionTestDto? _testResult;
    private bool _guardando;
    private bool _probando;
    private bool _cargado;
    private string? _mensaje;
    private string _claseAlerta = "alert-info";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _cargado) return;
        _cargado = true;
        await CargarConfigAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CargarConfigAsync()
    {
        _cfg = await SilvaSoft.ObtenerConfigAsync();
        if (_cfg is not null)
        {
            _req.NombreServidor = _cfg.NombreServidor;
            _req.BaseDatos = _cfg.BaseDatos;
            _req.Usuario = _cfg.Usuario;
            _req.Notas = _cfg.Notas;
            _req.Activo = _cfg.Activo;
        }
    }

    private async Task GuardarAsync()
    {
        _guardando = true;
        _mensaje = null;
        _testResult = null;
        try
        {
            var (ok, msg) = await SilvaSoft.GuardarConfigAsync(_req);
            _claseAlerta = ok ? "alert-success" : "alert-danger";
            _mensaje = msg;
            if (ok) await CargarConfigAsync();
        }
        finally { _guardando = false; }
    }

    private async Task ProbarAsync()
    {
        _probando = true;
        _mensaje = null;
        _testResult = null;
        try
        {
            _testResult = await SilvaSoft.ProbarConexionAsync();
        }
        finally { _probando = false; }
    }
}
