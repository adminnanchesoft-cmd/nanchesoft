@page "/integraciones/silvasoft/logs"
@rendermode InteractiveServer
@using Nanchesoft.Web.Services.SilvaSoft
@inject SilvaSoftApiService SilvaSoft

<PageTitle>SilvaSoft — Logs de sincronización</PageTitle>

<div class="ns-page-header">
    <div class="ns-page-header__left">
        <div class="ns-page-header__breadcrumb">Integraciones › SilvaSoft</div>
        <h1 class="ns-page-header__title">Logs de sincronización</h1>
        <p class="ns-page-header__subtitle">
            Historial de todas las operaciones de integración SilvaSoft:
            conexiones, consultas y (futuras) importaciones.
        </p>
    </div>
    <div class="ns-page-header__actions">
        <button class="ns-btn ns-btn--outline" @onclick="CargarAsync">Actualizar</button>
    </div>
</div>

@if (_pagina is null)
{
    <div class="text-muted mt-4"><span class="spinner-border spinner-border-sm me-2"></span>Cargando logs…</div>
}
else if (_pagina.Registros.Count == 0)
{
    <div class="ns-empty-state mt-4"><p>Sin registros de sincronización todavía.</p></div>
}
else
{
    <div class="ns-section mt-3">
        <div class="text-muted small mb-2">@_pagina.Total registros · Página @_pagina.Pagina</div>
        <div class="ns-table-wrap">
            <table class="ns-table">
                <thead>
                    <tr>
                        <th>Operación</th>
                        <th>Estado</th>
                        <th class="text-end">Leídos</th>
                        <th class="text-end">Importados</th>
                        <th class="text-end">Omitidos</th>
                        <th>Iniciado</th>
                        <th>Duración</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _pagina.Registros)
                    {
                        <tr>
                            <td><code>@r.Operacion</code></td>
                            <td>
                                @switch (r.Estado)
                                {
                                    case "ok":
                                        <span class="ns-badge ns-badge--green">ok</span>
                                        break;
                                    case "error":
                                        <span class="ns-badge" style="background:#fee2e2;color:#991b1b">error</span>
                                        break;
                                    default:
                                        <span class="ns-badge">@r.Estado</span>
                                        break;
                                }
                            </td>
                            <td class="text-end">@r.RegistrosLeidos</td>
                            <td class="text-end">@r.RegistrosImportados</td>
                            <td class="text-end">@r.RegistrosOmitidos</td>
                            <td class="text-muted small">
                                @r.Iniciado.ToLocalTime().ToString("dd/MM/yy HH:mm")
                            </td>
                            <td class="text-muted small">
                                @if (r.DuracionMs.HasValue)
                                {
                                    @(r.DuracionMs.Value < 1000
                                        ? $"{r.DuracionMs.Value}ms"
                                        : $"{r.DuracionMs.Value / 1000.0:N1}s")
                                }
                            </td>
                            <td class="text-danger small"
                                style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                title="@r.MensajeError">
                                @r.MensajeError
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_pagina.Total > _pagina.TamanoPagina)
        {
            <div class="d-flex gap-2 mt-3 align-items-center">
                <button class="ns-btn ns-btn--outline ns-btn--sm"
                        @onclick="PaginaAnterior" disabled="@(_pagina.Pagina <= 1)">
                    ‹ Anterior
                </button>
                <span class="text-muted small">
                    Página @_pagina.Pagina de @((int)Math.Ceiling((double)_pagina.Total / _pagina.TamanoPagina))
                </span>
                <button class="ns-btn ns-btn--outline ns-btn--sm"
                        @onclick="PaginaSiguiente"
                        disabled="@(_pagina.Pagina * _pagina.TamanoPagina >= _pagina.Total)">
                    Siguiente ›
                </button>
            </div>
        }
    </div>
}

@code {
    private SilvaSoftSyncLogPagina? _pagina;
    private int _paginaActual = 1;

    protected override async Task OnInitializedAsync() => await CargarAsync();

    private async Task CargarAsync()
    {
        _pagina = await SilvaSoft.ObtenerLogsAsync(_paginaActual);
    }

    private async Task PaginaAnterior()
    {
        if (_paginaActual > 1) { _paginaActual--; await CargarAsync(); }
    }

    private async Task PaginaSiguiente()
    {
        _paginaActual++;
        await CargarAsync();
    }
}
