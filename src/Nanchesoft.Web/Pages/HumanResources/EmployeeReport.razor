@page "/human-resources/employees/report"
@layout Nanchesoft.Web.Layouts.PrintLayout
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<PageTitle>Reporte de colaboradores | Nanchesoft</PageTitle>

@if (_loading)
{
    <div style="padding:32px;text-align:center;">Cargando reporte…</div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div style="padding:32px;color:#b91c1c;">@_error</div>
}
else
{
    <!-- Toolbar (oculto en impresión) -->
    <div class="d-print-none" style="padding:12px 20px;background:#f8fafc;border-bottom:1px solid #e2e8f0;display:flex;gap:8px;align-items:center;">
        <span style="font-weight:600;font-size:15px;">Reporte de colaboradores</span>
        <span class="text-muted" style="font-size:13px;">— @_rows.Count registro(s) al @DateTime.Today.ToString("dd/MM/yyyy")</span>
        <div style="flex:1;"></div>
        <button onclick="window.print()" style="background:#1d4ed8;color:#fff;border:none;padding:6px 16px;border-radius:6px;cursor:pointer;font-size:13px;">🖨️ Imprimir / Guardar PDF</button>
        <a href="/human-resources/employees" style="color:#64748b;text-decoration:none;font-size:13px;">✕ Cerrar</a>
    </div>

    <!-- Reporte -->
    <div style="padding:24px;font-family:'Segoe UI',sans-serif;font-size:11px;color:#0f172a;">
        <div style="display:flex;justify-content:space-between;margin-bottom:16px;">
            <div>
                <div style="font-size:18px;font-weight:700;color:#1e3a5f;">Lista de Colaboradores</div>
                <div style="color:#64748b;margin-top:2px;">Generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div style="text-align:right;color:#64748b;">
                <div>Total: @_rows.Count colaboradores</div>
                <div>Activos: @_rows.Count(x => x.IsActive)</div>
            </div>
        </div>

        <table style="width:100%;border-collapse:collapse;font-size:10px;">
            <thead>
                <tr style="background:#1e3a5f;color:#fff;">
                    <th style="padding:5px 6px;text-align:left;white-space:nowrap;">No. Emp</th>
                    <th style="padding:5px 6px;text-align:left;">Nombre completo</th>
                    <th style="padding:5px 6px;text-align:left;">RFC</th>
                    <th style="padding:5px 6px;text-align:left;">Departamento</th>
                    <th style="padding:5px 6px;text-align:left;">Puesto</th>
                    <th style="padding:5px 6px;text-align:right;white-space:nowrap;">F. Ingreso</th>
                    <th style="padding:5px 6px;text-align:right;white-space:nowrap;">Sal. diario</th>
                    <th style="padding:5px 6px;text-align:center;">Período</th>
                    <th style="padding:5px 6px;text-align:center;">Estatus</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (r, i) in _rows.Select((x, i) => (x, i)))
                {
                    <tr style="background:@(i % 2 == 0 ? "#ffffff" : "#f8fafc");border-bottom:1px solid #e2e8f0;">
                        <td style="padding:4px 6px;font-family:monospace;">@r.EmployeeNumber</td>
                        <td style="padding:4px 6px;font-weight:500;">@r.FullName</td>
                        <td style="padding:4px 6px;font-family:monospace;">@r.TaxId</td>
                        <td style="padding:4px 6px;">@r.DepartmentName</td>
                        <td style="padding:4px 6px;">@r.PositionName</td>
                        <td style="padding:4px 6px;text-align:right;white-space:nowrap;">@r.HireDate.ToString("dd/MM/yy")</td>
                        <td style="padding:4px 6px;text-align:right;white-space:nowrap;">@r.DailySalary.ToString("C2")</td>
                        <td style="padding:4px 6px;text-align:center;">@r.PayrollPeriodType</td>
                        <td style="padding:4px 6px;text-align:center;">
                            <span style="padding:2px 6px;border-radius:10px;font-size:9px;background:@(r.IsActive ? "#dcfce7" : "#fee2e2");color:@(r.IsActive ? "#166534" : "#991b1b");">
                                @(r.IsActive ? "Activo" : "Inactivo")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="background:#f1f5f9;font-weight:700;border-top:2px solid #cbd5e1;">
                    <td colspan="6" style="padding:5px 6px;">Totales</td>
                    <td style="padding:5px 6px;text-align:right;">@_rows.Sum(x => x.DailySalary).ToString("C2")</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>

        <div style="margin-top:24px;display:flex;gap:32px;flex-wrap:wrap;">
            @foreach (var dept in _rows.GroupBy(x => string.IsNullOrEmpty(x.DepartmentName) ? "Sin departamento" : x.DepartmentName).OrderBy(g => g.Key))
            {
                <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:8px 12px;min-width:140px;">
                    <div style="font-weight:600;font-size:10px;color:#475569;">@dept.Key</div>
                    <div style="font-size:18px;font-weight:700;color:#1e3a5f;">@dept.Count()</div>
                    <div style="font-size:9px;color:#94a3b8;">colaboradores</div>
                </div>
            }
        </div>
    </div>
}

<style>
    @@media print {
        .d-print-none { display: none !important; }
        @@page { margin: 10mm; }
        body { font-size: 10px; }
    }
</style>

@code {
    private List<EmpRow> _rows = [];
    private bool _loading = true;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var data = await client.GetFromJsonAsync<List<EmpRow>>("/api/hr/employees");
            _rows = data?.OrderBy(x => x.LastName).ThenBy(x => x.FirstName).ToList() ?? [];
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class EmpRow
    {
        public string EmployeeNumber { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string? SecondLastName { get; set; }
        public string? MiddleName { get; set; }
        public string TaxId { get; set; } = string.Empty;
        public string DepartmentName { get; set; } = string.Empty;
        public string PositionName { get; set; } = string.Empty;
        public DateTime HireDate { get; set; }
        public decimal DailySalary { get; set; }
        public string PayrollPeriodType { get; set; } = string.Empty;
        public bool IsActive { get; set; }
        public string FullName => string.Join(" ", new[] { LastName, SecondLastName, FirstName, MiddleName }
            .Where(x => !string.IsNullOrWhiteSpace(x)));
    }
}
