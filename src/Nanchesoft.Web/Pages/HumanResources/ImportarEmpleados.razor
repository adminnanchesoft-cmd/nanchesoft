@page "/human-resources/importar-empleados"
@using System.Net.Http.Headers
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Importar Empleados | Nanchesoft</PageTitle>

<div class="p-4" style="max-width:1400px;margin:0 auto;">

    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-link p-0" @onclick='() => Nav.NavigateTo("/human-resources/employees")'>
            <span class="bi bi-arrow-left fs-5"></span>
        </button>
        <div>
            <h4 class="mb-0 fw-bold">Importar Colaboradores desde Excel</h4>
            <small class="text-muted">Carga masiva con validación previa y vista previa de resultados.</small>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_globalError))
    {
        <div class="alert alert-danger alert-dismissible">
            <button type="button" class="btn-close" @onclick='() => _globalError = string.Empty'></button>
            @_globalError
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="btn-close" @onclick='() => _successMessage = string.Empty'></button>
            @_successMessage
        </div>
    }

    <!-- Paso 1: Cargar archivo + modo de conflicto -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white d-flex align-items-center gap-2">
            <span class="bi bi-file-earmark-excel fs-5"></span>
            <strong>Paso 1 — Seleccionar archivo Excel</strong>
        </div>
        <div class="card-body">
            <div class="row align-items-stretch g-3">
                <div class="col-12 col-md-6">
                    <div id="@_dropZoneId" class="border rounded-3 p-3 h-100 bg-light d-flex flex-column justify-content-center"
                         tabindex="0" style="border-style:dashed !important;">
                        <label class="form-label fw-semibold">Archivo .xlsx</label>
                        <InputFile OnChange="OnFileSelected" accept=".xlsx" class="form-control" disabled="@_loading" />
                        <div class="form-text">
                            Arrastra o pega el Excel aquí. Columnas requeridas: NoEmpleado, Nombre, ApellidoPaterno, FechaIngreso.
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_selectedFileName))
                        {
                            <div class="small text-primary fw-semibold mt-2">
                                <span class="bi bi-file-earmark-excel me-1"></span>@_selectedFileName
                            </div>
                        }
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold">Si el empleado ya existe en la base…</label>
                    <div class="d-flex flex-column gap-2">
                        <label class="form-check d-flex align-items-start gap-2 p-2 border rounded">
                            <input class="form-check-input mt-1" type="radio" name="conflictMode" value="update"
                                   checked="@(_conflictMode == "update")" @onchange='() => _conflictMode = "update"' />
                            <span><strong>Actualizar</strong><br /><span class="small text-muted">Sobrescribe nombre, RFC, sueldos, departamento, etc.</span></span>
                        </label>
                        <label class="form-check d-flex align-items-start gap-2 p-2 border rounded">
                            <input class="form-check-input mt-1" type="radio" name="conflictMode" value="skip"
                                   checked="@(_conflictMode == "skip")" @onchange='() => _conflictMode = "skip"' />
                            <span><strong>Omitir</strong><br /><span class="small text-muted">No toca el registro existente.</span></span>
                        </label>
                        <label class="form-check d-flex align-items-start gap-2 p-2 border rounded">
                            <input class="form-check-input mt-1" type="radio" name="conflictMode" value="error"
                                   checked="@(_conflictMode == "error")" @onchange='() => _conflictMode = "error"' />
                            <span><strong>Marcar como duplicado</strong><br /><span class="small text-muted">Rechaza esas filas y aborta si encuentra alguna.</span></span>
                        </label>
                    </div>
                </div>
                <div class="col-12 col-md-auto d-flex gap-2 align-items-end mt-3 mt-md-0" style="padding-top:1.6rem;">
                    <button class="btn btn-outline-secondary" @onclick="DownloadTemplate" disabled="@_loading">
                        <span class="bi bi-download me-1"></span> Plantilla
                    </button>
                    <button class="btn btn-primary" @onclick="PreviewImport" disabled="@(!HasSelectedFile || _loading)">
                        @if (_loading && _phase == "preview")
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <span class="bi bi-search me-1"></span> Validar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Paso 2: Resumen de validación + tarjetas KPI -->
    @if (_preview != null)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white d-flex align-items-center gap-2">
                <span class="bi bi-diagram-3 text-primary"></span>
                <strong>Asignación detectada de campos</strong>
            </div>
            <div class="card-body p-0">
                <div style="overflow-x:auto;">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Campo destino</th>
                                <th>Columna origen</th>
                                <th style="width:110px;">Requerido</th>
                                <th style="width:110px;">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mapping in _preview.Mappings)
                            {
                                <tr>
                                    <td class="fw-semibold">@mapping.Label</td>
                                    <td>@(string.IsNullOrWhiteSpace(mapping.SourceColumn) ? "-" : mapping.SourceColumn)</td>
                                    <td>@(mapping.Required ? "Sí" : "No")</td>
                                    <td>
                                        @if (mapping.Found)
                                        {
                                            <span class="badge bg-success">OK</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Falta</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-6 col-md-2">
                <div class="card text-center border-success h-100">
                    <div class="card-body p-2">
                        <div class="display-6 fw-bold text-success mb-0">@_preview.NewCount</div>
                        <div class="small text-muted">A insertar</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card text-center border-warning h-100">
                    <div class="card-body p-2">
                        <div class="display-6 fw-bold text-warning mb-0">@_preview.UpdateCount</div>
                        <div class="small text-muted">A actualizar</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card text-center border-danger h-100">
                    <div class="card-body p-2">
                        <div class="display-6 fw-bold text-danger mb-0">@_preview.ErrorCount</div>
                        <div class="small text-muted">Errores</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card text-center border-info h-100">
                    <div class="card-body p-2">
                        <div class="display-6 fw-bold text-info mb-0">@_preview.DuplicateCount</div>
                        <div class="small text-muted">Duplicados</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card text-center border-secondary h-100">
                    <div class="card-body p-2">
                        <div class="display-6 fw-bold text-secondary mb-0">@_preview.SkipCount</div>
                        <div class="small text-muted">Omitidos</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card text-center h-100">
                    <div class="card-body p-2">
                        <div class="display-6 fw-bold mb-0">@_preview.Total</div>
                        <div class="small text-muted">Total filas</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2">
                    <span class="bi bi-clipboard-check text-primary fs-5"></span>
                    <strong>Paso 2 — Detalle por fila</strong>
                </div>
                <div class="d-flex gap-2 flex-wrap small text-muted">
                    <span>Modo de conflicto:</span>
                    <span class="badge bg-dark text-uppercase">@_preview.ConflictMode</span>
                </div>
            </div>
            <div class="card-body p-0">
                <!-- Filtros de la tabla -->
                <div class="d-flex gap-2 p-3 border-bottom flex-wrap">
                    <button class="btn btn-sm @(_filter == "all" ? "btn-primary" : "btn-outline-secondary")"
                            @onclick='() => _filter = "all"'>
                        Todos (@_preview.Total)
                    </button>
                    <button class="btn btn-sm @(_filter == "new" ? "btn-success" : "btn-outline-success")"
                            @onclick='() => _filter = "new"'>
                        Nuevos (@_preview.NewCount)
                    </button>
                    <button class="btn btn-sm @(_filter == "update" ? "btn-warning" : "btn-outline-warning")"
                            @onclick='() => _filter = "update"'>
                        Actualizaciones (@_preview.UpdateCount)
                    </button>
                    <button class="btn btn-sm @(_filter == "error" ? "btn-danger" : "btn-outline-danger")"
                            @onclick='() => _filter = "error"'>
                        Errores (@_preview.ErrorCount)
                    </button>
                    @if (_preview.DuplicateCount > 0)
                    {
                        <button class="btn btn-sm @(_filter == "duplicate" ? "btn-info" : "btn-outline-info")"
                                @onclick='() => _filter = "duplicate"'>
                            Duplicados (@_preview.DuplicateCount)
                        </button>
                    }
                    @if (_preview.SkipCount > 0)
                    {
                        <button class="btn btn-sm @(_filter == "skip" ? "btn-secondary" : "btn-outline-secondary")"
                                @onclick='() => _filter = "skip"'>
                            Omitidos (@_preview.SkipCount)
                        </button>
                    }
                </div>

                <div style="overflow-x:auto;max-height:420px;overflow-y:auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width:60px;">Fila</th>
                                <th style="width:100px;">Código</th>
                                <th style="width:100px;">No. Emp.</th>
                                <th>Nombre completo</th>
                                <th>RFC</th>
                                <th style="width:100px;">Ingreso</th>
                                <th style="width:120px;">Sueldo periodo</th>
                                <th style="width:100px;">Salario diario</th>
                                <th>Sucursal</th>
                                <th>Departamento</th>
                                <th>Puesto</th>
                                <th style="width:120px;">Estado</th>
                                <th>Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in FilteredRows)
                            {
                                <tr class="@RowClass(row.Status)">
                                    <td class="text-muted small">@row.RowNumber</td>
                                    <td class="fw-semibold text-secondary">@row.Code</td>
                                    <td class="fw-semibold">@row.EmployeeNumber</td>
                                    <td>@row.FullName</td>
                                    <td class="text-muted small">@row.TaxId</td>
                                    <td class="small">@(row.HireDate.HasValue ? row.HireDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                                    <td class="small text-end">@(row.PeriodSalary > 0 ? row.PeriodSalary.ToString("N2") : "-")</td>
                                    <td class="small text-end">@(row.DailySalary > 0 ? row.DailySalary.ToString("N2") : "-")</td>
                                    <td class="small">@(string.IsNullOrEmpty(row.BranchName) ? row.BranchCode : row.BranchName)</td>
                                    <td class="small">@(string.IsNullOrEmpty(row.DepartmentName) ? row.DepartmentCode : row.DepartmentName)</td>
                                    <td class="small">@(string.IsNullOrEmpty(row.PositionName) ? row.PositionCode : row.PositionName)</td>
                                    <td>
                                        @switch (row.Status)
                                        {
                                            case "new":
                                                <span class="badge bg-success">Nuevo</span>
                                                break;
                                            case "update":
                                                <span class="badge bg-warning text-dark">Actualizar</span>
                                                break;
                                            case "error":
                                                <span class="badge bg-danger">Error</span>
                                                break;
                                            case "duplicate":
                                                <span class="badge bg-info text-dark">Duplicado</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">Omitido</span>
                                                break;
                                        }
                                    </td>
                                    <td class="small @(row.Status == "error" ? "text-danger" : "text-muted")">
                                        @row.Message
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Paso 3: Confirmar importación -->
            @if (_preview.NewCount + _preview.UpdateCount > 0)
            {
                <div class="card-footer d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="text-muted small">
                        Se importarán <strong>@(_preview.NewCount + _preview.UpdateCount)</strong> registros
                        (@_preview.NewCount nuevos + @_preview.UpdateCount actualizaciones).
                        Los @_preview.ErrorCount con error serán omitidos.
                    </div>
                    <button class="btn btn-success" @onclick="ExecuteImport" disabled="@(_loading)">
                        @if (_loading && _phase == "import")
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <span class="bi bi-cloud-upload me-1"></span>
                        Confirmar importación
                    </button>
                </div>
            }
            else if (_preview.Total > 0 && _preview.NewCount + _preview.UpdateCount == 0)
            {
                <div class="card-footer text-center text-danger">
                    No hay filas válidas para importar. Corrige los errores en tu archivo y vuelve a cargar.
                </div>
            }
        </div>
    }

</div>

@code {
    private const long MaxFileSize = 10 * 1024 * 1024;
    private readonly string _dropZoneId = $"employee-import-dropzone-{Guid.NewGuid():N}";
    private DotNetObjectReference<ImportarEmpleados>? _dotNetRef;
    private bool _dropZoneReady;
    private byte[]? _selectedFileBytes;
    private string _selectedFileName = string.Empty;
    private string _selectedFileContentType = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
    private PreviewResult? _preview;
    private string _filter = "all";
    private string _conflictMode = "update"; // update | skip | error
    private bool _loading;
    private string _phase = string.Empty;
    private string _globalError = string.Empty;
    private string _successMessage = string.Empty;
    private bool HasSelectedFile => _selectedFileBytes is { Length: > 0 };

    private IEnumerable<PreviewRow> FilteredRows => _preview?.Rows == null
        ? []
        : _filter == "all"
            ? _preview.Rows
            : _preview.Rows.Where(r => r.Status == _filter);

    private static string RowClass(string status) => status switch
    {
        "error" => "table-danger",
        "update" => "table-warning",
        "new" => "table-success",
        "duplicate" => "table-info",
        _ => "table-secondary"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((firstRender || !_dropZoneReady) && _dotNetRef is null)
            _dotNetRef = DotNetObjectReference.Create(this);

        if (firstRender || !_dropZoneReady)
        {
            try
            {
                await JS.InvokeVoidAsync("nsImport.initBinaryFileDropZone", _dropZoneId, _dotNetRef);
                _dropZoneReady = true;
            }
            catch { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await Task.CompletedTask;
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        if (e.File is null) return;
        await SetSelectedFileAsync(e.File);
    }

    private async Task SetSelectedFileAsync(IBrowserFile file)
    {
        _globalError = string.Empty;
        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            _globalError = "Solo se aceptan archivos .xlsx.";
            return;
        }

        using var ms = new System.IO.MemoryStream();
        await using var stream = file.OpenReadStream(maxAllowedSize: MaxFileSize);
        await stream.CopyToAsync(ms);
        SetSelectedFile(file.Name, file.ContentType, ms.ToArray());
    }

    [JSInvokable]
    public Task HandleDroppedFile(string fileName, string contentType, string base64)
    {
        _globalError = string.Empty;
        if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            _globalError = "Solo se aceptan archivos .xlsx.";
            return InvokeAsync(StateHasChanged);
        }

        try
        {
            SetSelectedFile(fileName, contentType, Convert.FromBase64String(base64));
        }
        catch (Exception ex)
        {
            _globalError = $"Error al leer archivo: {ex.Message}";
        }

        return InvokeAsync(StateHasChanged);
    }

    private void SetSelectedFile(string fileName, string contentType, byte[] bytes)
    {
        _selectedFileBytes = bytes;
        _selectedFileName = fileName;
        _selectedFileContentType = string.IsNullOrWhiteSpace(contentType)
            ? "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
            : contentType;
        _preview = null;
        _successMessage = string.Empty;
        _filter = "all";
    }

    private async Task DownloadTemplate()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var response = await client.GetAsync("/api/hr/employees/import/template");
            if (!response.IsSuccessStatusCode) { _globalError = "No se pudo descargar la plantilla."; return; }
            // The browser cannot download directly from Blazor Server; navigate to API URL
            var apiBase = client.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;
            Nav.NavigateTo($"{apiBase}/api/hr/employees/import/template", forceLoad: true);
        }
        catch (Exception ex)
        {
            _globalError = $"Error al descargar plantilla: {ex.Message}";
        }
    }

    private async Task PreviewImport()
    {
        if (!HasSelectedFile) return;
        _loading = true;
        _phase = "preview";
        _globalError = string.Empty;
        _preview = null;

        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new ByteArrayContent(_selectedFileBytes!);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(_selectedFileContentType);
            content.Add(fileContent, "file", _selectedFileName);

            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var response = await client.PostAsync($"/api/hr/employees/import/preview?conflict_mode={_conflictMode}", content);
            if (!response.IsSuccessStatusCode)
            {
                _globalError = $"Error del servidor: {response.StatusCode}";
                return;
            }

            _preview = await response.Content.ReadFromJsonAsync<PreviewResult>();
            _filter = "all";
        }
        catch (Exception ex)
        {
            _globalError = $"Error al procesar archivo: {ex.Message}";
        }
        finally
        {
            _loading = false;
            _phase = string.Empty;
        }
    }

    private async Task ExecuteImport()
    {
        if (!HasSelectedFile) return;
        _loading = true;
        _phase = "import";
        _globalError = string.Empty;
        _successMessage = string.Empty;

        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new ByteArrayContent(_selectedFileBytes!);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(_selectedFileContentType);
            content.Add(fileContent, "file", _selectedFileName);

            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var response = await client.PostAsync($"/api/hr/employees/import?conflict_mode={_conflictMode}", content);

            if (!response.IsSuccessStatusCode)
            {
                _globalError = $"Error al importar: {response.StatusCode}";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<ImportResult>();
            if (result != null)
            {
                _successMessage = $"Importación completada: {result.Created} nuevos, {result.Updated} actualizados, {result.Skipped} omitidos, {result.Duplicates} duplicados, {result.Errors} errores. ({result.DurationMs} ms)";
                _preview = null;
                _selectedFileBytes = null;
                _selectedFileName = string.Empty;
            }
        }
        catch (Exception ex)
        {
            _globalError = $"Error al importar: {ex.Message}";
        }
        finally
        {
            _loading = false;
            _phase = string.Empty;
        }
    }

    private sealed class PreviewResult
    {
        public int Total { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("newCount")]
        public int NewCount { get; set; }
        public int UpdateCount { get; set; }
        public int ErrorCount { get; set; }
        public int SkipCount { get; set; }
        public int DuplicateCount { get; set; }
        public string ConflictMode { get; set; } = "update";
        public List<FieldMapping> Mappings { get; set; } = [];
        public List<PreviewRow> Rows { get; set; } = [];
    }

    private sealed class FieldMapping
    {
        public string TargetField { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string SourceColumn { get; set; } = string.Empty;
        public bool Required { get; set; }
        public bool Found { get; set; }
    }

    private sealed class PreviewRow
    {
        public int RowNumber { get; set; }
        public string Code { get; set; } = string.Empty;
        public string EmployeeNumber { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string TaxId { get; set; } = string.Empty;
        public string Curp { get; set; } = string.Empty;
        public string Nss { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public DateTime? HireDate { get; set; }
        public decimal PeriodSalary { get; set; }
        public decimal DailySalary { get; set; }
        public string BranchCode { get; set; } = string.Empty;
        public string BranchName { get; set; } = string.Empty;
        public string DepartmentCode { get; set; } = string.Empty;
        public string DepartmentName { get; set; } = string.Empty;
        public string PositionCode { get; set; } = string.Empty;
        public string PositionName { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }

    private sealed class ImportResult
    {
        public bool Success { get; set; }
        public int Created { get; set; }
        public int Updated { get; set; }
        public int Skipped { get; set; }
        public int Duplicates { get; set; }
        public int Errors { get; set; }
        public Guid? LogId { get; set; }
        public int DurationMs { get; set; }
    }
}
