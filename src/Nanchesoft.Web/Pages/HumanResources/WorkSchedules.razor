@page "/human-resources/work-schedules"
@using System.Net.Http.Json
@using System.Text.Json
@using System.Globalization
@using Nanchesoft.Web.Services.HumanResources
@using Nanchesoft.Web.State
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AppState AppState
@inject AuthState AuthState

<PageTitle>Horarios laborales | Nanchesoft</PageTitle>

@* ══════════════════════════════════════════════════════════════════════════ *@
@*                                LISTADO                                      *@
@* ══════════════════════════════════════════════════════════════════════════ *@
@if (_mode == Mode.List)
{
    <div class="ns-header">
        <div class="flex-grow-1">
            <div class="ns-breadcrumb mb-0">
                <a href="/human-resources">RRHH</a>
                <span class="sep">/</span>
                <span class="text-dark fw-semibold">Horarios laborales</span>
            </div>
            <div class="d-flex align-items-center gap-2 mt-1">
                <span class="bi bi-calendar-week text-primary fs-5"></span>
                <span class="fw-bold" style="font-size:16px;">Horarios laborales</span>
                <span class="ns-badge-active">@_schedules.Count(x => x.IsActive) activos</span>
                <span class="ns-badge-inactive">@_schedules.Count(x => !x.IsActive) inactivos</span>
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <button class="btn btn-outline-secondary btn-sm px-3" @onclick="LoadListAsync" title="Recargar">
                <span class="bi bi-arrow-clockwise"></span>
            </button>
            <button class="btn btn-primary btn-sm px-4" @onclick="OpenNew">
                <span class="bi bi-plus-lg me-1"></span>
                <span>Nuevo horario</span>
            </button>
        </div>
    </div>

    <div style="max-width:1280px;margin:0 auto;padding:20px 16px 40px 16px;">

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-3 py-2" style="font-size:13px;">
                <span class="bi bi-exclamation-triangle-fill"></span>
                <span class="flex-grow-1">@_error</span>
                <button type="button" class="btn-close" @onclick="() => _error = string.Empty"></button>
            </div>
        }

        @* KPIs *@
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="ws-kpi ws-kpi-blue">
                    <div class="ws-kpi-icon"><span class="bi bi-calendar-week"></span></div>
                    <div>
                        <div class="ws-kpi-label">Total horarios</div>
                        <div class="ws-kpi-value">@_schedules.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ws-kpi ws-kpi-green">
                    <div class="ws-kpi-icon"><span class="bi bi-check2-circle"></span></div>
                    <div>
                        <div class="ws-kpi-label">Activos</div>
                        <div class="ws-kpi-value">@_schedules.Count(x => x.IsActive)</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ws-kpi ws-kpi-purple">
                    <div class="ws-kpi-icon"><span class="bi bi-lightning-charge"></span></div>
                    <div>
                        <div class="ws-kpi-label">Flexibles</div>
                        <div class="ws-kpi-value">@_schedules.Count(x => x.IsFlexible)</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ws-kpi ws-kpi-amber">
                    <div class="ws-kpi-icon"><span class="bi bi-clock-history"></span></div>
                    <div>
                        <div class="ws-kpi-label">Horas/sem promedio</div>
                        <div class="ws-kpi-value">@(_schedules.Count == 0 ? "0" : Math.Round(_schedules.Average(x => x.WeeklyHours), 1).ToString(CultureInfo.InvariantCulture))</div>
                    </div>
                </div>
            </div>
        </div>

        @* Filtros *@
        <div class="ws-filters">
            <div class="ws-search">
                <span class="bi bi-search"></span>
                <input class="form-control ns-form-input" placeholder="Buscar por código, nombre o turno..." @bind="_search" @bind:event="oninput" />
            </div>
            <div class="d-flex gap-1 flex-wrap">
                <button class="ws-chip @(_filter == "all" ? "ws-chip-active" : "")" @onclick='() => _filter = "all"'>Todos</button>
                <button class="ws-chip @(_filter == "active" ? "ws-chip-active" : "")" @onclick='() => _filter = "active"'>Activos</button>
                <button class="ws-chip @(_filter == "inactive" ? "ws-chip-active" : "")" @onclick='() => _filter = "inactive"'>Inactivos</button>
                <button class="ws-chip @(_filter == "flexible" ? "ws-chip-active" : "")" @onclick='() => _filter = "flexible"'>Flexibles</button>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary mb-2" style="width:2.5rem;height:2.5rem;"></div>
                <p class="text-muted" style="font-size:13px;">Cargando horarios laborales…</p>
            </div>
        }
        else if (FilteredSchedules().Count == 0)
        {
            <div class="ws-empty">
                <span class="bi bi-calendar-x" style="font-size:48px;color:#cbd5e1;"></span>
                <h5 class="mt-3" style="color:#475569;">Sin horarios configurados</h5>
                <p class="text-muted" style="font-size:13px;">Crea el primer horario laboral para tus colaboradores.</p>
                <button class="btn btn-primary btn-sm px-4" @onclick="OpenNew">
                    <span class="bi bi-plus-lg me-1"></span> Crear horario
                </button>
            </div>
        }
        else
        {
            <div class="ws-grid">
                @foreach (var s in FilteredSchedules())
                {
                    var totalDays = ActiveDayCount(s);
                    <div class="ws-card @(s.IsActive ? "" : "ws-card-inactive")" @onclick="() => OpenEdit(s)">
                        <div class="ws-card-header">
                            <div class="d-flex align-items-center gap-2 flex-grow-1 min-w-0">
                                <span class="ws-card-icon"><span class="bi bi-calendar-week"></span></span>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="ws-card-title text-truncate" title="@s.Name">@(string.IsNullOrWhiteSpace(s.Name) ? "(Sin nombre)" : s.Name)</div>
                                    <div class="ws-card-code">@s.Code</div>
                                </div>
                            </div>
                            @if (s.IsActive)
                            {
                                <span class="ns-badge-active">Activo</span>
                            }
                            else
                            {
                                <span class="ns-badge-inactive">Inactivo</span>
                            }
                        </div>

                        <div class="ws-card-week">
                            @foreach (var d in WeekDayList())
                            {
                                var on = IsDayActive(s, d.Index);
                                <div class="ws-mini-day @(on ? "ws-mini-on" : "ws-mini-off")" title="@d.LongLabel">@d.ShortLabel</div>
                            }
                        </div>

                        <div class="ws-card-footer">
                            <div class="ws-card-metric">
                                <span class="bi bi-clock"></span>
                                <span>@s.WeeklyHours.ToString("0.#") h/sem</span>
                            </div>
                            <div class="ws-card-metric">
                                <span class="bi bi-calendar2-check"></span>
                                <span>@totalDays días</span>
                            </div>
                            @if (s.IsFlexible)
                            {
                                <span class="ws-tag ws-tag-purple"><span class="bi bi-lightning-charge"></span> Flexible</span>
                            }
                        </div>

                        <div class="ws-card-actions">
                            <button class="btn btn-link btn-sm p-0 text-primary"
                                    @onclick="(e) => { OpenEdit(s); }"
                                    @onclick:stopPropagation="true">
                                <span class="bi bi-pencil-square me-1"></span>Editar
                            </button>
                            <button class="btn btn-link btn-sm p-0 text-danger"
                                    @onclick="(e) => DeleteAsync(s)"
                                    @onclick:stopPropagation="true">
                                <span class="bi bi-trash me-1"></span>Eliminar
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@* ══════════════════════════════════════════════════════════════════════════ *@
@*                                  EDITOR                                     *@
@* ══════════════════════════════════════════════════════════════════════════ *@
@if (_mode == Mode.Edit && _form is not null)
{
    <div class="ns-header">
        <button class="btn btn-link p-0 text-secondary" @onclick="CancelEdit" title="Volver">
            <span class="bi bi-arrow-left fs-5"></span>
        </button>
        <div class="flex-grow-1">
            <div class="ns-breadcrumb mb-0">
                <a href="/human-resources">RRHH</a>
                <span class="sep">/</span>
                <a href="javascript:void(0)" @onclick="CancelEdit">Horarios laborales</a>
                <span class="sep">/</span>
                <span class="text-dark fw-semibold">@(_isNew ? "Nuevo" : _form.Name)</span>
            </div>
            <div class="d-flex align-items-center gap-2 mt-1">
                <span class="bi bi-calendar-week text-primary fs-5"></span>
                <span class="fw-bold" style="font-size:15px;">
                    @(_isNew ? "Nuevo horario laboral" : _form.Name)
                </span>
                @if (!_isNew)
                {
                    <span class="ns-badge-@(_form.IsActive ? "active" : "inactive")">
                        @(_form.IsActive ? "Activo" : "Inactivo")
                    </span>
                    <small class="text-muted" style="font-size:12px;">@_form.Code</small>
                }
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <button class="btn btn-outline-secondary btn-sm px-3" @onclick="CancelEdit">
                <span class="bi bi-x-lg me-1"></span>Cancelar
            </button>
            <button class="btn btn-primary btn-sm px-4" @onclick="SaveAsync" disabled="@_saving">
                @if (_saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    <span>Guardando…</span>
                }
                else
                {
                    <span class="bi bi-check2 me-1"></span>
                    <span>Guardar</span>
                }
            </button>
        </div>
    </div>

    <div style="max-width:1280px;margin:0 auto;padding:20px 16px 40px 16px;">

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-3 py-2" style="font-size:13px;">
                <span class="bi bi-exclamation-triangle-fill"></span>
                <span class="flex-grow-1">@_error</span>
                <button type="button" class="btn-close" @onclick="() => _error = string.Empty"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(_success))
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-3 py-2" style="font-size:13px;">
                <span class="bi bi-check-circle-fill"></span>
                <span class="flex-grow-1">@_success</span>
                <button type="button" class="btn-close" @onclick="() => _success = string.Empty"></button>
            </div>
        }

        @{
            var liveIssues = LiveWarnings();
        }
        @if (liveIssues.Count > 0)
        {
            <div class="ws-warn">
                <div class="ws-warn-head">
                    <span class="bi bi-exclamation-triangle-fill"></span>
                    <strong>Hay @liveIssues.Count detalle(s) por revisar antes de guardar</strong>
                </div>
                <ul class="ws-warn-list">
                    @foreach (var msg in liveIssues)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        }

        @* ══ Resumen automático (sticky top) ══ *@
        <div class="ws-summary">
            <div class="ws-summary-item ws-summary-blue">
                <div class="ws-summary-icon"><span class="bi bi-clock-history"></span></div>
                <div>
                    <div class="ws-summary-label">Horas semanales</div>
                    <div class="ws-summary-value">@CalcWeeklyHours().ToString("0.##") <small>h</small></div>
                </div>
            </div>
            <div class="ws-summary-item ws-summary-green">
                <div class="ws-summary-icon"><span class="bi bi-calendar2-check"></span></div>
                <div>
                    <div class="ws-summary-label">Días laborales</div>
                    <div class="ws-summary-value">@CalcActiveDays() <small>de 7</small></div>
                </div>
            </div>
            <div class="ws-summary-item ws-summary-slate">
                <div class="ws-summary-icon"><span class="bi bi-cup-hot"></span></div>
                <div>
                    <div class="ws-summary-label">Días con descanso</div>
                    <div class="ws-summary-value">@CalcLunchDays() <small>días</small></div>
                </div>
            </div>
            <div class="ws-summary-item ws-summary-purple">
                <div class="ws-summary-icon"><span class="bi bi-sunrise"></span></div>
                <div>
                    <div class="ws-summary-label">Entrada prom.</div>
                    <div class="ws-summary-value">@CalcAvgEntry()</div>
                </div>
            </div>
            <div class="ws-summary-item ws-summary-amber">
                <div class="ws-summary-icon"><span class="bi bi-sunset"></span></div>
                <div>
                    <div class="ws-summary-label">Salida prom.</div>
                    <div class="ws-summary-value">@CalcAvgExit()</div>
                </div>
            </div>
        </div>

        @* ══ Datos generales ══ *@
        <div class="ns-section ns-blue">
            <div class="ns-section-header">
                <span class="bi bi-info-circle"></span> Datos generales del horario
            </div>
            <div class="ns-section-body">
                <div class="row g-3">
                    <div class="col-12 col-md-3">
                        <label class="ns-field-label">Código <span class="text-danger">*</span></label>
                        <input class="form-control ns-form-input" @bind="_form.Code" placeholder="HOR-001" />
                    </div>
                    <div class="col-12 col-md-5">
                        <label class="ns-field-label">Nombre del horario <span class="text-danger">*</span></label>
                        <input class="form-control ns-form-input" @bind="_form.Name" placeholder="Lunes a viernes 8 a 5" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="ns-field-label">Empresa</label>
                        @if (_singleCompanyMode)
                        {
                            <div class="ws-readonly-pill" title="El tenant tiene una sola empresa activa.">
                                <span class="bi bi-building"></span>
                                <span class="ws-readonly-text">@_autoCompanyName</span>
                                <span class="ws-readonly-tag">Auto</span>
                            </div>
                        }
                        else
                        {
                            <select class="form-select ns-form-input" @bind="_form.CompanyId">
                                <option value="">— Selecciona empresa —</option>
                                @foreach (var c in _companies)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="ns-field-label">Turno base (opcional)</label>
                        <select class="form-select ns-form-input" @bind="_form.WorkShiftId">
                            <option value="">— Sin turno base —</option>
                            @foreach (var s in _shifts)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                        <div class="ws-help"><span class="bi bi-info-circle"></span> Si el horario hereda de un turno, asocialo aquí.</div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="ns-field-label">Horario flexible</label>
                        <div class="form-check form-switch pt-1">
                            <input class="form-check-input" type="checkbox" id="chkFlex" @bind="_form.IsFlexible" />
                            <label class="form-check-label" for="chkFlex" style="font-size:13px;">
                                @(_form.IsFlexible ? "Sí, horario flexible" : "Horario fijo")
                            </label>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="ns-field-label">Estatus</label>
                        <div class="form-check form-switch pt-1">
                            <input class="form-check-input" type="checkbox" id="chkActive" @bind="_form.IsActive" />
                            <label class="form-check-label" for="chkActive" style="font-size:13px;">
                                @(_form.IsActive ? "Activo" : "Inactivo")
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ══ Vista previa semanal ══ *@
        <div class="ns-section ns-cyan">
            <div class="ns-section-header">
                <span class="bi bi-calendar2-week"></span> Vista previa semanal
                <span class="ws-help ms-auto" style="font-weight:400;">
                    <span class="bi bi-hand-index"></span> Haz clic en un día para activarlo / desactivarlo
                </span>
            </div>
            <div class="ns-section-body">
                <div class="ws-week-grid">
                    @foreach (var d in WeekDayList())
                    {
                        var on = GetDayActive(d.Index);
                        var entry = GetEntry(d.Index);
                        var exit = GetExit(d.Index);
                        var lunch1 = GetLunchStart(d.Index);
                        var lunch2 = GetLunchEnd(d.Index);
                        var hours = CalcDayHours(d.Index);
                        <div class="ws-day-card @(on ? "ws-day-on" : "ws-day-off") @(_dayTab == d.Index ? "ws-day-focused" : "")"
                             @onclick="() => _dayTab = d.Index">
                            <div class="ws-day-head">
                                <div>
                                    <div class="ws-day-title">@d.LongLabel</div>
                                    <div class="ws-day-sub">@(on ? "Laboral" : "Descanso")</div>
                                </div>
                                <label class="ws-switch" @onclick:stopPropagation="true">
                                    <input type="checkbox" checked="@on" @onchange="(e) => SetDayActive(d.Index, (bool?)e.Value ?? false)" />
                                    <span></span>
                                </label>
                            </div>
                            @if (on)
                            {
                                <div class="ws-day-times">
                                    <div class="ws-time-row">
                                        <span class="ws-tag ws-tag-blue"><span class="bi bi-box-arrow-in-right"></span> Entrada</span>
                                        <span class="ws-time-val">@FormatTimeOrDash(entry)</span>
                                    </div>
                                    <div class="ws-time-row">
                                        <span class="ws-tag ws-tag-slate"><span class="bi bi-cup-hot"></span> Comida</span>
                                        <span class="ws-time-val">@FormatTimeRangeOrDash(lunch1, lunch2)</span>
                                    </div>
                                    <div class="ws-time-row">
                                        <span class="ws-tag ws-tag-purple"><span class="bi bi-box-arrow-right"></span> Salida</span>
                                        <span class="ws-time-val">@FormatTimeOrDash(exit)</span>
                                    </div>
                                </div>
                                <div class="ws-day-foot">
                                    <span class="ws-tag ws-tag-green"><span class="bi bi-clock"></span> @hours.ToString("0.##") h</span>
                                </div>
                            }
                            else
                            {
                                <div class="ws-day-rest">
                                    <span class="bi bi-moon-stars" style="font-size:24px;color:#94a3b8;"></span>
                                    <div style="font-size:11px;color:#94a3b8;margin-top:4px;">Día de descanso</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ══ Días trabajados (acciones rápidas) ══ *@
        <div class="ns-section ns-green">
            <div class="ns-section-header">
                <span class="bi bi-calendar2-check"></span> Días trabajados
            </div>
            <div class="ns-section-body">
                <div class="d-flex flex-wrap gap-2 mb-2">
                    <button class="btn btn-outline-success btn-sm" @onclick="SetWeekdaysOnly">
                        <span class="bi bi-briefcase me-1"></span> Lunes a viernes
                    </button>
                    <button class="btn btn-outline-success btn-sm" @onclick="SetMondayToSaturday">
                        <span class="bi bi-calendar-week me-1"></span> Lunes a sábado
                    </button>
                    <button class="btn btn-outline-success btn-sm" @onclick="SetAllDays">
                        <span class="bi bi-calendar3 me-1"></span> Todos los días
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearAllDays">
                        <span class="bi bi-eraser me-1"></span> Ninguno
                    </button>
                    <button class="btn btn-outline-primary btn-sm" @onclick="CopyMondayToWeekdays" disabled="@(!GetDayActive(0))">
                        <span class="bi bi-clipboard-check me-1"></span> Copiar lunes a L-V
                    </button>
                    <button class="btn btn-outline-primary btn-sm" @onclick="CopyMondayToAllActive" disabled="@(!GetDayActive(0))">
                        <span class="bi bi-stack me-1"></span> Copiar lunes a todos
                    </button>
                </div>
                <div class="ws-help"><span class="bi bi-info-circle"></span> Las acciones rápidas marcan qué días son laborables. Captura los horarios específicos en la siguiente sección.</div>
            </div>
        </div>

        @* ══ Captura por día ══ *@
        <div class="ns-section ns-blue">
            <div class="ns-section-header">
                <span class="bi bi-keyboard"></span> Captura del día
            </div>
            <div class="ns-section-body">
                @* Tabs de días *@
                <ul class="nav ns-tab-nav mb-3">
                    @foreach (var d in WeekDayList())
                    {
                        var on = GetDayActive(d.Index);
                        <li class="nav-item">
                            <button class="nav-link @(_dayTab == d.Index ? "active" : "")"
                                    @onclick="() => _dayTab = d.Index">
                                <span class="bi @(on ? "bi-check-circle-fill text-success" : "bi-circle text-muted")"></span>
                                <span>@d.LongLabel</span>
                            </button>
                        </li>
                    }
                </ul>

                @{
                    var idx = _dayTab;
                    var dayOn = GetDayActive(idx);
                    var dayName = WeekDayList()[idx].LongLabel;
                }

                @if (!dayOn)
                {
                    <div class="ws-day-empty">
                        <span class="bi bi-moon-stars" style="font-size:36px;color:#94a3b8;"></span>
                        <div class="mt-2" style="font-size:14px;color:#475569;font-weight:600;">@dayName es día de descanso</div>
                        <div style="font-size:12px;color:#94a3b8;margin-bottom:10px;">Activa el día para capturar horarios.</div>
                        <button class="btn btn-success btn-sm px-3" @onclick="() => SetDayActive(idx, true)">
                            <span class="bi bi-toggle-on me-1"></span> Activar @dayName
                        </button>
                    </div>
                }
                else
                {
                    @* Jornada laboral *@
                    <div class="ws-subsection ws-sub-blue">
                        <div class="ws-subsection-title"><span class="bi bi-sunrise"></span> Jornada laboral — @dayName</div>
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <label class="ns-field-label">Hora de entrada</label>
                                <input type="time" class="form-control ns-form-input"
                                       value="@GetEntry(idx)"
                                       @onchange="(e) => SetEntry(idx, e.Value?.ToString())" />
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="ns-field-label">Hora de salida</label>
                                <input type="time" class="form-control ns-form-input"
                                       value="@GetExit(idx)"
                                       @onchange="(e) => SetExit(idx, e.Value?.ToString())" />
                            </div>
                            <div class="col-12 col-md-6 d-flex align-items-end">
                                <div class="ws-jornada-info">
                                    <span class="bi bi-clock"></span>
                                    <span><strong>@CalcDayHours(idx).ToString("0.##") h</strong> de trabajo efectivo</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Descansos *@
                    <div class="ws-subsection ws-sub-slate">
                        <div class="ws-subsection-title"><span class="bi bi-cup-hot"></span> Descanso / Comida</div>
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <label class="ns-field-label">Sale a comer</label>
                                <input type="time" class="form-control ns-form-input"
                                       value="@GetLunchStart(idx)"
                                       @onchange="(e) => SetLunchStart(idx, e.Value?.ToString())" />
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="ns-field-label">Regresa de comer</label>
                                <input type="time" class="form-control ns-form-input"
                                       value="@GetLunchEnd(idx)"
                                       @onchange="(e) => SetLunchEnd(idx, e.Value?.ToString())" />
                            </div>
                            <div class="col-12 col-md-6 d-flex align-items-end">
                                <div class="ws-jornada-info ws-jornada-slate">
                                    <span class="bi bi-cup-hot"></span>
                                    <span>Descanso: <strong>@FormatMinutesOrDash(CalcLunchMinutes(idx))</strong></span>
                                </div>
                            </div>
                        </div>
                        <div class="ws-help mt-2"><span class="bi bi-info-circle"></span> Si no aplica comida deja ambos campos vacíos.</div>
                    </div>

                    @* Tolerancias *@
                    <div class="ws-subsection ws-sub-amber">
                        <div class="ws-subsection-title"><span class="bi bi-shield-exclamation"></span> Tolerancia / Reglas de retardos</div>
                        <div class="row g-3">
                            <div class="col-6 col-md-4">
                                <label class="ns-field-label">Tolerancia (minutos)</label>
                                <input type="number" min="0" max="120" step="1"
                                       class="form-control ns-form-input"
                                       value="@GetTolerance(idx)"
                                       @onchange="(e) => SetTolerance(idx, e.Value?.ToString())" />
                            </div>
                            <div class="col-12 col-md-8 d-flex align-items-end">
                                <div class="ws-jornada-info ws-jornada-amber">
                                    <span class="bi bi-info-circle"></span>
                                    <span>
                                        Si llega después de
                                        <strong>@LateThreshold(idx)</strong>
                                        se considera retardo.
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            <button class="btn btn-outline-warning btn-sm" @onclick="() => SetTolerance(idx, 0)">Sin tolerancia</button>
                            <button class="btn btn-outline-warning btn-sm" @onclick="() => SetTolerance(idx, 5)">5 min</button>
                            <button class="btn btn-outline-warning btn-sm" @onclick="() => SetTolerance(idx, 10)">10 min</button>
                            <button class="btn btn-outline-warning btn-sm" @onclick="() => SetTolerance(idx, 15)">15 min</button>
                        </div>
                    </div>

                    @* Horas extra *@
                    <div class="ws-subsection ws-sub-purple">
                        <div class="ws-subsection-title"><span class="bi bi-lightning-charge"></span> Horas extra</div>
                        <div class="row g-3 align-items-center">
                            <div class="col-12">
                                <div class="ws-jornada-info ws-jornada-purple">
                                    <span class="bi bi-info-circle"></span>
                                    <span>
                                        Cualquier hora trabajada después de
                                        <strong>@FormatTimeOrDash(GetExit(idx))</strong>
                                        se contabiliza como hora extra en la pre-nómina.
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="ws-help mt-2">
                            <span class="bi bi-info-circle"></span>
                            Las reglas de hora extra simple/doble/triple se calculan en el cálculo de nómina según el día y el rango (ver catálogo HE1..HE5).
                        </div>
                    </div>

                    @* Acciones de copiado *@
                    <div class="ws-subsection ws-sub-cyan">
                        <div class="ws-subsection-title"><span class="bi bi-clipboard-check"></span> Acciones</div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => CopyDayToAllActive(idx)">
                                <span class="bi bi-files me-1"></span> Copiar este día a todos los días activos
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => ClearDay(idx)">
                                <span class="bi bi-eraser me-1"></span> Limpiar horarios de @dayName
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ══ Notas ══ *@
        <div class="ns-section ns-slate">
            <div class="ns-section-header">
                <span class="bi bi-journal-text"></span> Notas internas
            </div>
            <div class="ns-section-body">
                <textarea class="form-control ns-form-input" rows="3"
                          placeholder="Observaciones internas sobre el horario, excepciones, criterios..."
                          @bind="_form.Notes"></textarea>
            </div>
        </div>
    </div>
}

