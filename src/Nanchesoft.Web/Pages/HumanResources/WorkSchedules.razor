    // ─── Cálculos ───────────────────────────────────────────────────────────
    private static TimeSpan? ParseTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        var trimmed = value.Trim();

        // Limpiar AM/PM si vienen pegados (poco común pero defensivo)
        var upper = trimmed.ToUpperInvariant();
        bool isPm = false, isAm = false;
        if (upper.EndsWith("PM") || upper.EndsWith("P.M."))
        {
            isPm = true;
            trimmed = upper.Replace("P.M.", "").Replace("PM", "").Trim();
        }
        else if (upper.EndsWith("AM") || upper.EndsWith("A.M."))
        {
            isAm = true;
            trimmed = upper.Replace("A.M.", "").Replace("AM", "").Trim();
        }

        if (TimeSpan.TryParseExact(trimmed,
                new[] { @"hh\:mm", @"hh\:mm\:ss", @"h\:mm", @"h\:mm\:ss" },
                CultureInfo.InvariantCulture, out var ts))
        {
            if (isPm && ts.Hours < 12) ts = ts.Add(TimeSpan.FromHours(12));
            else if (isAm && ts.Hours == 12) ts = ts.Subtract(TimeSpan.FromHours(12));
            return ts;
        }
        if (TimeSpan.TryParse(trimmed, CultureInfo.InvariantCulture, out var ts2))
        {
            if (isPm && ts2.Hours < 12) ts2 = ts2.Add(TimeSpan.FromHours(12));
            else if (isAm && ts2.Hours == 12) ts2 = ts2.Subtract(TimeSpan.FromHours(12));
            return ts2;
        }
        return null;
    }

    // Normaliza cualquier formato de hora a "HH:mm" para inputs type=time.
    // Si no es parseable, retorna el original (no destruye datos no estándar).
    private static string NormalizeHHmm(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        var ts = ParseTime(value);
        if (ts is null) return value.Trim();
        return $"{(int)ts.Value.TotalHours:D2}:{ts.Value.Minutes:D2}";
    }

    private double CalcDayHours(int idx)
    {
        if (!GetDayActive(idx)) return 0;
        var entry = ParseTime(GetEntry(idx));
        var exit = ParseTime(GetExit(idx));
        if (entry is null || exit is null) return 0;
        var diff = exit.Value - entry.Value;
        if (diff.TotalMinutes <= 0) return 0;
        var lunch = CalcLunchMinutes(idx);
        var net = diff.TotalMinutes - lunch;
        return net > 0 ? Math.Round(net / 60.0, 2) : 0;
    }

    private double CalcLunchMinutes(int idx)
    {
        var s = ParseTime(GetLunchStart(idx));
        var e = ParseTime(GetLunchEnd(idx));
        if (s is null || e is null) return 0;
        var diff = (e.Value - s.Value).TotalMinutes;
        return diff > 0 ? diff : 0;
    }

    private double CalcWeeklyHours()
    {
        double total = 0;
        for (int i = 0; i <= 6; i++) total += CalcDayHours(i);
        return Math.Round(total, 2);
    }

    private int CalcActiveDays()
    {
        int n = 0;
        for (int i = 0; i <= 6; i++) if (GetDayActive(i)) n++;
        return n;
    }

    private int CalcLunchDays()
    {
        int n = 0;
        for (int i = 0; i <= 6; i++)
        {
            if (!GetDayActive(i)) continue;
            if (CalcLunchMinutes(i) > 0) n++;
        }
        return n;
    }

    private string CalcAvgEntry()
    {
        var values = new List<TimeSpan>();
        for (int i = 0; i <= 6; i++)
        {
            if (!GetDayActive(i)) continue;
            var t = ParseTime(GetEntry(i));
            if (t is not null) values.Add(t.Value);
        }
        if (values.Count == 0) return "—";
        var avg = TimeSpan.FromMinutes(values.Average(x => x.TotalMinutes));
        return $"{(int)avg.TotalHours:D2}:{avg.Minutes:D2}";
    }

    private string CalcAvgExit()
    {
        var values = new List<TimeSpan>();
        for (int i = 0; i <= 6; i++)
        {
            if (!GetDayActive(i)) continue;
            var t = ParseTime(GetExit(i));
            if (t is not null) values.Add(t.Value);
        }
        if (values.Count == 0) return "—";
        var avg = TimeSpan.FromMinutes(values.Average(x => x.TotalMinutes));
        return $"{(int)avg.TotalHours:D2}:{avg.Minutes:D2}";
    }

    private List<string> ValidateSchedule()
    {
        var issues = new List<string>();
        if (_form is null) return issues;

        // 1) Debe haber al menos un día activo
        if (CalcActiveDays() == 0)
        {
            issues.Add("Debes activar al menos un día laboral.");
            return issues;
        }

        for (int i = 0; i <= 6; i++)
        {
            if (!GetDayActive(i)) continue;
            var dayName = _weekdays[i].LongLabel;

            var entry = ParseTime(GetEntry(i));
            var exit = ParseTime(GetExit(i));

            if (entry is null || exit is null)
            {
                issues.Add($"{dayName}: captura entrada y salida.");
                continue;
            }

            if (exit.Value <= entry.Value)
            {
                issues.Add($"{dayName}: la hora de salida debe ser mayor a la de entrada.");
                continue;
            }

            var turnMinutes = (exit.Value - entry.Value).TotalMinutes;

            var lunchStart = ParseTime(GetLunchStart(i));
            var lunchEnd = ParseTime(GetLunchEnd(i));

            if (lunchStart is not null && lunchEnd is null)
            {
                issues.Add($"{dayName}: capturaste salida a comer pero falta el regreso.");
                continue;
            }
            if (lunchStart is null && lunchEnd is not null)
            {
                issues.Add($"{dayName}: capturaste regreso de comer pero falta la salida.");
                continue;
            }
            if (lunchStart is not null && lunchEnd is not null)
            {
                if (lunchEnd.Value <= lunchStart.Value)
                {
                    issues.Add($"{dayName}: el regreso de comer debe ser después de la salida a comer.");
                    continue;
                }
                if (lunchStart.Value < entry.Value || lunchEnd.Value > exit.Value)
                {
                    issues.Add($"{dayName}: el horario de comida debe estar dentro de la jornada.");
                    continue;
                }
                var lunchMinutes = (lunchEnd.Value - lunchStart.Value).TotalMinutes;
                if (lunchMinutes >= turnMinutes)
                {
                    issues.Add($"{dayName}: el descanso de comida no puede ser mayor o igual a la jornada.");
                    continue;
                }
                if (turnMinutes - lunchMinutes <= 0)
                {
                    issues.Add($"{dayName}: las horas efectivas no pueden ser negativas o cero.");
                    continue;
                }
            }

            var tolerance = GetTolerance(i);
            if (tolerance < 0 || tolerance > 120)
            {
                issues.Add($"{dayName}: la tolerancia debe estar entre 0 y 120 minutos.");
            }
        }

        return issues;
    }

    private List<string> LiveWarnings()
    {
        // Versión "no bloqueante" para mostrar en el editor mientras captura.
        return ValidateSchedule();
    }

    private string LateThreshold(int idx)
    {
        var entry = ParseTime(GetEntry(idx));
        if (entry is null) return "—";
        var t = entry.Value + TimeSpan.FromMinutes(GetTolerance(idx));
        return $"{(int)t.TotalHours:D2}:{t.Minutes:D2}";
    }

    private static string FormatTimeOrDash(string? value)
    {
        var t = ParseTime(value);
        if (t is null) return "—";
        return $"{(int)t.Value.TotalHours:D2}:{t.Value.Minutes:D2}";
    }

    private static string FormatTimeRangeOrDash(string? a, string? b)
    {
        var ta = FormatTimeOrDash(a);
        var tb = FormatTimeOrDash(b);
        if (ta == "—" && tb == "—") return "—";
        return $"{ta} — {tb}";
    }

    private static string FormatMinutesOrDash(double minutes)
    {
        if (minutes <= 0) return "—";
        if (minutes >= 60)
        {
            var h = (int)(minutes / 60);
            var m = (int)(minutes % 60);
            return m == 0 ? $"{h} h" : $"{h} h {m} min";
        }
        return $"{(int)minutes} min";
    }

