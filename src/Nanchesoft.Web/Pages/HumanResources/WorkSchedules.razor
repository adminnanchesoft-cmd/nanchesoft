@code {
    private enum Mode { List, Edit }
    private Mode _mode = Mode.List;

    private List<WorkScheduleDto> _schedules = new();
    private List<LookupItem> _companies = new();
    private List<LookupItem> _shifts = new();

    private bool _loading;
    private bool _saving;
    private string _error = string.Empty;
    private string _success = string.Empty;

    private string _search = string.Empty;
    private string _filter = "all";

    private WorkScheduleForm? _form;
    private bool _isNew;
    private int _dayTab;

    // Auto-selección de empresa cuando el tenant tiene una sola
    private bool _singleCompanyMode;
    private string? _autoCompanyId;
    private string _autoCompanyName = string.Empty;

    private HttpClient Client => HttpClientFactory.CreateClient("Nanchesoft.Api");

    protected override async Task OnInitializedAsync()
    {
        await LoadListAsync();
        await LoadLookupsAsync();
    }

    private async Task LoadListAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            var rows = await Client.GetFromJsonAsync<List<WorkScheduleDto>>("/api/hr/work-schedules") ?? new();
            _schedules = rows.OrderBy(x => x.Code).ToList();
        }
        catch (Exception ex)
        {
            _error = $"No se pudieron cargar los horarios: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            var companies = await Client.GetFromJsonAsync<List<CompanyLookup>>("/api/organization/companies") ?? new();
            var tenantId = AppState.CurrentTenantId ?? AuthState.TenantId;
            var filtered = companies.Where(x => x.IsActive);
            if (tenantId.HasValue)
                filtered = filtered.Where(x => x.TenantId == tenantId.Value);
            _companies = filtered.OrderBy(x => x.Name)
                .Select(x => new LookupItem { Id = x.CompanyId.ToString("D"), Name = x.Name }).ToList();

            // Si el tenant tiene UNA sola empresa activa, auto-seleccionarla.
            if (_companies.Count == 1)
            {
                _singleCompanyMode = true;
                _autoCompanyId = _companies[0].Id;
                _autoCompanyName = _companies[0].Name;
            }
            else
            {
                _singleCompanyMode = false;
                // Si el contexto ya tiene una empresa seleccionada, úsala como sugerencia inicial.
                var ctxCompany = (AppState.CurrentCompanyId ?? AuthState.CompanyId)?.ToString("D");
                if (!string.IsNullOrEmpty(ctxCompany) && _companies.Any(c => string.Equals(c.Id, ctxCompany, StringComparison.OrdinalIgnoreCase)))
                {
                    _autoCompanyId = ctxCompany;
                    _autoCompanyName = _companies.First(c => string.Equals(c.Id, ctxCompany, StringComparison.OrdinalIgnoreCase)).Name;
                }
            }
        }
        catch { _companies = new(); }

        try
        {
            var shifts = await Client.GetFromJsonAsync<List<WorkShiftLookup>>("/api/hr/shifts") ?? new();
            _shifts = shifts.Where(x => x.IsActive).OrderBy(x => x.Name)
                .Select(x => new LookupItem { Id = x.WorkShiftId.ToString("D"), Name = string.IsNullOrWhiteSpace(x.Code) ? x.Name : $"{x.Code} · {x.Name}" }).ToList();
        }
        catch { _shifts = new(); }
    }

    private List<WorkScheduleDto> FilteredSchedules()
    {
        var q = (_search ?? string.Empty).Trim();
        IEnumerable<WorkScheduleDto> result = _schedules;

        result = _filter switch
        {
            "active" => result.Where(x => x.IsActive),
            "inactive" => result.Where(x => !x.IsActive),
            "flexible" => result.Where(x => x.IsFlexible),
            _ => result
        };

        if (!string.IsNullOrEmpty(q))
        {
            result = result.Where(x =>
                (x.Code ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (x.Name ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (x.Notes ?? "").Contains(q, StringComparison.OrdinalIgnoreCase));
        }

        return result.ToList();
    }

    private void OpenNew()
    {
        _isNew = true;
        _form = new WorkScheduleForm
        {
            IsActive = true,
            CompanyId = _autoCompanyId,
            Monday = true, Tuesday = true, Wednesday = true, Thursday = true, Friday = true,
            MonEntryTime = "08:00", MonExitTime = "17:00", MonLunchStartTime = "13:00", MonLunchEndTime = "14:00", MonToleranceMinutes = 10,
            TueEntryTime = "08:00", TueExitTime = "17:00", TueLunchStartTime = "13:00", TueLunchEndTime = "14:00", TueToleranceMinutes = 10,
            WedEntryTime = "08:00", WedExitTime = "17:00", WedLunchStartTime = "13:00", WedLunchEndTime = "14:00", WedToleranceMinutes = 10,
            ThuEntryTime = "08:00", ThuExitTime = "17:00", ThuLunchStartTime = "13:00", ThuLunchEndTime = "14:00", ThuToleranceMinutes = 10,
            FriEntryTime = "08:00", FriExitTime = "17:00", FriLunchStartTime = "13:00", FriLunchEndTime = "14:00", FriToleranceMinutes = 10,
        };
        _dayTab = 0;
        _mode = Mode.Edit;
        _error = string.Empty;
        _success = string.Empty;
    }

    private void OpenEdit(WorkScheduleDto s)
    {
        _isNew = false;
        _form = WorkScheduleForm.FromDto(s);
        // Si el horario no tiene empresa pero el tenant tiene una única, asígnala automáticamente.
        if (string.IsNullOrWhiteSpace(_form.CompanyId) && !string.IsNullOrEmpty(_autoCompanyId))
            _form.CompanyId = _autoCompanyId;
        _dayTab = 0;
        _mode = Mode.Edit;
        _error = string.Empty;
        _success = string.Empty;
    }

    private void CancelEdit()
    {
        _mode = Mode.List;
        _form = null;
        _error = string.Empty;
        _success = string.Empty;
    }

    private async Task SaveAsync()
    {
        if (_form is null) return;

        // Validaciones de campos básicos
        if (string.IsNullOrWhiteSpace(_form.Code))
        {
            _error = "El código del horario es obligatorio.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _error = "El nombre del horario es obligatorio.";
            return;
        }

        // Si el tenant tiene una sola empresa, garantizar que viaje en el payload.
        if (string.IsNullOrWhiteSpace(_form.CompanyId) && !string.IsNullOrEmpty(_autoCompanyId))
            _form.CompanyId = _autoCompanyId;

        // Validaciones de jornada
        var issues = ValidateSchedule();
        if (issues.Count > 0)
        {
            _error = "Revisa la captura del horario:\n• " + string.Join("\n• ", issues);
            return;
        }

        _saving = true;
        _error = string.Empty;
        try
        {
            _form.WeeklyHours = (decimal)Math.Round(CalcWeeklyHours(), 2);
            var payload = _form.ToRequest();
            HttpResponseMessage response;
            if (_isNew)
                response = await Client.PostAsJsonAsync("/api/hr/work-schedules", payload);
            else
                response = await Client.PutAsJsonAsync($"/api/hr/work-schedules/{_form.WorkScheduleId:D}", payload);

            if (!response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync();
                _error = $"Error al guardar: {msg}";
                return;
            }

            _success = _isNew ? "Horario creado correctamente." : "Horario actualizado correctamente.";
            await LoadListAsync();
            _mode = Mode.List;
            _form = null;
        }
        catch (Exception ex)
        {
            _error = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync(WorkScheduleDto s)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar el horario '{s.Name}'?");
        if (!confirmed) return;

        try
        {
            var response = await Client.DeleteAsync($"/api/hr/work-schedules/{s.WorkScheduleId:D}");
            if (!response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync();
                _error = $"No se pudo eliminar: {msg}";
                return;
            }
            await LoadListAsync();
        }
        catch (Exception ex)
        {
            _error = $"Error al eliminar: {ex.Message}";
        }
    }

