    private sealed record CompanyItem(Guid CompanyId, string Name, bool IsActive);
    private sealed record BranchItem(Guid BranchId, string Name, bool IsActive);
    private sealed record DeptItem(Guid DepartmentId, Guid? CompanyId, string Name, bool IsActive);
    private sealed record PosItem(Guid PositionId, Guid? CompanyId, string Name, bool IsActive);
    private sealed record SchedItem(Guid WorkScheduleId, string Name, bool IsActive);
    private sealed record BankItem(Guid BankId, string Code, string ShortName, string Name, bool IsActive);
    private sealed record IdResult(Guid? Id);

    private sealed class NewDeptForm { public string Code { get; set; } = string.Empty; public string Name { get; set; } = string.Empty; }
    private sealed class NewPosForm { public string Code { get; set; } = string.Empty; public string Name { get; set; } = string.Empty; public Guid? DepartmentId { get; set; } }
