@page "/human-resources/clock-import"
@using Nanchesoft.Web.Services.HumanResources
@inject PayrollOperationsApiService Svc
@inject IJSRuntime JS

<PageTitle>Importar CSV reloj checador | Nanchesoft</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Importar CSV del reloj checador</h4>
</div>

<div class="text-muted small mb-3">
    Sube el archivo CSV exportado por tu reloj checador. El sistema detecta las columnas automáticamente
    para los formatos estándar. Usa <strong>Vista previa</strong> antes de confirmar la importación.
</div>

@if (!string.IsNullOrWhiteSpace(_msg))
{
    <div class="alert @(_msgOk ? "alert-success" : "alert-danger") alert-dismissible py-2 mb-3">
        @_msg
        <button type="button" class="btn-close btn-sm" @onclick="() => _msg = null"></button>
    </div>
}

<!-- Paso 1: subir archivo -->
<div class="card shadow-sm mb-3">
    <div class="card-header py-2 fw-semibold">
        <span class="badge bg-primary me-2">1</span>Seleccionar archivo CSV
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label form-label-sm mb-1">Archivo CSV del checador</label>
                <InputFile OnChange="OnFileSelected" accept=".csv,.txt,.xls,.xlsx"
                           class="form-control form-control-sm" />
                @if (_file != null)
                {
                    <div class="text-muted small mt-1">
                        @_file.Name — @FormatSize(_file.Size)
                    </div>
                }
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary btn-sm" @onclick="PreviewAsync"
                        disabled="@(_file == null || _previewing)">
                    @if (_previewing)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Vista previa
                </button>
            </div>
        </div>

        <div class="mt-3 text-muted small">
            <strong>Formatos soportados:</strong>
            <ul class="mb-0 mt-1">
                <li><code>NoEmpleado, FechaHora, Tipo</code> — registro por marcación</li>
                <li><code>NoEmpleado, Fecha, HoraEntrada, HoraSalida</code> — resumen diario</li>
            </ul>
        </div>
    </div>
</div>

<!-- Paso 2: vista previa -->
@if (_preview != null)
{
    var okRows    = _preview.Count(r => r.Status == "ok");
    var skipRows  = _preview.Count(r => r.Status == "skip");
    var errorRows = _preview.Count(r => r.Status == "error");

    <div class="card shadow-sm mb-3">
        <div class="card-header py-2 d-flex justify-content-between align-items-center">
            <span><span class="badge bg-primary me-2">2</span>Vista previa</span>
            <div class="d-flex gap-2">
                <span class="badge bg-success">@okRows OK</span>
                <span class="badge bg-warning text-dark">@skipRows omitidos</span>
                <span class="badge bg-danger">@errorRows errores</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div style="overflow-x:auto;max-height:400px;overflow-y:auto">
                <table class="table table-sm table-hover mb-0" style="min-width:750px">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th style="width:60px">#</th>
                            <th>No. empleado</th>
                            <th>Colaborador</th>
                            <th>Fecha</th>
                            <th>Entrada</th>
                            <th>Salida</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Mensaje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _preview)
                        {
                            var rowClass = r.Status switch
                            {
                                "ok"    => "",
                                "skip"  => "table-warning",
                                "error" => "table-danger",
                                _       => ""
                            };
                            <tr class="@rowClass">
                                <td class="text-muted small">@r.RowNumber</td>
                                <td><code class="small">@r.EmployeeNumber</code></td>
                                <td>@r.EmployeeName</td>
                                <td class="text-nowrap">@(r.PunchDate.HasValue ? r.PunchDate.Value.ToString("dd/MM/yyyy") : "—")</td>
                                <td>@(r.EntryTime.HasValue ? r.EntryTime.Value.ToString(@"hh\:mm") : "—")</td>
                                <td>@(r.ExitTime.HasValue  ? r.ExitTime.Value.ToString(@"hh\:mm")  : "—")</td>
                                <td>
                                    @if (r.PunchType == "entry")      { <span class="badge bg-success">Entrada</span> }
                                    else if (r.PunchType == "exit")   { <span class="badge bg-secondary">Salida</span> }
                                    else if (r.PunchType == "both")   { <span class="badge bg-info text-dark">E+S</span> }
                                    else if (!string.IsNullOrEmpty(r.PunchType)) { <span class="badge bg-light text-dark">@r.PunchType</span> }
                                </td>
                                <td>
                                    @if (r.Status == "ok")    { <span class="badge bg-success">OK</span> }
                                    else if (r.Status == "skip")  { <span class="badge bg-warning text-dark">Omitir</span> }
                                    else if (r.Status == "error") { <span class="badge bg-danger">Error</span> }
                                </td>
                                <td class="small text-muted">@r.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (okRows > 0)
        {
            <div class="card-footer py-2 text-end">
                <button class="btn btn-primary btn-sm" @onclick="ImportAsync" disabled="@_importing">
                    @if (_importing)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span><span>Importando...</span>
                    }
                    else
                    {
                        <span>Confirmar importación (@okRows registros)</span>
                    }
                </button>
            </div>
        }
    </div>
}

<!-- Paso 3: resultado -->
@if (_result != null)
{
    <div class="card shadow-sm border-success mb-3">
        <div class="card-header py-2 bg-success text-white fw-semibold">
            <span class="badge bg-white text-success me-2">3</span>Resultado de la importación
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="card text-center py-2 border-success">
                        <div class="fs-4 fw-bold text-success">@_result.Value.Created</div>
                        <div class="text-muted small">Marcaciones creadas</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card text-center py-2 border-warning">
                        <div class="fs-4 fw-bold text-warning">@_result.Value.Skipped</div>
                        <div class="text-muted small">Duplicadas / omitidas</div>
                    </div>
                </div>
                @if (_result.Value.Errors.Count > 0)
                {
                    <div class="col-12">
                        <div class="alert alert-warning py-2 mb-0">
                            <strong>@_result.Value.Errors.Count error(es):</strong>
                            <ul class="mb-0 mt-1 small">
                                @foreach (var e in _result.Value.Errors.Take(10))
                                {
                                    <li>@e</li>
                                }
                                @if (_result.Value.Errors.Count > 10)
                                {
                                    <li>... y @(_result.Value.Errors.Count - 10) más.</li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-3">
                <button class="btn btn-outline-primary btn-sm" @onclick="Reset">Nueva importación</button>
                <a href="/human-resources/attendance-processing" class="btn btn-primary btn-sm ms-2">
                    Procesar asistencia →
                </a>
            </div>
        </div>
    </div>
}

@code {
    IBrowserFile? _file;
    bool _previewing;
    bool _importing;
    string? _msg;
    bool _msgOk;
    List<PunchPreviewRow>? _preview;
    (int Created, int Skipped, List<string> Errors)? _result;

    void OnFileSelected(InputFileChangeEventArgs e)
    {
        _file = e.File;
        _preview = null;
        _result = null;
        _msg = null;
    }

    async Task PreviewAsync()
    {
        if (_file == null) return;
        _previewing = true; _msg = null; _preview = null; StateHasChanged();
        try
        {
            await using var stream = _file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _preview = await Svc.PreviewClockCsvAsync(stream, _file.Name);
            if (_preview.Count == 0)
            {
                _msg = "El archivo no contiene filas válidas o el formato no es reconocido.";
                _msgOk = false;
            }
        }
        catch (Exception ex) { _msg = ex.Message; _msgOk = false; }
        finally { _previewing = false; }
    }

    async Task ImportAsync()
    {
        if (_file == null) return;
        _importing = true; _msg = null; StateHasChanged();
        try
        {
            await using var stream = _file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var (created, skipped, errors) = await Svc.ImportClockCsvAsync(stream, _file.Name);
            _result = (created, skipped, errors);
            _msgOk = true;
            _msg = $"Importación completada: {created} marcaciones creadas, {skipped} omitidas.";
        }
        catch (Exception ex) { _msg = ex.Message; _msgOk = false; }
        finally { _importing = false; }
    }

    void Reset()
    {
        _file = null; _preview = null; _result = null; _msg = null;
    }

    static string FormatSize(long bytes) => bytes switch
    {
        >= 1_048_576 => $"{bytes / 1_048_576.0:N1} MB",
        >= 1_024     => $"{bytes / 1_024.0:N1} KB",
        _            => $"{bytes} B"
    };
}
