@page "/purchases/material-payments/{Id:guid}/preview"
@using Nanchesoft.Web.Services.Purchases
@inject MaterialPurchaseApiService Api
@inject NavigationManager Nav

<PageTitle>Pago @(_doc?.Folio ?? "") | Nanchesoft</PageTitle>

<div class="ns-doc-preview">
    @if (_loading)
    {
        <div class="ns-loader-center"><div class="ns-spinner"></div></div>
    }
    else if (_doc is null)
    {
        <div class="ns-alert ns-alert--danger">No se encontró el comprobante de pago.</div>
    }
    else
    {
        <div class="ns-doc-preview__toolbar ns-no-print">
            <button class="ns-btn ns-btn--ghost" @onclick="Back">
                <i class="bi bi-arrow-left"></i> Regresar
            </button>
            <button class="ns-btn ns-btn--secondary" @onclick="Print">
                <i class="bi bi-printer"></i> Imprimir
            </button>
            <button class="ns-btn ns-btn--ghost" @onclick='() => Nav.NavigateTo("/purchases/material-receipts")'>
                <i class="bi bi-list-ul"></i> Recepciones
            </button>
        </div>

        <div class="ns-doc-paper">
            @* Header *@
            <div class="ns-doc-paper__header">
                <div class="ns-doc-paper__company">
                    <div class="ns-doc-paper__company-name">@(string.IsNullOrWhiteSpace(_doc.CompanyName) ? "Nanchesoft ERP" : _doc.CompanyName)</div>
                    @if (!string.IsNullOrWhiteSpace(_doc.CompanyRfc))
                    { <div class="ns-doc-paper__company-rfc">RFC: @_doc.CompanyRfc</div> }
                </div>
                <div class="ns-doc-paper__title-block">
                    <div class="ns-doc-paper__doc-type">Comprobante de Pago a Proveedor</div>
                    <div class="ns-doc-paper__folio">@_doc.Folio</div>
                </div>
            </div>

            @* Amount big *@
            <div style="text-align:center;margin:16px 0 8px">
                <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:#9ca3af;letter-spacing:.4px">Monto pagado</div>
                <div class="ns-doc-paper__amount-big">@_doc.Amount.ToString("C")</div>
                <div style="font-size:13px;color:#6b7280">@PayMethodLabel(_doc.PaymentMethod)</div>
            </div>

            @* Meta *@
            <div class="ns-doc-paper__meta">
                <div class="ns-doc-paper__meta-block">
                    <div class="ns-doc-paper__meta-label">Proveedor</div>
                    <div class="ns-doc-paper__meta-value">@_doc.SupplierName</div>
                    @if (!string.IsNullOrWhiteSpace(_doc.SupplierRfc))
                    { <div style="font-size:11px;color:#6b7280">RFC: @_doc.SupplierRfc</div> }
                </div>
                <div class="ns-doc-paper__meta-block">
                    <div class="ns-doc-paper__meta-label">Fecha de pago</div>
                    <div class="ns-doc-paper__meta-value">@_doc.PaymentDate.ToString("dd/MM/yyyy")</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(_doc.BankAccount))
                {
                    <div class="ns-doc-paper__meta-block">
                        <div class="ns-doc-paper__meta-label">Cuenta bancaria</div>
                        <div class="ns-doc-paper__meta-value" style="font-family:monospace">@_doc.BankAccount</div>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_doc.Reference))
                {
                    <div class="ns-doc-paper__meta-block">
                        <div class="ns-doc-paper__meta-label">Referencia / Número de operación</div>
                        <div class="ns-doc-paper__meta-value" style="font-family:monospace">@_doc.Reference</div>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_doc.ReceiptFolio))
                {
                    <div class="ns-doc-paper__meta-block">
                        <div class="ns-doc-paper__meta-label">Recepción de materiales</div>
                        <div class="ns-doc-paper__meta-value">@_doc.ReceiptFolio</div>
                        @if (_doc.ReceiptDate.HasValue)
                        { <div style="font-size:11px;color:#6b7280">@_doc.ReceiptDate.Value.ToString("dd/MM/yyyy") · Total: @_doc.ReceiptTotal.ToString("C")</div> }
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_doc.Notes))
            { <div class="ns-doc-paper__notes"><strong>Notas:</strong> @_doc.Notes</div> }

            @* Status ribbon *@
            <div style="margin-top:20px;text-align:center;padding:10px;background:#f0fdf4;border-radius:4px;border:1px solid #bbf7d0">
                <i class="bi bi-check-circle-fill" style="color:#16a34a"></i>
                <span style="font-weight:600;color:#166534;margin-left:6px">Pago registrado</span>
            </div>

            <div class="ns-doc-paper__signatures" style="grid-template-columns: 1fr 1fr">
                <div class="ns-doc-paper__sig-line">Elaboró</div>
                <div class="ns-doc-paper__sig-line">Autorizó</div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private MatPaymentPreview? _doc;
    private bool _loading = true;
    private Guid _receiptId;

    protected override async Task OnInitializedAsync()
    {
        try { _doc = await Api.GetPaymentPreviewAsync(Id); }
        finally { _loading = false; }
    }

    private void Back()
    {
        if (_doc is not null && !string.IsNullOrWhiteSpace(_doc.ReceiptFolio))
            Nav.NavigateTo("/purchases/material-receipts");
        else
            Nav.NavigateTo("/purchases/material-receipts");
    }

    private async Task Print() => await JS.InvokeVoidAsync("window.print");

    private static string PayMethodLabel(string m) => m switch
    {
        "transfer" => "Transferencia bancaria", "cash" => "Efectivo", "check" => "Cheque",
        "card" => "Tarjeta", _ => m
    };
}
