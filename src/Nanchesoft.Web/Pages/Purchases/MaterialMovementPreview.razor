@page "/purchases/inventory-movements/{Id:guid}/preview"
@using Nanchesoft.Web.Services.Purchases
@inject MaterialPurchaseApiService Api
@inject NavigationManager Nav

<PageTitle>Movimiento @(_doc?.DocumentFolio ?? "") | Nanchesoft</PageTitle>

<div class="ns-doc-preview">
    @if (_loading)
    {
        <div class="ns-loader-center"><div class="ns-spinner"></div></div>
    }
    else if (_doc is null)
    {
        <div class="ns-alert ns-alert--danger">No se encontró el movimiento de inventario.</div>
    }
    else
    {
        <div class="ns-doc-preview__toolbar ns-no-print">
            <button class="ns-btn ns-btn--ghost" @onclick='() => Nav.NavigateTo("/purchases/material-kardex")'>
                <i class="bi bi-arrow-left"></i> Kardex
            </button>
            <button class="ns-btn ns-btn--secondary" @onclick="Print">
                <i class="bi bi-printer"></i> Imprimir
            </button>
        </div>

        <div class="ns-doc-paper">
            @* Header *@
            <div class="ns-doc-paper__header">
                <div class="ns-doc-paper__company">
                    <div class="ns-doc-paper__company-name">@(string.IsNullOrWhiteSpace(_doc.CompanyName) ? "Nanchesoft ERP" : _doc.CompanyName)</div>
                    @if (!string.IsNullOrWhiteSpace(_doc.CompanyRfc))
                    { <div class="ns-doc-paper__company-rfc">RFC: @_doc.CompanyRfc</div> }
                </div>
                <div class="ns-doc-paper__title-block">
                    <div class="ns-doc-paper__doc-type">Movimiento de Inventario</div>
                    <div class="ns-doc-paper__folio">@_doc.DocumentFolio</div>
                </div>
            </div>

            @* Movement type badge *@
            <div style="margin-bottom:20px">
                <span class="ns-doc-paper__mov-badge ns-doc-paper__mov-badge--@MovBadgeClass(_doc.MovementType)">
                    @MovTypeLabel(_doc.MovementType)
                </span>
                <span style="font-size:12px;color:#6b7280;margin-left:10px">@DocTypeLabel(_doc.DocumentType)</span>
            </div>

            @* Meta *@
            <div class="ns-doc-paper__meta">
                <div class="ns-doc-paper__meta-block">
                    <div class="ns-doc-paper__meta-label">Material</div>
                    <div class="ns-doc-paper__meta-value">@_doc.MaterialName</div>
                    @if (!string.IsNullOrWhiteSpace(_doc.MaterialCode))
                    { <div style="font-family:monospace;font-size:11px;color:#6b7280">@_doc.MaterialCode</div> }
                </div>
                <div class="ns-doc-paper__meta-block">
                    <div class="ns-doc-paper__meta-label">Fecha</div>
                    <div class="ns-doc-paper__meta-value">@_doc.MovementDate.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="ns-doc-paper__meta-block">
                    <div class="ns-doc-paper__meta-label">Almacén</div>
                    <div class="ns-doc-paper__meta-value">@(string.IsNullOrWhiteSpace(_doc.WarehouseName) ? "—" : _doc.WarehouseName)</div>
                </div>
                <div class="ns-doc-paper__meta-block">
                    <div class="ns-doc-paper__meta-label">Documento origen</div>
                    <div class="ns-doc-paper__meta-value" style="font-family:monospace">@(string.IsNullOrWhiteSpace(_doc.DocumentFolio) ? "—" : _doc.DocumentFolio)</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(_doc.SupplierName))
                {
                    <div class="ns-doc-paper__meta-block">
                        <div class="ns-doc-paper__meta-label">Proveedor</div>
                        <div class="ns-doc-paper__meta-value">@_doc.SupplierName</div>
                    </div>
                }
                <div class="ns-doc-paper__meta-block">
                    <div class="ns-doc-paper__meta-label">Usuario</div>
                    <div class="ns-doc-paper__meta-value">@(string.IsNullOrWhiteSpace(_doc.UserName) ? "Sistema" : _doc.UserName)</div>
                </div>
            </div>

            @* Quantities table *@
            <div class="ns-doc-paper__section-title">Detalle del movimiento</div>
            <table class="ns-doc-paper__table">
                <thead>
                    <tr>
                        <th>Concepto</th>
                        <th class="text-right" style="width:120px">Cantidad</th>
                        <th class="text-right" style="width:120px">Costo unit.</th>
                        <th class="text-right" style="width:130px">Costo total</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_doc.QuantityIn > 0)
                    {
                        <tr>
                            <td style="color:#15803d;font-weight:600">Entrada</td>
                            <td class="text-right" style="color:#15803d;font-weight:700">+@_doc.QuantityIn.ToString("N4")</td>
                            <td class="text-right">@_doc.UnitCost.ToString("N4")</td>
                            <td class="text-right fw-semibold">@_doc.TotalCost.ToString("N2")</td>
                        </tr>
                    }
                    @if (_doc.QuantityOut > 0)
                    {
                        <tr>
                            <td style="color:#b91c1c;font-weight:600">Salida</td>
                            <td class="text-right" style="color:#b91c1c;font-weight:700">-@_doc.QuantityOut.ToString("N4")</td>
                            <td class="text-right">@_doc.UnitCost.ToString("N4")</td>
                            <td class="text-right fw-semibold">@_doc.TotalCost.ToString("N2")</td>
                        </tr>
                    }
                    <tr style="background:#f3f6fb">
                        <td style="font-weight:700">Saldo resultante</td>
                        <td class="text-right fw-bold" style="font-size:15px">@_doc.BalanceAfter.ToString("N4")</td>
                        <td></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>

            @if (!string.IsNullOrWhiteSpace(_doc.Notes))
            { <div class="ns-doc-paper__notes"><strong>Notas:</strong> @_doc.Notes</div> }

            <div class="ns-doc-paper__signatures" style="grid-template-columns: 1fr 1fr">
                <div class="ns-doc-paper__sig-line">Elaboró</div>
                <div class="ns-doc-paper__sig-line">Almacenista</div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private MatMovementPreview? _doc;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { _doc = await Api.GetMovementPreviewAsync(Id); }
        finally { _loading = false; }
    }

    private async Task Print() => await JS.InvokeVoidAsync("window.print");

    private static string MovBadgeClass(string t) => t switch
    {
        "entry" => "entry", "exit" => "exit", _ => "adj"
    };
    private static string MovTypeLabel(string t) => t switch
    {
        "entry" => "Entrada", "exit" => "Salida", "adjustment" => "Ajuste",
        "return" => "Devolución", _ => t
    };
    private static string DocTypeLabel(string t) => t switch
    {
        "review_receipt" => "Recepción revisión", "purchase_invoice" => "Compra factura",
        "return" => "Devolución", "adjustment" => "Ajuste manual", _ => t
    };
}
