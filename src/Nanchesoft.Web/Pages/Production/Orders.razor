@page "/produccion/ordenes"
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Órdenes de producción | Nanchesoft</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase small text-secondary fw-semibold">Producción · Órdenes</div>
            <h2 class="mb-1">Órdenes de producción</h2>
            <div class="text-secondary">Ciclo de vida completo: crear, confirmar, explotar, iniciar, completar y cerrar.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (_companies.Count > 1)
            {
                <select class="form-select form-select-sm" style="width:200px;" @onchange="OnCompanyChanged">
                    @foreach (var c in _companies)
                    {
                        <option value="@c.CompanyId" selected="@(c.CompanyId == _selectedCompanyId)">@c.Name</option>
                    }
                </select>
            }
            <select class="form-select form-select-sm" style="width:150px;" @bind="_statusFilter" @bind:after="LoadOrdersAsync">
                <option value="">Todos los estados</option>
                <option value="draft">Borrador</option>
                <option value="planned">Planeada</option>
                <option value="exploded">Explosionada</option>
                <option value="reserved">Reservada</option>
                <option value="in_progress">En proceso</option>
                <option value="completed">Completada</option>
                <option value="closed">Cerrada</option>
                <option value="cancelled">Cancelada</option>
            </select>
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadOrdersAsync">Actualizar</button>
            <a class="btn btn-primary btn-sm" href="/produccion/dashboard">Dashboard</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success alert-dismissible">@_message <button type="button" class="btn-close" @onclick='() => _message = string.Empty'></button></div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger alert-dismissible">@_error <button type="button" class="btn-close" @onclick='() => _error = string.Empty'></button></div>
    }

    @if (_loading)
    {
        <div class="alert alert-info">Cargando órdenes...</div>
    }
    else if (_orders.Count == 0)
    {
        <div class="card shadow-sm"><div class="card-body text-center text-secondary py-5">Sin órdenes registradas.</div></div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Folio</th>
                            <th>Semana</th>
                            <th>Estado</th>
                            <th>Explosión</th>
                            <th class="text-end">Planeadas</th>
                            <th class="text-end">Producidas</th>
                            <th>Entrega</th>
                            <th>Líneas</th>
                            <th style="width:340px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _orders)
                        {
                            <tr>
                                <td class="fw-semibold">@o.Folio</td>
                                <td><span class="badge bg-light text-dark border">@o.WeekCode</span></td>
                                <td><span class="badge" style="background:@StatusColor(o.Status)">@StatusLabel(o.Status)</span></td>
                                <td>
                                    @if (o.Status == "exploded" || o.Status == "reserved" || o.Status == "in_progress" || o.Status == "completed" || o.Status == "closed")
                                    {
                                        <span class="badge" style="background:@ExplosionColor(o.ExplosionStatus)">@ExplosionLabel(o.ExplosionStatus)</span>
                                    }
                                </td>
                                <td class="text-end">@o.TotalUnitsPlanned</td>
                                <td class="text-end">@o.TotalUnitsProduced</td>
                                <td class="small text-secondary">@o.DeliveryDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">@o.LineCount</td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        @if (o.Status == "draft")
                                        {
                                            <button class="btn btn-sm btn-outline-primary" disabled="@_busy" @onclick="() => Confirm(o.ProductionOrderId)">Confirmar</button>
                                        }
                                        @if (o.Status == "planned")
                                        {
                                            <button class="btn btn-sm btn-warning" disabled="@_busy" @onclick="() => Explode(o.ProductionOrderId)">Explotar</button>
                                        }
                                        @if (o.Status == "exploded" || o.Status == "reserved")
                                        {
                                            <button class="btn btn-sm btn-outline-info" disabled="@_busy" @onclick="() => ShowRequirement(o.ProductionOrderId, o.Folio)">Ver materiales</button>
                                        }
                                        @if (o.Status == "exploded")
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="() => Reserve(o.ProductionOrderId)">Reservar</button>
                                        }
                                        @if (o.Status == "reserved" || o.Status == "planned" || o.Status == "exploded")
                                        {
                                            <button class="btn btn-sm btn-success" disabled="@_busy" @onclick="() => Start(o.ProductionOrderId)">Iniciar</button>
                                        }
                                        @if (o.Status == "in_progress")
                                        {
                                            <button class="btn btn-sm btn-outline-info" disabled="@_busy" @onclick="() => ShowRequirement(o.ProductionOrderId, o.Folio)">Ver materiales</button>
                                            <button class="btn btn-sm btn-success" disabled="@_busy" @onclick="() => Complete(o.ProductionOrderId)">Completar</button>
                                        }
                                        @if (o.Status == "completed")
                                        {
                                            <button class="btn btn-sm btn-dark" disabled="@_busy" @onclick="() => Close(o.ProductionOrderId)">Cerrar</button>
                                        }
                                        @if (o.Status is "draft" or "planned" or "exploded" or "reserved")
                                        {
                                            <button class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="() => ConfirmCancel(o.ProductionOrderId, o.Folio)">Cancelar</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* ── Panel de explosión de materiales ─────────────────────────────────── *@
@if (_showRequirement)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Requerimiento de materiales — @_reqOrderFolio</h5>
                    <button class="btn-close" @onclick="CloseRequirement"></button>
                </div>
                <div class="modal-body">
                    @if (_reqLoading)
                    {
                        <div class="alert alert-info">Cargando requerimiento...</div>
                    }
                    else if (_req is null)
                    {
                        <div class="alert alert-warning">No hay explosión registrada para esta orden. Ejecute "Explotar" primero.</div>
                    }
                    else
                    {
                        <div class="row g-3 mb-3">
                            <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-secondary small">Total líneas</div><div class="fs-4 fw-bold">@_req.TotalLines</div></div></div></div>
                            <div class="col-md-3"><div class="card shadow-sm border-success"><div class="card-body"><div class="text-secondary small">Cubiertas</div><div class="fs-4 fw-bold text-success">@_req.LinesFulyCovered</div></div></div></div>
                            <div class="col-md-3"><div class="card shadow-sm border-danger"><div class="card-body"><div class="text-secondary small">Con faltante</div><div class="fs-4 fw-bold text-danger">@_req.LinesWithShortage</div></div></div></div>
                            <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-secondary small">Calculado</div><div class="small fw-semibold">@_req.CalculatedAt.ToString("dd/MM/yyyy HH:mm")</div></div></div></div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Componente</th>
                                        <th>Material</th>
                                        <th class="text-end">Requerido</th>
                                        <th class="text-end">En almacén</th>
                                        <th class="text-end">Faltante</th>
                                        <th class="text-end">Costo total</th>
                                        <th>Cobertura</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in _req.Lines.OrderBy(x => x.CoverageStatus))
                                    {
                                        <tr class="@(l.CoverageStatus == "shortage" ? "table-danger" : l.CoverageStatus == "partial" ? "table-warning" : string.Empty)">
                                            <td><span class="badge bg-secondary">@l.ComponentCode</span> @l.ComponentName</td>
                                            <td>@l.MaterialName</td>
                                            <td class="text-end">@l.QuantityRequired.ToString("N3")</td>
                                            <td class="text-end">@l.QuantityOnHand.ToString("N3")</td>
                                            <td class="text-end @(l.QuantityShortage > 0 ? "text-danger fw-bold" : string.Empty)">@(l.QuantityShortage > 0 ? l.QuantityShortage.ToString("N3") : "-")</td>
                                            <td class="text-end">$@l.TotalCost.ToString("N2")</td>
                                            <td><span class="badge" style="background:@CoverageColor(l.CoverageStatus)">@CoverageLabel(l.CoverageStatus)</span></td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light fw-semibold">
                                    <tr>
                                        <td colspan="5">Total</td>
                                        <td class="text-end">$@_req.Lines.Sum(x => x.TotalCost).ToString("N2")</td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseRequirement">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Confirmación de cancelación ────────────────────────────────────────── *@
@if (_cancelId != Guid.Empty)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Cancelar orden @_cancelFolio</h5></div>
                <div class="modal-body">
                    <label class="form-label">Motivo de cancelación</label>
                    <input class="form-control" @bind="_cancelReason" placeholder="Describe el motivo..." />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _cancelId = Guid.Empty">No cancelar</button>
                    <button class="btn btn-danger" disabled="@_busy" @onclick="ExecuteCancel">Sí, cancelar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private string _message = string.Empty;
    private string _error = string.Empty;
    private string _statusFilter = string.Empty;

    private List<CompanyRow> _companies = [];
    private Guid _selectedCompanyId;

    private List<OrderRow> _orders = [];

    // Material requirement modal
    private bool _showRequirement;
    private bool _reqLoading;
    private string _reqOrderFolio = string.Empty;
    private RequirementResult? _req;

    // Cancel confirmation
    private Guid _cancelId;
    private string _cancelFolio = string.Empty;
    private string _cancelReason = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
        var companies = await client.GetFromJsonAsync<List<CompanyRow>>("/api/organization/companies") ?? [];
        _companies = companies;
        if (_companies.Count > 0) _selectedCompanyId = _companies[0].CompanyId;
        await LoadOrdersAsync();
    }

    private async Task OnCompanyChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedCompanyId = id;
            await LoadOrdersAsync();
        }
    }

    private async Task LoadOrdersAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var url = $"/api/production/orders?pageSize=100&companyId={_selectedCompanyId}";
            if (!string.IsNullOrWhiteSpace(_statusFilter)) url += $"&status={_statusFilter}";
            var resp = await client.GetFromJsonAsync<OrderListResult>(url);
            _orders = resp?.Items ?? [];
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private Task Confirm(Guid id) => DoAction(id, "confirm");
    private Task Explode(Guid id) => DoAction(id, "explode");
    private Task Reserve(Guid id) => DoAction(id, "reserve");
    private Task Start(Guid id) => DoAction(id, "start");
    private Task Complete(Guid id) => DoAction(id, "complete");
    private Task Close(Guid id) => DoAction(id, "close");

    private async Task DoAction(Guid orderId, string action)
    {
        _busy = true;
        _message = _error = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var resp = await client.PostAsJsonAsync($"/api/production/orders/{orderId}/{action}", new { userId = "web" });
            if (resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _message = body.TryGetProperty("message", out var m) ? m.GetString() ?? "OK" : "Acción ejecutada.";
                await LoadOrdersAsync();
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _error = body.TryGetProperty("message", out var m) ? m.GetString() ?? resp.ReasonPhrase : resp.ReasonPhrase ?? "Error";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task ShowRequirement(Guid orderId, string folio)
    {
        _showRequirement = true;
        _reqOrderFolio = folio;
        _req = null;
        _reqLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            _req = await client.GetFromJsonAsync<RequirementResult>($"/api/production/orders/{orderId}/material-requirement");
        }
        catch { }
        finally { _reqLoading = false; }
    }

    private void CloseRequirement()
    {
        _showRequirement = false;
        _req = null;
    }

    private void ConfirmCancel(Guid id, string folio)
    {
        _cancelId = id;
        _cancelFolio = folio;
        _cancelReason = string.Empty;
    }

    private async Task ExecuteCancel()
    {
        _busy = true;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var resp = await client.PostAsJsonAsync($"/api/production/orders/{_cancelId}/cancel",
                new { userId = "web", reason = _cancelReason });
            if (resp.IsSuccessStatusCode)
            {
                _message = "Orden cancelada.";
                _cancelId = Guid.Empty;
                await LoadOrdersAsync();
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _error = body.TryGetProperty("message", out var m) ? m.GetString() ?? "Error" : "Error";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private static string StatusColor(string s) => s switch
    {
        "draft"       => "#6b7280",
        "planned"     => "#3b82f6",
        "exploded"    => "#8b5cf6",
        "reserved"    => "#f59e0b",
        "in_progress" => "#f97316",
        "completed"   => "#10b981",
        "closed"      => "#059669",
        "cancelled"   => "#ef4444",
        _             => "#6b7280"
    };

    private static string StatusLabel(string s) => s switch
    {
        "draft"       => "Borrador",
        "planned"     => "Planeada",
        "exploded"    => "Explosionada",
        "reserved"    => "Reservada",
        "in_progress" => "En proceso",
        "completed"   => "Completada",
        "closed"      => "Cerrada",
        "cancelled"   => "Cancelada",
        _             => s
    };

    private static string ExplosionColor(string s) => s switch
    {
        "complete"      => "#10b981",
        "with_shortages"=> "#ef4444",
        "pending"       => "#9ca3af",
        _               => "#9ca3af"
    };

    private static string ExplosionLabel(string s) => s switch
    {
        "complete"       => "Completa",
        "with_shortages" => "Con faltantes",
        "pending"        => "Pendiente",
        _                => s
    };

    private static string CoverageColor(string s) => s switch
    {
        "covered"  => "#10b981",
        "partial"  => "#f59e0b",
        "shortage" => "#ef4444",
        _          => "#6b7280"
    };

    private static string CoverageLabel(string s) => s switch
    {
        "covered"  => "Cubierto",
        "partial"  => "Parcial",
        "shortage" => "Faltante",
        _          => s
    };

    private sealed record CompanyRow(Guid CompanyId, string Name);
    private sealed record OrderListResult(int Total, int Page, int PageSize, List<OrderRow> Items);

    private sealed record OrderRow(
        Guid ProductionOrderId, Guid CompanyId, Guid BranchId,
        string Folio, string WeekCode, string Status, string ExplosionStatus,
        int Priority, DateOnly StartDate, DateOnly EndDate, DateOnly DeliveryDate,
        int TotalUnitsPlanned, int TotalUnitsProduced, int TotalUnitsShipped,
        int LineCount, string? Notes, DateTime CreatedAt);

    private sealed class RequirementResult
    {
        public Guid MaterialRequirementId { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateTime CalculatedAt { get; set; }
        public int TotalLines { get; set; }
        public int LinesWithShortage { get; set; }
        public int LinesFulyCovered { get; set; }
        public List<RequirementLine> Lines { get; set; } = [];
    }

    private sealed class RequirementLine
    {
        public string ComponentCode { get; set; } = string.Empty;
        public string ComponentName { get; set; } = string.Empty;
        public string MaterialName { get; set; } = string.Empty;
        public decimal QuantityRequired { get; set; }
        public decimal QuantityOnHand { get; set; }
        public decimal QuantityToReserve { get; set; }
        public decimal QuantityShortage { get; set; }
        public decimal UnitCost { get; set; }
        public decimal TotalCost { get; set; }
        public string CoverageStatus { get; set; } = string.Empty;
    }
}
