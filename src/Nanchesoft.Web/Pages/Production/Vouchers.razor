@page "/produccion/vales"
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Vales de producción | Nanchesoft</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase small text-secondary fw-semibold">Producción · Vales</div>
            <h2 class="mb-1">Vales de proceso</h2>
            <div class="text-secondary">Emisión, seguimiento y registro de producción por fase y operario.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <select class="form-select form-select-sm" style="width:170px;" @bind="_statusFilter" @bind:after="LoadVouchersAsync">
                <option value="">Todos los estados</option>
                <option value="issued">Emitido</option>
                <option value="in_progress">En proceso</option>
                <option value="completed">Completado</option>
                <option value="cancelled">Cancelado</option>
            </select>
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadVouchersAsync">Actualizar</button>
            <a class="btn btn-outline-secondary btn-sm" href="/produccion/ordenes">Órdenes</a>
            <a class="btn btn-primary btn-sm" href="/produccion/dashboard">Dashboard</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success alert-dismissible">@_message <button type="button" class="btn-close" @onclick='() => _message = string.Empty'></button></div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger alert-dismissible">@_error <button type="button" class="btn-close" @onclick='() => _error = string.Empty'></button></div>
    }

    @if (_loading)
    {
        <div class="alert alert-info">Cargando vales...</div>
    }
    else if (_vouchers.Count == 0)
    {
        <div class="alert alert-secondary">No hay vales para los filtros seleccionados.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Folio</th>
                        <th>Fase</th>
                        <th>Lote</th>
                        <th class="text-end">Lote/talla</th>
                        <th>Estatus</th>
                        <th>Emisión</th>
                        <th>Completado</th>
                        <th class="text-center">Impreso</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in _vouchers)
                    {
                        <tr class="@(v.ProductionVoucherId == _activeVoucherId ? "table-active" : "")">
                            <td><strong>@v.Folio</strong></td>
                            <td>@v.PhaseName</td>
                            <td>@v.LotNumber</td>
                            <td class="text-end">@v.BatchSize</td>
                            <td>
                                <span class="badge @StatusBadgeClass(v.Status)">@StatusLabel(v.Status)</span>
                            </td>
                            <td>@v.IssuedDate.ToString("dd/MM/yy")</td>
                            <td>@(v.CompletedDate.HasValue ? v.CompletedDate.Value.ToString("dd/MM/yy") : "—")</td>
                            <td class="text-center">
                                @if (v.Printed)
                                {
                                    <span class="text-success" title="@v.PrintCount impresiones">✓ @v.PrintCount</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (v.Status is "issued" or "in_progress")
                                    {
                                        <button class="btn btn-success btn-sm" @onclick="() => OpenComplete(v.ProductionVoucherId)" disabled="@_busy">Completar</button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => OpenCancel(v.ProductionVoucherId)" disabled="@_busy">Cancelar</button>
                                    }
                                    <button class="btn btn-outline-secondary btn-sm" title="Imprimir PDF" @onclick="() => PrintVoucherAsync(v.ProductionVoucherId)" disabled="@_busy">🖨</button>
                                </div>
                            </td>
                        </tr>

                        @if (_activeVoucherId == v.ProductionVoucherId && _completeMode)
                        {
                            <tr>
                                <td colspan="9" class="p-0">
                                    <div class="card border-success mx-2 my-1">
                                        <div class="card-header bg-success-subtle fw-semibold">Completar vale @v.Folio</div>
                                        <div class="card-body">
                                            @if (_detailLoading)
                                            {
                                                <div class="text-muted small">Cargando detalle...</div>
                                            }
                                            else if (_detail is not null)
                                            {
                                                @if (_detail.Details.Count > 0)
                                                {
                                                    <div class="table-responsive mb-3">
                                                        <table class="table table-sm table-bordered mb-0" style="min-width:500px;">
                                                            <thead class="table-success">
                                                                <tr>
                                                                    <th>Talla</th>
                                                                    <th class="text-end">Asignado</th>
                                                                    <th class="text-end">Producido</th>
                                                                    <th class="text-end">Rechazado</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var d in _sizeEntries)
                                                                {
                                                                    <tr>
                                                                        <td>@d.SizeLabel <span class="text-muted small">(@d.SizeCode)</span></td>
                                                                        <td class="text-end">@d.QuantityAssigned</td>
                                                                        <td style="width:110px;">
                                                                            <input type="number" class="form-control form-control-sm text-end" min="0" @bind="d.QuantityProduced" />
                                                                        </td>
                                                                        <td style="width:110px;">
                                                                            <input type="number" class="form-control form-control-sm text-end" min="0" @bind="d.QuantityRejected" />
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="text-muted small mb-3">Este vale no tiene tallas registradas. Se completará sin cantidades por talla.</div>
                                                }
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-success" @onclick="SubmitCompleteAsync" disabled="@_busy">Confirmar completado</button>
                                                    <button class="btn btn-outline-secondary" @onclick="ClosePanel">Cancelar</button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (_activeVoucherId == v.ProductionVoucherId && _cancelMode)
                        {
                            <tr>
                                <td colspan="9" class="p-0">
                                    <div class="card border-danger mx-2 my-1">
                                        <div class="card-header bg-danger-subtle fw-semibold">Cancelar vale @v.Folio</div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label class="form-label small">Motivo de cancelación</label>
                                                <input type="text" class="form-control form-control-sm" placeholder="Motivo (opcional)" @bind="_cancelReason" />
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-danger" @onclick="SubmitCancelAsync" disabled="@_busy">Confirmar cancelación</button>
                                                <button class="btn btn-outline-secondary" @onclick="ClosePanel">Volver</button>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="text-muted small">@_vouchers.Count vale(s) mostrado(s)</div>
    }
</div>

@code {
    private List<VoucherRow> _vouchers = [];
    private string _statusFilter = "";
    private bool _loading = true;
    private bool _busy = false;
    private string _message = string.Empty;
    private string _error = string.Empty;

    private Guid? _activeVoucherId;
    private bool _completeMode;
    private bool _cancelMode;
    private bool _detailLoading;
    private VoucherDetail? _detail;
    private List<SizeEntry> _sizeEntries = [];
    private string _cancelReason = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadVouchersAsync();

    private async Task LoadVouchersAsync()
    {
        _loading = true;
        _error = string.Empty;
        ClosePanel();
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var url = $"/api/production/vouchers?pageSize=300{(string.IsNullOrWhiteSpace(_statusFilter) ? "" : $"&status={_statusFilter}")}";
            var result = await client.GetFromJsonAsync<PagedVouchers>(url);
            _vouchers = result?.Items ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar vales: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenComplete(Guid voucherId)
    {
        ClosePanel();
        _activeVoucherId = voucherId;
        _completeMode = true;
        _detailLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            _detail = await client.GetFromJsonAsync<VoucherDetail>($"/api/production/vouchers/{voucherId}");
            _sizeEntries = _detail?.Details.Select(d => new SizeEntry
            {
                SizeRunSizeId = d.ProductionVoucherDetailId,
                SizeCode = d.SizeCode,
                SizeLabel = d.SizeLabel,
                QuantityAssigned = d.QuantityAssigned,
                QuantityProduced = d.QuantityProduced,
                QuantityRejected = d.QuantityRejected
            }).ToList() ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar detalle: {ex.Message}";
            ClosePanel();
        }
        finally
        {
            _detailLoading = false;
        }
    }

    private void OpenCancel(Guid voucherId)
    {
        ClosePanel();
        _activeVoucherId = voucherId;
        _cancelMode = true;
        _cancelReason = string.Empty;
    }

    private void ClosePanel()
    {
        _activeVoucherId = null;
        _completeMode = false;
        _cancelMode = false;
        _detail = null;
        _sizeEntries = [];
        _cancelReason = string.Empty;
    }

    private async Task SubmitCompleteAsync()
    {
        if (_activeVoucherId is null) return;
        _busy = true;
        _error = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var payload = new
            {
                sizeResults = _sizeEntries.Select(e => new
                {
                    sizeRunSizeId = e.SizeRunSizeId,
                    quantityProduced = e.QuantityProduced,
                    quantityRejected = e.QuantityRejected
                }).ToList()
            };
            var response = await client.PostAsJsonAsync($"/api/production/vouchers/{_activeVoucherId}/complete", payload);
            if (!response.IsSuccessStatusCode)
            {
                _error = await ExtractErrorAsync(response);
            }
            else
            {
                _message = "Vale completado correctamente.";
                ClosePanel();
                await LoadVouchersAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SubmitCancelAsync()
    {
        if (_activeVoucherId is null) return;
        _busy = true;
        _error = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var payload = new { reason = _cancelReason };
            var response = await client.PostAsJsonAsync($"/api/production/vouchers/{_activeVoucherId}/cancel", payload);
            if (!response.IsSuccessStatusCode)
            {
                _error = await ExtractErrorAsync(response);
            }
            else
            {
                _message = "Vale cancelado.";
                ClosePanel();
                await LoadVouchersAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PrintVoucherAsync(Guid voucherId)
    {
        _busy = true;
        _error = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var response = await client.PostAsJsonAsync($"/api/production/vouchers/{voucherId}/print", new { companyName = "Nanchesoft ERP" });
            if (!response.IsSuccessStatusCode)
            {
                _error = await ExtractErrorAsync(response);
            }
            else
            {
                var result = await response.Content.ReadFromJsonAsync<PrintResult>();
                if (result is not null)
                {
                    Navigation.NavigateTo($"data:application/pdf;base64,{result.Base64}", true);
                }
                _message = "PDF generado.";
                await LoadVouchersAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static async Task<string> ExtractErrorAsync(HttpResponseMessage response)
    {
        var content = await response.Content.ReadAsStringAsync();
        try
        {
            using var doc = JsonDocument.Parse(content);
            if (doc.RootElement.TryGetProperty("message", out var msg))
                return msg.GetString() ?? "Error desconocido.";
        }
        catch { }
        return string.IsNullOrWhiteSpace(content) ? "Error sin detalle." : content;
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "issued"      => "bg-primary",
        "in_progress" => "bg-warning text-dark",
        "completed"   => "bg-success",
        "cancelled"   => "bg-secondary",
        _             => "bg-light text-dark"
    };

    private static string StatusLabel(string status) => status switch
    {
        "issued"      => "Emitido",
        "in_progress" => "En proceso",
        "completed"   => "Completado",
        "cancelled"   => "Cancelado",
        _             => status
    };

    private sealed class VoucherRow
    {
        public Guid ProductionVoucherId { get; set; }
        public Guid ProductionOrderId { get; set; }
        public string Folio { get; set; } = string.Empty;
        public string LotNumber { get; set; } = string.Empty;
        public string PhaseName { get; set; } = string.Empty;
        public int BatchSize { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateOnly IssuedDate { get; set; }
        public string? IssuedBy { get; set; }
        public DateOnly? CompletedDate { get; set; }
        public bool Printed { get; set; }
        public int PrintCount { get; set; }
    }

    private sealed class PagedVouchers
    {
        public List<VoucherRow> Items { get; set; } = [];
        public int Total { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
    }

    private sealed class VoucherDetail
    {
        public Guid ProductionVoucherId { get; set; }
        public string Folio { get; set; } = string.Empty;
        public string PhaseName { get; set; } = string.Empty;
        public int BatchSize { get; set; }
        public string Status { get; set; } = string.Empty;
        public List<DetailLine> Details { get; set; } = [];
    }

    private sealed class DetailLine
    {
        public Guid ProductionVoucherDetailId { get; set; }
        public string SizeCode { get; set; } = string.Empty;
        public string SizeLabel { get; set; } = string.Empty;
        public int QuantityAssigned { get; set; }
        public int QuantityProduced { get; set; }
        public int QuantityRejected { get; set; }
    }

    private sealed class SizeEntry
    {
        public Guid SizeRunSizeId { get; set; }
        public string SizeCode { get; set; } = string.Empty;
        public string SizeLabel { get; set; } = string.Empty;
        public int QuantityAssigned { get; set; }
        public int QuantityProduced { get; set; }
        public int QuantityRejected { get; set; }
    }

    private sealed record PrintResult(string Base64, string FileName);
}
