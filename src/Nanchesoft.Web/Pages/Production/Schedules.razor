@page "/produccion/programacion"
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Programación semanal | Nanchesoft</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase small text-secondary fw-semibold">Producción · Programación</div>
            <h2 class="mb-1">Programación semanal</h2>
            <div class="text-secondary">Crea y gestiona programas semanales de producción por empresa.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (_companies.Count > 1)
            {
                <select class="form-select form-select-sm" style="width:200px;" @onchange="OnCompanyChanged">
                    @foreach (var c in _companies)
                    {
                        <option value="@c.Id" selected="@(c.Id == _selectedCompanyId)">@c.Name</option>
                    }
                </select>
            }
            <select class="form-select form-select-sm" style="width:100px;" @bind="_yearFilter" @bind:after="LoadSchedulesAsync">
                @for (int y = DateTime.UtcNow.Year + 1; y >= DateTime.UtcNow.Year - 2; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadSchedulesAsync">Actualizar</button>
            <button class="btn btn-primary btn-sm" @onclick="OpenNewScheduleModal">+ Nuevo programa</button>
            <a class="btn btn-outline-secondary btn-sm" href="/produccion/ordenes">Órdenes</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success alert-dismissible">@_message <button type="button" class="btn-close" @onclick='() => _message = string.Empty'></button></div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger alert-dismissible">@_error <button type="button" class="btn-close" @onclick='() => _error = string.Empty'></button></div>
    }

    @if (_loading)
    {
        <div class="alert alert-info">Cargando programas...</div>
    }
    else if (_schedules.Count == 0)
    {
        <div class="card shadow-sm"><div class="card-body text-center text-secondary py-5">Sin programas para @_yearFilter. Crea el primero con "Nuevo programa".</div></div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Semana</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Estado</th>
                            <th class="text-end">Capacidad</th>
                            <th class="text-end">Programadas</th>
                            <th class="text-end">Producidas</th>
                            <th class="text-center">Carga %</th>
                            <th class="text-center">Líneas</th>
                            <th style="width:260px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _schedules)
                        {
                            <tr>
                                <td class="fw-semibold"><span class="badge bg-light text-dark border">@s.WeekCode</span></td>
                                <td class="small text-secondary">@s.WeekStartDate.ToString("dd/MM")</td>
                                <td class="small text-secondary">@s.WeekEndDate.ToString("dd/MM")</td>
                                <td><span class="badge" style="background:@ScheduleStatusColor(s.Status)">@ScheduleStatusLabel(s.Status)</span></td>
                                <td class="text-end">@s.TotalCapacityUnits.ToString("N0")</td>
                                <td class="text-end">@s.TotalScheduledUnits.ToString("N0")</td>
                                <td class="text-end">@s.TotalProducedUnits.ToString("N0")</td>
                                <td class="text-center">
                                    <span class="badge" style="background:@LoadColor(s.LoadPercentage)">@s.LoadPercentage.ToString("N1")%</span>
                                </td>
                                <td class="text-center">@s.LineCount</td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenDetailModal(s)">Ver detalle</button>
                                        @if (s.Status == "open" || s.Status == "planning")
                                        {
                                            <button class="btn btn-sm btn-outline-warning" disabled="@_busy" @onclick="() => LockSchedule(s.ProductionScheduleId)">Bloquear</button>
                                        }
                                        @if (s.Status == "locked")
                                        {
                                            <button class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="() => CloseSchedule(s.ProductionScheduleId)">Cerrar</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Modal: nuevo programa -->
@if (_showNewModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nuevo programa semanal</h5>
                    <button type="button" class="btn-close" @onclick="CloseNewModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Empresa</label>
                        <select class="form-select" @bind="_newCompanyId">
                            @foreach (var c in _companies)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sucursal</label>
                        <select class="form-select" @bind="_newBranchId">
                            @foreach (var b in _branches)
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Código de semana <span class="text-secondary small">(ej. 2026-W22)</span></label>
                        <input class="form-control" @bind="_newWeekCode" placeholder="2026-W22" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Notas</label>
                        <textarea class="form-control" rows="2" @bind="_newNotes"></textarea>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_modalError))
                    {
                        <div class="alert alert-danger py-2">@_modalError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseNewModal">Cancelar</button>
                    <button class="btn btn-primary" disabled="@_busy" @onclick="CreateScheduleAsync">Crear programa</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: detalle del programa -->
@if (_showDetailModal && _detail is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Programa @_detail.WeekCode — @ScheduleStatusLabel(_detail.Status)</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetailModal"></button>
                </div>
                <div class="modal-body">
                    <!-- KPIs -->
                    <div class="row g-3 mb-3">
                        <div class="col-6 col-md-3">
                            <div class="card border-0 bg-light text-center p-2">
                                <div class="small text-secondary">Capacidad</div>
                                <div class="fw-bold fs-5">@_detail.TotalCapacityUnits.ToString("N0")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 bg-light text-center p-2">
                                <div class="small text-secondary">Programadas</div>
                                <div class="fw-bold fs-5">@_detail.TotalScheduledUnits.ToString("N0")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 bg-light text-center p-2">
                                <div class="small text-secondary">Producidas</div>
                                <div class="fw-bold fs-5">@_detail.TotalProducedUnits.ToString("N0")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 text-center p-2" style="background:#e8f5e9">
                                <div class="small text-secondary">Carga</div>
                                <div class="fw-bold fs-5">@_detail.LoadPercentage.ToString("N1")%</div>
                            </div>
                        </div>
                    </div>

                    <!-- Add line -->
                    @if (_detail.Status == "open" || _detail.Status == "planning")
                    {
                        <div class="card mb-3">
                            <div class="card-header fw-semibold py-2">Agregar línea</div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <label class="form-label small">Orden de producción</label>
                                        <select class="form-select form-select-sm" @bind="_lineOrderId">
                                            <option value="">— selecciona —</option>
                                            @foreach (var o in _ordersToSchedule)
                                            {
                                                <option value="@o.Id">@o.Folio (@o.TotalUnitsPlanned u.)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Fecha programada</label>
                                        <input type="date" class="form-control form-control-sm" @bind="_lineDate" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Turno</label>
                                        <select class="form-select form-select-sm" @bind="_lineShift">
                                            <option value="morning">Matutino</option>
                                            <option value="afternoon">Vespertino</option>
                                            <option value="night">Nocturno</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Unidades</label>
                                        <input type="number" class="form-control form-control-sm" @bind="_lineUnits" min="1" />
                                    </div>
                                    <div class="col-md-2 d-flex align-items-end">
                                        <button class="btn btn-primary btn-sm w-100" disabled="@_busy" @onclick="AddLineAsync">Agregar</button>
                                    </div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_lineError))
                                {
                                    <div class="alert alert-danger py-1 mt-2">@_lineError</div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Lines table -->
                    @if (_detail.Lines.Count == 0)
                    {
                        <div class="text-secondary text-center py-3">Sin líneas programadas aún.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Orden</th>
                                        <th>Fase</th>
                                        <th>Celda</th>
                                        <th>Fecha</th>
                                        <th>Turno</th>
                                        <th class="text-end">Programadas</th>
                                        <th class="text-end">Producidas</th>
                                        @if (_detail.Status == "open" || _detail.Status == "planning")
                                        {
                                            <th></th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in _detail.Lines)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@l.OrderFolio</td>
                                            <td>@l.PhaseName</td>
                                            <td class="text-secondary">@l.CellName</td>
                                            <td class="small">@l.ScheduledDate.ToString("dd/MM")</td>
                                            <td><span class="badge bg-secondary">@ShiftLabel(l.Shift)</span></td>
                                            <td class="text-end">@l.UnitsScheduled</td>
                                            <td class="text-end">@l.UnitsProduced</td>
                                            @if (_detail.Status == "open" || _detail.Status == "planning")
                                            {
                                                <td>
                                                    <button class="btn btn-sm btn-outline-danger" disabled="@_busy"
                                                            @onclick="() => RemoveLineAsync(_detail.ProductionScheduleId, l.ProductionScheduleLineId)">
                                                        Quitar
                                                    </button>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDetailModal">Cerrar</button>
                    @if (_detail.Status == "open" || _detail.Status == "planning")
                    {
                        <button class="btn btn-warning" disabled="@_busy" @onclick="() => LockFromDetail()">Bloquear programa</button>
                    }
                    @if (_detail.Status == "locked")
                    {
                        <button class="btn btn-danger" disabled="@_busy" @onclick="() => CloseFromDetail()">Cerrar programa</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private HttpClient? _http;

    private List<CompanyRow> _companies = new();
    private List<BranchRow> _branches = new();
    private Guid _selectedCompanyId;
    private int _yearFilter = DateTime.UtcNow.Year;

    private List<ScheduleSummaryRow> _schedules = new();
    private ScheduleDetailResult? _detail;

    private bool _loading;
    private bool _busy;
    private string _message = string.Empty;
    private string _error = string.Empty;

    // New schedule modal
    private bool _showNewModal;
    private Guid _newCompanyId;
    private Guid _newBranchId;
    private string _newWeekCode = string.Empty;
    private string _newNotes = string.Empty;
    private string _modalError = string.Empty;

    // Detail modal
    private bool _showDetailModal;
    private string _lineError = string.Empty;
    private string _lineOrderId = string.Empty;
    private DateOnly _lineDate = DateOnly.FromDateTime(DateTime.Today);
    private string _lineShift = "morning";
    private int _lineUnits = 1;

    private List<OrderToScheduleRow> _ordersToSchedule = new();

    protected override async Task OnInitializedAsync()
    {
        _http = HttpClientFactory.CreateClient("Nanchesoft.Api");
        await LoadCompaniesAsync();
    }

    private async Task LoadCompaniesAsync()
    {
        try
        {
            var result = await _http!.GetFromJsonAsync<List<CompanyRow>>("/api/organization/companies");
            _companies = result ?? new();
            if (_companies.Count > 0)
            {
                _selectedCompanyId = _companies[0].Id;
                _newCompanyId = _selectedCompanyId;
            }
            await LoadBranchesAsync();
            await LoadSchedulesAsync();
        }
        catch { _error = "Error al cargar empresas."; }
    }

    private async Task LoadBranchesAsync()
    {
        try
        {
            var result = await _http!.GetFromJsonAsync<List<BranchRow>>($"/api/organization/branches?companyId={_selectedCompanyId}");
            _branches = result ?? new();
            if (_branches.Count > 0) _newBranchId = _branches[0].Id;
        }
        catch { }
    }

    private async Task LoadSchedulesAsync()
    {
        _loading = true;
        _schedules = new();
        try
        {
            var result = await _http!.GetFromJsonAsync<List<ScheduleSummaryRow>>(
                $"/api/production/schedules?companyId={_selectedCompanyId}&year={_yearFilter}");
            _schedules = result ?? new();
        }
        catch { _error = "Error al cargar programas."; }
        _loading = false;
    }

    private async Task OnCompanyChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedCompanyId = id;
            _newCompanyId = id;
        }
        await LoadBranchesAsync();
        await LoadSchedulesAsync();
    }

    private void OpenNewScheduleModal()
    {
        _newCompanyId = _selectedCompanyId;
        if (_branches.Count > 0) _newBranchId = _branches[0].Id;
        _newWeekCode = $"{_yearFilter}-W{ISOWeekNumber(DateTime.Today):D2}";
        _newNotes = string.Empty;
        _modalError = string.Empty;
        _showNewModal = true;
    }

    private void CloseNewModal() => _showNewModal = false;

    private async Task CreateScheduleAsync()
    {
        _modalError = string.Empty;
        if (string.IsNullOrWhiteSpace(_newWeekCode)) { _modalError = "Ingresa el código de semana."; return; }
        if (_newBranchId == Guid.Empty) { _modalError = "Selecciona una sucursal."; return; }

        _busy = true;
        try
        {
            var payload = new { companyId = _newCompanyId, branchId = _newBranchId, weekCode = _newWeekCode, notes = _newNotes, userId = "web" };
            var resp = await _http!.PostAsJsonAsync("/api/production/schedules/week", payload);
            if (resp.IsSuccessStatusCode)
            {
                _showNewModal = false;
                _message = $"Programa {_newWeekCode} creado correctamente.";
                await LoadSchedulesAsync();
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<ErrorBody>();
                _modalError = body?.Message ?? "Error al crear el programa.";
            }
        }
        catch { _modalError = "Error de conexión."; }
        _busy = false;
    }

    private async Task OpenDetailModal(ScheduleSummaryRow s)
    {
        _lineError = string.Empty;
        _lineOrderId = string.Empty;
        _lineDate = DateOnly.FromDateTime(DateTime.Today);
        _lineShift = "morning";
        _lineUnits = 1;

        await LoadOrdersToScheduleAsync();

        try
        {
            _detail = await _http!.GetFromJsonAsync<ScheduleDetailResult>($"/api/production/schedules/{s.ProductionScheduleId}");
            _showDetailModal = true;
        }
        catch { _error = "Error al cargar detalle del programa."; }
    }

    private async Task LoadOrdersToScheduleAsync()
    {
        try
        {
            var result = await _http!.GetFromJsonAsync<List<OrderToScheduleRow>>(
                $"/api/production/orders-to-schedule?companyId={_selectedCompanyId}");
            _ordersToSchedule = result ?? new();
        }
        catch { }
    }

    private void CloseDetailModal() { _showDetailModal = false; _detail = null; }

    private async Task AddLineAsync()
    {
        _lineError = string.Empty;
        if (!Guid.TryParse(_lineOrderId, out var orderId)) { _lineError = "Selecciona una orden."; return; }
        if (_lineUnits <= 0) { _lineError = "Ingresa unidades mayores a 0."; return; }
        if (_detail is null) return;

        _busy = true;
        try
        {
            var order = _ordersToSchedule.FirstOrDefault(o => o.Id == orderId);
            var payload = new
            {
                productionOrderId = orderId,
                productionOrderLineId = Guid.Empty,
                productionPhaseId = Guid.Empty,
                scheduledDate = _lineDate,
                shift = _lineShift,
                unitsScheduled = _lineUnits,
                userId = "web"
            };
            var resp = await _http!.PostAsJsonAsync($"/api/production/schedules/{_detail.ProductionScheduleId}/lines", payload);
            if (resp.IsSuccessStatusCode)
            {
                _lineOrderId = string.Empty;
                _lineUnits = 1;
                // Reload detail
                _detail = await _http!.GetFromJsonAsync<ScheduleDetailResult>($"/api/production/schedules/{_detail.ProductionScheduleId}");
                await LoadSchedulesAsync();
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<ErrorBody>();
                _lineError = body?.Message ?? "Error al agregar línea.";
            }
        }
        catch { _lineError = "Error de conexión."; }
        _busy = false;
    }

    private async Task RemoveLineAsync(Guid scheduleId, Guid lineId)
    {
        _busy = true;
        try
        {
            var resp = await _http!.DeleteAsync($"/api/production/schedules/{scheduleId}/lines/{lineId}");
            if (resp.IsSuccessStatusCode)
            {
                _detail = await _http!.GetFromJsonAsync<ScheduleDetailResult>($"/api/production/schedules/{scheduleId}");
                await LoadSchedulesAsync();
            }
            else { _error = "Error al quitar línea."; }
        }
        catch { _error = "Error de conexión."; }
        _busy = false;
    }

    private async Task LockSchedule(Guid id)
    {
        _busy = true;
        try
        {
            var resp = await _http!.PostAsJsonAsync($"/api/production/schedules/{id}/lock", new { userId = "web" });
            if (resp.IsSuccessStatusCode) { _message = "Programa bloqueado."; await LoadSchedulesAsync(); }
            else { _error = "Error al bloquear programa."; }
        }
        catch { _error = "Error de conexión."; }
        _busy = false;
    }

    private async Task CloseSchedule(Guid id)
    {
        _busy = true;
        try
        {
            var resp = await _http!.PostAsJsonAsync($"/api/production/schedules/{id}/close", new { userId = "web" });
            if (resp.IsSuccessStatusCode) { _message = "Programa cerrado."; await LoadSchedulesAsync(); }
            else { _error = "Error al cerrar programa."; }
        }
        catch { _error = "Error de conexión."; }
        _busy = false;
    }

    private async Task LockFromDetail()
    {
        if (_detail is null) return;
        await LockSchedule(_detail.ProductionScheduleId);
        _detail = await _http!.GetFromJsonAsync<ScheduleDetailResult>($"/api/production/schedules/{_detail.ProductionScheduleId}");
    }

    private async Task CloseFromDetail()
    {
        if (_detail is null) return;
        await CloseSchedule(_detail.ProductionScheduleId);
        _detail = await _http!.GetFromJsonAsync<ScheduleDetailResult>($"/api/production/schedules/{_detail.ProductionScheduleId}");
    }

    private static int ISOWeekNumber(DateTime dt)
    {
        var day = (int)System.Globalization.CultureInfo.InvariantCulture.Calendar.GetDayOfWeek(dt);
        return System.Globalization.CultureInfo.InvariantCulture.Calendar.GetWeekOfYear(dt.AddDays(4 - (day == 0 ? 7 : day)), System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
    }

    private static string ScheduleStatusColor(string status) => status switch
    {
        "open"     => "#1976d2",
        "planning" => "#7b1fa2",
        "locked"   => "#f57c00",
        "closed"   => "#388e3c",
        _          => "#757575"
    };

    private static string ScheduleStatusLabel(string status) => status switch
    {
        "open"     => "Abierto",
        "planning" => "En planificación",
        "locked"   => "Bloqueado",
        "closed"   => "Cerrado",
        _          => status
    };

    private static string LoadColor(decimal pct)
    {
        if (pct < 50m) return "#388e3c";
        if (pct < 80m) return "#f57c00";
        if (pct < 100m) return "#e65100";
        return "#c62828";
    }

    private static string ShiftLabel(string shift) => shift switch
    {
        "morning"   => "Matutino",
        "afternoon" => "Vespertino",
        "night"     => "Nocturno",
        _           => shift
    };

    // ── Records ──────────────────────────────────────────────────────────────

    private sealed record CompanyRow(Guid Id, string Name);
    private sealed record BranchRow(Guid Id, string Name);
    private sealed record ErrorBody(string Message);

    private sealed class ScheduleSummaryRow
    {
        public Guid ProductionScheduleId { get; set; }
        public Guid CompanyId { get; set; }
        public Guid BranchId { get; set; }
        public string WeekCode { get; set; } = string.Empty;
        public DateOnly WeekStartDate { get; set; }
        public DateOnly WeekEndDate { get; set; }
        public string Status { get; set; } = string.Empty;
        public int TotalCapacityUnits { get; set; }
        public int TotalScheduledUnits { get; set; }
        public int TotalProducedUnits { get; set; }
        public decimal LoadPercentage { get; set; }
        public int LineCount { get; set; }
    }

    private sealed class ScheduleDetailResult
    {
        public Guid ProductionScheduleId { get; set; }
        public string WeekCode { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public int TotalCapacityUnits { get; set; }
        public int TotalScheduledUnits { get; set; }
        public int TotalProducedUnits { get; set; }
        public decimal LoadPercentage { get; set; }
        public List<ScheduleLineRow> Lines { get; set; } = new();
    }

    private sealed class ScheduleLineRow
    {
        public Guid ProductionScheduleLineId { get; set; }
        public Guid ProductionOrderId { get; set; }
        public string OrderFolio { get; set; } = string.Empty;
        public Guid ProductionPhaseId { get; set; }
        public string PhaseName { get; set; } = string.Empty;
        public string CellName { get; set; } = string.Empty;
        public DateOnly ScheduledDate { get; set; }
        public string Shift { get; set; } = string.Empty;
        public int UnitsScheduled { get; set; }
        public int UnitsProduced { get; set; }
    }

    private sealed class OrderToScheduleRow
    {
        public Guid Id { get; set; }
        public string Folio { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
