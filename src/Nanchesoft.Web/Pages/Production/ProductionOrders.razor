    private void RemoveLine(OrderLineForm line) => _formLines.Remove(line);

    private List<FinishedProductOption> FilteredProducts(string search)
    {
        if (string.IsNullOrWhiteSpace(search)) return [];
        var q = search.Trim().ToLowerInvariant();
        return _products
            .Where(p => p.Code.ToLowerInvariant().Contains(q) || p.Name.ToLowerInvariant().Contains(q))
            .Take(12)
            .ToList();
    }

    private async Task SelectProductAsync(OrderLineForm line, FinishedProductOption product)
    {
        line.FinishedProductId = product.FinishedProductId;
        line.ProductCode = product.Code;
        line.ProductName = product.Name;
        line.ProductSearch = string.Empty;
        line.ShowDropdown = false;
        line.Sizes = [];
        line.LoadingSizes = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var result = await client.GetFromJsonAsync<ProductSizesResult>($"/api/production/product-sizes/{product.FinishedProductId}");
            if (result?.Sizes is { Count: > 0 })
            {
                line.ProductSizeRunId = result.ProductSizeRunId;
                line.ProductStyleId = result.ProductStyleId;
                line.Sizes = result.Sizes.Select(s => new SizeQty
                {
                    SizeRunSizeId = s.SizeRunSizeId,
                    SizeCode = s.SizeCode,
                    Qty = 0
                }).ToList();
            }

            if (_formCustomerId != Guid.Empty && line.UnitPrice == 0)
                await TryLoadPriceAsync(line);
        }
        catch { }
        finally
        {
            line.LoadingSizes = false;
            StateHasChanged();
        }
    }

    private async Task TryLoadPriceAsync(OrderLineForm line)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var priceResp = await client.GetFromJsonAsync<PriceLookupResult>(
                $"/api/production/product-price?finishedProductId={line.FinishedProductId}&customerId={_formCustomerId}");
            if (priceResp?.Found == true && priceResp.Price > 0)
                line.UnitPrice = priceResp.Price;
        }
        catch { }
    }

    private void ClearProduct(OrderLineForm line)
    {
        line.FinishedProductId = Guid.Empty;
        line.ProductCode = string.Empty;
        line.ProductName = string.Empty;
        line.ProductSearch = string.Empty;
        line.Sizes = [];
        line.ProductSizeRunId = null;
        line.UnitPrice = 0;
    }

    // ─── Submit ───────────────────────────────────────────────────────────────
    private async Task SubmitFormAsync()
    {
        _formError = string.Empty;

        if (_formCompanyId == Guid.Empty) { _formError = "Selecciona una empresa."; return; }
        if (_formBranchId == Guid.Empty) { _formError = "Selecciona una sucursal."; return; }
        if (_formCustomerId == Guid.Empty) { _formError = "El cliente es obligatorio."; return; }
        if (string.IsNullOrWhiteSpace(_formReference)) { _formError = "La referencia del cliente es obligatoria."; return; }
        if (_formDeliveryDate == default) { _formError = "La fecha de entrega es obligatoria."; return; }
        if (_formLines.Count == 0) { _formError = "Agrega al menos una línea."; return; }
        if (_formLines.Any(l => l.FinishedProductId == Guid.Empty)) { _formError = "Todas las líneas deben tener un producto seleccionado."; return; }
        if (_formLines.Any(l => string.IsNullOrWhiteSpace(l.CustomerPoReference))) { _formError = "Todas las líneas requieren el campo P.O. (pedido del cliente)."; return; }
        if (_formLines.All(l => l.TotalQty == 0)) { _formError = "Captura al menos una cantidad en las líneas."; return; }

        _busy = true;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var notesText = string.IsNullOrWhiteSpace(_formSeason) ? _formNotes : $"[Temporada: {_formSeason}] {_formNotes}".Trim();

            var payload = new
            {
                companyId = _formCompanyId,
                branchId = _formBranchId,
                warehouseId = _formWarehouseId,
                customerId = _formCustomerId == Guid.Empty ? (Guid?)null : _formCustomerId,
                customerReference = _formReference,
                weekCode = _formWeekCode,
                season = _formSeason,
                startDate = _formStartDate,
                endDate = _formEndDate,
                deliveryDate = _formDeliveryDate,
                cancellationDate = _formCancellationDate,
                priority = _formPriority,
                notes = notesText,
                legalName = _formLegalName,
                shipToAddressId = _formShipToAddressId,
                shipToAddressText = _formShipToAddressText,
                userId = "web",
                lines = _formLines.Select(l => new
                {
                    finishedProductId = l.FinishedProductId,
                    productStyleId = l.ProductStyleId,
                    productSizeRunId = l.ProductSizeRunId,
                    customerId = _formCustomerId == Guid.Empty ? (Guid?)null : _formCustomerId,
                    customerPoReference = l.CustomerPoReference,
                    unitPrice = l.UnitPrice,
                    discountPercent = l.DiscountPercent,
                    notes = l.Notes,
                    deliveryDate = _formDeliveryDate,
                    priority = _formPriority,
                    warehouseId = l.WarehouseId ?? _formWarehouseId,
                    shipToAddressId = l.ShipToAddressId ?? _formShipToAddressId,
                    shipToAddressText = !string.IsNullOrWhiteSpace(l.ShipToAddressText) ? l.ShipToAddressText : _formShipToAddressText,
                    legalName = !string.IsNullOrWhiteSpace(l.LegalName) ? l.LegalName : _formLegalName,
                    quantitiesPerSize = l.Sizes
                        .Where(s => s.SizeRunSizeId != Guid.Empty && s.Qty > 0)
                        .ToDictionary(s => s.SizeRunSizeId.ToString(), s => s.Qty),
                    userId = "web"
                }).ToList()
            };

            var resp = await client.PostAsJsonAsync("/api/production/orders", payload);
            if (resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadFromJsonAsync<CreateOrderResult>();
                if (body is not null)
                {
                    _lastCreatedOrder = new PrintOrderData
                    {
                        Folio = body.Folio,
                        CustomerReference = _formReference,
                        PrintLines = _formLines.Select((l, i) =>
                        {
                            var apiLine = body.Lines?.ElementAtOrDefault(i);
                            return new PrintLineData
                            {
                                NcFolio = apiLine?.NcFolio ?? $"NC-{i + 1:D6}",
                                ProductCode = l.ProductCode,
                                ProductName = l.ProductName,
                                CustomerPoReference = l.CustomerPoReference,
                                UnitPrice = l.UnitPrice,
                                DiscountPercent = l.DiscountPercent,
                                TotalQty = l.TotalQty,
                                LineTotal = l.LineTotal,
                                SizeQtys = l.Sizes.Where(s => s.Qty > 0).ToDictionary(s => s.SizeCode, s => s.Qty)
                            };
                        }).ToList()
                    };
                    _showPrint = true;
                    CloseForm();
                    await LoadOrdersAsync();
                }
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _formError = body.TryGetProperty("message", out var m) ? m.GetString() ?? "Error." : "Error al guardar.";
            }
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _busy = false; }
    }

    private void ClosePrintAndContinue()
    {
        _showPrint = false;
        _lastCreatedOrder = null;
        _message = "Pedido creado. Puedes capturar otro.";
    }

    // ─── Actions ──────────────────────────────────────────────────────────────
    private async Task DoActionAsync(Guid orderId, string action)
    {
        _busy = true; _message = _error = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var resp = await client.PostAsJsonAsync($"/api/production/orders/{orderId}/{action}", new { userId = "web" });
            if (resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _message = body.TryGetProperty("message", out var m) ? m.GetString() ?? "OK" : "Acción ejecutada.";
                await LoadOrdersAsync();
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _error = body.TryGetProperty("message", out var m) ? m.GetString() ?? "Error" : "Error";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private void StartCancel(Guid id, string folio) { _cancelId = id; _cancelFolio = folio; _cancelReason = string.Empty; }

    private async Task ExecuteCancelAsync()
    {
        _busy = true;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var resp = await client.PostAsJsonAsync($"/api/production/orders/{_cancelId}/cancel", new { userId = "web", reason = _cancelReason });
            if (resp.IsSuccessStatusCode) { _message = "Orden cancelada."; _cancelId = Guid.Empty; await LoadOrdersAsync(); }
            else { var b = await resp.Content.ReadFromJsonAsync<JsonElement>(); _error = b.TryGetProperty("message", out var m) ? m.GetString() ?? "Error" : "Error"; }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    // ─── Display ──────────────────────────────────────────────────────────────
    private static string StatusColor(string s) => s switch { "draft" => "#6b7280", "planned" => "#3b82f6", "exploded" => "#8b5cf6", "reserved" => "#f59e0b", "in_progress" => "#f97316", "completed" => "#10b981", "closed" => "#059669", "cancelled" => "#ef4444", _ => "#6b7280" };
    private static string StatusLabel(string s) => s switch { "draft" => "Borrador", "planned" => "Planeada", "exploded" => "Explosionada", "reserved" => "Reservada", "in_progress" => "En proceso", "completed" => "Completada", "closed" => "Cerrada", "cancelled" => "Cancelada", _ => s };
    private static string PriorityColor(int p) => p switch { 2 => "#f59e0b", 3 => "#ef4444", _ => "#10b981" };
    private static string PriorityLabel(int p) => p switch { 2 => "Alta", 3 => "Urgente", _ => "Normal" };

    // ─── Models ───────────────────────────────────────────────────────────────
    private sealed record CompanyOption(Guid CompanyId, string Name, Guid TenantId);
    private sealed record BranchOption(Guid BranchId, string Name);
    private sealed record WarehouseOption(Guid WarehouseId, string Name);
    private sealed record FinishedProductOption(Guid FinishedProductId, string Code, string Name);
    private sealed record CustomerOption(Guid CustomerId, string Code, string Name, string LegalName, bool IsActive, Guid TenantId);
    private sealed record AddressOption(Guid AddressId, string AddressType, bool IsPrimary, string FullAddress);

    private sealed class LegalEntityOption
    {
        public Guid LegalEntityId { get; set; }
        public string LegalName { get; set; } = string.Empty;
        public string TaxId { get; set; } = string.Empty;
        public bool IsPrimary { get; set; }
    }

    private sealed class QuickLocationResult
    {
        public Guid LocationId { get; set; }
        public string FullAddress { get; set; } = string.Empty;
        public bool IsPrimary { get; set; }
    }

    private sealed class SizeQty
    {
        public Guid SizeRunSizeId { get; set; }
        public string SizeCode { get; set; } = string.Empty;
        public int Qty { get; set; }
    }

    private sealed class OrderLineForm
    {
        public Guid FinishedProductId { get; set; }
        public string ProductCode { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public string ProductSearch { get; set; } = string.Empty;
        public bool ShowDropdown { get; set; }
        public Guid? ProductStyleId { get; set; }
        public Guid? ProductSizeRunId { get; set; }
        public string CustomerPoReference { get; set; } = string.Empty;
        public decimal UnitPrice { get; set; }
        public decimal DiscountPercent { get; set; }
        public string Notes { get; set; } = string.Empty;
        public List<SizeQty> Sizes { get; set; } = [];
        public bool LoadingSizes { get; set; }
        public string NcPreview { get; set; } = string.Empty;
        // Per-line overrides
        public Guid? WarehouseId { get; set; }
        public Guid? ShipToAddressId { get; set; }
        public string ShipToAddressText { get; set; } = string.Empty;
        public Guid? LegalEntityId { get; set; }
        public string LegalName { get; set; } = string.Empty;
        public bool ShowShippingOverrides { get; set; }

        public int TotalQty => Sizes.Sum(s => s.Qty);
        public decimal LineTotal => Math.Round(TotalQty * UnitPrice * (1 - DiscountPercent / 100m), 2);
    }

    private sealed class ProductSizesResult
    {
        public Guid? ProductSizeRunId { get; set; }
        public Guid? ProductStyleId { get; set; }
        public List<SizeEntry> Sizes { get; set; } = [];
        public sealed class SizeEntry { public Guid SizeRunSizeId { get; set; } public string SizeCode { get; set; } = string.Empty; public int Sequence { get; set; } }
    }

    private sealed class PriceLookupResult
    {
        public decimal Price { get; set; }
        public bool Found { get; set; }
    }

    private sealed record OrderListResult(int Total, int Page, int PageSize, List<OrderSummary> Items);

