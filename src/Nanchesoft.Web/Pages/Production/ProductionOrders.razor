    // ─── Init ─────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
        var t1 = client.GetFromJsonAsync<List<CompanyOption>>("/api/organization/companies");
        var t2 = client.GetFromJsonAsync<List<FinishedProductOption>>("/api/products/finished-products/options");
        var t3 = client.GetFromJsonAsync<List<CustomerOption>>("/api/third-parties/customers");
        await Task.WhenAll(t1, t2, t3);

        _allCompanies = t1.Result ?? [];
        _products = t2.Result ?? [];
        _allCustomers = (t3.Result ?? []).Where(c => c.IsActive).ToList();

        // Filter by current tenant
        var tenantId = AuthState.TenantId;
        _tenantCompanies = tenantId.HasValue
            ? _allCompanies.Where(c => c.TenantId == tenantId.Value).ToList()
            : _allCompanies;

        _tenantCustomers = tenantId.HasValue
            ? _allCustomers.Where(c => c.TenantId == tenantId.Value).ToList()
            : _allCustomers;

        if (_tenantCompanies.Count > 0) _selectedCompanyId = _tenantCompanies[0].CompanyId;
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        _loading = true; _error = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var url = $"/api/production/orders?pageSize=200&companyId={_selectedCompanyId}";
            if (!string.IsNullOrWhiteSpace(_statusFilter)) url += $"&status={_statusFilter}";
            var resp = await client.GetFromJsonAsync<OrderListResult>(url);
            _orders = resp?.Items ?? [];
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task OnCompanyFilterChangedAsync(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedCompanyId = id;
            await LoadOrdersAsync();
        }
    }

    // ─── Form open/close ──────────────────────────────────────────────────────
    private async Task OpenNewFormAsync()
    {
        _formError = string.Empty;
        var today = DateOnly.FromDateTime(DateTime.Today);
        var dow = (int)DateTime.Today.DayOfWeek;
        var monday = today.AddDays(dow == 0 ? -6 : 1 - dow);
        var weekNum = System.Globalization.ISOWeek.GetWeekOfYear(monday.ToDateTime(TimeOnly.MinValue));

        _formCompanyId = _selectedCompanyId != Guid.Empty ? _selectedCompanyId : (_tenantCompanies.Count > 0 ? _tenantCompanies[0].CompanyId : Guid.Empty);
        _formWeekCode = $"{today.Year}-W{weekNum:D2}";
        _formSeason = today.Year.ToString();
        _formStartDate = monday;
        _formEndDate = monday.AddDays(4);
        _formDeliveryDate = monday.AddDays(7);
        _formCancellationDate = null;
        _formPriority = 1;
        _formNotes = string.Empty;
        _formReference = string.Empty;
        _formCustomerId = Guid.Empty;
        _formWarehouseId = null;
        _formLegalName = string.Empty;
        _formLegalEntityId = null;
        _formShipToAddressId = null;
        _formShipToAddressText = string.Empty;
        _customerAddresses = [];
        _customerLegalEntities = [];
        _formLines = [new OrderLineForm()];

        var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
        var bt = client.GetFromJsonAsync<List<BranchOption>>($"/api/organization/branches?companyId={_formCompanyId}");
        var wt = client.GetFromJsonAsync<List<WarehouseOption>>("/api/organization/warehouses");
        await Task.WhenAll(bt, wt);
        _branches = bt.Result ?? [];
        _warehouses = wt.Result ?? [];
        _formBranchId = _branches.Count > 0 ? _branches[0].BranchId : Guid.Empty;
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _formLines = []; _customerAddresses = []; }

    // ─── Form helpers ─────────────────────────────────────────────────────────
    private async Task OnFormCompanyChangedAsync()
    {
        var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
        _branches = await client.GetFromJsonAsync<List<BranchOption>>($"/api/organization/branches?companyId={_formCompanyId}") ?? [];
        _formBranchId = _branches.Count > 0 ? _branches[0].BranchId : Guid.Empty;
    }

    private async Task OnFormCustomerChangedAsync()
    {
        var cust = _tenantCustomers.FirstOrDefault(c => c.CustomerId == _formCustomerId);

        _formLegalEntityId = null;
        _formLegalName = string.Empty;
        _formShipToAddressId = null;
        _formShipToAddressText = string.Empty;
        _customerAddresses = [];
        _customerLegalEntities = [];

        if (_formCustomerId != Guid.Empty && _formCustomerId != default)
        {
            try
            {
                var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
                var t1 = client.GetFromJsonAsync<List<AddressOption>>($"/api/production/customer-addresses/{_formCustomerId}");
                var t2 = client.GetFromJsonAsync<List<LegalEntityOption>>($"/api/third-parties/customers/{_formCustomerId}/legal-entities");
                await Task.WhenAll(t1, t2);

                _customerAddresses = t1.Result ?? [];
                _customerLegalEntities = t2.Result ?? [];

                var primary = _customerAddresses.FirstOrDefault(a => a.IsPrimary) ?? _customerAddresses.FirstOrDefault();
                if (primary is not null) { _formShipToAddressId = primary.AddressId; _formShipToAddressText = primary.FullAddress; }

                var primaryLe = _customerLegalEntities.FirstOrDefault(x => x.IsPrimary) ?? _customerLegalEntities.FirstOrDefault();
                if (primaryLe is not null) { _formLegalEntityId = primaryLe.LegalEntityId; _formLegalName = primaryLe.LegalName; }
                else _formLegalName = cust?.LegalName ?? string.Empty;
            }
            catch { _formLegalName = cust?.LegalName ?? string.Empty; }

            foreach (var line in _formLines.Where(l => l.FinishedProductId != Guid.Empty && l.UnitPrice == 0))
                await TryLoadPriceAsync(line);
        }
    }

