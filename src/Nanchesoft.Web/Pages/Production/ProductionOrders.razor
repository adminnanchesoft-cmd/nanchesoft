    private void PropagateReferenceToLines()
    {
        foreach (var line in _formLines.Where(l => string.IsNullOrWhiteSpace(l.CustomerPoReference)))
            line.CustomerPoReference = _formReference;
    }

    private void AddLine()
    {
        var line = new OrderLineForm
        {
            CustomerPoReference = _formReference,
            WarehouseId = _formWarehouseId,
            ShipToAddressId = _formShipToAddressId,
            ShipToAddressText = _formShipToAddressText,
            LegalEntityId = _formLegalEntityId,
            LegalName = _formLegalName
        };
        _formLines.Add(line);
