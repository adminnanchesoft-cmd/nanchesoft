    private void OpenQuickAddLegalEntity()
    {
        _qaLeName = string.Empty; _qaLeTaxId = string.Empty; _qaLeError = string.Empty;
        _showQaLegalEntity = true;
    }

    private async Task SaveQuickLegalEntityAsync()
    {
        if (string.IsNullOrWhiteSpace(_qaLeName)) { _qaLeError = "El nombre es obligatorio."; return; }
        _qaLeBusy = true; _qaLeError = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var resp = await client.PostAsJsonAsync(
                $"/api/third-parties/customers/{_formCustomerId}/quick-add-legal-entity",
                new { legalName = _qaLeName, taxId = _qaLeTaxId, isPrimary = false, userId = "web" });
            if (resp.IsSuccessStatusCode)
            {
                var dto = await resp.Content.ReadFromJsonAsync<LegalEntityOption>();
                if (dto is not null)
                {
                    _customerLegalEntities.Add(dto);
                    _formLegalEntityId = dto.LegalEntityId;
                    _formLegalName = dto.LegalName;
                }
                _showQaLegalEntity = false;
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _qaLeError = body.TryGetProperty("message", out var m) ? m.GetString() ?? "Error" : "Error al guardar.";
            }
        }
        catch (Exception ex) { _qaLeError = ex.Message; }
        finally { _qaLeBusy = false; }
    }

    private void OpenQuickAddLocation()
    {
        _qaLocName = _qaLocStreet = _qaLocExtNum = _qaLocNeighborhood = _qaLocZip = _qaLocError = string.Empty;
        _showQaLocation = true;
    }

    private async Task SaveQuickLocationAsync()
    {
        if (string.IsNullOrWhiteSpace(_qaLocStreet) && string.IsNullOrWhiteSpace(_qaLocName))
        { _qaLocError = "Ingresa al menos el nombre de la ubicación o la calle."; return; }
        _qaLocBusy = true; _qaLocError = string.Empty;
        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var resp = await client.PostAsJsonAsync(
                $"/api/third-parties/customers/{_formCustomerId}/quick-add-location",
                new { locationName = _qaLocName, street = _qaLocStreet, exteriorNumber = _qaLocExtNum, neighborhood = _qaLocNeighborhood, zipCode = _qaLocZip, isPrimary = false, userId = "web" });
            if (resp.IsSuccessStatusCode)
            {
                var dto = await resp.Content.ReadFromJsonAsync<QuickLocationResult>();
                if (dto is not null)
                {
                    var opt = new AddressOption(dto.LocationId, "shipping", dto.IsPrimary, dto.FullAddress);
                    _customerAddresses.Add(opt);
                    _formShipToAddressId = opt.AddressId;
                    _formShipToAddressText = opt.FullAddress;
                }
                _showQaLocation = false;
            }
            else
            {
                var body = await resp.Content.ReadFromJsonAsync<JsonElement>();
                _qaLocError = body.TryGetProperty("message", out var m) ? m.GetString() ?? "Error" : "Error al guardar.";
            }
        }
        catch (Exception ex) { _qaLocError = ex.Message; }
        finally { _qaLocBusy = false; }
    }

