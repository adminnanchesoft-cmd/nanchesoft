    private sealed record CompanyRow(Guid Id, string Name);
    private sealed record ErrorBody(string Message);

    private sealed class QcRecordRow
    {
        public Guid Id { get; set; }
        public string Folio { get; set; } = string.Empty;
        public Guid CompanyId { get; set; }
        public Guid ProductionOrderId { get; set; }
        public DateOnly InspectionDate { get; set; }
        public string InspectorName { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string Result { get; set; } = string.Empty;
        public int TotalUnitsInspected { get; set; }
        public int TotalUnitsApproved { get; set; }
        public int TotalUnitsRejected { get; set; }
        public int DefectCount { get; set; }
        public string Notes { get; set; } = string.Empty;
    }

    private sealed class QcDetailResult
    {
        public Guid Id { get; set; }
        public string Folio { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public int TotalUnitsInspected { get; set; }
