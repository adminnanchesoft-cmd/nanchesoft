@page "/inventory/kardex-by-item"
@using Nanchesoft.Web.Services.Inventory
@inject InventoryApiService InventoryApiService

<PageTitle>Kardex por producto | Nanchesoft</PageTitle>

@if (_loading)
{
    <div class="p-4">Cargando...</div>
}
else
{
    <div class="container-fluid py-3">
        <div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
            <div>
                <div class="text-uppercase small text-secondary fw-semibold">Inventario · kardex por producto</div>
                <h2 class="mb-1">Kardex por producto</h2>
                <div class="text-secondary">Selecciona un producto para ver movimientos, costo y saldo.</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" href="/inventory/kardex">Volver al kardex</a>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label">Producto</label>
                        <select class="form-select" @bind="SelectedItemIdText">
                            <option value="">Seleccione...</option>
                            @foreach (var item in _lookups.Items)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" @onclick="LoadRowsAsync" disabled="@(!SelectedItemId.HasValue)">Consultar</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">
                <strong>Movimientos</strong>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Almacén</th>
                                <th>Tipo</th>
                                <th>Documento</th>
                                <th>Entrada</th>
                                <th>Salida</th>
                                <th>Saldo</th>
                                <th>Costo U.</th>
                                <th>Costo T.</th>
                                <th>Referencia</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_rows.Count == 0)
                            {
                                <tr><td colspan="10" class="text-center py-4 text-secondary">No hay movimientos para mostrar.</td></tr>
                            }
                            else
                            {
                                @foreach (var row in _rows)
                                {
                                    <tr>
                                        <td>@row.MovementDate.ToString("yyyy-MM-dd")</td>
                                        <td>@row.WarehouseName</td>
                                        <td>@row.MovementType</td>
                                        <td>@row.DocumentType</td>
                                        <td>@row.QuantityIn</td>
                                        <td>@row.QuantityOut</td>
                                        <td>@row.BalanceAfter</td>
                                        <td>@row.UnitCost</td>
                                        <td>@row.TotalCost</td>
                                        <td>@row.Reference</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private InventoryLookups _lookups = new();
    private List<InventoryKardexDetailRow> _rows = [];
    private bool _loading = true;
    private Guid? SelectedItemId;

    private string SelectedItemIdText
    {
        get => SelectedItemId?.ToString() ?? string.Empty;
        set => SelectedItemId = Guid.TryParse(value, out var parsed) ? parsed : null;
    }

    protected override async Task OnInitializedAsync()
    {
        _lookups = (await InventoryApiService.GetEditorDefinitionAsync("inventory-entries")).Lookups;
        _loading = false;
    }

    private async Task LoadRowsAsync()
    {
        if (!SelectedItemId.HasValue) return;
        _rows = await InventoryApiService.GetKardexByItemAsync(SelectedItemId.Value);
    }
}
