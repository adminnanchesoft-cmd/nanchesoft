@page "/inventory/print-center"
@inject InventoryApiService InventoryApiService

<PageTitle>Formatos inventario | Nanchesoft</PageTitle>

@if (_sections.Count == 0)
{
    <div class="p-4">Cargando formatos...</div>
}
else
{
    <div class="container-fluid py-3">
        <h1>Formatos de inventario</h1>
        <p class="text-secondary">Imprime entradas, salidas, traspasos, ajustes y conteos físicos.</p>
        @foreach (var grp in _sections)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header"><strong>@grp.Title</strong></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr><th>Folio</th><th>Fecha</th><th>Estatus</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var row in grp.Rows)
                                {
                                    <tr>
                                        <td>@GetValue(row, "Folio")</td>
                                        <td>@GetValue(row, grp.DateField)</td>
                                        <td>@GetValue(row, "Status")</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(GetValue(row, grp.KeyField)))
                                            {
                                                <a class="btn btn-sm btn-outline-primary" target="_blank" href="/inventory/print/@grp.CatalogKey/@GetValue(row, grp.KeyField)">Imprimir</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private readonly List<PrintSection> _sections = [];

    protected override async Task OnInitializedAsync()
    {
        _sections.Add(new PrintSection("inventory-entries", "Entradas", "InventoryEntryId", "EntryDate", (await InventoryApiService.GetCatalogAsync("inventory-entries")).Rows));
        _sections.Add(new PrintSection("inventory-exits", "Salidas", "InventoryExitId", "ExitDate", (await InventoryApiService.GetCatalogAsync("inventory-exits")).Rows));
        _sections.Add(new PrintSection("inventory-transfers", "Traspasos", "InventoryTransferId", "TransferDate", (await InventoryApiService.GetCatalogAsync("inventory-transfers")).Rows));
        _sections.Add(new PrintSection("inventory-adjustments", "Ajustes", "InventoryAdjustmentId", "AdjustmentDate", (await InventoryApiService.GetCatalogAsync("inventory-adjustments")).Rows));
        _sections.Add(new PrintSection("physical-counts", "Conteos físicos", "PhysicalCountId", "CountDate", (await InventoryApiService.GetCatalogAsync("physical-counts")).Rows));
    }

    private static string GetValue(Dictionary<string, object?> row, string key)
        => row.TryGetValue(key, out var value) ? value?.ToString() ?? string.Empty : string.Empty;

    private sealed record PrintSection(string CatalogKey, string Title, string KeyField, string DateField, List<Dictionary<string, object?>> Rows);
}
