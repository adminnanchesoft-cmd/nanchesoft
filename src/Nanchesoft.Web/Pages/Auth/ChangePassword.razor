@page "/change-password"
@layout AuthLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject Nanchesoft.Web.State.AuthState AuthState

<PageTitle>Cambiar contraseña | Nanchesoft ERP</PageTitle>

<div class="ns-lux-form">
    <div class="ns-lux-form__kicker">Primer acceso</div>
    <h2 class="ns-lux-form__title">Cambia tu contraseña</h2>
    <p class="ns-lux-form__subtitle">
        Por seguridad, este usuario debe cambiar su contraseña antes de entrar al ERP.
    </p>

    <EditForm Model="@model" OnValidSubmit="HandleSubmitAsync">
        <DataAnnotationsValidator />

        <div class="ns-lux-form__group">
            <label class="ns-lux-form__label">Contraseña actual</label>
            <div class="ns-lux-input">
                <span class="ns-lux-input__icon">●</span>
                <input @bind="model.CurrentPassword" type="password" class="ns-lux-input__control" autocomplete="current-password" placeholder="Admin123*" />
            </div>
        </div>

        <div class="ns-lux-form__group">
            <label class="ns-lux-form__label">Nueva contraseña</label>
            <div class="ns-lux-input">
                <span class="ns-lux-input__icon">●</span>
                <input @bind="model.NewPassword" @bind:event="oninput" type="password" class="ns-lux-input__control" autocomplete="new-password" />
            </div>

            @if (!string.IsNullOrEmpty(model.NewPassword))
            {
                <div class="ns-pwmeter">
                    <div class="ns-pwmeter__track">
                        <div class="ns-pwmeter__fill ns-pwmeter__fill--@(StrengthClass)" style="width:@(StrengthPercent)%"></div>
                    </div>
                    <div class="ns-pwmeter__label ns-pwmeter__label--@(StrengthClass)">@StrengthText</div>
                </div>

                <ul class="ns-pwreq">
                    <li class="@(HasMinLength ? "ns-pwreq--ok" : "")">
                        <span class="ns-pwreq__mark">@(HasMinLength ? "✓" : "○")</span> Mínimo 8 caracteres
                    </li>
                    <li class="@(HasUpper ? "ns-pwreq--ok" : "")">
                        <span class="ns-pwreq__mark">@(HasUpper ? "✓" : "○")</span> Una mayúscula (A-Z)
                    </li>
                    <li class="@(HasLower ? "ns-pwreq--ok" : "")">
                        <span class="ns-pwreq__mark">@(HasLower ? "✓" : "○")</span> Una minúscula (a-z)
                    </li>
                    <li class="@(HasDigit ? "ns-pwreq--ok" : "")">
                        <span class="ns-pwreq__mark">@(HasDigit ? "✓" : "○")</span> Un número (0-9)
                    </li>
                    <li class="@(HasSymbol ? "ns-pwreq--ok" : "")">
                        <span class="ns-pwreq__mark">@(HasSymbol ? "✓" : "○")</span> Un símbolo (!@@#$%...)
                    </li>
                </ul>
            }
        </div>

        <div class="ns-lux-form__group">
            <label class="ns-lux-form__label">Confirmar nueva contraseña</label>
            <div class="ns-lux-input">
                <span class="ns-lux-input__icon">●</span>
                <input @bind="model.ConfirmPassword" @bind:event="oninput" type="password" class="ns-lux-input__control" autocomplete="new-password" />
            </div>
            @if (!string.IsNullOrEmpty(model.ConfirmPassword) && model.NewPassword != model.ConfirmPassword)
            {
                <div class="ns-pwmismatch">Las contraseñas no coinciden.</div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="ns-lux-alert ns-lux-alert--error">@errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="ns-lux-alert ns-lux-alert--info">@successMessage</div>
        }

        <button type="submit" class="ns-lux-form__submit" disabled="@(isLoading || !CanSubmit)">
            <span>@(isLoading ? "Guardando..." : "Guardar nueva contraseña")</span>
            <span class="ns-lux-form__submitarrow">→</span>
        </button>
    </EditForm>
</div>

<style>
    .ns-lux-form { position: relative; z-index: 1; }
    .ns-lux-form__kicker { color: #2e67ee; font-size: .82rem; text-transform: uppercase; letter-spacing: .18em; font-weight: 900; margin-bottom: 14px; }
    .ns-lux-form__title { margin: 0; font-size: 2.2rem; line-height: .98; letter-spacing: -.04em; font-weight: 900; color: #122441; }
    .ns-lux-form__subtitle { margin: 14px 0 26px; color: rgba(18, 36, 65, .72); line-height: 1.7; font-size: .98rem; }
    .ns-lux-form__group + .ns-lux-form__group { margin-top: 18px; }
    .ns-lux-form__label { display: block; margin-bottom: 10px; color: #203150; font-size: .94rem; font-weight: 800; }
    .ns-lux-input { display: grid; grid-template-columns: 56px minmax(0, 1fr); align-items: center; min-height: 64px; border-radius: 22px; background: rgba(255,255,255,.84); border: 1px solid rgba(67, 112, 197, .18); box-shadow: inset 0 1px 0 rgba(255,255,255,.85), 0 12px 30px rgba(33, 73, 151, .08); overflow: hidden; }
    .ns-lux-input__icon { display: grid; place-items: center; align-self: stretch; color: #2f5dcc; font-size: 1.05rem; font-weight: 900; border-right: 1px solid rgba(67, 112, 197, .14); background: linear-gradient(180deg, rgba(233, 242, 255, .96), rgba(245, 249, 255, .84)); }
    .ns-lux-input__control { width: 100%; border: 0; outline: none; padding: 0 18px; background: transparent; color: #142542; font-size: 1rem; }
    .ns-lux-alert { margin-top: 18px; padding: 14px 16px; border-radius: 18px; font-size: .92rem; line-height: 1.55; border: 1px solid transparent; }
    .ns-lux-alert--error { color: #92253d; background: rgba(255, 228, 234, .92); border-color: rgba(233, 128, 150, .38); }
    .ns-lux-alert--info { color: #19335e; background: rgba(234, 243, 255, .88); border-color: rgba(121, 162, 235, .24); }
    .ns-lux-form__submit { width: 100%; margin-top: 22px; min-height: 64px; border: 0; border-radius: 22px; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 0 22px; background: linear-gradient(135deg, #1f55d9 0%, #2896f3 55%, #59d4ff 100%); color: #ffffff; font-size: 1rem; font-weight: 900; letter-spacing: .02em; cursor: pointer; box-shadow: 0 20px 42px rgba(32, 90, 214, .24); }
    .ns-lux-form__submit:disabled { opacity: .72; cursor: default; }
    .ns-lux-form__submitarrow { font-size: 1.25rem; }

    /* ===== Medidor de fuerza de contraseña ===== */
    .ns-pwmeter { margin-top: 12px; display: flex; align-items: center; gap: 12px; }
    .ns-pwmeter__track { flex: 1; height: 8px; border-radius: 999px; background: rgba(67, 112, 197, .14); overflow: hidden; }
    .ns-pwmeter__fill { height: 100%; border-radius: 999px; transition: width .25s ease, background .25s ease; }
    .ns-pwmeter__fill--weak { background: linear-gradient(90deg, #f87171, #ef4444); }
    .ns-pwmeter__fill--fair { background: linear-gradient(90deg, #fbbf24, #f59e0b); }
    .ns-pwmeter__fill--good { background: linear-gradient(90deg, #facc15, #eab308); }
    .ns-pwmeter__fill--strong { background: linear-gradient(90deg, #4ade80, #16a34a); }
    .ns-pwmeter__label { font-size: .82rem; font-weight: 800; min-width: 56px; text-align: right; }
    .ns-pwmeter__label--weak { color: #ef4444; }
    .ns-pwmeter__label--fair { color: #f59e0b; }
    .ns-pwmeter__label--good { color: #ca8a04; }
    .ns-pwmeter__label--strong { color: #16a34a; }

    .ns-pwreq { list-style: none; margin: 14px 0 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 7px 16px; }
    .ns-pwreq li { display: flex; align-items: center; gap: 8px; font-size: .82rem; color: rgba(18, 36, 65, .55); font-weight: 600; }
    .ns-pwreq li.ns-pwreq--ok { color: #16a34a; }
    .ns-pwreq__mark { display: inline-flex; width: 16px; justify-content: center; font-weight: 900; }

    .ns-pwmismatch { margin-top: 10px; color: #92253d; font-size: .85rem; font-weight: 700; }

    @@media (max-width: 520px) {
        .ns-pwreq { grid-template-columns: 1fr; }
    }
</style>

@code {
    private readonly ChangePasswordViewModel model = new();
    private bool isLoading;
    private string? errorMessage;
    private string? successMessage;

    // ===== Medidor de fuerza de contraseña (solo lectura, computa en tiempo real) =====
    private bool HasMinLength => model.NewPassword.Length >= 8;
    private bool HasUpper => model.NewPassword.Any(char.IsUpper);
    private bool HasLower => model.NewPassword.Any(char.IsLower);
    private bool HasDigit => model.NewPassword.Any(char.IsDigit);
    private bool HasSymbol => model.NewPassword.Any(c => !char.IsLetterOrDigit(c));

    private int RequirementsMet =>
        (HasMinLength ? 1 : 0) + (HasUpper ? 1 : 0) + (HasLower ? 1 : 0) + (HasDigit ? 1 : 0) + (HasSymbol ? 1 : 0);

    private string StrengthClass => RequirementsMet switch
    {
        <= 1 => "weak",
        2 => "fair",
        3 or 4 => "good",
        _ => "strong"
    };

    private string StrengthText => RequirementsMet switch
    {
        <= 1 => "Débil",
        2 => "Regular",
        3 or 4 => "Buena",
        _ => "Fuerte"
    };

    private int StrengthPercent => RequirementsMet switch
    {
        0 => 8,
        1 => 22,
        2 => 45,
        3 => 65,
        4 => 84,
        _ => 100
    };

    private bool CanSubmit =>
        RequirementsMet >= 4
        && !string.IsNullOrEmpty(model.NewPassword)
        && model.NewPassword == model.ConfirmPassword
        && !string.IsNullOrWhiteSpace(model.CurrentPassword);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthService.RestoreSessionAsync();

        if (!AuthState.IsAuthenticated || !AuthState.UserId.HasValue)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (isLoading)
            return;

        if (!AuthState.UserId.HasValue)
        {
            errorMessage = "No se encontró la sesión del usuario.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await AuthService.ChangePasswordAsync(AuthState.UserId.Value, model.CurrentPassword, model.NewPassword, model.ConfirmPassword);
            if (!result.Success)
            {
                errorMessage = result.ErrorMessage ?? "No fue posible cambiar la contraseña.";
                return;
            }

            successMessage = "Contraseña actualizada correctamente. Entrando al ERP...";
            await Task.Delay(700);
            Navigation.NavigateTo(AuthState.IsPlatformOwner ? "/platform/tenants" : "/dashboard", forceLoad: false);
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed class ChangePasswordViewModel
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
