    .ns-login3-submit {
        position: relative;
        height: 52px;
        border: 0;
        border-radius: 17px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: #02101d;
        background: linear-gradient(135deg, #e6faff 0%, #64e7ff 38%, #20a8ff 100%);
        box-shadow: 0 18px 42px rgba(20, 200, 255, .25), inset 0 1px 0 rgba(255,255,255,.52);
        font-size: .97rem;
        font-weight: 950;
        letter-spacing: -.01em;
        cursor: pointer;
        transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
        overflow: hidden;
    }

    .ns-login3-submit::before {
        content: "";
        position: absolute;
        inset: 0;
        transform: translateX(-120%);
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.42), transparent);
        transition: transform .48s ease;
    }

    .ns-login3-submit:hover:not(:disabled) {
        transform: translateY(-1px);
        filter: brightness(1.04);
        box-shadow: 0 24px 54px rgba(20, 200, 255, .32), inset 0 1px 0 rgba(255,255,255,.58);
