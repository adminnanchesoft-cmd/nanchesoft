    }

    .ns-login3-mobile-logo {
        display: none;
        position: relative;
        z-index: 1;
        margin: -6px 0 20px;
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(100, 231, 255, .20);
        box-shadow: 0 22px 56px rgba(0, 0, 0, .30);
    }

    .ns-login3-mobile-logo img {
        display: block;
        width: 100%;
        aspect-ratio: 3 / 1.55;
        object-fit: cover;
        object-position: center 38%;
    }

    .ns-login3-card__head {
        position: relative;
        z-index: 1;
        margin-bottom: 24px;
    }

    .ns-login3-card__badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 15px;
        padding: 7px 11px;
        border-radius: 999px;
        background: rgba(20, 200, 255, .11);
