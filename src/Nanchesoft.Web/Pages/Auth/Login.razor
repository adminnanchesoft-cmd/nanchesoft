    }

    .ns-login3-card__title {
        margin: 0;
        color: #fff;
        font-size: 2rem;
        font-weight: 950;
        letter-spacing: -.048em;
        line-height: 1.05;
        text-wrap: balance;
    }

    .ns-login3-card__sub {
        margin: 11px 0 0;
        color: rgba(226, 242, 255, .76);
        font-size: .96rem;
