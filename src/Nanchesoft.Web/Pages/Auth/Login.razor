        background: linear-gradient(135deg, rgba(10, 29, 62, .95), rgba(3, 8, 22, .98));
        box-shadow:
            0 0 0 4px rgba(100, 231, 255, .10),
            0 14px 36px rgba(0, 120, 212, .36),
            inset 0 1px 0 rgba(255,255,255,.16);
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ns-login3-brand__img img {
        width: 110px;
        height: 74px;
        object-fit: cover;
        object-position: 42% 30%;
        transform: scale(1.28);
    }

    .ns-login3-brand__text {
        display: flex;
        flex-direction: column;
        gap: 3px;
        line-height: 1.1;
    }

    .ns-login3-brand__text strong {
        font-size: 1.2rem;
        font-weight: 950;
        letter-spacing: -.032em;
        color: #fff;
        text-shadow: 0 2px 12px rgba(0,0,0,.28);
