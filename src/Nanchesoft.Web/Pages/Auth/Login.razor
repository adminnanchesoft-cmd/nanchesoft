@page "/login"
@layout AuthLayout
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Acceso seguro | Nanchesoft Cloud ERP</PageTitle>

<div class="ns-loginlight">
    <div class="ns-loginlight__logo">
        <img src="images/brand/nanchesoft_full_light.svg" alt="Nanchesoft Cloud" />
    </div>

    <div class="ns-loginlight__head">
        <h2 class="ns-loginlight__title">Inicia sesión</h2>
        <p class="ns-loginlight__sub">Entra a tu cuenta para continuar.</p>
    </div>

    <EditForm Model="@model" OnValidSubmit="HandleLoginAsync" class="ns-loginlight__body">
        <DataAnnotationsValidator />

        <div class="ns-loginlight__field">
            <label class="ns-loginlight__label" for="ns-login-user">Usuario o correo</label>
            <div class="ns-loginlight__wrap">
                <span class="ns-loginlight__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" />
                    </svg>
                </span>
                <input id="ns-login-user"
                       @bind="model.UsernameOrEmail"
                       class="ns-loginlight__input"
                       autocomplete="username"
                       placeholder="usuario@empresa.com" />
            </div>
        </div>

        <div class="ns-loginlight__field">
            <div class="ns-loginlight__field-row">
                <label class="ns-loginlight__label" for="ns-login-pass">Contraseña</label>
                <a class="ns-loginlight__link" href="#" @onclick:preventDefault="true" @onclick="ForgotPassword">
                    ¿Necesitas ayuda?
                </a>
            </div>
            <div class="ns-loginlight__wrap">
                <span class="ns-loginlight__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="11" width="16" height="10" rx="2" />
                        <path d="M8 11V7a4 4 0 0 1 8 0v4" />
                    </svg>
                </span>
                <input id="ns-login-pass"
                       @bind="model.Password"
                       @bind:event="oninput"
                       type="@(_showPassword ? "text" : "password")"
                       class="ns-loginlight__input"
                       autocomplete="current-password"
                       placeholder="Contraseña" />
                <button type="button" class="ns-loginlight__eye" @onclick="TogglePassword" aria-label="@(_showPassword ? "Ocultar contraseña" : "Mostrar contraseña")">
                    @if (_showPassword)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 12s3.5-7 10-7c2.4 0 4.5.9 6.2 2.1" />
                            <path d="M22 12s-3.5 7-10 7c-2.4 0-4.5-.9-6.2-2.1" />
                            <line x1="3" y1="3" x2="21" y2="21" />
                            <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2" />
                        </svg>
                    }
                </button>
            </div>
        </div>

        <label class="ns-loginlight__remember">
            <input type="checkbox" @bind="model.RememberMe" />
            <span class="ns-loginlight__remember-box" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            </span>
            Mantener mi sesión en este dispositivo
        </label>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="ns-loginlight__alert ns-loginlight__alert--error" role="alert">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                <span>@errorMessage</span>
            </div>
        }

        <button type="submit" class="ns-loginlight__submit" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="ns-loginlight__spin" aria-hidden="true"></span>
                <span>Entrando…</span>
            }
            else
            {
                <span>Entrar a Nanchesoft Cloud</span>
                <svg class="ns-loginlight__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="M13 6l6 6-6 6" /></svg>
            }
        </button>
    </EditForm>
</div>

<style>
    /* ========================================================
       NANCHESOFT LOGIN · Tema claro premium estilo Apple
       ======================================================== */

    .ns-loginlight {
        position: relative;
        width: 100%;
        animation: ns-loginlight-rise .4s cubic-bezier(.16, 1, .3, 1) both;
    }

    @@keyframes ns-loginlight-rise {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .ns-loginlight__logo {
        display: none;
        margin-bottom: 22px;
        text-align: center;
    }

    .ns-loginlight__logo img {
        height: 56px;
        width: auto;
    }

    .ns-loginlight__head {
        margin-bottom: 26px;
    }

    .ns-loginlight__title {
        margin: 0;
        color: #0b1f3c;
        font-size: 2rem;
        font-weight: 850;
        letter-spacing: -.03em;
    }

    .ns-loginlight__sub {
        margin: 8px 0 0;
        color: #51637c;
        font-size: .96rem;
        font-weight: 500;
    }

    .ns-loginlight__body {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .ns-loginlight__field {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .ns-loginlight__field-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .ns-loginlight__label {
        color: #1f3350;
        font-size: .82rem;
        font-weight: 750;
    }

    .ns-loginlight__link {
        color: #0078d4;
        font-size: .8rem;
        font-weight: 700;
        text-decoration: none;
        transition: color .14s ease;
    }

    .ns-loginlight__link:hover {
        color: #14c8ff;
        text-decoration: underline;
    }

    .ns-loginlight__wrap {
        position: relative;
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr) auto;
        align-items: center;
        height: 52px;
        background: #fff;
        border: 1px solid #dce4ee;
        border-radius: 14px;
        transition: border-color .14s ease, box-shadow .14s ease;
    }

    .ns-loginlight__wrap:focus-within {
        border-color: #14c8ff;
        box-shadow: 0 0 0 4px rgba(20, 200, 255, .14);
    }

    .ns-loginlight__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #0078d4;
    }

    .ns-loginlight__input {
        min-width: 0;
        width: 100%;
        height: 100%;
        border: 0;
        outline: 0;
        background: transparent;
        color: #0b1f3c;
        font-size: .96rem;
        font-weight: 600;
    }

    .ns-loginlight__input::placeholder {
        color: #9aa9bd;
        font-weight: 450;
    }

    .ns-loginlight__eye {
        width: 42px;
        height: 42px;
        margin-right: 4px;
        border: 0;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #7888a0;
        background: transparent;
        cursor: pointer;
        transition: background .14s ease, color .14s ease;
    }

    .ns-loginlight__eye:hover {
        color: #0078d4;
        background: rgba(0, 120, 212, .07);
    }

    .ns-loginlight__remember {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        color: #51637c;
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        user-select: none;
    }

    .ns-loginlight__remember input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .ns-loginlight__remember-box {
        width: 19px;
        height: 19px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        background: #fff;
        border: 1.5px solid #cbd5e1;
        transition: background .14s ease, border-color .14s ease;
        flex: 0 0 auto;
    }

    .ns-loginlight__remember-box svg {
        opacity: 0;
        transform: scale(.7);
        transition: opacity .14s ease, transform .14s ease;
    }

    .ns-loginlight__remember input:checked + .ns-loginlight__remember-box {
        background: linear-gradient(135deg, #14c8ff, #0078d4);
        border-color: transparent;
    }

    .ns-loginlight__remember input:checked + .ns-loginlight__remember-box svg {
        opacity: 1;
        transform: scale(1);
    }

    .ns-loginlight__alert {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 10px;
        align-items: flex-start;
        padding: 12px 13px;
        border-radius: 12px;
        font-size: .84rem;
        font-weight: 650;
        line-height: 1.42;
    }

    .ns-loginlight__alert--error {
        color: #b91c1c;
        background: #fef2f2;
        border: 1px solid #fecaca;
    }

    .ns-loginlight__alert svg {
        margin-top: 1px;
        flex: 0 0 auto;
    }

    .ns-loginlight__submit {
        position: relative;
        height: 52px;
        margin-top: 4px;
        border: 0;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: #fff;
        background: linear-gradient(135deg, #14c8ff 0%, #0078d4 100%);
        box-shadow: 0 14px 30px rgba(0, 120, 212, .26);
        font-size: .97rem;
        font-weight: 800;
        letter-spacing: -.01em;
        cursor: pointer;
        transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
    }

    .ns-loginlight__submit:hover:not(:disabled) {
        transform: translateY(-1px);
        filter: brightness(1.05);
        box-shadow: 0 20px 40px rgba(0, 120, 212, .32);
    }

    .ns-loginlight__submit:disabled {
        cursor: wait;
        opacity: .82;
    }

    .ns-loginlight__arrow {
        transition: transform .15s ease;
    }

    .ns-loginlight__submit:hover:not(:disabled) .ns-loginlight__arrow {
        transform: translateX(3px);
    }

    .ns-loginlight__spin {
        width: 17px;
        height: 17px;
        border: 2px solid rgba(255, 255, 255, .4);
        border-top-color: #fff;
        border-radius: 999px;
        animation: ns-loginlight-spin .75s linear infinite;
    }

    @@keyframes ns-loginlight-spin {
        to { transform: rotate(360deg); }
    }

    /* En móvil/tablet (cuando se oculta la columna del logo), mostrar el logo dentro de la tarjeta */
    @@media (max-width: 1120px) {
        .ns-loginlight__logo {
            display: block;
        }
    }
</style>

@code {
    private readonly LoginViewModel model = new();
    private bool isLoading;
    private bool _showPassword;
    private string? errorMessage;

    private async Task HandleLoginAsync()
    {
        if (isLoading) return;

        if (string.IsNullOrWhiteSpace(model.UsernameOrEmail) || string.IsNullOrWhiteSpace(model.Password))
        {
            errorMessage = "Captura tu usuario y contraseña para entrar al ERP.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.LoginAsync(model.UsernameOrEmail.Trim(), model.Password);

            if (!result.Success)
            {
                errorMessage = result.ErrorMessage ?? "No fue posible iniciar sesión. Verifica tus datos de acceso.";
                return;
            }

            if (result.MustChangePassword)
            {
                Navigation.NavigateTo("/change-password", forceLoad: false);
                return;
            }

            Navigation.NavigateTo(result.IsPlatformOwner ? "/platform/tenants" : "/dashboard", forceLoad: false);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void TogglePassword() => _showPassword = !_showPassword;

    private void ForgotPassword()
    {
        errorMessage = "Solicita al administrador de tu empresa que restablezca tu acceso. Si eres el propietario, contacta a soporte de Nanchesoft.";
    }

    private sealed class LoginViewModel
    {
        public string UsernameOrEmail { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; } = true;
    }
}
