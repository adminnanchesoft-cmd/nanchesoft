@page "/login"
@layout AuthLayout
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Acceso seguro | Nanchesoft IA ERP</PageTitle>

<div class="ns-login3-card">

    <div class="ns-login3-brand">
        <div class="ns-login3-brand__img">
            <img src="images/nanchesoft-cloud-login.webp" alt="Nanchesoft IA ERP" />
        </div>
        <div class="ns-login3-brand__text">
            <strong>Nanchesoft IA</strong>
            <small>ERP · Cloud Enterprise Platform</small>
        </div>
    </div>

    <div class="ns-login3-card__head">
        <div class="ns-login3-card__badge">
            <span class="ns-login3-card__badge-dot"></span>
            ERP Cloud para crecer con control
        </div>
        <h2 class="ns-login3-card__title">Inicia sesión y toma el control</h2>
        <p class="ns-login3-card__sub">
            Entra a Nanchesoft para convertir ventas, compras, inventario, bancos y cobranza
            en información útil para vender más, operar mejor y crecer con orden.
        </p>
    </div>

    <EditForm Model="@model" OnValidSubmit="HandleLoginAsync" class="ns-login3-card__body">
        <DataAnnotationsValidator />

        <div class="ns-login3-field">
            <label class="ns-login3-field__label" for="ns-login-user">Usuario o correo</label>
            <div class="ns-login3-field__wrap">
                <span class="ns-login3-field__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" />
                    </svg>
                </span>
                <input id="ns-login-user"
                       @bind="model.UsernameOrEmail"
                       class="ns-login3-field__input"
                       autocomplete="username"
                       placeholder="usuario@empresa.com" />
            </div>
        </div>

        <div class="ns-login3-field">
            <div class="ns-login3-field__row">
                <label class="ns-login3-field__label" for="ns-login-pass">Contraseña</label>
                <a class="ns-login3-field__link" href="#" @onclick:preventDefault="true" @onclick="ForgotPassword">
                    ¿Necesitas ayuda?
                </a>
            </div>
            <div class="ns-login3-field__wrap">
                <span class="ns-login3-field__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="11" width="16" height="10" rx="2" />
                        <path d="M8 11V7a4 4 0 0 1 8 0v4" />
                    </svg>
                </span>
                <input id="ns-login-pass"
                       @bind="model.Password"
                       @bind:event="oninput"
                       type="@(_showPassword ? "text" : "password")"
                       class="ns-login3-field__input"
                       autocomplete="current-password"
                       placeholder="Contraseña" />
                <button type="button" class="ns-login3-field__eye" @onclick="TogglePassword" aria-label="@(_showPassword ? "Ocultar contraseña" : "Mostrar contraseña")">
                    @if (_showPassword)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 12s3.5-7 10-7c2.4 0 4.5.9 6.2 2.1" />
                            <path d="M22 12s-3.5 7-10 7c-2.4 0-4.5-.9-6.2-2.1" />
                            <line x1="3" y1="3" x2="21" y2="21" />
                            <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2" />
                        </svg>
                    }
                </button>
            </div>
        </div>

        <label class="ns-login3-card__remember">
            <input type="checkbox" @bind="model.RememberMe" />
            <span class="ns-login3-card__remember-box" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            </span>
            <span class="ns-login3-card__remember-text">Mantener mi sesión en este dispositivo</span>
        </label>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="ns-login3-alert ns-login3-alert--error" role="alert">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                <span>@errorMessage</span>
            </div>
        }

        <button type="submit" class="ns-login3-submit" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="ns-login3-submit__spin" aria-hidden="true"></span>
                <span>Verificando acceso...</span>
            }
            else
            {
                <span>Entrar a Nanchesoft IA</span>
                <svg class="ns-login3-submit__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="M13 6l6 6-6 6" /></svg>
            }
        </button>
    </EditForm>

    <div class="ns-login3-growth" aria-label="Motivos para usar Nanchesoft">
        <div class="ns-login3-growth__item">
            <span class="ns-login3-growth__icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
            </span>
            <div>
                <strong>Vende mejor</strong>
                <span>Tu equipo atiende con datos de clientes, inventario, precios y cobranza en el mismo lugar.</span>
            </div>
        </div>
        <div class="ns-login3-growth__item">
            <span class="ns-login3-growth__icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
            </span>
            <div>
                <strong>Controla mejor</strong>
                <span>Compras, almacenes, bancos, CxC, CxP y permisos trabajan conectados.</span>
            </div>
        </div>
        <div class="ns-login3-growth__item">
            <span class="ns-login3-growth__icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
            </span>
            <div>
                <strong>Crece mejor</strong>
                <span>Multiempresa, multisucursal y reportes para escalar sin perder visibilidad.</span>
            </div>
        </div>
    </div>

    <div class="ns-login3-card__foot">
        <div>
            <strong>¿Tu empresa sigue operando con información dispersa?</strong>
            <span>Nanchesoft te ayuda a ordenar la operación para crecer con datos, control y seguimiento.</span>
        </div>
        <a href="https://nanchesoft.com/contact" target="_blank" rel="noopener">Quiero una demo</a>
    </div>
</div>

<style>
    /* ========================================================
       NANCHESOFT LOGIN · Formulario comercial premium
       ======================================================== */

    .ns-login3-card {
        position: relative;
        padding: 30px;
        border-radius: 30px;
        color: #eaf6ff;
        background:
            linear-gradient(180deg, rgba(7, 18, 37, .82), rgba(3, 8, 22, .76)),
            radial-gradient(circle at 18% 0%, rgba(20, 200, 255, .18), transparent 34%);
        border: 1px solid rgba(219, 234, 254, .16);
        box-shadow:
            0 34px 90px rgba(0, 0, 0, .36),
            inset 0 1px 0 rgba(255, 255, 255, .11);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        animation: ns-login3-rise .44s cubic-bezier(.16, 1, .3, 1) both;
        overflow: hidden;
    }

    .ns-login3-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #64e7ff, #0078d4, #64e7ff, transparent);
        opacity: .95;
    }

    .ns-login3-card::after {
        content: "";
        position: absolute;
        right: -90px;
        top: -100px;
        width: 210px;
        height: 210px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(20, 200, 255, .23), transparent 68%);
        pointer-events: none;
    }

    @@keyframes ns-login3-rise {
        from { opacity: 0; transform: translateY(14px) scale(.985); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    .ns-login3-brand {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
        position: relative;
        z-index: 1;
    }

    .ns-login3-brand__img {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        overflow: hidden;
