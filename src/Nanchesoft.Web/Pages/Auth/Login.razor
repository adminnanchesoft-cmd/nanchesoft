        font-weight: 510;
    }

    .ns-login3-card__body {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .ns-login3-field {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .ns-login3-field__row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .ns-login3-field__label {
        color: rgba(226, 242, 255, .90);
        font-size: .82rem;
        font-weight: 850;
        letter-spacing: -.005em;
    }

    .ns-login3-field__link {
        color: #64e7ff;
        font-size: .8rem;
        font-weight: 800;
        text-decoration: none;
        transition: color .14s ease;
    }

    .ns-login3-field__link:hover {
        color: #bff3ff;
        text-decoration: underline;
    }

    .ns-login3-field__wrap {
        position: relative;
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr) auto;
        align-items: center;
        height: 50px;
        background: rgba(255, 255, 255, .92);
        border: 1px solid rgba(219, 234, 254, .22);
        border-radius: 16px;
        transition: border-color .14s ease, box-shadow .14s ease, transform .14s ease, background .14s ease;
