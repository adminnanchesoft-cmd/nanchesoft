    }

    .ns-login3-field__wrap:focus-within {
        background: #fff;
        border-color: rgba(100, 231, 255, .84);
        box-shadow: 0 0 0 4px rgba(20, 200, 255, .13), 0 18px 34px rgba(0, 0, 0, .18);
        transform: translateY(-1px);
    }

    .ns-login3-field__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #0078d4;
    }

    .ns-login3-field__input {
        min-width: 0;
        width: 100%;
        height: 100%;
        border: 0;
        outline: 0;
        background: transparent;
        color: #071225;
        font-size: .96rem;
        font-weight: 650;
        letter-spacing: -.01em;
    }

    .ns-login3-field__input::placeholder {
        color: #94a3b8;
        font-weight: 520;
    }

    .ns-login3-field__eye {
        width: 42px;
        height: 42px;
        margin-right: 4px;
        border: 0;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        background: transparent;
        cursor: pointer;
        transition: background .14s ease, color .14s ease;
    }

    .ns-login3-field__eye:hover {
        color: #0078d4;
        background: rgba(0, 120, 212, .08);
    }

    .ns-login3-card__remember {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        color: rgba(226, 242, 255, .76);
        font-size: .82rem;
        font-weight: 650;
        cursor: pointer;
        user-select: none;
    }

    .ns-login3-card__remember input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .ns-login3-card__remember-box {
        width: 18px;
        height: 18px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #061125;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(219, 234, 254, .28);
        transition: background .14s ease, border-color .14s ease, color .14s ease;
        flex: 0 0 auto;
    }

    .ns-login3-card__remember-box svg {
        opacity: 0;
        transform: scale(.7);
        transition: opacity .14s ease, transform .14s ease;
    }

    .ns-login3-card__remember input:checked + .ns-login3-card__remember-box {
        background: linear-gradient(135deg, #64e7ff, #20a8ff);
        border-color: transparent;
        color: #061125;
    }

    .ns-login3-card__remember input:checked + .ns-login3-card__remember-box svg {
        opacity: 1;
        transform: scale(1);
    }

    .ns-login3-alert {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 10px;
        align-items: flex-start;
        padding: 12px 13px;
        border-radius: 15px;
        font-size: .84rem;
        font-weight: 700;
        line-height: 1.42;
    }

    .ns-login3-alert--error {
