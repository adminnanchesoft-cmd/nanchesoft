    }

    @@keyframes ns-login3-spin {
        to { transform: rotate(360deg); }
    }

    .ns-login3-growth {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 10px;
        margin-top: 20px;
        padding: 14px;
        border-radius: 20px;
        background: rgba(255, 255, 255, .065);
        border: 1px solid rgba(255, 255, 255, .105);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    }

    .ns-login3-growth__item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 11px;
        align-items: flex-start;
    }

    .ns-login3-growth__icon {
        width: 28px;
        height: 28px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #061125;
        background: linear-gradient(135deg, #9ff5ff, #20a8ff);
        box-shadow: 0 10px 24px rgba(20, 200, 255, .18);
    }

    .ns-login3-growth__item strong {
        display: block;
        margin-bottom: 2px;
        color: #fff;
        font-size: .88rem;
        font-weight: 900;
    }

    .ns-login3-growth__item span {
        display: block;
        color: rgba(226, 242, 255, .72);
        font-size: .79rem;
        line-height: 1.42;
    }

    .ns-login3-card__foot {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16px;
        align-items: center;
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid rgba(219, 234, 254, .14);
    }

    .ns-login3-card__foot strong,
    .ns-login3-card__foot span {
        display: block;
    }

    .ns-login3-card__foot strong {
        margin-bottom: 4px;
        color: #fff;
        font-size: .88rem;
        font-weight: 900;
        letter-spacing: -.01em;
    }

    .ns-login3-card__foot span {
        color: rgba(226, 242, 255, .68);
        font-size: .78rem;
        line-height: 1.4;
    }

    .ns-login3-card__foot a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        color: #bff3ff;
        border: 1px solid rgba(100, 231, 255, .25);
        background: rgba(20, 200, 255, .08);
        text-decoration: none;
        font-size: .8rem;
        font-weight: 900;
        white-space: nowrap;
        transition: background .14s ease, color .14s ease, border-color .14s ease;
    }

    .ns-login3-card__foot a:hover {
        color: #fff;
        border-color: rgba(100, 231, 255, .46);
        background: rgba(20, 200, 255, .14);
    }

    @@media (max-width: 1120px) {
        .ns-login3-mobile-logo {
            display: block;
        }
    }

    @@media (max-width: 520px) {
        .ns-login3-card {
            padding: 24px 18px;
            border-radius: 24px;
        }

        .ns-login3-card__title {
            font-size: 1.65rem;
        }

        .ns-login3-card__foot {
            grid-template-columns: 1fr;
            align-items: stretch;
        }

        .ns-login3-card__foot a {
            width: 100%;
        }
    }
</style>

@code {
    private readonly LoginViewModel model = new();
    private bool isLoading;
    private bool _showPassword;
    private string? errorMessage;

    private async Task HandleLoginAsync()
    {
        if (isLoading) return;

        if (string.IsNullOrWhiteSpace(model.UsernameOrEmail) || string.IsNullOrWhiteSpace(model.Password))
        {
            errorMessage = "Captura tu usuario y contraseña para entrar al ERP.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.LoginAsync(model.UsernameOrEmail.Trim(), model.Password);

            if (!result.Success)
            {
                errorMessage = result.ErrorMessage ?? "No fue posible iniciar sesión. Verifica tus datos de acceso.";
                return;
            }

            if (result.MustChangePassword)
            {
                Navigation.NavigateTo("/change-password", forceLoad: false);
                return;
            }

            Navigation.NavigateTo(result.IsPlatformOwner ? "/platform/tenants" : "/dashboard", forceLoad: false);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void TogglePassword() => _showPassword = !_showPassword;

    private void ForgotPassword()
    {
        errorMessage = "Solicita al administrador de tu empresa que restablezca tu acceso. Si eres el propietario, contacta a soporte de Nanchesoft.";
    }

    private sealed class LoginViewModel
    {
        public string UsernameOrEmail { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; } = true;
    }
}
