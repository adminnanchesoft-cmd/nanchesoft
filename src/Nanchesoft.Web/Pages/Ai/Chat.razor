    private static void RenderTraining(RenderTreeBuilder b, JsonElement data)
    {
        b.OpenElement(90, "div"); b.AddAttribute(91, "class", "nia-pill-grid");
        AddPill(b, 92, "info", "Tema", GetString(data, "title"));
        AddPill(b, 93, "info", "Módulo", GetString(data, "module").ToUpperInvariant());
        if (!string.IsNullOrEmpty(GetString(data, "route")))
        {
            AddPill(b, 94, "warn", "Ruta", GetString(data, "route"));
        }
        b.CloseElement();
    }

    private static void RenderTable(RenderTreeBuilder b, int seqStart, string[] headers, List<string[]> rows, bool[] numericFlags)
    {
        b.OpenElement(seqStart, "div"); b.AddAttribute(seqStart + 1, "class", "table-responsive mt-2");
        b.OpenElement(seqStart + 2, "table"); b.AddAttribute(seqStart + 3, "class", "nia-table");
        var thead = "<thead><tr>" + string.Concat(headers.Select((h, i) => $"<th class=\"{(numericFlags[i] ? "text-end" : "")}\">{System.Web.HttpUtility.HtmlEncode(h)}</th>")) + "</tr></thead>";
        b.AddMarkupContent(seqStart + 4, thead);
        b.OpenElement(seqStart + 5, "tbody");
        var s = seqStart + 10;
        foreach (var r in rows)
        {
            b.OpenElement(s++, "tr");
            for (int i = 0; i < r.Length; i++)
            {
                b.OpenElement(s++, "td");
                if (numericFlags[i]) b.AddAttribute(s++, "class", "num");
                b.AddContent(s++, r[i]);
                b.CloseElement();
            }
            b.CloseElement();
        }
        b.CloseElement();
        b.CloseElement();
        b.CloseElement();
    }

    private static void AddPill(RenderTreeBuilder b, int seq, string variant, string label, string value)
    {
        b.OpenElement(seq, "div");
        b.AddAttribute(seq + 1, "class", $"nia-pill {variant}");
        b.OpenElement(seq + 2, "div"); b.AddAttribute(seq + 3, "class", "nia-pill-label"); b.AddContent(seq + 4, label); b.CloseElement();
        b.OpenElement(seq + 5, "div"); b.AddAttribute(seq + 6, "class", "nia-pill-value"); b.AddContent(seq + 7, value); b.CloseElement();
        b.CloseElement();
    }

    private static int GetInt(JsonElement data, string property)
        => data.TryGetProperty(property, out var el) && el.ValueKind == JsonValueKind.Number ? el.GetInt32() : 0;

    private static decimal GetDecimal(JsonElement data, string property)
        => data.TryGetProperty(property, out var el) && el.ValueKind == JsonValueKind.Number ? el.GetDecimal() : 0m;

    private static string GetString(JsonElement data, string property)
        => data.TryGetProperty(property, out var el) && el.ValueKind == JsonValueKind.String ? (el.GetString() ?? string.Empty) : string.Empty;

    private static List<JsonElement> GetArray(JsonElement data, string property)
        => data.TryGetProperty(property, out var el) && el.ValueKind == JsonValueKind.Array
            ? el.EnumerateArray().ToList()
            : new();

    private static string FormatCurrency(decimal value)
        => value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("es-MX"));

    private static string FormatDate(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        return DateTime.TryParse(raw, out var dt) ? dt.ToString("dd/MM/yyyy") : raw;
    }

