            new[] { "Código", "Empleado", "Departamento", "Ingreso", "Sueldo periodo" },
            rows.Take(15).Select(r => new[]
            {
                GetString(r, "employeeCode"),
                GetString(r, "employeeName"),
                GetString(r, "departmentName"),
                FormatDate(GetString(r, "hireDate")),
                FormatCurrency(GetDecimal(r, "periodSalary"))
            }).ToList(),
            new[] { false, false, false, false, true });
    }

