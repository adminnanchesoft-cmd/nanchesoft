@page "/ia/chat"
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components.Web
@using Nanchesoft.Web.Services
@using Nanchesoft.Web.Services.Ai
@using Nanchesoft.Web.State
@inject AiAssistantApiService AiApi
@inject AuthService AuthService
@inject AuthState AuthState
@inject IJSRuntime JS

<PageTitle>Nanchesoft IA - Nóminas y RH</PageTitle>

<style>
    .nia-page { padding: 12px; }
    .nia-shell { display: grid; grid-template-columns: 280px 1fr; gap: 14px; min-height: 78vh; }
    @@media (max-width: 992px) { .nia-shell { grid-template-columns: 1fr; } }
    .nia-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; box-shadow: 0 1px 4px rgba(15,23,42,.05); display: flex; flex-direction: column; overflow: hidden; }
    .nia-card-header { padding: 14px 18px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .nia-card-body { padding: 14px 18px; flex: 1; overflow: auto; }
    .nia-eyebrow { text-transform: uppercase; letter-spacing: .04em; font-size: .68rem; color: #64748b; font-weight: 700; }
    .nia-title { font-size: 1.2rem; font-weight: 800; color: #0f172a; margin: 0; }
    .nia-subtitle { font-size: .82rem; color: #64748b; margin-top: 2px; }
    .nia-badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: .68rem; font-weight: 700; letter-spacing: .03em; }
    .nia-badge-active { background: #ecfdf5; color: #047857; }
    .nia-badge-soon { background: #fef3c7; color: #b45309; }
    .nia-badge-ia { background: linear-gradient(135deg, #6366f1, #ec4899); color: #fff; }

    .nia-conv-list { display: flex; flex-direction: column; gap: 4px; }
    .nia-conv-item {
        padding: 10px 12px; border-radius: 10px; border: 1px solid transparent;
        cursor: pointer; background: #f8fafc; transition: all .15s;
    }
    .nia-conv-item:hover { background: #eef2ff; border-color: #c7d2fe; }
    .nia-conv-item.active { background: #eef2ff; border-color: #6366f1; box-shadow: 0 1px 3px rgba(99,102,241,.18); }
    .nia-conv-item-title { font-size: .88rem; font-weight: 700; color: #0f172a; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .nia-conv-item-meta { font-size: .68rem; color: #94a3b8; margin-top: 2px; display: flex; align-items: center; gap: 6px; }
    .nia-conv-empty { text-align: center; color: #94a3b8; padding: 16px; font-size: .84rem; }

    .nia-quick-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-top: 10px; }
    .nia-quick-card {
        border: 1px solid #e2e8f0; border-radius: 10px; padding: 10px 12px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); cursor: pointer;
        font-size: .78rem; color: #0f172a; line-height: 1.25; min-height: 56px;
        text-align: left; transition: all .15s;
    }
    .nia-quick-card:hover { border-color: #6366f1; background: #eef2ff; }
    .nia-quick-card-icon { font-size: 1.1rem; margin-bottom: 4px; }

    .nia-main { display: flex; flex-direction: column; flex: 1; min-height: 78vh; }
    .nia-chat-body { padding: 18px 22px; overflow-y: auto; flex: 1; background: linear-gradient(180deg, #fdfdff 0%, #ffffff 60%); }
    .nia-empty { text-align: center; padding: 60px 20px; color: #475569; }
    .nia-empty-icon {
        width: 64px; height: 64px; border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #ec4899);
        color: #fff; font-weight: 800; font-size: 1.4rem;
        display: inline-flex; align-items: center; justify-content: center;
        margin-bottom: 14px; box-shadow: 0 6px 20px rgba(99,102,241,.35);
    }
    .nia-empty-title { font-size: 1.1rem; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
    .nia-empty-text { font-size: .9rem; color: #475569; max-width: 580px; margin: 0 auto; }

    .nia-msg { display: flex; gap: 10px; margin-bottom: 16px; animation: niaIn .25s ease; }
    @@keyframes niaIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .nia-msg-avatar {
        width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: .82rem; color: #fff;
    }
    .nia-msg-avatar-user { background: linear-gradient(135deg, #6366f1, #4338ca); }
    .nia-msg-avatar-bot  { background: linear-gradient(135deg, #10b981, #047857); }
    .nia-msg-content {
        background: #ffffff; border: 1px solid #e2e8f0; border-radius: 14px;
        padding: 10px 14px; max-width: 85%; font-size: .92rem; color: #0f172a;
        line-height: 1.5; white-space: pre-wrap;
    }
    .nia-msg-user .nia-msg-content { background: #eef2ff; border-color: #c7d2fe; }
    .nia-msg-bot  .nia-msg-content { background: #f0fdf4; border-color: #bbf7d0; }
    .nia-msg-meta { font-size: .66rem; color: #94a3b8; margin-top: 4px; display: flex; gap: 8px; align-items: center; }
    .nia-typing { display: flex; gap: 6px; padding: 12px 16px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 14px; width: max-content; }
    .nia-typing span { width: 6px; height: 6px; border-radius: 50%; background: #047857; animation: niaTyping 1.2s infinite ease-in-out; }
    .nia-typing span:nth-child(2) { animation-delay: .15s; }
    .nia-typing span:nth-child(3) { animation-delay: .3s; }
    @@keyframes niaTyping { 0%, 80%, 100% { transform: scale(.6); opacity: .4; } 40% { transform: scale(1); opacity: 1; } }

    .nia-data-card { margin-top: 10px; background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 12px; font-size: .82rem; }
    .nia-pill-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 8px; }
    .nia-pill { background: #f8fafc; border-radius: 10px; padding: 8px 10px; }
    .nia-pill-label { font-size: .66rem; color: #64748b; text-transform: uppercase; letter-spacing: .04em; }
    .nia-pill-value { font-size: 1rem; font-weight: 700; color: #0f172a; margin-top: 2px; }
    .nia-pill.success .nia-pill-value { color: #047857; }
    .nia-pill.danger  .nia-pill-value { color: #b91c1c; }
    .nia-pill.info    .nia-pill-value { color: #1d4ed8; }
    .nia-pill.warn    .nia-pill-value { color: #b45309; }

    .nia-table { width: 100%; font-size: .82rem; border-collapse: collapse; }
    .nia-table th, .nia-table td { padding: 6px 8px; border-bottom: 1px solid #f1f5f9; }
    .nia-table th { text-align: left; color: #64748b; font-weight: 600; background: #f8fafc; }
    .nia-table td.num { text-align: right; font-variant-numeric: tabular-nums; }

    .nia-route-link {
        display: inline-flex; align-items: center; gap: 6px;
        margin-top: 8px; padding: 6px 12px; border-radius: 999px;
        background: #eef2ff; color: #4338ca; text-decoration: none;
        font-size: .76rem; font-weight: 600;
    }
    .nia-route-link:hover { background: #c7d2fe; color: #3730a3; }

    .nia-input-bar {
        border-top: 1px solid #e5e7eb; padding: 12px 14px;
        display: flex; gap: 8px; background: #fff;
        border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;
    }
    .nia-input {
        flex: 1; border: 1px solid #cbd5e1; border-radius: 12px; padding: 12px 16px;
        font-size: .95rem; outline: none; transition: border-color .15s, box-shadow .15s;
    }
    .nia-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.18); }
    .nia-send-btn {
        background: linear-gradient(135deg, #6366f1, #4338ca); color: #fff; border: 0;
        border-radius: 12px; padding: 0 20px; font-weight: 700; cursor: pointer;
        font-size: .92rem; transition: opacity .15s;
    }
    .nia-send-btn:disabled { opacity: .5; cursor: not-allowed; }

    .nia-suggestion-chip {
        display: inline-block; margin: 3px 4px 0 0;
        padding: 5px 12px; border-radius: 999px;
        background: #f1f5f9; border: 1px solid #e2e8f0;
        font-size: .76rem; color: #1e293b; cursor: pointer;
        transition: all .15s;
    }
    .nia-suggestion-chip:hover { background: #eef2ff; border-color: #c7d2fe; color: #312e81; }
</style>

<div class="nia-page">
    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div>
            <div class="nia-eyebrow">Nanchesoft ERP · Inteligencia artificial</div>
            <h1 class="nia-title">
                Nanchesoft IA — Nóminas y RH
                <span class="nia-badge nia-badge-ia ms-2">Fase 2</span>
            </h1>
            <p class="nia-subtitle">Asistente operativo y de capacitación. Pregunta como hablas: la IA entiende sinónimos.</p>
        </div>
        <div class="text-end d-flex gap-2 align-items-center">
            <span class="nia-badge nia-badge-active">Memoria activa</span>
            <button class="btn btn-outline-primary btn-sm" @onclick="StartNewConversationAsync" disabled="@_busy">
                + Nueva conversación
            </button>
        </div>
    </div>

    <div class="nia-shell">
        <div class="nia-card">
            <div class="nia-card-header">
                <div>
                    <div class="nia-eyebrow">Conversaciones</div>
                    <div class="fw-semibold mt-1" style="font-size:.9rem;">Tu historial</div>
                </div>
                <button class="btn btn-light btn-sm" @onclick="ReloadConversationsAsync" title="Refrescar" disabled="@_busy">↻</button>
            </div>
            <div class="nia-card-body">
                @if (_conversations.Count == 0)
                {
                    <div class="nia-conv-empty">Aún no tienes conversaciones. Escribe abajo para iniciar una.</div>
                }
                else
                {
                    <div class="nia-conv-list">
                        @foreach (var conv in _conversations)
                        {
                            <div class="nia-conv-item @(conv.Id == _activeConversationId ? "active" : "")"
                                 @onclick="@(() => LoadConversationAsync(conv.Id))">
                                <div class="nia-conv-item-title">@conv.Title</div>
                                <div class="nia-conv-item-meta">
                                    <span>@conv.MessageCount msg</span>
                                    <span>·</span>
                                    <span>@FormatRelative(conv.LastActivityAt)</span>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="mt-4">
                    <div class="nia-eyebrow">Tarjetas rápidas</div>
                    <div class="nia-quick-cards">
                        <button class="nia-quick-card" @onclick='@(() => AskAsync("¿Cuánto se pagará de nómina?"))' disabled="@_busy">
                            <div class="nia-quick-card-icon">$</div>
                            ¿Cuánto se pagará de nómina?
                        </button>
                        <button class="nia-quick-card" @onclick='@(() => AskAsync("¿Qué empleados tienen incidencias?"))' disabled="@_busy">
                            <div class="nia-quick-card-icon">!</div>
                            Empleados con incidencias
                        </button>
                        <button class="nia-quick-card" @onclick='@(() => AskAsync("¿Cómo doy de alta un colaborador?"))' disabled="@_busy">
                            <div class="nia-quick-card-icon">+</div>
                            Cómo dar de alta un colaborador
                        </button>
                        <button class="nia-quick-card" @onclick='@(() => AskAsync("¿Qué departamentos cuestan más?"))' disabled="@_busy">
                            <div class="nia-quick-card-icon">#</div>
                            Departamentos con mayor costo
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="nia-card nia-main">
            <div class="nia-card-header">
                <div>
                    <div class="nia-eyebrow">Asistente</div>
                    <div class="fw-semibold mt-1" style="font-size:.95rem;">@(_activeTitle ?? "Conversación")</div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    @if (_busy)
                    {
                        <span class="badge bg-primary"><span class="spinner-border spinner-border-sm me-1" style="width:.7rem;height:.7rem;"></span>Procesando</span>
                    }
                    else
                    {
                        <span class="nia-badge nia-badge-active">Listo</span>
                    }
                </div>
            </div>
            <div class="nia-chat-body" @ref="_chatBodyRef">
                @if (_messages.Count == 0)
                {
                    <div class="nia-empty">
                        <div class="nia-empty-icon">IA</div>
                        <div class="nia-empty-title">Bienvenido a Nanchesoft IA</div>
                        <div class="nia-empty-text">
                            Pregúntame lo que necesites sobre Nóminas y Recursos Humanos. Puedo consultar datos reales (incidencias, plantilla, periodos)
                            y enseñarte cómo usar el sistema paso a paso.
                        </div>
                        <div class="mt-3">
                            @foreach (var grp in _suggestionGroups)
                            {
                                <div class="mt-3">
                                    <div class="nia-eyebrow">@grp.Title</div>
                                    <div class="mt-1">
                                        @foreach (var s in grp.Items)
                                        {
                                            <span class="nia-suggestion-chip" @onclick="@(() => AskAsync(s))">@s</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var msg in _messages)
                    {
                        <div class="nia-msg @(msg.IsUser ? "nia-msg-user" : "nia-msg-bot")">
                            <div class="nia-msg-avatar @(msg.IsUser ? "nia-msg-avatar-user" : "nia-msg-avatar-bot")">@(msg.IsUser ? "TU" : "IA")</div>
                            <div style="flex:1; min-width:0;">
                                <div class="nia-msg-content">@msg.Text</div>
                                @if (!msg.IsUser && msg.Result is not null)
                                {
                                    @RenderResultData(msg.Result)
                                    @if (!string.IsNullOrEmpty(msg.Result.Route))
                                    {
                                        <a class="nia-route-link" href="@msg.Result.Route">→ Ir a @msg.Result.Route</a>
                                    }
                                    @if (msg.Result.Suggestions is { Count: > 0 })
                                    {
                                        <div class="mt-2">
                                            @foreach (var s in msg.Result.Suggestions)
                                            {
                                                <span class="nia-suggestion-chip" @onclick="@(() => AskAsync(s))">@s</span>
                                            }
                                        </div>
                                    }
                                }
                                <div class="nia-msg-meta">
                                    <span>@msg.Timestamp.ToString("HH:mm:ss")</span>
                                    @if (!msg.IsUser && !string.IsNullOrEmpty(msg.Result?.Endpoint))
                                    {
                                        <span>· @msg.Result!.Endpoint</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    @if (_busy)
                    {
                        <div class="nia-msg nia-msg-bot">
                            <div class="nia-msg-avatar nia-msg-avatar-bot">IA</div>
                            <div class="nia-typing"><span></span><span></span><span></span></div>
                        </div>
                    }
                }
            </div>
            <div class="nia-input-bar">
                <input class="nia-input" placeholder="Pregunta cualquier cosa de Nóminas o RH..."
                       @bind="_input" @bind:event="oninput" @onkeydown="HandleKeyDown" disabled="@_busy" />
                <button class="nia-send-btn" @onclick="SendCurrentAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_input))">
                    @(_busy ? "..." : "Enviar")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly List<ChatMessage> _messages = new();
    private List<AiConversationDto> _conversations = new();
    private List<AiSuggestionGroupDto> _suggestionGroups = new();

    private Guid? _activeConversationId;
    private string? _activeTitle;
    private string _input = string.Empty;
    private bool _busy;
    private ElementReference _chatBodyRef;

    protected override async Task OnInitializedAsync()
    {
        try { _suggestionGroups = await AiApi.GetSuggestionsAsync(); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Ensure auth state is restored from localStorage before making user-scoped calls.
        if (!AuthState.IsAuthenticated)
        {
            try { await AuthService.RestoreSessionAsync(); } catch { }
        }
        try { _conversations = await AiApi.GetConversationsAsync(); } catch { }
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendCurrentAsync();
        }
    }

    private async Task SendCurrentAsync()
    {
        if (string.IsNullOrWhiteSpace(_input)) return;
        var q = _input.Trim();
        _input = string.Empty;
        await AskAsync(q);
    }

    private async Task AskAsync(string question)
    {
        if (_busy || string.IsNullOrWhiteSpace(question)) return;
        _busy = true;
        var now = DateTime.Now;
        _messages.Add(new ChatMessage { IsUser = true, Text = question, Timestamp = now });
        StateHasChanged();
        await ScrollChatToBottom();

        try
        {
            var result = await AiApi.ChatAsync(question, _activeConversationId);
            _activeConversationId = result.ConversationId;
            _activeTitle = result.ConversationTitle;
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = string.IsNullOrWhiteSpace(result.Answer)
                    ? "No encontré información suficiente para responder eso."
                    : result.Answer,
                Result = result,
                Timestamp = DateTime.Now
            });
            await ReloadConversationsAsync();
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = $"Ocurrió un error: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _busy = false;
            StateHasChanged();
            await ScrollChatToBottom();
        }
    }

    private async Task ReloadConversationsAsync()
    {
        try { _conversations = await AiApi.GetConversationsAsync(); } catch { }
        StateHasChanged();
    }

    private async Task StartNewConversationAsync()
    {
        _activeConversationId = null;
        _activeTitle = null;
        _messages.Clear();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task LoadConversationAsync(Guid id)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var msgs = await AiApi.GetMessagesAsync(id);
            _activeConversationId = id;
            _activeTitle = _conversations.FirstOrDefault(c => c.Id == id)?.Title;
            _messages.Clear();
            foreach (var m in msgs)
            {
                _messages.Add(new ChatMessage
                {
                    IsUser = m.Role == "user",
                    Text = m.Content,
                    Timestamp = m.CreatedAt.ToLocalTime(),
                    Result = m.Role == "user" ? null : new AiChatResultDto
                    {
                        ConversationId = m.ConversationId,
                        Intent = m.Intent ?? "unknown",
                        Answer = m.Content,
                        Endpoint = m.Endpoint,
                        Data = m.Data
                    }
                });
            }
        }
        catch { }
        finally
        {
            _busy = false;
            StateHasChanged();
            await ScrollChatToBottom();
        }
    }

    private async Task ScrollChatToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "(function(){var el=document.querySelector('.nia-chat-body'); if(el){el.scrollTop=el.scrollHeight;}})()");
        }
        catch { }
    }

    private static string FormatRelative(DateTime utc)
    {
        var local = utc.Kind == DateTimeKind.Utc ? utc.ToLocalTime() : utc;
        var diff = DateTime.Now - local;
        if (diff.TotalMinutes < 1) return "ahora";
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours} h";
        if (diff.TotalDays < 7) return $"hace {(int)diff.TotalDays} d";
        return local.ToString("dd/MM/yyyy");
    }

    private RenderFragment RenderResultData(AiChatResultDto result) => builder =>
    {
        if (result.Data is null || result.Data.Value.ValueKind == JsonValueKind.Null)
        {
            return;
        }

        var data = result.Data.Value;
        var kind = GetString(data, "kind");

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "nia-data-card");

        switch (kind)
        {
            case "payroll_summary":
                RenderPayrollSummary(builder, data);
                break;
            case "employee_incidents":
            case "today_incidents":
            case "overtime_employees":
            case "faltas":
                RenderEmployeeIncidents(builder, data);
                break;
            case "employees_status":
                RenderEmployeesStatus(builder, data);
                break;
            case "employee_loans":
                RenderEmployeeLoans(builder, data);
                break;
            case "departments_cost":
                RenderDepartmentsCost(builder, data);
                break;
            case "concept_totals":
                RenderConceptTotals(builder, data);
                break;
            case "missing_data":
                RenderMissingData(builder, data);
                break;
            case "training":
                RenderTraining(builder, data);
                break;
        }

        builder.CloseElement();
    };

    private static void RenderPayrollSummary(RenderTreeBuilder b, JsonElement data)
    {
        if (!data.TryGetProperty("period", out var period) || period.ValueKind != JsonValueKind.Object) return;
        b.OpenElement(10, "div"); b.AddAttribute(11, "class", "nia-pill-grid");
        AddPill(b, 12, "info", "Periodo", GetString(period, "periodName"));
        AddPill(b, 13, "info", "Empleados", GetInt(period, "employeeCount").ToString("N0"));
        AddPill(b, 14, "success", "Percepciones", FormatCurrency(GetDecimal(period, "gross")));
        AddPill(b, 15, "danger",  "Deducciones", FormatCurrency(GetDecimal(period, "deductions")));
        AddPill(b, 16, "success", "Neto a pagar", FormatCurrency(GetDecimal(period, "net")));
        AddPill(b, 17, "info", "Pago", FormatDate(GetString(period, "paymentDate")));
        b.CloseElement();

        if (data.TryGetProperty("byDepartment", out var depts) && depts.ValueKind == JsonValueKind.Array)
        {
            RenderTable(b, 20,
                new[] { "Departamento", "Empleados", "Sueldo del periodo" },
                depts.EnumerateArray().Take(8).Select(r => new[]
                {
                    GetString(r, "departmentName"),
                    GetInt(r, "employeeCount").ToString("N0"),
                    FormatCurrency(GetDecimal(r, "totalSalary"))
                }).ToList(),
                new[] { false, true, true });
        }
    }

    private static void RenderEmployeeIncidents(RenderTreeBuilder b, JsonElement data)
    {
        var rows = GetArray(data, "rows");
        if (rows.Count == 0) return;
        RenderTable(b, 30,
            new[] { "Empleado", "Departamento", "Incidencias", "Importe" },
            rows.Take(15).Select(r => new[]
            {
                GetString(r, "employeeCode") + " · " + GetString(r, "employeeName"),
                GetString(r, "departmentName"),
                GetInt(r, "incidentCount").ToString("N0"),
                FormatCurrency(GetDecimal(r, "totalAmount"))
            }).ToList(),
            new[] { false, false, true, true });
    }

    private static void RenderEmployeesStatus(RenderTreeBuilder b, JsonElement data)
    {
        var rows = GetArray(data, "rows");
