@page "/payroll/global-movements"
@using System.Net.Http.Json
@using Nanchesoft.Web.Services.HumanResources
@inject PayrollOperationsApiService PayrollOperationsApiService
@inject PayrollMvpApiService PayrollMvpApiService
@inject IHttpClientFactory HttpFactory

<PageTitle>Movimientos globales | Nanchesoft</PageTitle>

<style>
    .gm-card { border-left: 4px solid #0d6efd; }
    .gm-card.gm-draft { border-left-color: #adb5bd; }
    .gm-card.gm-active { border-left-color: #0d6efd; }
    .gm-card.gm-closed { border-left-color: #198754; }
    .gm-card.gm-cancelled { border-left-color: #dc3545; }
    .gm-pill { font-size: 11px; padding: 2px 8px; border-radius: 12px; text-transform: uppercase; }
    .gm-filter-pill { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 12px; background:#eef2ff; color:#3730a3; font-size: 11px; margin-right:4px; }
    .gm-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; }
    @@media (max-width: 992px) { .gm-grid { grid-template-columns: 1fr; } }
    .gm-employee-table th, .gm-employee-table td { padding: 4px 8px; font-size: 13px; white-space: nowrap; }
    .gm-multiselect { max-height: 180px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 4px; padding: 8px; background: #fff; }
    .gm-multiselect label { display:flex; gap:6px; align-items:center; font-size:12px; }
</style>

<div class="container-fluid py-3">
    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div>
            <h1 class="mb-0">Movimientos globales</h1>
            <p class="text-secondary mb-0">Aplicación masiva de percepciones, deducciones y obligaciones a grupos de colaboradores filtrados.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="StartNew">
                <i class="bi bi-plus-lg"></i> Nuevo lote
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @_message <button class="btn-close" @onclick="() => _message = null"></button>
        </div>
    }

    <div class="gm-grid">
        <div>
            @if (_loadingList)
            {
                <div class="text-center py-5 text-secondary">Cargando lotes...</div>
            }
            else if (_batches.Count == 0)
            {
                <div class="alert alert-info">Aún no hay movimientos globales registrados. Crea el primero con el botón <strong>Nuevo lote</strong>.</div>
            }
            else
            {
                @foreach (var batch in _batches)
                {
                    <div class="card mb-2 shadow-sm gm-card @StatusCss(batch.Status)" @onclick="() => SelectAsync(batch)" style="cursor:pointer;">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <div class="fw-semibold">@batch.BatchCode · @batch.BatchName</div>
                                    <div class="small text-secondary">
                                        @batch.PayrollConceptCode · @batch.PayrollConceptName
                                        @if (!string.IsNullOrEmpty(batch.ControlNumber))
                                        {
                                            <span class="ms-2">N° control: @batch.ControlNumber</span>
                                        }
                                    </div>
                                </div>
                                <div class="text-end">
                                    <span class="gm-pill @StatusBadge(batch.Status)">@batch.Status</span>
                                    <div class="small text-secondary mt-1">
                                        @batch.StartDate.ToString("dd/MM/yyyy")
                                        @if (batch.EndDate.HasValue)
                                        {
                                            <span> - @batch.EndDate.Value.ToString("dd/MM/yyyy")</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="mt-1 small">
                                <span class="me-2"><i class="bi bi-coin"></i> @batch.Amount.ToString("C")</span>
                                <span class="me-2"><i class="bi bi-arrow-repeat"></i> @batch.TimesApplied / @(batch.TimesToApply == 0 ? "∞" : batch.TimesToApply.ToString())</span>
                                <span class="me-2"><i class="bi bi-bank2"></i> Acum: @batch.AccumulatedAmount.ToString("C")</span>
                                @if (batch.MakeRecurring)
                                {
                                    <span class="badge bg-warning text-dark me-2">Permanente</span>
                                }
                                @if (batch.MaxAmount > 0)
                                {
                                    <span>Límite: @batch.MaxAmount.ToString("C")</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div>
            @if (_editMode)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <strong>@(_editingId == Guid.Empty ? "Nuevo lote" : "Editar lote")</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Nombre del lote</label>
                            <input class="form-control form-control-sm" @bind="_form.BatchName" placeholder="Bono trimestral, descuento sindicato, etc." />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Código</label>
                            <input class="form-control form-control-sm" @bind="_form.BatchCode" placeholder="Auto si lo dejas vacío" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Concepto</label>
                            <select class="form-select form-select-sm" @bind="_form.PayrollConceptId">
                                <option value="">— Selecciona concepto —</option>
                                @foreach (var c in _concepts.Where(x => x.IsActive))
                                {
                                    <option value="@c.ConceptId">@c.Code · @c.Name (@c.ConceptType)</option>
                                }
                            </select>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Importe unitario</label>
                                <input class="form-control form-control-sm text-end" type="number" min="0" step="0.01" @bind="_form.Amount" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Cantidad</label>
                                <input class="form-control form-control-sm text-end" type="number" min="0" step="0.01" @bind="_form.Quantity" />
                            </div>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Desde</label>
                                <input class="form-control form-control-sm" type="date" @bind="_formStartDate" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Hasta (opcional)</label>
                                <input class="form-control form-control-sm" type="date" @bind="_formEndDate" />
                            </div>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Veces a aplicar (0 = ilim.)</label>
                                <input class="form-control form-control-sm text-end" type="number" min="0" step="1" @bind="_form.TimesToApply" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Monto límite (0 = sin)</label>
                                <input class="form-control form-control-sm text-end" type="number" min="0" step="0.01" @bind="_form.MaxAmount" />
                            </div>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Salario mínimo</label>
                                <input class="form-control form-control-sm text-end" type="number" min="0" step="0.01" @bind="_form.MinSalary" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Salario máximo</label>
                                <input class="form-control form-control-sm text-end" type="number" min="0" step="0.01" @bind="_form.MaxSalary" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">N° de control</label>
                            <input class="form-control form-control-sm" @bind="_form.ControlNumber" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Filtro: Departamentos</label>
                            <div class="gm-multiselect">
                                @foreach (var d in _departments)
                                {
                                    <label><input type="checkbox" checked="@_form.FilterDepartmentIds.Contains(d.DepartmentId)" @onchange="e => Toggle(_form.FilterDepartmentIds, d.DepartmentId, e)" /> @d.Name</label>
                                }
                                @if (_departments.Count == 0) { <div class="text-secondary small">Sin departamentos.</div> }
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Filtro: Puestos</label>
                            <div class="gm-multiselect">
                                @foreach (var p in _positions)
                                {
                                    <label><input type="checkbox" checked="@_form.FilterPositionIds.Contains(p.PositionId)" @onchange="e => Toggle(_form.FilterPositionIds, p.PositionId, e)" /> @p.Name</label>
                                }
                                @if (_positions.Count == 0) { <div class="text-secondary small">Sin puestos.</div> }
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Filtro: Sucursales</label>
                            <div class="gm-multiselect">
                                @foreach (var b in _branches)
                                {
                                    <label><input type="checkbox" checked="@_form.FilterBranchIds.Contains(b.BranchId)" @onchange="e => Toggle(_form.FilterBranchIds, b.BranchId, e)" /> @b.Name</label>
                                }
                                @if (_branches.Count == 0) { <div class="text-secondary small">Sin sucursales.</div> }
                            </div>
                        </div>
                        <div class="mb-2 form-check">
                            <input class="form-check-input" type="checkbox" id="gm-recurring" @bind="_form.MakeRecurring" />
                            <label class="form-check-label small" for="gm-recurring">Crear movimiento permanente para cada empleado</label>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Notas</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="_form.Notes"></textarea>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button class="btn btn-sm btn-light" @onclick="CancelEdit" disabled="@_busy">Cancelar</button>
                            <button class="btn btn-sm btn-primary" @onclick="SaveAsync" disabled="@(_busy || _form.PayrollConceptId is null || _form.PayrollConceptId == Guid.Empty)">
                                @(_busy ? "Guardando..." : (_editingId == Guid.Empty ? "Crear lote" : "Guardar cambios"))
                            </button>
                        </div>
                    </div>
                </div>
            }
            else if (_selected is not null)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center flex-wrap gap-1">
                        <div>
                            <strong>@_selected.BatchCode · @_selected.BatchName</strong>
                            <div class="small text-secondary">@_selected.PayrollConceptCode · @_selected.PayrollConceptName</div>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(_selected)" disabled="@_busy">Editar</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteAsync" disabled="@_busy">Eliminar</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-2 small">
                            <span class="gm-filter-pill"><i class="bi bi-coin"></i> @_selected.Amount.ToString("C") × @_selected.Quantity</span>
                            <span class="gm-filter-pill"><i class="bi bi-calendar"></i> @_selected.StartDate.ToString("dd/MM/yyyy")</span>
                            <span class="gm-filter-pill"><i class="bi bi-arrow-repeat"></i> @_selected.TimesApplied/@(_selected.TimesToApply == 0 ? "∞" : _selected.TimesToApply.ToString())</span>
                            <span class="gm-filter-pill"><i class="bi bi-bank2"></i> @_selected.AccumulatedAmount.ToString("C")</span>
                        </div>

                        <div class="border-top pt-2 mt-2">
                            <div class="d-flex gap-2 align-items-end mb-2 flex-wrap">
                                <div style="min-width:220px;">
                                    <label class="form-label small fw-semibold mb-1">Aplicar al periodo</label>
                                    <select class="form-select form-select-sm" @bind="_applyPeriodId">
                                        <option value="">Selecciona un periodo</option>
                                        @foreach (var p in _periods)
                                        {
                                            <option value="@p.PayrollPeriodId">@p.Name · @p.StartDate.ToString("dd/MM/yyyy")</option>
                                        }
                                    </select>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" @onclick="PreviewAsync" disabled="@_busy">
                                    <i class="bi bi-eye"></i> Previsualizar
                                </button>
                                <button class="btn btn-sm btn-success" @onclick="ApplyAsync" disabled="@(_busy || _applyPeriodId == Guid.Empty || _selected.Status == "closed" || _selected.Status == "cancelled")">
                                    <i class="bi bi-check2-square"></i> Aplicar al periodo
                                </button>
                                @if (_selected.Status != "closed" && _selected.Status != "cancelled")
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseAsync" disabled="@_busy">
                                        <i class="bi bi-lock"></i> Cerrar lote
                                    </button>
                                }
                            </div>

                            @if (_preview is not null)
                            {
                                <div class="small text-secondary mb-1">@_preview.TotalEmployees empleado(s) · total @_preview.TotalAmount.ToString("C")</div>
                                <div style="max-height:200px;overflow:auto;">
                                    <table class="table table-sm gm-employee-table mb-0">
                                        <thead>
                                            <tr><th>#</th><th>Nombre</th><th>Depto</th><th class="text-end">Importe</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _preview.Employees)
                                            {
                                                <tr>
                                                    <td>@row.EmployeeNumber</td>
                                                    <td>@row.EmployeeName</td>
                                                    <td>@row.DepartmentName</td>
                                                    <td class="text-end">@row.Amount.ToString("C")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>

                        @if (_lines.Count > 0)
                        {
                            <div class="border-top pt-2 mt-2">
                                <div class="small text-secondary mb-1">Aplicaciones registradas (@_lines.Count)</div>
                                <div style="max-height:200px;overflow:auto;">
                                    <table class="table table-sm gm-employee-table mb-0">
                                        <thead>
                                            <tr><th>Fecha</th><th>Empleado</th><th>Periodo</th><th class="text-end">Importe</th><th>Estado</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var line in _lines)
                                            {
                                                <tr>
                                                    <td>@line.AppliedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td>@line.EmployeeNumber · @line.EmployeeName</td>
                                                    <td>@line.PayrollPeriodName</td>
                                                    <td class="text-end">@line.Amount.ToString("C")</td>
                                                    <td><span class="gm-pill bg-light text-dark">@line.Status</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-light">Selecciona un lote para ver detalles, previsualizar empleados y aplicar al periodo.</div>
            }
        </div>
    </div>
</div>

@code {
    private List<PayrollGlobalMovementListItem> _batches = [];
    private List<PayrollConceptItem> _concepts = [];
    private List<DepartmentDto> _departments = [];
    private List<PositionDto> _positions = [];
    private List<BranchLookupDto> _branches = [];
    private List<PayrollPeriodSimple> _periods = [];
    private PayrollGlobalMovementListItem? _selected;
    private PayrollGlobalMovementPreview? _preview;
    private List<PayrollGlobalMovementLineItem> _lines = [];

    private bool _loadingList = true;
    private bool _busy;
    private bool _editMode;
    private Guid _editingId;
    private Guid _applyPeriodId;
    private string? _message;
    private bool _isError;

    private PayrollGlobalMovementSubmit _form = new();
    private DateTime? _formStartDate;
    private DateTime? _formEndDate;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpFactory.CreateClient("Nanchesoft.Api");
        var conceptsTask = PayrollOperationsApiService.GetPayrollConceptsAsync();
        var departmentsTask = client.GetFromJsonAsync<List<DepartmentDto>>("/api/hr/departments");
        var positionsTask = client.GetFromJsonAsync<List<PositionDto>>("/api/hr/positions");
        var branchesTask = client.GetFromJsonAsync<List<BranchLookupDto>>("/api/organization/branches");
        var periodsTask = PayrollMvpApiService.GetPeriodsAsync();

        await Task.WhenAll(conceptsTask, departmentsTask, positionsTask, branchesTask, periodsTask);

        _concepts = conceptsTask.Result;
        _departments = (departmentsTask.Result ?? []).Where(x => x.IsActive).OrderBy(x => x.Name).ToList();
        _positions = (positionsTask.Result ?? []).Where(x => x.IsActive).OrderBy(x => x.Name).ToList();
        _branches = (branchesTask.Result ?? []).Where(x => x.IsActive).OrderBy(x => x.Name).ToList();
        _periods = periodsTask.Result;

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loadingList = true;
        try
        {
            _batches = await PayrollOperationsApiService.GetGlobalMovementsAsync();
        }
        finally
        {
            _loadingList = false;
        }
    }

    private static string StatusCss(string status) => status switch
    {
        "draft" => "gm-draft",
        "active" => "gm-active",
        "closed" => "gm-closed",
        "cancelled" => "gm-cancelled",
        _ => string.Empty
    };

    private static string StatusBadge(string status) => status switch
    {
        "draft" => "bg-secondary text-white",
        "active" => "bg-primary text-white",
        "closed" => "bg-success text-white",
        "cancelled" => "bg-danger text-white",
        _ => "bg-light text-dark"
    };

    private void StartNew()
    {
        _editMode = true;
        _editingId = Guid.Empty;
        _form = new PayrollGlobalMovementSubmit
        {
            Quantity = 1m,
            Amount = 0m,
            MovementType = "perception",
            CalculationMode = "fixed",
            Status = "draft",
            IsActive = true,
            FilterDepartmentIds = [],
            FilterPositionIds = [],
            FilterBranchIds = []
        };
        _formStartDate = DateTime.Today;
        _formEndDate = null;
        _selected = null;
        _preview = null;
    }

    private void StartEdit(PayrollGlobalMovementListItem batch)
    {
        _editMode = true;
        _editingId = batch.PayrollGlobalMovementId;
        _form = new PayrollGlobalMovementSubmit
        {
            PayrollConceptId = batch.PayrollConceptId,
            BatchCode = batch.BatchCode,
            BatchName = batch.BatchName,
            MovementType = batch.MovementType,
            CalculationMode = batch.CalculationMode,
            Quantity = batch.Quantity,
            Amount = batch.Amount,
            Percentage = batch.Percentage,
            TimesToApply = batch.TimesToApply,
            MaxAmount = batch.MaxAmount,
            ControlNumber = batch.ControlNumber,
            FilterDepartmentIds = ParseList(batch.FilterDepartmentIds),
            FilterPositionIds = ParseList(batch.FilterPositionIds),
            FilterBranchIds = ParseList(batch.FilterBranchIds),
            FilterEmployerRegistrationIds = ParseList(batch.FilterEmployerRegistrationIds),
            FilterWorkShiftIds = ParseList(batch.FilterWorkShiftIds),
            FilterEmployeeIds = ParseList(batch.FilterEmployeeIds),
            ExcludeEmployeeIds = ParseList(batch.ExcludeEmployeeIds),
            MinSalary = batch.MinSalary,
            MaxSalary = batch.MaxSalary,
            MakeRecurring = batch.MakeRecurring,
            Status = batch.Status,
            Notes = batch.Notes,
            IsActive = batch.IsActive
        };
        _formStartDate = batch.StartDate;
        _formEndDate = batch.EndDate;
    }

    private static List<Guid> ParseList(string raw)
        => string.IsNullOrWhiteSpace(raw)
            ? new List<Guid>()
            : raw.Split(new[] { ',', ';', ' ' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(x => Guid.TryParse(x, out var id) ? id : Guid.Empty)
                .Where(x => x != Guid.Empty)
                .Distinct()
                .ToList();

    private void Toggle(List<Guid> target, Guid id, ChangeEventArgs e)
    {
        var on = e.Value is bool b && b;
        if (on)
        {
            if (!target.Contains(id)) target.Add(id);
        }
        else
        {
            target.Remove(id);
        }
    }

    private void CancelEdit()
    {
        _editMode = false;
        _editingId = Guid.Empty;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _message = null;
        try
        {
            _form.StartDate = _formStartDate ?? DateTime.UtcNow.Date;
            _form.EndDate = _formEndDate;
            if (_editingId == Guid.Empty)
            {
                var newId = await PayrollOperationsApiService.CreateGlobalMovementAsync(_form);
                await ReloadAsync();
                _editMode = false;
                _selected = _batches.FirstOrDefault(x => x.PayrollGlobalMovementId == newId);
                if (_selected is not null) await LoadLinesAsync();
                Show("Lote creado.", false);
            }
            else
            {
                await PayrollOperationsApiService.UpdateGlobalMovementAsync(_editingId, _form);
                await ReloadAsync();
                _editMode = false;
                _selected = _batches.FirstOrDefault(x => x.PayrollGlobalMovementId == _editingId);
                Show("Lote actualizado.", false);
            }
        }
        catch (Exception ex)
        {
            Show(ex.Message, true);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SelectAsync(PayrollGlobalMovementListItem batch)
    {
        _editMode = false;
        _selected = batch;
        _preview = null;
        await LoadLinesAsync();
    }

    private async Task LoadLinesAsync()
    {
        if (_selected is null) { _lines = []; return; }
        try
        {
            _lines = await PayrollOperationsApiService.GetGlobalMovementLinesAsync(_selected.PayrollGlobalMovementId);
        }
        catch
        {
            _lines = [];
        }
    }

    private async Task PreviewAsync()
    {
        if (_selected is null) return;
        _busy = true;
        try
        {
            _preview = await PayrollOperationsApiService.PreviewGlobalMovementAsync(_selected.PayrollGlobalMovementId);
        }
        catch (Exception ex)
        {
            Show(ex.Message, true);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ApplyAsync()
    {
        if (_selected is null || _applyPeriodId == Guid.Empty) return;
        _busy = true;
        try
        {
            var result = await PayrollOperationsApiService.ApplyGlobalMovementAsync(_selected.PayrollGlobalMovementId, _applyPeriodId);
            await ReloadAsync();
            _selected = _batches.FirstOrDefault(x => x.PayrollGlobalMovementId == _selected.PayrollGlobalMovementId);
            await LoadLinesAsync();
            Show($"Aplicado a {result.Applied} colaboradores. Omitidos: {result.Skipped}. Total: {result.TotalAmount:C}.", false);
        }
        catch (Exception ex)
        {
            Show(ex.Message, true);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CloseAsync()
    {
        if (_selected is null) return;
        _busy = true;
        try
        {
            await PayrollOperationsApiService.CloseGlobalMovementAsync(_selected.PayrollGlobalMovementId);
            await ReloadAsync();
            _selected = _batches.FirstOrDefault(x => x.PayrollGlobalMovementId == _selected.PayrollGlobalMovementId);
            Show("Lote cerrado.", false);
        }
        catch (Exception ex)
        {
            Show(ex.Message, true);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (_selected is null) return;
        _busy = true;
        try
        {
            await PayrollOperationsApiService.DeleteGlobalMovementAsync(_selected.PayrollGlobalMovementId);
            await ReloadAsync();
            _selected = null;
            _preview = null;
            _lines = [];
            Show("Lote eliminado.", false);
        }
        catch (Exception ex)
        {
            Show(ex.Message, true);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Show(string text, bool isError)
    {
        _message = text;
        _isError = isError;
    }
}
