@page "/payroll/periods"
@using Nanchesoft.Web.Services.HumanResources
@inject HumanResourcesApiService Api
@inject IJSRuntime JS

<PageTitle>Periodos de nómina | Nanchesoft</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Periodos de nómina</h4>
    <button class="btn btn-primary btn-sm" @onclick="OpenNew">+ Nuevo periodo</button>
</div>

@if (!string.IsNullOrWhiteSpace(_msg))
{
    <div class="alert @(_msgOk ? "alert-success" : "alert-danger") alert-dismissible py-2">
        @_msg
        <button type="button" class="btn-close btn-sm" @onclick="() => _msg = null"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4 text-muted">Cargando...</div>
        }
        else if (_periods.Count == 0)
        {
            <div class="text-center py-4 text-muted">Sin periodos configurados.</div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Pago</th>
                            <th class="text-center">Estatus</th>
                            <th class="text-center">IMSS</th>
                            <th class="text-center">Activo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _periods.OrderByDescending(x => x.StartDate))
                        {
                            <tr class="@(p.IsClosed ? "table-secondary" : "")">
                                <td><code>@p.Code</code></td>
                                <td>@p.Name</td>
                                <td class="small">@p.PeriodType</td>
                                <td class="text-nowrap">@(p.StartDate?.ToString("dd/MM/yy"))</td>
                                <td class="text-nowrap">@(p.EndDate?.ToString("dd/MM/yy"))</td>
                                <td class="text-nowrap">@(p.PaymentDate?.ToString("dd/MM/yy"))</td>
                                <td class="text-center">
                                    @if (p.IsClosed)
                                    {
                                        <span class="badge bg-danger">Cerrado</span>
                                    }
                                    else
                                    {
                                        <span class="badge @StatusBadge(p.Status)">@p.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (p.IsImssInsured) { <span class="badge bg-info text-dark">Sí</span> }
                                </td>
                                <td class="text-center">
                                    @if (p.IsActive) { <span class="badge bg-success">Sí</span> }
                                    else { <span class="badge bg-secondary">No</span> }
                                </td>
                                <td class="text-nowrap text-end">
                                    <button class="btn btn-xs btn-outline-secondary me-1"
                                            @onclick="() => OpenEdit(p)">Editar</button>
                                    @if (!p.IsClosed)
                                    {
                                        <button class="btn btn-xs btn-warning"
                                                @onclick="() => ClosePeriodAsync(p)">Cerrar</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-xs btn-outline-success"
                                                @onclick="() => ReopenPeriodAsync(p)">Reabrir</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (_showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">@(_editId.HasValue ? "Editar periodo" : "Nuevo periodo")</h6>
                    <button type="button" class="btn-close btn-sm" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label form-label-sm">Código *</label>
                            <input class="form-control form-control-sm" @bind="_form.Code" />
                        </div>
                        <div class="col-md-9">
                            <label class="form-label form-label-sm">Nombre *</label>
                            <input class="form-control form-control-sm" @bind="_form.Name" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label form-label-sm">Tipo de periodo *</label>
                            <select class="form-select form-select-sm" @bind="_form.PeriodType">
                                <option value="">— Seleccionar —</option>
                                <option value="semanal">Semanal (7 días)</option>
                                <option value="quincenal">Quincenal (15 días)</option>
                                <option value="mensual">Mensual (30/31 días)</option>
                                <option value="decenal">Decenal (10 días)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label form-label-sm">Estatus</label>
                            <select class="form-select form-select-sm" @bind="_form.Status">
                                <option value="draft">Borrador</option>
                                <option value="captura">Captura</option>
                                <option value="open">Abierto</option>
                                <option value="calculated">Calculado</option>
                                <option value="cerrado">Cerrado</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label form-label-sm">&nbsp;</label>
                            <div class="d-flex gap-3 mt-1">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" @bind="_form.IsImssInsured" />
                                    <label class="form-check-label small">Aseg. IMSS</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" @bind="_form.IsActive" />
                                    <label class="form-check-label small">Activo</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label form-label-sm">Fecha inicio *</label>
                            <input type="date" class="form-control form-control-sm" @bind="_form.StartDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label form-label-sm">Fecha fin *</label>
                            <input type="date" class="form-control form-control-sm" @bind="_form.EndDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label form-label-sm">Fecha de pago *</label>
                            <input type="date" class="form-control form-control-sm" @bind="_form.PaymentDate" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    @if (!string.IsNullOrWhiteSpace(_modalError))
                    {
                        <span class="text-danger small me-auto">@_modalError</span>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="CloseModal" disabled="@_saving">Cancelar</button>
                    <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_saving">
                        @(_saving ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    bool _loading;
    bool _saving;
    bool _showModal;
    string? _msg;
    bool _msgOk;
    string? _modalError;
    Guid? _editId;

    List<PayrollPeriodDto> _periods = [];

    PeriodFormModel _form = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        _periods = await Api.GetAllPeriodsAsync();
        _loading = false;
    }

    void OpenNew()
    {
        _editId = null;
        _form = new PeriodFormModel
        {
            Status = "draft",
            IsImssInsured = true,
            IsActive = true,
            StartDate = DateTime.Today,
            EndDate = DateTime.Today.AddDays(14),
            PaymentDate = DateTime.Today.AddDays(16),
            PeriodType = "quincenal"
        };
        _modalError = null;
        _showModal = true;
    }

    void OpenEdit(PayrollPeriodDto p)
    {
        _editId = p.PayrollPeriodId;
        _form = new PeriodFormModel
        {
            Code = p.Code, Name = p.Name,
            PeriodType = p.PeriodType,
            StartDate = p.StartDate ?? DateTime.Today,
            EndDate = p.EndDate ?? DateTime.Today,
            PaymentDate = p.PaymentDate ?? DateTime.Today,
            Status = p.Status,
            IsImssInsured = p.IsImssInsured,
            IsActive = p.IsActive
        };
        _modalError = null;
        _showModal = true;
    }

    void CloseModal() { _showModal = false; _modalError = null; }

    async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        { _modalError = "Código y nombre son obligatorios."; return; }
        if (string.IsNullOrWhiteSpace(_form.PeriodType))
        { _modalError = "El tipo de periodo es obligatorio."; return; }

        _saving = true;
        _modalError = null;
        var req = new PayrollPeriodRequest
        {
            Code = _form.Code, Name = _form.Name,
            PeriodType = _form.PeriodType,
            StartDate = _form.StartDate,
            EndDate = _form.EndDate,
            PaymentDate = _form.PaymentDate,
            Status = _form.Status,
            IsImssInsured = _form.IsImssInsured,
            IsActive = _form.IsActive
        };

        (bool Ok, string? Error) result;
        if (_editId.HasValue)
            result = await Api.UpdatePeriodAsync(_editId.Value, req);
        else
            result = await Api.CreatePeriodAsync(req);

        _saving = false;
        if (result.Ok)
        {
            CloseModal();
            ShowMsg(_editId.HasValue ? "Periodo actualizado." : "Periodo creado.", true);
            await LoadAsync();
        }
        else
        {
            _modalError = result.Error ?? "Error al guardar.";
        }
    }

    async Task ClosePeriodAsync(PayrollPeriodDto p)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"¿Cerrar el periodo {p.Code} · {p.Name}? Una vez cerrado no se podrán agregar ni editar incidencias.");
        if (!ok) return;
        var (success, error) = await Api.ClosePeriodAsync(p.PayrollPeriodId);
        ShowMsg(success ? $"Periodo {p.Code} cerrado." : (error ?? "Error al cerrar."), success);
        if (success) await LoadAsync();
    }

    async Task ReopenPeriodAsync(PayrollPeriodDto p)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"¿Reabrir el periodo {p.Code} · {p.Name}?");
        if (!ok) return;
        var (success, error) = await Api.ReopenPeriodAsync(p.PayrollPeriodId);
        ShowMsg(success ? $"Periodo {p.Code} reabierto." : (error ?? "Error al reabrir."), success);
        if (success) await LoadAsync();
    }

    void ShowMsg(string text, bool ok) { _msg = text; _msgOk = ok; }

    static string StatusBadge(string status) => status switch
    {
        "open" or "abierto" or "captura" => "bg-success",
        "calculated" => "bg-info text-dark",
        "cerrado" or "closed" => "bg-danger",
        _ => "bg-secondary"
    };

    sealed class PeriodFormModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string PeriodType { get; set; } = "quincenal";
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public DateTime PaymentDate { get; set; }
        public string Status { get; set; } = "draft";
        public bool IsImssInsured { get; set; } = true;
        public bool IsActive { get; set; } = true;
    }
}
