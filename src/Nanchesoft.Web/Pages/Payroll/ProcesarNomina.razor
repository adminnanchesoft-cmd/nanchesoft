@page "/payroll/procesar"
@inject Nanchesoft.Web.Services.HumanResources.PayrollMvpApiService PayrollMvpApiService
@inject NavigationManager NavigationManager

<PageTitle>Procesar nómina | Nanchesoft</PageTitle>

<div class="container-fluid py-3" style="max-width:900px;">
    <div class="mb-4">
        <h1 class="mb-1">Procesar nómina</h1>
        <p class="text-secondary mb-0">Sigue los pasos para generar la corrida semanal de nómina.</p>
    </div>

    @* ── Stepper ── *@
    <div class="d-flex align-items-center mb-4 gap-2 flex-wrap">
        @for (int i = 1; i <= TotalSteps; i++)
        {
            var step = i;
            var isActive = _step == step;
            var isDone = _step > step;
            <div class="d-flex align-items-center @(step < TotalSteps ? "flex-grow-1" : "")">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width:32px;height:32px;flex-shrink:0;font-size:13px;
                            background:@(isDone ? "#198754" : isActive ? "#0d6efd" : "#e9ecef");
                            color:@(isDone || isActive ? "white" : "#6c757d")">
                    @if (isDone) { <span>✓</span> } else { <span>@step</span> }
                </div>
                <span class="ms-2 me-2 text-nowrap" style="font-size:13px;font-weight:@(isActive ? "600" : "400");color:@(isActive ? "#0d6efd" : isDone ? "#198754" : "#6c757d")">
                    @StepLabel(step)
                </span>
                @if (step < TotalSteps)
                {
                    <div class="flex-grow-1 border-top" style="border-color:#dee2e6 !important;margin:0 4px;"></div>
                }
            </div>
        }
    </div>

    @* ── Mensaje de error/éxito global ── *@
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger d-flex align-items-start gap-2 mb-3" role="alert">
            <strong>Error:</strong> @_errorMessage
            <button type="button" class="btn-close ms-auto" @onclick="() => _errorMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-3" role="alert">@_successMessage</div>
    }

    @* ══════════════════════════════════════════════════════════ *@
    @* PASO 1: Seleccionar periodo *@
    @* ══════════════════════════════════════════════════════════ *@
    @if (_step == 1)
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Paso 1 — Seleccionar periodo de nómina</div>
            <div class="card-body">
                @if (_periods.Count == 0)
                {
                    <p class="text-secondary">Cargando periodos…</p>
                }
                else
                {
                    <div class="mb-3" style="max-width:480px;">
                        <label class="form-label fw-semibold">Periodo</label>
                        <select class="form-select" @bind="_selectedPeriodId">
                            <option value="">— Selecciona un periodo —</option>
                            @foreach (var p in _periods)
                            {
                                <option value="@p.PayrollPeriodId">@p.Name — @p.StartDate.ToString("dd/MM/yyyy") al @p.EndDate.ToString("dd/MM/yyyy") [@p.Status]</option>
                            }
                        </select>
                    </div>
                    @if (_selectedPeriodId != Guid.Empty)
                    {
                        var sel = _periods.FirstOrDefault(x => x.PayrollPeriodId == _selectedPeriodId);
                        @if (sel is not null)
                        {
                            <div class="table-responsive mb-3" style="max-width:480px;">
                                <table class="table table-sm table-borderless mb-0">
                                    <tbody>
                                        <tr><td class="text-secondary" style="width:160px;">Tipo</td><td><strong>@sel.PeriodType</strong></td></tr>
                                        <tr><td class="text-secondary">Inicio</td><td><strong>@sel.StartDate.ToString("dd/MM/yyyy")</strong></td></tr>
                                        <tr><td class="text-secondary">Fin</td><td><strong>@sel.EndDate.ToString("dd/MM/yyyy")</strong></td></tr>
                                        <tr><td class="text-secondary">Pago</td><td><strong>@sel.PaymentDate.ToString("dd/MM/yyyy")</strong></td></tr>
                                        <tr><td class="text-secondary">Días del periodo</td><td><strong>@((sel.EndDate - sel.StartDate).Days + 1)</strong></td></tr>
                                    </tbody>
                                </table>
                            </div>
                        }
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                            <button class="btn btn-outline-primary btn-sm" @onclick="ValidatePeriodAsync" disabled="@_busy">
                                @(_busy ? "Validando…" : "Validar generación")
                            </button>
                            @if (_preview is not null)
                            {
                                <span class="badge text-bg-light border">Colaboradores: @_preview.ActiveEmployees</span>
                                <span class="badge text-bg-light border">Asistencia: @_preview.AttendanceSummaries</span>
                                <span class="badge text-bg-light border">Incidencias: @_preview.Incidents</span>
                                <span class="badge text-bg-light border">Prenómina: @_preview.PrePayrollAdjustments</span>
                            }
                        </div>
                        @if (_preview is not null)
                        {
                            <div class="border rounded p-3 mb-3 bg-light">
                                <div class="row g-2 small">
                                    <div class="col-6 col-md-3"><span class="text-secondary">Empleados en empresa</span><div class="fw-semibold">@_preview.TotalEmployeesInCompany</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Elegibles</span><div class="fw-semibold text-success">@_preview.ActiveEmployees</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Descartados (inactivos)</span><div class="fw-semibold @(_preview.DiscardedInactive > 0 ? "text-warning" : "")">@_preview.DiscardedInactive</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Descartados (status)</span><div class="fw-semibold @(_preview.DiscardedByStatus > 0 ? "text-warning" : "")">@_preview.DiscardedByStatus</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Sin salario</span><div class="fw-semibold @(_preview.EmployeesWithoutSalary > 0 ? "text-danger" : "")">@_preview.EmployeesWithoutSalary</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Sin departamento</span><div class="fw-semibold">@_preview.WithoutDepartment</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Sin puesto</span><div class="fw-semibold">@_preview.WithoutPosition</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Periódicos activos</span><div class="fw-semibold">@_preview.RecurringMovements</div></div>
                                    <div class="col-6 col-md-3"><span class="text-secondary">Préstamos activos</span><div class="fw-semibold">@_preview.ActiveLoans</div></div>
                                </div>
                                @if (_preview.MissingConceptCodes.Count > 0)
                                {
                                    <div class="alert alert-info py-2 px-3 mt-3 mb-0 small">
                                        Conceptos base por crear automáticamente al calcular: @string.Join(", ", _preview.MissingConceptCodes)
                                    </div>
                                }
                                @if (_preview.Warnings.Count > 0)
                                {
                                    <ul class="mt-3 mb-0 small text-secondary">
                                        @foreach (var warning in _preview.Warnings)
                                        {
                                            <li>@warning</li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    }
                }
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <button class="btn btn-primary" @onclick="GoToStep2" disabled="@(_selectedPeriodId == Guid.Empty || _busy)">
                    Siguiente →
                </button>
            </div>
        </div>
    }

    @* ══════════════════════════════════════════════════════════ *@
    @* PASO 2: Importar checadas *@
    @* ══════════════════════════════════════════════════════════ *@
    @if (_step == 2)
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Paso 2 — Importar checadas / reloj checador</div>
            <div class="card-body">
                <p class="text-secondary mb-3">
                    Sube un archivo Excel (.xlsx) o CSV de checadas del periodo.<br />
                    <strong>Formato A (recomendado):</strong> columnas <code>NoEmpleado | Fecha | HoraEntrada | HoraSalida</code><br />
                    <strong>Formato B:</strong> columnas <code>NoEmpleado | FechaHora | Tipo</code> (Tipo = entry / exit)<br />
                    <strong>Silvasoft:</strong> <code>ID de persona | Fecha | Primera perforación | Última perforación</code>
                </p>
                <div class="mb-3" style="max-width:400px;">
                    <label class="form-label fw-semibold">Archivo de checadas</label>
                    <InputFile OnChange="OnPunchFileSelected" accept=".xlsx,.csv,.txt" class="form-control" />
                </div>
                @if (_punchImportResult is not null)
                {
                    <div class="alert @(_punchImportResult.Errors.Count > 0 ? "alert-warning" : "alert-success") mt-2">
                        <strong>Resultado:</strong> @_punchImportResult.Created registros creados, @_punchImportResult.Skipped omitidos.
                        @if (_punchImportResult.Errors.Count > 0)
                        {
                            <ul class="mt-1 mb-0">
                                @foreach (var e in _punchImportResult.Errors.Take(5))
                                {
                                    <li>@e</li>
                                }
                                @if (_punchImportResult.Errors.Count > 5)
                                {
                                    <li>... y @(_punchImportResult.Errors.Count - 5) errores más.</li>
                                }
                            </ul>
                        }
                    </div>
                }
                <p class="text-secondary mt-3 mb-0" style="font-size:13px;">
                    <em>También puedes saltarte este paso si ya capturaste las checadas manualmente en Reloj checador.</em>
                </p>
            </div>
            <div class="card-footer d-flex justify-content-between gap-2">
                <button class="btn btn-outline-secondary" @onclick="() => GoToStep(1)">← Anterior</button>
                <div class="d-flex gap-2">
                    @if (_punchFile is not null && _punchImportResult is null)
                    {
                        <button class="btn btn-outline-primary" @onclick="ImportPunchesAsync" disabled="@_busy">
                            @(_busy ? "Importando…" : "Importar ahora")
                        </button>
                    }
                    <button class="btn btn-primary" @onclick="() => GoToStep(3)" disabled="@_busy">
                        @(_punchImportResult is not null ? "Siguiente →" : "Omitir / Siguiente →")
                    </button>
                </div>
            </div>
        </div>
    }

    @* ══════════════════════════════════════════════════════════ *@
    @* PASO 3: Generar resumen diario *@
    @* ══════════════════════════════════════════════════════════ *@
    @if (_step == 3)
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Paso 3 — Generar resumen diario de asistencia</div>
            <div class="card-body">
                <p class="text-secondary mb-3">
                    El sistema procesará las checadas del periodo y calculará:<br />
                    horas trabajadas, retardos, horas extra y faltas por empleado.
                </p>
                <div class="row g-3 mb-3">
                    <div class="col-sm-6 col-lg-3">
                        <label class="form-label fw-semibold">Tolerancia entrada (min)</label>
                        <input type="number" min="0" max="240" class="form-control" @bind="_attendanceOptions.DefaultToleranceMinutes" />
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <label class="form-label fw-semibold">Tolerancia salida (min)</label>
                        <input type="number" min="0" max="240" class="form-control" @bind="_attendanceOptions.EarlyLeaveToleranceMinutes" />
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <label class="form-label fw-semibold">Falta completa si horas &lt;</label>
                        <input type="number" min="0" max="24" step="0.5" class="form-control" @bind="_attendanceOptions.FullAbsenceUnderHours" />
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <label class="form-label fw-semibold">Media falta si horas &lt;</label>
                        <input type="number" min="0" max="24" step="0.5" class="form-control" @bind="_attendanceOptions.HalfAbsenceUnderHours" />
                    </div>
                </div>
                @if (_summaryResult is null)
                {
                    <button class="btn btn-outline-primary" @onclick="GenerateSummariesAsync" disabled="@_busy">
                        @(_busy ? "Generando resumen…" : "Generar resumen de asistencia")
                    </button>
                    <div class="alert alert-info mt-3 py-2 px-3 small mb-0">
                        <strong>Este paso es opcional.</strong> Si no capturaste checadas puedes omitirlo —
                        se procesará con sueldo completo (sin descuento por inasistencias).
                    </div>
                }
                @if (_summaryResult is not null)
                {
                    <div class="alert alert-success mt-2">
                        <strong>✓ Resumen generado.</strong> @_summaryResult.Employees empleados × @_summaryResult.Days días = @_summaryResult.Created registros.
                    </div>
                }
            </div>
            <div class="card-footer d-flex justify-content-between gap-2">
                <button class="btn btn-outline-secondary" @onclick="() => GoToStep(2)">← Anterior</button>
                <button class="btn btn-primary" @onclick="() => GoToStep(4)" disabled="@_busy">
                    @(_summaryResult is not null ? "Siguiente →" : "Omitir / Siguiente →")
                </button>
            </div>
        </div>
    }

    @* ══════════════════════════════════════════════════════════ *@
    @* PASO 4: Generar incidencias *@
    @* ══════════════════════════════════════════════════════════ *@
    @if (_step == 4)
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Paso 4 — Generar incidencias automáticas</div>
            <div class="card-body">
                <p class="text-secondary mb-3">
                    A partir del resumen de asistencia se generarán incidencias de tipo:<br />
                    <strong>falta</strong> (ausencias), <strong>retardo</strong> (llegadas tarde acumuladas) y <strong>hora_extra</strong> (tiempo adicional).
                </p>
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label class="form-label fw-semibold">Generar retardo si minutos acumulados &gt;</label>
                        <input type="number" min="0" max="240" class="form-control" @bind="_incidentOptions.DelayIncidentThresholdMinutes" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label fw-semibold">Multiplicador hora extra</label>
                        <input type="number" min="1" max="5" step="0.1" class="form-control" @bind="_incidentOptions.OvertimeMultiplier" />
                    </div>
                </div>
                @if (_incidentResult is null)
                {
                    <button class="btn btn-outline-primary" @onclick="GenerateIncidentsAsync" disabled="@_busy">
                        @(_busy ? "Generando incidencias…" : "Generar incidencias")
                    </button>
                    <div class="alert alert-info mt-3 py-2 px-3 small mb-0">
                        <strong>Las incidencias son opcionales.</strong>
                        Si no las capturas, se procesará la nómina con sueldo completo del periodo.
                    </div>
                }
                @if (_incidentResult is not null)
                {
                    <div class="alert alert-success mt-2">
                        <strong>✓ Incidencias generadas.</strong> @_incidentResult.Created incidencias para @_incidentResult.Employees empleados.
                    </div>
                }
            </div>
            <div class="card-footer d-flex justify-content-between gap-2">
                <button class="btn btn-outline-secondary" @onclick="() => GoToStep(3)">← Anterior</button>
                <button class="btn btn-primary" @onclick="() => GoToStep(5)" disabled="@_busy">
                    @(_incidentResult is not null ? "Siguiente →" : "Omitir / Siguiente →")
                </button>
            </div>
        </div>
    }

    @* ══════════════════════════════════════════════════════════ *@
    @* PASO 5: Calcular nómina *@
    @* ══════════════════════════════════════════════════════════ *@
    @if (_step == 5)
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Paso 5 — Calcular corrida de nómina</div>
            <div class="card-body">
                @if (_run is null)
                {
                    @* Validaciones pre-cálculo *@
                    var canCalculate = _preview is not null
                        && _preview.ActiveEmployees > 0
                        && _preview.EmployeesWithoutSalary < _preview.ActiveEmployees
                        && !string.IsNullOrWhiteSpace(_runFolio);

                    @if (_preview is null)
                    {
                        <div class="alert alert-warning py-2 px-3 mb-3 small">
                            <strong>Validando…</strong> No se ha podido validar el periodo. Regresa al Paso 1 y oprime "Validar generación".
                        </div>
                    }
                    else
                    {
                        <div class="border rounded p-3 mb-3 bg-light small">
                            <strong>Resumen antes de calcular</strong>
                            <ul class="mt-2 mb-0">
                                <li>Colaboradores activos: <strong>@_preview.ActiveEmployees</strong></li>
                                <li>Préstamos activos a aplicar: <strong>@_preview.ActiveLoans</strong></li>
                                <li>Incidencias capturadas: <strong>@_preview.Incidents</strong> @(_preview.Incidents == 0 ? "(opcional)" : "")</li>
                                @if (_preview.EmployeesWithoutSalary > 0)
                                {
                                    <li class="text-warning">
                                        ⚠ <strong>@_preview.EmployeesWithoutSalary</strong> empleado(s) sin sueldo del periodo ni sueldo diario — quedarán en 0.
                                    </li>
                                }
                            </ul>
                        </div>

                        @if (_preview.ActiveEmployees == 0)
                        {
                            <div class="alert alert-danger py-2 px-3 mb-3 small">
                                <strong>No hay empleados activos en este periodo.</strong>
                                Asegúrate de tener empleados con estatus "active" en la empresa antes de procesar.
                            </div>
                        }
                        else if (_preview.EmployeesWithoutSalary >= _preview.ActiveEmployees)
                        {
                            <div class="alert alert-danger py-2 px-3 mb-3 small">
                                <strong>Ningún empleado tiene sueldo capturado.</strong>
                                Edita los colaboradores y captura "Sueldo del periodo" o "Sueldo diario" antes de procesar.
                            </div>
                        }
                    }

                    <div class="mb-3" style="max-width:400px;">
                        <label class="form-label fw-semibold">Folio de la corrida</label>
                        <input type="text" class="form-control" @bind="_runFolio" placeholder="Ej. NOM-2026-001" />
                        <div class="form-text">Identificador único para esta corrida de nómina.</div>
                    </div>
                    <button class="btn btn-primary" @onclick="CreateAndCalculateAsync" disabled="@(_busy || !canCalculate)">
                        @(_busy ? "Procesando…" : "Procesar nómina")
                    </button>
                    <div class="small text-secondary mt-2">
                        Se aplicará: sueldo del periodo como percepción #1, incidencias, movimientos periódicos, préstamos activos e ISR/IMSS.
                    </div>
                }
                @if (_calculateResult is not null && _run is not null)
                {
                    <div class="alert alert-success mb-3">
                        <strong>✓ Nómina calculada.</strong>
                    </div>
                    <div class="table-responsive" style="max-width:400px;">
                        <table class="table table-sm table-borderless mb-0">
                            <tbody>
                                <tr><td class="text-secondary">Folio</td><td><strong>@_run.Folio</strong></td></tr>
                                <tr><td class="text-secondary">Empleados</td><td><strong>@_calculateResult.Employees</strong></td></tr>
                                <tr><td class="text-secondary">Total bruto</td><td><strong>@_calculateResult.GrossAmount.ToString("C2")</strong></td></tr>
                                <tr><td class="text-secondary">Deducciones</td><td><strong>@_calculateResult.DeductionsAmount.ToString("C2")</strong></td></tr>
                                <tr><td class="text-secondary" style="border-top:2px solid #dee2e6;">Neto a pagar</td><td style="border-top:2px solid #dee2e6;"><strong class="text-success fs-5">@_calculateResult.NetAmount.ToString("C2")</strong></td></tr>
                            </tbody>
                        </table>
                    @if (_calculateResult.DeductionsAmount > _calculateResult.GrossAmount)
                    {
                        <div class="alert alert-warning py-2 px-3 mt-2 mb-0 small">
                            ⚠ Las deducciones superan al total de percepciones. Revisa préstamos, descuentos e incidencias.
                        </div>
                    }
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <button class="btn btn-outline-primary btn-sm" @onclick="RecalculateRunAsync" disabled="@_busy">
                            🔄 @(_busy ? "Recalculando…" : "Recalcular todos")
                        </button>
                    </div>
                    </div>
                }
            </div>
            <div class="card-footer d-flex justify-content-between gap-2">
                <button class="btn btn-outline-secondary" @onclick="() => GoToStep(4)">← Anterior</button>
                @if (_run is not null && _calculateResult is not null)
                {
                    <button class="btn btn-primary" @onclick="() => GoToStep(6)">Ver recibos →</button>
                }
            </div>
        </div>
    }

    @* ══════════════════════════════════════════════════════════ *@
    @* PASO 6: Imprimir recibos *@
    @* ══════════════════════════════════════════════════════════ *@
    @if (_step == 6)
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Paso 6 — Revisar y autorizar</div>
            <div class="card-body">
                <p class="text-secondary mb-3">La nómina está lista. Revisa los recibos individuales, imprime el resumen y autoriza cuando esté correcta.</p>
                @if (_run is not null)
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-3 col-6">
                            <div class="border rounded p-2 small bg-white text-center">
                                <div class="text-secondary">Folio</div>
                                <div class="fw-bold">@_run.Folio</div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="border rounded p-2 small bg-white text-center">
                                <div class="text-secondary">Empleados</div>
                                <div class="fw-bold">@_run.EmployeeCount</div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="border rounded p-2 small bg-white text-center">
                                <div class="text-secondary">Deducciones</div>
                                <div class="fw-bold text-danger">@_run.DeductionsAmount.ToString("C2")</div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="border rounded p-2 small bg-success text-white text-center">
                                <div style="opacity:.85">Neto a pagar</div>
                                <div class="fw-bold fs-5">@_run.NetAmount.ToString("C2")</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" href="/payroll/receipts/@_run.PayrollRunId">
                            📄 Ver recibos
                        </a>
                        <a class="btn btn-outline-primary" target="_blank" href="/payroll/print/run/@_run.PayrollRunId">
                            🖨️ Imprimir resumen / PDF
                        </a>
                        <a class="btn btn-outline-secondary" href="/payroll/reporte">
                            📈 Ver resumen (Reporte / Lista de raya)
                        </a>
                        <a class="btn btn-outline-secondary" href="/payroll/captura-matricial/@_run.PayrollRunId">
                            📊 Captura matricial
                        </a>
                        <button class="btn btn-outline-warning" @onclick="RecalculateRunAsync" disabled="@_busy">
                            🔄 @(_busy ? "Recalculando…" : "Recalcular todos")
                        </button>
                        <a class="btn btn-outline-dark" href="/payroll/runs">
                            📋 Listado de corridas
                        </a>
                    </div>

                    <div class="alert alert-info mt-3 py-2 px-3 small mb-0">
                        <strong>Siguiente paso:</strong> revisa los recibos uno por uno. Cuando estén correctos, ve a "Listado de corridas" y marca la corrida como autorizada/cerrada para que los saldos de préstamos queden firmes.
                    </div>
                }
            </div>
            <div class="card-footer d-flex justify-content-between gap-2">
                <button class="btn btn-outline-secondary" @onclick="() => GoToStep(5)">← Anterior</button>
                <button class="btn btn-success" @onclick="ResetWizard">Nueva corrida</button>
            </div>
        </div>
    }
</div>

@* ── Import empleados (acceso rápido desde cualquier paso) ── *@
@if (_step is 1 or 2)
{
    <div class="container-fluid mt-3" style="max-width:900px;">
        <details class="border rounded p-3">
            <summary class="fw-semibold" style="cursor:pointer;">📥 Importar empleados desde Excel (opcional)</summary>
            <div class="mt-3">
                <p class="text-secondary mb-2" style="font-size:13px;">
                    Columnas: <code>NoEmpleado | Nombre | ApellidoPaterno | ApellidoMaterno | RFC | CURP | Email | Telefono | FechaIngreso | SalarioDiario | SalarioDiarioIntegrado | DepartamentoCodigo | PuestoCodigo</code>
                </p>
                <div class="d-flex gap-2 align-items-end flex-wrap">
                    <div>
                        <label class="form-label fw-semibold mb-1" style="font-size:13px;">Archivo Excel</label>
                        <InputFile OnChange="OnEmployeeFileSelected" accept=".xlsx" class="form-control form-control-sm" style="width:300px;" />
                    </div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="ImportEmployeesAsync" disabled="@(_employeeFile is null || _busy)">
                        @(_busy ? "Importando…" : "Importar empleados")
                    </button>
                </div>
                @if (_employeeImportResult is not null)
                {
                    <div class="alert @(_employeeImportResult.Errors.Count > 0 ? "alert-warning" : "alert-success") mt-2 mb-0">
                        <strong>Resultado:</strong> @_employeeImportResult.Created creados, @_employeeImportResult.Updated actualizados, @_employeeImportResult.Skipped omitidos.
                        @if (_employeeImportResult.Errors.Count > 0)
                        {
                            <ul class="mt-1 mb-0">
                                @foreach (var e in _employeeImportResult.Errors.Take(5))
                                {
                                    <li>@e</li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>
        </details>
    </div>
}

@code {
    private const int TotalSteps = 6;
    private int _step = 1;
    private bool _busy;
    private string? _errorMessage;
    private string? _successMessage;

    // Paso 1
    private List<Nanchesoft.Web.Services.HumanResources.PayrollPeriodSimple> _periods = [];
    private Guid _selectedPeriodId;
    private Nanchesoft.Web.Services.HumanResources.PayrollGenerationPreview? _preview;

    // Paso 2
    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? _punchFile;
    private Nanchesoft.Web.Services.HumanResources.PayrollMvpImportResult? _punchImportResult;

    // Paso 3
    private Nanchesoft.Web.Services.HumanResources.PayrollMvpOperationResult? _summaryResult;
    private Nanchesoft.Web.Services.HumanResources.PayrollAttendanceOptions _attendanceOptions = new();

    // Paso 4
    private Nanchesoft.Web.Services.HumanResources.PayrollMvpOperationResult? _incidentResult;
    private Nanchesoft.Web.Services.HumanResources.PayrollIncidentOptions _incidentOptions = new();

    // Paso 5
    private string _runFolio = string.Empty;
    private Nanchesoft.Web.Services.HumanResources.PayrollRunSimple? _run;
    private Nanchesoft.Web.Services.HumanResources.PayrollMvpCalculateResult? _calculateResult;

    // Importar empleados
    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? _employeeFile;
    private Nanchesoft.Web.Services.HumanResources.PayrollMvpImportResult? _employeeImportResult;

    protected override async Task OnInitializedAsync()
    {
        _periods = await PayrollMvpApiService.GetPeriodsAsync();
    }

    private string StepLabel(int step) => step switch
    {
        1 => "Periodo",
        2 => "Checadas",
        3 => "Resumen",
        4 => "Incidencias",
        5 => "Calcular",
        6 => "Recibos",
        _ => step.ToString()
    };

    private void GoToStep(int step)
    {
        _errorMessage = null;
        _successMessage = null;
        _step = step;
        // Refrescar preview al entrar a calcular para tener cifras actualizadas
        if (step == 5 && _selectedPeriodId != Guid.Empty)
        {
            _ = RefreshPreviewAsync();
        }
    }

    private async Task RefreshPreviewAsync()
    {
        try
        {
            _preview = await PayrollMvpApiService.GetGenerationPreviewAsync(_selectedPeriodId);
            await InvokeAsync(StateHasChanged);
        }
        catch { /* no-op: lo manejará el botón Validar */ }
    }

    private async Task GoToStep2()
    {
        if (_selectedPeriodId == Guid.Empty) return;
        await ValidatePeriodAsync();
        var sel = _periods.FirstOrDefault(x => x.PayrollPeriodId == _selectedPeriodId);
        _runFolio = sel is not null
            ? $"NOM-{sel.StartDate:yyyyMMdd}"
            : $"NOM-{DateTime.UtcNow:yyyyMMdd}";
        GoToStep(2);
    }

    private void OnPunchFileSelected(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        _punchFile = e.File;
        _punchImportResult = null;
    }

    private void OnEmployeeFileSelected(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        _employeeFile = e.File;
        _employeeImportResult = null;
    }

    private async Task ImportPunchesAsync()
    {
        if (_punchFile is null) return;
        await RunAsync(async () =>
        {
            using var stream = _punchFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _punchImportResult = await PayrollMvpApiService.ImportPunchesFromExcelAsync(stream, _punchFile.Name);
        });
    }

    private async Task ImportEmployeesAsync()
    {
        if (_employeeFile is null) return;
        await RunAsync(async () =>
        {
            using var stream = _employeeFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _employeeImportResult = await PayrollMvpApiService.ImportEmployeesFromExcelAsync(stream, _employeeFile.Name);
        });
    }

    private async Task GenerateSummariesAsync()
    {
        await RunAsync(async () =>
        {
            _summaryResult = await PayrollMvpApiService.GenerateAttendanceSummariesAsync(_selectedPeriodId, _attendanceOptions);
            _preview = await PayrollMvpApiService.GetGenerationPreviewAsync(_selectedPeriodId);
        });
    }

    private async Task GenerateIncidentsAsync()
    {
        await RunAsync(async () =>
        {
            _incidentResult = await PayrollMvpApiService.GenerateIncidentsAsync(_selectedPeriodId, _incidentOptions);
            _preview = await PayrollMvpApiService.GetGenerationPreviewAsync(_selectedPeriodId);
        });
    }

    private async Task ValidatePeriodAsync()
    {
        if (_selectedPeriodId == Guid.Empty) return;
        await RunAsync(async () =>
        {
            _preview = await PayrollMvpApiService.GetGenerationPreviewAsync(_selectedPeriodId);
        });
    }

    private async Task CreateAndCalculateAsync()
    {
        if (string.IsNullOrWhiteSpace(_runFolio)) return;
        await RunAsync(async () =>
        {
            _run = await PayrollMvpApiService.CreateRunAsync(_selectedPeriodId, _runFolio.Trim().ToUpperInvariant());
            if (_run is null) throw new InvalidOperationException("No se pudo crear la corrida.");
            _calculateResult = await PayrollMvpApiService.CalculatePayrollRunAsync(_run.PayrollRunId);
            _preview = await PayrollMvpApiService.GetGenerationPreviewAsync(_selectedPeriodId);
            // Reload to get updated totals
            var runs = await PayrollMvpApiService.GetRunsAsync();
            _run = runs.FirstOrDefault(x => x.PayrollRunId == _run.PayrollRunId) ?? _run;
            _successMessage = $"Nómina procesada: {_calculateResult.Employees} empleado(s), neto {_calculateResult.NetAmount:C2}.";
        });
    }

    private async Task RecalculateRunAsync()
    {
        if (_run is null) return;
        await RunAsync(async () =>
        {
            _calculateResult = await PayrollMvpApiService.CalculatePayrollRunAsync(_run.PayrollRunId);
            var runs = await PayrollMvpApiService.GetRunsAsync();
            _run = runs.FirstOrDefault(x => x.PayrollRunId == _run.PayrollRunId) ?? _run;
            _preview = await PayrollMvpApiService.GetGenerationPreviewAsync(_selectedPeriodId);
            _successMessage = $"Nómina recalculada: {_calculateResult.Employees} empleado(s), neto {_calculateResult.NetAmount:C2}.";
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        _busy = true;
        _errorMessage = null;
        _successMessage = null;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void ResetWizard()
    {
        _step = 1;
        _selectedPeriodId = Guid.Empty;
        _preview = null;
        _punchFile = null;
        _punchImportResult = null;
        _summaryResult = null;
        _attendanceOptions = new();
        _incidentResult = null;
        _incidentOptions = new();
        _runFolio = string.Empty;
        _run = null;
        _calculateResult = null;
        _employeeFile = null;
        _employeeImportResult = null;
        _errorMessage = null;
        _successMessage = null;
    }
}
