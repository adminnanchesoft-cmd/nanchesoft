@page "/reports/operational"
@using Nanchesoft.Web.Services.Reports
@inject ReportsApiService ReportsApiService

<PageTitle>Reportes operativos | Nanchesoft</PageTitle>

<div class="ns-catalog-page">
    <div class="ns-catalog-header">
        <div>
            <div class="ns-catalog-eyebrow">Nanchesoft ERP · Sprint 9</div>
            <h1 class="ns-catalog-title">Reportes operativos</h1>
            <p class="ns-catalog-subtitle">Compras, ventas, inventario y tesorería con exportación CSV.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary" href="@ReportsApiService.GetExportUrl("purchases")" target="_blank">Exportar compras</a>
            <a class="btn btn-outline-secondary" href="@ReportsApiService.GetExportUrl("sales")" target="_blank">Exportar ventas</a>
            <a class="btn btn-outline-secondary" href="@ReportsApiService.GetExportUrl("inventory")" target="_blank">Exportar inventario</a>
            <a class="btn btn-outline-secondary" href="@ReportsApiService.GetExportUrl("treasury")" target="_blank">Exportar tesorería</a>
        </div>
    </div>

    @if (_loading)
    {
        <div class="ns-catalog-loading"><div class="ns-loader"></div><span>Cargando reportes...</span></div>
    }
    else
    {
        <div class="ns-kpi-grid mb-4">
            <div class="ns-kpi-card"><div class="ns-kpi-label">OC abiertas</div><div class="ns-kpi-value">@_summary.PurchaseOrdersOpen</div></div>
            <div class="ns-kpi-card"><div class="ns-kpi-label">Compras 30 días</div><div class="ns-kpi-value ns-kpi-value-small">@_summary.PurchaseInvoicesPeriod.ToString("C")</div></div>
            <div class="ns-kpi-card"><div class="ns-kpi-label">Pedidos abiertos</div><div class="ns-kpi-value">@_summary.SalesOrdersOpen</div></div>
            <div class="ns-kpi-card"><div class="ns-kpi-label">Ventas 30 días</div><div class="ns-kpi-value ns-kpi-value-small">@_summary.SalesInvoicesPeriod.ToString("C")</div></div>
            <div class="ns-kpi-card"><div class="ns-kpi-label">Renglones stock</div><div class="ns-kpi-value">@_summary.StockRows</div></div>
            <div class="ns-kpi-card"><div class="ns-kpi-label">Existencia total</div><div class="ns-kpi-value ns-kpi-value-small">@_summary.StockOnHand.ToString("N2")</div></div>
            <div class="ns-kpi-card"><div class="ns-kpi-label">Valor inventario</div><div class="ns-kpi-value ns-kpi-value-small">@_summary.StockValue.ToString("C")</div></div>
            <div class="ns-kpi-card"><div class="ns-kpi-label">Tesorería total</div><div class="ns-kpi-value ns-kpi-value-small">@_summary.CombinedTreasuryBalance.ToString("C")</div></div>
        </div>

        <div class="row g-3">
            <div class="col-xl-6">
                <div class="card shadow-sm">
                    <div class="card-header"><strong>Compras recientes</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead><tr><th>Folio</th><th>Fecha</th><th>Proveedor</th><th class="text-end">Total</th></tr></thead>
                            <tbody>
                            @foreach (var row in _purchases.Take(12))
                            {
                                <tr><td>@row.Folio</td><td>@row.Date.ToString("d")</td><td>@row.PartyName</td><td class="text-end">@row.Total.ToString("C")</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card shadow-sm">
                    <div class="card-header"><strong>Ventas recientes</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead><tr><th>Folio</th><th>Fecha</th><th>Cliente</th><th class="text-end">Total</th></tr></thead>
                            <tbody>
                            @foreach (var row in _sales.Take(12))
                            {
                                <tr><td>@row.Folio</td><td>@row.Date.ToString("d")</td><td>@row.PartyName</td><td class="text-end">@row.Total.ToString("C")</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card shadow-sm">
                    <div class="card-header"><strong>Inventario</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead><tr><th>Almacén</th><th>Item</th><th class="text-end">Disponible</th><th class="text-end">Valor</th></tr></thead>
                            <tbody>
                            @foreach (var row in _inventory.Take(12))
                            {
                                <tr><td>@row.WarehouseName</td><td>@row.ItemCode - @row.ItemName</td><td class="text-end">@row.QuantityAvailable.ToString("N2")</td><td class="text-end">@row.ExtendedValue.ToString("C")</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card shadow-sm">
                    <div class="card-header"><strong>Tesorería</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead><tr><th>Tipo</th><th>Cuenta</th><th>Estatus</th><th class="text-end">Saldo</th></tr></thead>
                            <tbody>
                            @foreach (var row in _treasury.Take(12))
                            {
                                <tr><td>@row.AccountType</td><td>@row.Code - @row.Name</td><td>@row.Status</td><td class="text-end">@row.Balance.ToString("C")</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private ReportsOperationalSummaryDto _summary = new();
    private List<ReportsPurchaseRowDto> _purchases = new();
    private List<ReportsSalesRowDto> _sales = new();
    private List<ReportsInventoryRowDto> _inventory = new();
    private List<ReportsTreasuryRowDto> _treasury = new();

    protected override async Task OnInitializedAsync()
    {
        _summary = await ReportsApiService.GetOperationalSummaryAsync();
        _purchases = await ReportsApiService.GetPurchasesAsync();
        _sales = await ReportsApiService.GetSalesAsync();
        _inventory = await ReportsApiService.GetInventoryAsync();
        _treasury = await ReportsApiService.GetTreasuryAsync();
        _loading = false;
    }
}
