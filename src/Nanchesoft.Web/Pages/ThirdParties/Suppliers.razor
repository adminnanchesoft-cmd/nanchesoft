@page "/third-parties/suppliers"
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@inject IHttpClientFactory HttpClientFactory
@inject Nanchesoft.Web.State.AuthState AuthState
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Proveedores | Nanchesoft</PageTitle>

<style>
    .sup-csf-fab { position:fixed; bottom:28px; right:28px; z-index:900; display:flex; align-items:center; gap:9px; padding:12px 20px; border-radius:50px; background:linear-gradient(135deg,#1e3a5f,#2563eb); color:#fff; font-size:0.85rem; font-weight:700; box-shadow:0 6px 24px rgba(37,99,235,0.32); border:none; cursor:pointer; transition:transform .18s,box-shadow .18s; }
    .sup-csf-fab:hover { transform:translateY(-2px); box-shadow:0 10px 30px rgba(37,99,235,0.38); }
    .sup-csf-fab svg { flex-shrink:0; }

    .sup-import-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:2000; display:flex; align-items:center; justify-content:center; }
    .sup-import-box { background:#fff; border-radius:18px; width:580px; max-width:96vw; max-height:92vh; overflow-y:auto; box-shadow:0 8px 40px rgba(0,0,0,.28); padding:1.5rem; }
    .sup-import-title { font-size:1.05rem; font-weight:800; color:#1e3a5f; margin-bottom:4px; }
    .sup-import-sub { font-size:0.78rem; color:#64748b; margin-bottom:1.2rem; }

    .sup-csf-drop { border:2px dashed #93c5fd; border-radius:10px; padding:2rem 1rem; text-align:center; cursor:pointer; transition:all .2s; background:#f0f9ff; }
    .sup-csf-drop:hover, .sup-csf-drop.dragging { border-color:#2563eb; background:#dbeafe; }
    .sup-csf-drop svg { color:#3b82f6; margin-bottom:8px; }

    .sup-tab-btn { padding:0.4rem 1.1rem; font-size:0.8rem; font-weight:600; border:none; background:none; color:#6b7280; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-2px; }
    .sup-tab-btn.active { color:#2563eb; border-bottom-color:#2563eb; }
    .sup-tab-nav { display:flex; gap:0; border-bottom:2px solid #e5e7eb; margin-bottom:1rem; }

    .sup-preview-tag { display:inline-block; background:#dbeafe; color:#1d4ed8; font-size:0.7rem; font-weight:700; border-radius:6px; padding:0.1rem 0.4rem; margin-bottom:0.5rem; }
    .sup-field-row { display:grid; grid-template-columns:1fr 1fr; gap:0.5rem 1rem; }
    .sup-field { display:flex; flex-direction:column; gap:3px; font-size:0.8rem; color:#374151; }
    .sup-field input { border:1px solid #d1d5db; border-radius:6px; padding:6px 10px; font-size:0.8rem; }
    .sup-field input:focus { outline:none; border-color:#2563eb; box-shadow:0 0 0 2px rgba(37,99,235,0.12); }

    .sup-alert { padding:10px 14px; border-radius:8px; font-size:0.82rem; font-weight:600; margin-bottom:10px; }
    .sup-alert--err { background:#fef2f2; color:#991b1b; border:1px solid #fecdd3; }
    .sup-alert--ok  { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
</style>

<CatalogCrudPage CatalogKey="suppliers" />

@* ── FAB: Importar CSF ──────────────────────────────────────────────────── *@
<button class="sup-csf-fab" @onclick="OpenModal" title="Importar Constancia de Situación Fiscal">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
    </svg>
    Importar CSF
</button>

@* ── Modal ───────────────────────────────────────────────────────────────── *@
@if (_showModal)
{
    <div class="sup-import-overlay" @onclick="CloseModal">
        <div class="sup-import-box" @onclick:stopPropagation>
            <div class="d-flex justify-content-between align-items-start mb-1">
                <div>
                    <div class="sup-import-title">Importar Constancia de Situación Fiscal</div>
                    <div class="sup-import-sub">Crea o actualiza un proveedor con datos del SAT.</div>
                </div>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="sup-alert sup-alert--err">@_error</div>
            }
            @if (!string.IsNullOrWhiteSpace(_success))
            {
                <div class="sup-alert sup-alert--ok">@_success</div>
            }

            @if (!_parsed)
            {
                <div class="sup-tab-nav">
                    <button class="sup-tab-btn @(_tab==0?"active":"")" @onclick='()=>_tab=0'>PDF</button>
                    <button class="sup-tab-btn @(_tab==1?"active":"")" @onclick='()=>_tab=1'>Código QR</button>
                </div>

                @if (_tab == 0)
                {
                    <label id="sup-csf-drop-zone" class="sup-csf-drop @(_dragging?"dragging":"")">
                        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        <div class="fw-semibold small">Arrastra el PDF aquí o haz clic para seleccionar</div>
                        <div class="text-secondary" style="font-size:0.72rem;">Constancia de Situación Fiscal del SAT (.pdf)</div>
                        <input id="sup-csf-pdf-input" type="file" accept=".pdf" style="display:none;" />
                    </label>
                }
                else
                {
                    <div class="text-center">
                        <label for="sup-csf-qr-input" class="btn btn-primary btn-sm px-3" style="cursor:pointer;border-radius:8px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/>
                                <line x1="14" y1="14" x2="14" y2="21"/><line x1="14" y1="14" x2="21" y2="14"/>
                                <line x1="21" y1="21" x2="21" y2="21"/>
                            </svg>
                            Tomar foto del QR
                        </label>
                        <input id="sup-csf-qr-input" type="file" accept="image/*" capture="environment" style="display:none;" />
                        <div class="mt-2 mb-2 text-secondary small">— o ingresa el RFC manualmente —</div>
                        <div class="input-group input-group-sm" style="max-width:260px;margin:0 auto;">
                            <input type="text" class="form-control" placeholder="RFC del proveedor" maxlength="13"
                                   @bind="_rfcManual" @bind:event="oninput" style="text-transform:uppercase;" />
                            <button class="btn btn-outline-primary" type="button" @onclick="ImportManualAsync">Importar</button>
                        </div>
                    </div>
                }

                @if (_parsing)
                {
                    <div class="text-center py-3 text-primary small fw-semibold">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        Procesando archivo...
                    </div>
                }
            }
            else
            {
                @* Preview de datos extraídos *@
                <div class="sup-preview-tag">Vista previa · Datos extraídos de la CSF</div>

                <div class="sup-field-row mt-2">
                    <div class="sup-field">
                        <label>RFC</label>
                        <input @bind="_data.Rfc" />
                    </div>
                    <div class="sup-field">
                        <label>Razón Social / Nombre</label>
                        <input @bind="_data.LegalName" />
                    </div>
                    <div class="sup-field">
                        <label>Código Postal</label>
                        <input @bind="_data.ZipCode" />
                    </div>
                    <div class="sup-field">
                        <label>Régimen fiscal</label>
                        <input @bind="_data.PrimaryFiscalRegime" />
                    </div>
                    <div class="sup-field">
                        <label>Calle</label>
                        <input @bind="_data.Street" />
                    </div>
                    <div class="sup-field">
                        <label>Núm. Exterior</label>
                        <input @bind="_data.ExteriorNumber" />
                    </div>
                    <div class="sup-field">
                        <label>Colonia</label>
                        <input @bind="_data.Neighborhood" />
                    </div>
                    <div class="sup-field">
                        <label>Municipio</label>
                        <input @bind="_data.Municipality" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary btn-sm px-4" @onclick="CommitImportAsync" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <span>Guardar proveedor</span>
                        }
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ResetModal">Cancelar</button>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _showModal;
    private int _tab;
    private bool _parsing;
    private bool _parsed;
    private bool _saving;
    private bool _dragging;
    private string _rfcManual = string.Empty;
    private string _error = string.Empty;
    private string _success = string.Empty;

    private ConstanciaData _data = new();
    private DotNetObjectReference<Suppliers>? _dotNetRef;

    private sealed class ConstanciaData
    {
        public string Rfc { get; set; } = string.Empty;
        public string LegalName { get; set; } = string.Empty;
        public string ZipCode { get; set; } = string.Empty;
        public string Street { get; set; } = string.Empty;
        public string ExteriorNumber { get; set; } = string.Empty;
        public string Neighborhood { get; set; } = string.Empty;
        public string Municipality { get; set; } = string.Empty;
        public string PrimaryFiscalRegime { get; set; } = string.Empty;
    }

    private void OpenModal()
    {
        ResetModal();
        _showModal = true;
        _ = Task.Run(async () =>
        {
            await Task.Delay(120);
            await InvokeAsync(InitJsAsync);
        });
    }

    private async Task InitJsAsync()
    {
        _dotNetRef ??= DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("constanciaHelper.dispose");
            await JS.InvokeVoidAsync("constanciaHelper.init", _dotNetRef);
            await JS.InvokeVoidAsync("constanciaHelper.wireFileInput", "sup-csf-pdf-input", true);
            await JS.InvokeVoidAsync("constanciaHelper.wireFileInput", "sup-csf-qr-input", false);
        }
        catch { }
    }

    private void CloseModal()
    {
        _showModal = false;
        _ = JS.InvokeVoidAsync("constanciaHelper.dispose").AsTask();
    }

    private void ResetModal()
    {
        _tab = 0; _parsing = false; _parsed = false; _saving = false; _dragging = false;
        _rfcManual = string.Empty; _error = string.Empty; _success = string.Empty;
        _data = new();
    }

    [JSInvokable]
    public void SetParsing(bool v) { _parsing = v; InvokeAsync(StateHasChanged); }

    [JSInvokable]
    public void ReceiveParsedData(string json)
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var raw = JsonSerializer.Deserialize<JsonElement>(json, opts);
            _data = new ConstanciaData
            {
                Rfc = raw.TryGetProperty("rfc", out var rfc) ? rfc.GetString() ?? "" : "",
                LegalName = raw.TryGetProperty("legalName", out var ln) ? ln.GetString() ?? "" : "",
                ZipCode = raw.TryGetProperty("zipCode", out var zc) ? zc.GetString() ?? "" : "",
                Street = raw.TryGetProperty("street", out var st) ? st.GetString() ?? "" : "",
                ExteriorNumber = raw.TryGetProperty("exteriorNumber", out var en) ? en.GetString() ?? "" : "",
                Neighborhood = raw.TryGetProperty("neighborhood", out var nb) ? nb.GetString() ?? "" : "",
                Municipality = raw.TryGetProperty("municipality", out var mu) ? mu.GetString() ?? "" : "",
                PrimaryFiscalRegime = raw.TryGetProperty("primaryFiscalRegime", out var pr) ? pr.GetString() ?? "" : "",
            };
            _parsing = false; _parsed = true; _error = string.Empty;
        }
        catch { _error = "Error al interpretar la respuesta."; _parsing = false; }
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void ReceiveParseError(string msg) { _error = msg; _parsing = false; InvokeAsync(StateHasChanged); }

    private async Task ImportManualAsync()
    {
        var rfc = _rfcManual.Trim().ToUpper();
        if (rfc.Length < 12) { _error = "RFC inválido."; return; }
        _data = new ConstanciaData { Rfc = rfc };
        _parsed = true; _error = string.Empty;
        await Task.CompletedTask;
    }

    private async Task CommitImportAsync()
    {
        if (string.IsNullOrWhiteSpace(_data.Rfc)) { _error = "RFC es obligatorio."; return; }

        _saving = true; _error = string.Empty; _success = string.Empty;
        var tenantId = AuthState.TenantId;
        var companyId = AuthState.CompanyId;

        try
        {
            var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
            var body = new
            {
                rfc = _data.Rfc, legalName = _data.LegalName, zipCode = _data.ZipCode,
                street = _data.Street, exteriorNumber = _data.ExteriorNumber,
                neighborhood = _data.Neighborhood, municipality = _data.Municipality,
                fiscalRegimeCode = _data.PrimaryFiscalRegime,
                userId = AuthState.UserId?.ToString()
            };
            var resp = await client.PostAsJsonAsync($"/api/suppliers/import-constancia?tenantId={tenantId}&companyId={companyId}", body);
            var json = await resp.Content.ReadFromJsonAsync<JsonElement>();

            if (resp.IsSuccessStatusCode)
            {
                var msg = json.TryGetProperty("message", out var m) ? m.GetString() : "Proveedor guardado.";
                _success = msg ?? "Proveedor guardado.";
                _parsed = false;
            }
            else
            {
                _error = json.TryGetProperty("message", out var em) ? em.GetString() ?? "Error." : "Error al guardar.";
            }
        }
        catch (Exception ex) { _error = $"Error de conexión: {ex.Message}"; }
        finally { _saving = false; }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("constanciaHelper.dispose"); } catch { }
        _dotNetRef?.Dispose();
    }
}
