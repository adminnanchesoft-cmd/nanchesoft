@page "/administration/universal-import"
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject Nanchesoft.Web.Services.AuthService AuthService
@inject Nanchesoft.Web.State.AppState AppState
@inject Nanchesoft.Web.State.AuthState AuthState
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>

<div class="ns-page-header">
    <div class="ns-page-header__left">
        <div class="ns-page-header__breadcrumb">@BreadcrumbText</div>
        <h1 class="ns-page-header__title">@HeaderTitle</h1>
        <p class="ns-page-header__subtitle">@HeaderSubtitle</p>
    </div>
</div>

<div class="ns-section">

    @* ── Stepper ───────────────────────────────────────────────── *@
    <div class="ns-import-stepper">
        <div class="ns-import-step @StepClass(1)"><span class="ns-import-step__num">1</span><span class="ns-import-step__label">Cargar archivo</span></div>
        <div class="ns-import-step-sep"></div>
        <div class="ns-import-step @StepClass(2)"><span class="ns-import-step__num">2</span><span class="ns-import-step__label">Revisar mapeo</span></div>
        <div class="ns-import-step-sep"></div>
        <div class="ns-import-step @StepClass(3)"><span class="ns-import-step__num">3</span><span class="ns-import-step__label">Resultados</span></div>
    </div>

    @* ══════ Step 1 — Upload ══════════════════════════════════════ *@
    @if (_step == 1)
    {
        <div id="ns-universal-import-dz"
             class="ns-import-upload-zone">
            <svg viewBox="0 0 48 48" width="42" height="42" fill="none"><path d="M24 34V14m0 0-8 8m8-8 8 8" stroke="#64748b" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/><rect x="4" y="36" width="40" height="6" rx="3" fill="#e2e8f0"/></svg>
            <div class="ns-import-upload-zone__text">Arrastra tu archivo CSV aquí</div>
            <div class="ns-import-upload-zone__sub">o haz clic para seleccionar</div>
            <label class="ns-import-upload-btn">
                Seleccionar CSV
                <InputFile OnChange="OnFileSelectedAsync" accept=".csv,.txt" style="display:none" />
            </label>
        </div>

        @if (!string.IsNullOrEmpty(_uploadError))
        {
            <div class="alert alert-danger mt-3">@_uploadError</div>
        }

        @if (_analyzing)
        {
            <div class="text-muted mt-3"><span class="spinner-border spinner-border-sm me-2"></span>Analizando columnas…</div>
        }
    }

    @* ══════ Step 2 — Mapping ══════════════════════════════════════ *@
    @if (_step == 2 && _analysis is not null)
    {
        <div class="ns-import-analysis-header">
            <div>
                <strong>Entidad detectada:</strong>
                <span class="badge bg-primary ms-2">@_analysis.EntityName</span>
                <span class="text-muted ms-2 small">(puntuación @_analysis.Score)</span>
            </div>

            @* Entity override *@
            <div class="d-flex align-items-center gap-2 mt-2">
                <label class="ns-field-label mb-0">¿Incorrecta? Elige manualmente:</label>
                <select class="form-select form-select-sm" style="width:220px" @onchange="OnEntityOverrideAsync">
                    <option value="">— Automático —</option>
                    @foreach (var e in _entities)
                    {
                        <option value="@e.Key" selected="@(_analysis.EntityKey == e.Key)">[@e.Group] @e.Name</option>
                    }
                </select>
            </div>
        </div>

        @* Row count banner *@
        <div class="alert alert-success d-flex align-items-center gap-2 mt-3 py-2" style="font-size:.9rem;">
            <span class="bi bi-check-circle-fill"></span>
            <span>Archivo cargado — <strong>@_allRows.Count</strong> @(_allRows.Count == 1 ? "registro listo" : "registros listos") para importar</span>
        </div>

        @* Data preview — all rows (scrollable) *@
        @if (_allRows.Count > 0)
        {
            <div style="overflow-x:auto;max-height:280px;border:1px solid #bfdbfe;border-radius:8px;margin-bottom:16px;">
                <table class="table table-sm table-bordered mb-0" style="font-size:.8rem;white-space:nowrap;">
                    <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                        <tr>
                            <th style="min-width:36px;">#</th>
                            @foreach (var h in _csvHeaders) { <th>@h</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rowNum = 1; }
                        @foreach (var row in _allRows)
                        {
                            <tr>
                                <td class="text-muted">@(rowNum++)</td>
                                @foreach (var cell in row) { <td>@cell</td> }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @* Column mapping *@
        <p class="ns-field-label mb-1">Mapeo de columnas</p>
        <div class="table-responsive">
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Columna CSV</th>
                        <th>Campo Nanchesoft</th>
                        <th>Tipo</th>
                        <th>Requerido</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in _analysis.Mappings)
                    {
                        <tr class="@(m.FieldKey is null ? "table-warning" : "")">
                            <td><code>@m.CsvColumn</code></td>
                            <td>
                                <select class="form-select form-select-sm"
                                        value="@m.FieldKey"
                                        @onchange="e => OnMappingChange(m, e.Value?.ToString())">
                                    <option value="">— Ignorar —</option>
                                    @foreach (var field in _currentEntityFields)
                                    {
                                        <option value="@field.Key" selected="@(m.FieldKey == field.Key)">@field.Name</option>
                                    }
                                </select>
                            </td>
                            <td><span class="badge bg-secondary">@(m.DataType ?? "—")</span></td>
                            <td>@(m.IsRequired ? "✓" : "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-secondary" @onclick="ResetWizard">← Volver</button>
            <button class="btn btn-primary" @onclick="ExecuteImportAsync" disabled="@_executing">
                @if (_executing)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Importar @_allRows.Count @(_allRows.Count == 1 ? "registro" : "registros")
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_executeError))
        {
            <div class="alert alert-danger mt-3">@_executeError</div>
        }
    }

    @* ══════ Step 3 — Results ══════════════════════════════════════ *@
    @if (_step == 3 && _importResult is not null)
    {
        <div class="ns-import-result-summary">
            <div class="ns-import-result-card ns-import-result-card--ok">
                <div class="ns-import-result-card__num">@_importResult.Created</div>
                <div class="ns-import-result-card__label">Creados</div>
            </div>
            <div class="ns-import-result-card ns-import-result-card--ok">
                <div class="ns-import-result-card__num">@_importResult.Updated</div>
                <div class="ns-import-result-card__label">Actualizados</div>
            </div>
            <div class="ns-import-result-card ns-import-result-card--dup">
                <div class="ns-import-result-card__num">@_importResult.Duplicates</div>
                <div class="ns-import-result-card__label">Duplicados</div>
            </div>
            <div class="ns-import-result-card ns-import-result-card--err">
                <div class="ns-import-result-card__num">@_importResult.Failed</div>
                <div class="ns-import-result-card__label">Con error</div>
            </div>
            <div class="ns-import-result-card">
                <div class="ns-import-result-card__num">@_importResult.Total</div>
                <div class="ns-import-result-card__label">Total</div>
            </div>
        </div>

        <div class="table-responsive mt-4">
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr><th>Fila</th><th>Estado</th><th>Mensaje</th></tr>
                </thead>
                <tbody>
                    @foreach (var r in _importResult.Rows)
                    {
                        <tr class="@ResultRowClass(r.Status)">
                            <td>@r.Row</td>
                            <td>@ResultStatusText(r.Status)</td>
                            <td>@r.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" @onclick="ResetWizard">Nueva importación</button>
        </div>
    }

</div>

@code {
    // ── State ──────────────────────────────────────────────────────
    private int _step = 1;
    private bool _analyzing;
    private bool _dropZoneReady;
    private DotNetObjectReference<UniversalImport>? _dotNetRef;
    private bool _executing;
    private string _uploadError = "";
    private string _executeError = "";

    private List<string> _csvHeaders = [];
    private List<List<string?>> _previewRows = [];
    private List<List<string?>> _allRows = [];

    private List<EntityInfo> _entities = [];
    private AnalysisResult? _analysis;
    private List<FieldInfo> _currentEntityFields = [];
    private ImportResult? _importResult;
    [Parameter, SupplyParameterFromQuery(Name = "entity")] public string? Entity { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }

    private bool IsEmployeesImport => string.Equals(Entity, "hr-employees", StringComparison.OrdinalIgnoreCase);
    private string PageTitleText => IsEmployeesImport ? "Importar colaboradores | Nanchesoft" : "Importación universal | Nanchesoft";
    private string BreadcrumbText => IsEmployeesImport ? "Recursos Humanos / Colaboradores / Importar CSV" : "Administración / Importación universal";
    private string HeaderTitle => IsEmployeesImport ? "Importar colaboradores" : "Importación universal";
    private string HeaderSubtitle => IsEmployeesImport
        ? "Carga el CSV de colaboradores, revisa el mapeo y confirma la importación."
        : "Sube cualquier CSV del ERP — el sistema detecta la entidad y mapea las columnas automáticamente.";

    // ── Lifecycle ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try { await AuthService.RestoreSessionAsync(); } catch { }
        var client = CreateScopedClient();
        _entities = await client.GetFromJsonAsync<List<EntityInfo>>("/api/import/entities") ?? [];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || !_dropZoneReady)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("nsImport.initDropZone", "ns-universal-import-dz", _dotNetRef);
                _dropZoneReady = true;
            }
            catch { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await Task.CompletedTask;
    }

    // ── File handling ─────────────────────────────────────────────
    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        await LoadFileAsync(e.File);
    }

    [JSInvokable]
    public async Task HandleDroppedCsv(string csvText)
    {
        _uploadError = "";
        try
        {
            await ProcessCsvText(csvText);
        }
        catch (Exception ex)
        {
            _uploadError = $"Error al leer el archivo: {ex.Message}";
        }
        finally
        {
            _analyzing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadFileAsync(IBrowserFile file)
    {
        _uploadError = "";
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase) &&
            !file.Name.EndsWith(".txt", StringComparison.OrdinalIgnoreCase))
        {
            _uploadError = "Solo se aceptan archivos .csv o .txt";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var text = DecodeWithFallback(bytes);
            await ProcessCsvText(text);
        }
        catch (Exception ex)
        {
            _uploadError = $"Error al leer el archivo: {ex.Message}";
        }
        finally
        {
            _analyzing = false;
        }
    }

    private static string DecodeWithFallback(byte[] bytes)
    {
        // Try UTF-8 strictly; on failure (invalid byte sequence) fall back to Latin-1.
        try
        {
            var utf8 = new System.Text.UTF8Encoding(false, throwOnInvalidBytes: true);
            return utf8.GetString(bytes);
        }
        catch
        {
            return System.Text.Encoding.Latin1.GetString(bytes);
        }
    }

    private async Task ProcessCsvText(string text)
    {
        var lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries)
                        .Select(l => l.TrimEnd('\r'))
                        .Where(l => !string.IsNullOrWhiteSpace(l))
                        .ToList();

        if (lines.Count < 2)
        {
            _uploadError = "El archivo está vacío o solo tiene encabezados.";
            return;
        }

        var sep = DetectSeparator(lines);

        // Saltar filas de preámbulo: el verdadero header es la primera fila con ≥3 celdas no vacías
        int headerIdx = 0;
        for (int i = 0; i < Math.Min(lines.Count, 10); i++)
        {
            var fields = ParseCsvLine(lines[i], sep);
            var nonEmpty = fields.Count(f => !string.IsNullOrWhiteSpace(f));
            if (nonEmpty >= 3) { headerIdx = i; break; }
        }

        _csvHeaders = ParseCsvLine(lines[headerIdx], sep);
        _allRows = lines.Skip(headerIdx + 1)
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .Select(l => (List<string?>)ParseCsvLine(l, sep).Cast<string?>().ToList())
            // Filtrar filas que son todas vacías (después de saltar preámbulo puede haber otras)
            .Where(r => r.Any(c => !string.IsNullOrWhiteSpace(c)))
            .ToList();
        _previewRows = _allRows.Take(5).ToList();

        _analyzing = true;
        StateHasChanged();

        await AnalyzeAsync();
    }

    private static List<string> ParseCsvLine(string line, char sep)
    {
        var fields = new List<string>();
        var sb = new System.Text.StringBuilder();
        bool inQuotes = false;
        for (int i = 0; i < line.Length; i++)
        {
            char c = line[i];
            if (c == '"')
            {
                if (inQuotes && i + 1 < line.Length && line[i + 1] == '"')
                { sb.Append('"'); i++; }
                else inQuotes = !inQuotes;
            }
            else if (c == sep && !inQuotes)
            { fields.Add(sb.ToString().Trim()); sb.Clear(); }
            else sb.Append(c);
        }
        fields.Add(sb.ToString().Trim());
        return fields;
    }

    private static char DetectSeparator(List<string> lines)
    {
        var sample = lines.Take(10).ToList();
        var candidates = new[] { '\t', ';', ',' };
        char bestSep = ',';
        int bestScore = int.MinValue;

        foreach (var candidate in candidates)
        {
            var counts = sample
                .Select(line => ParseCsvLine(line, candidate).Count)
                .ToList();

            var nonTrivial = counts.Where(x => x >= 3).ToList();
            if (nonTrivial.Count == 0)
                continue;

            var mode = nonTrivial
                .GroupBy(x => x)
                .OrderByDescending(g => g.Count())
                .ThenByDescending(g => g.Key)
                .First();

            var score = (mode.Count() * 100) + mode.Key;

            if (candidate == '\t' && sample.Any(x => x.Contains('\t')))
                score += 50;

            if (score > bestScore)
            {
                bestScore = score;
                bestSep = candidate;
            }
        }

        return bestSep;
    }

    // ── Analysis ──────────────────────────────────────────────────
    private async Task AnalyzeAsync()
    {
        var client = CreateScopedClient();
        var req = new { Headers = _csvHeaders, FirstRows = _previewRows };
        var resp = await client.PostAsJsonAsync("/api/import/analyze", req);
        if (!resp.IsSuccessStatusCode) { _uploadError = "Error al analizar el archivo."; return; }

        _analysis = await resp.Content.ReadFromJsonAsync<AnalysisResult>();
        if (_analysis is not null)
        {
            if (!string.IsNullOrWhiteSpace(Entity))
            {
                var entity = _entities.FirstOrDefault(x => string.Equals(x.Key, Entity, StringComparison.OrdinalIgnoreCase));
                if (entity is not null)
                {
                    _analysis.EntityKey = entity.Key;
                    _analysis.EntityName = entity.Name;
                }
            }
            UpdateFieldList(_analysis.EntityKey);
        }

        _step = 2;
    }

    private async Task OnEntityOverrideAsync(ChangeEventArgs e)
    {
        var key = e.Value?.ToString();
        if (string.IsNullOrEmpty(key) || _analysis is null) return;

        // Re-analyze with forced entity key by sending only matching headers
        var client = CreateScopedClient();
        var req = new { Headers = _csvHeaders, FirstRows = _previewRows };
        var resp = await client.PostAsJsonAsync("/api/import/analyze", req);
        _analysis = await resp.Content.ReadFromJsonAsync<AnalysisResult>();

        // Override entity key/name
        var entity = _entities.FirstOrDefault(x => x.Key == key);
        if (_analysis is not null && entity is not null)
        {
            _analysis.EntityKey = key;
            _analysis.EntityName = entity.Name;
        }
        UpdateFieldList(key);
    }

    private void UpdateFieldList(string? entityKey)
    {
        // Build field list from the analysis mappings as authoritative source
        // We reconstruct from all mapped fields + entity knowledge
        // Since we don't have a separate /fields endpoint, derive from analysis
        if (_analysis is null) return;

        // Collect all fields seen in mappings plus any unmapped ones we know about
        _currentEntityFields = _analysis.Mappings
            .Where(m => m.FieldKey is not null)
            .GroupBy(m => m.FieldKey!)
            .Select(g => new FieldInfo(g.Key, g.First().FieldName ?? g.Key, g.First().DataType ?? "text", g.First().IsRequired))
            .ToList();

        // Add fields from entity that are not yet in the mapping list
        // (so user can manually map ignored columns)
        // We don't have full schema on the client, so just use what we've got.
    }

    private void OnMappingChange(ColumnMapping m, string? newFieldKey)
    {
        m.FieldKey = string.IsNullOrEmpty(newFieldKey) ? null : newFieldKey;
        var field = _currentEntityFields.FirstOrDefault(f => f.Key == newFieldKey);
        m.FieldName = field?.Name;
        m.DataType = field?.DataType;
        m.IsRequired = field?.IsRequired ?? false;
    }

    // ── Execution ─────────────────────────────────────────────────
    private async Task ExecuteImportAsync()
    {
        if (_analysis is null) return;
        _executeError = "";
        _executing = true;
        StateHasChanged();

        try
        {
            var client = CreateScopedClient();
            var mappings = _analysis.Mappings
                .Where(m => m.FieldKey is not null)
                .Select(m => new { ColumnIndex = m.ColumnIndex, CsvColumn = m.CsvColumn, FieldKey = m.FieldKey! })
                .ToList();

            var req = new
            {
                EntityKey = _analysis.EntityKey,
                Headers = _csvHeaders,
                Rows = _allRows,
                Mappings = mappings
            };

            var resp = await client.PostAsJsonAsync("/api/import/execute", req);
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                _executeError = $"Error del servidor: {body}";
                return;
            }

            _importResult = System.Text.Json.JsonSerializer.Deserialize<ImportResult>(body,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            _step = 3;
        }
        catch (Exception ex)
        {
            _executeError = $"Error: {ex.Message}";
        }
        finally
        {
            _executing = false;
        }
    }

    // ── Reset ─────────────────────────────────────────────────────
    private void ResetWizard()
    {
        _step = 1;
        _csvHeaders = [];
        _previewRows = [];
        _allRows = [];
        _analysis = null;
        _importResult = null;
        _uploadError = "";
        _executeError = "";
        _dropZoneReady = false;
    }

    private string StepClass(int n) =>
        _step == n ? "ns-import-step--active" :
        _step > n  ? "ns-import-step--done" : "";

    private static string ResultRowClass(string status) => status switch
    {
        "error" => "table-danger",
        "duplicado" => "table-warning",
        "updated" => "table-info",
        "created" => "table-success",
        _ => ""
    };

    private static string ResultStatusText(string status) => status switch
    {
        "created" => "Creado",
        "updated" => "Actualizado",
        "duplicado" => "Duplicado",
        "error" => "Error",
        _ => status
    };

    private HttpClient CreateScopedClient()
    {
        var client = HttpClientFactory.CreateClient("Nanchesoft.Api");
        Set("X-Tenant-Id", AppState.CurrentTenantId ?? AuthState.TenantId, client);
        Set("X-Company-Id", AppState.CurrentCompanyId ?? AuthState.CompanyId, client);
        Set("X-Branch-Id", AppState.CurrentBranchId ?? AuthState.BranchId, client);
        Set("X-User-Id", AuthState.UserId, client);
        client.DefaultRequestHeaders.Remove("X-Is-Platform-Owner");
        client.DefaultRequestHeaders.Add("X-Is-Platform-Owner", AuthState.IsPlatformOwner ? "true" : "false");
        return client;
    }

    private static void Set(string header, Guid? value, HttpClient client)
    {
        client.DefaultRequestHeaders.Remove(header);
        if (value.HasValue && value.Value != Guid.Empty)
            client.DefaultRequestHeaders.Add(header, value.Value.ToString("D"));
    }

    // ── DTOs ──────────────────────────────────────────────────────
    private sealed record EntityInfo(string Key, string Name, string Group);
    private sealed record FieldInfo(string Key, string Name, string DataType, bool IsRequired);

    private sealed class AnalysisResult
    {
        public string? EntityKey  { get; set; }
        public string? EntityName { get; set; }
        public List<ColumnMapping> Mappings { get; set; } = [];
        public int Score { get; set; }
    }

    private sealed class ColumnMapping
    {
        public int ColumnIndex  { get; set; }
        public string CsvColumn  { get; set; } = "";
        public string? FieldKey  { get; set; }
        public string? FieldName { get; set; }
        public string? DataType  { get; set; }
        public bool IsFk         { get; set; }
        public string? FkEntity  { get; set; }
        public bool IsRequired   { get; set; }
    }

    private sealed class ImportResult
    {
        public int Total     { get; set; }
        public int Imported  { get; set; }
        public int Created   { get; set; }
        public int Updated   { get; set; }
        public int Duplicates{ get; set; }
        public int Failed    { get; set; }
        public List<RowResult> Rows { get; set; } = [];
    }

    private sealed record RowResult(int Row, string Status, string Message);
}
