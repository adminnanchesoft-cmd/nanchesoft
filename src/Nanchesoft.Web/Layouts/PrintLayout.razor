@inherits LayoutComponentBase

<div class="print-layout">
    @Body
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
        background: #ffffff;
    }

    .print-layout {
        margin: 0;
        padding: 0;
        background: #ffffff;
        min-height: 100vh;
    }

    @@media print {
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            background: #ffffff !important;
        }

        .print-layout {
            margin: 0 !important;
            padding: 0 !important;
            background: #ffffff !important;
        }
    }
</style>