@inherits LayoutComponentBase

<div class="ns-authlight">
    <header class="ns-authlight__topbar">
        <a class="ns-authlight__brand" href="https://nanchesoft.com" target="_blank" rel="noopener" aria-label="Nanchesoft Cloud">
            <img class="ns-authlight__brand-logo" src="images/brand/nanchesoft_full_light.svg" alt="Nanchesoft Cloud" />
        </a>

        <div class="ns-authlight__top-actions">
            <span class="ns-authlight__top-pill">
                <span class="ns-authlight__top-pill-dot"></span>
                Ventas · Inventario · Finanzas · Reportes
            </span>
            <a class="ns-authlight__demo-link" href="https://nanchesoft.com/contact" target="_blank" rel="noopener">
                Solicitar una demo
            </a>
        </div>
    </header>

    <div class="ns-authlight__shell">
        <section class="ns-authlight__hero" aria-label="Nanchesoft Cloud">
            <div class="ns-authlight__hero-logo">
                <img src="images/brand/nanchesoft_full_light.svg" alt="Nanchesoft Cloud - Controla, vende y crece desde la nube" />
            </div>
        </section>

        <main class="ns-authlight__form-side">
            <div class="ns-authlight__form-panel">
                @Body
            </div>
        </main>
    </div>

    <footer class="ns-authlight__footer">
        <span>© @DateTime.Now.Year Nanchesoft Cloud · ERP para empresas mexicanas</span>
        <span class="ns-authlight__footer-links">
            <a href="https://nanchesoft.com/contact" target="_blank" rel="noopener">Contacto</a>
            <span aria-hidden="true">·</span>
            <a href="https://nanchesoft.com/privacy" target="_blank" rel="noopener">Privacidad</a>
            <span aria-hidden="true">·</span>
            <a href="https://nanchesoft.com/security" target="_blank" rel="noopener">Seguridad</a>
        </span>
    </footer>
</div>

<style>
    /* ========================================================
       NANCHESOFT AUTH · Tema claro premium estilo Apple
       ======================================================== */

    .ns-authlight {
        --ns-bg: #f5f7fa;
        --ns-bg-soft: #eef2f7;
        --ns-card: #ffffff;
        --ns-blue-700: #0b4ea2;
        --ns-blue-500: #0078d4;
        --ns-cyan-400: #14c8ff;
        --ns-cyan-300: #64e7ff;
        --ns-ink-900: #0b1f3c;
        --ns-ink-700: #1f3350;
        --ns-ink-500: #51637c;
        --ns-ink-400: #7888a0;
        --ns-line: #e2e8f0;
        --ns-success: #16a34a;

        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        color: var(--ns-ink-900);
        background:
            radial-gradient(circle at 12% 14%, rgba(20, 200, 255, .10), transparent 38%),
            radial-gradient(circle at 86% 8%, rgba(0, 120, 212, .08), transparent 32%),
            linear-gradient(180deg, #f7f9fc 0%, #eef2f7 100%);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    .ns-authlight__topbar {
        position: relative;
        z-index: 4;
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 12px 34px;
        border-bottom: 1px solid var(--ns-line);
        background: rgba(255, 255, 255, .72);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
    }

    .ns-authlight__brand {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }

    .ns-authlight__brand-logo {
        height: 42px;
        width: auto;
        display: block;
    }

    .ns-authlight__top-actions {
        display: inline-flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
    }

    .ns-authlight__top-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        color: var(--ns-ink-700);
        background: #fff;
        border: 1px solid var(--ns-line);
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
        box-shadow: 0 1px 2px rgba(15, 35, 80, .04);
    }

    .ns-authlight__top-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--ns-success);
        box-shadow: 0 0 0 4px rgba(22, 163, 74, .14);
    }

    .ns-authlight__demo-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 16px;
        border-radius: 999px;
        color: #fff;
        text-decoration: none;
        font-size: .82rem;
        font-weight: 800;
        background: linear-gradient(135deg, #14c8ff 0%, #0078d4 100%);
        box-shadow: 0 10px 24px rgba(0, 120, 212, .22);
        transition: transform .16s ease, box-shadow .16s ease, filter .16s ease;
        white-space: nowrap;
    }

    .ns-authlight__demo-link:hover {
        transform: translateY(-1px);
        filter: brightness(1.05);
        box-shadow: 0 14px 30px rgba(0, 120, 212, .30);
    }

    .ns-authlight__shell {
        position: relative;
        z-index: 2;
        flex: 1;
        display: grid;
        grid-template-columns: 1.05fr .95fr;
        min-height: calc(100vh - 120px);
    }

    .ns-authlight__hero {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 44px 58px;
    }

    .ns-authlight__hero-logo {
        max-width: 560px;
        width: 100%;
    }

    .ns-authlight__hero-logo img {
        width: 100%;
        height: auto;
        display: block;
        filter: drop-shadow(0 28px 60px rgba(11, 31, 60, .12));
    }

    .ns-authlight__form-side {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 38px 44px;
    }

    .ns-authlight__form-panel {
        width: 100%;
        max-width: 440px;
    }

    .ns-authlight__footer {
        position: relative;
        z-index: 3;
        min-height: 48px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 12px 34px;
        color: var(--ns-ink-400);
        border-top: 1px solid var(--ns-line);
        background: rgba(255, 255, 255, .72);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        font-size: .76rem;
        font-weight: 600;
    }

    .ns-authlight__footer-links {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .ns-authlight__footer a {
        color: var(--ns-ink-500);
        text-decoration: none;
        font-weight: 700;
        transition: color .15s ease;
    }

    .ns-authlight__footer a:hover {
        color: var(--ns-blue-500);
    }

    @@media (max-width: 1120px) {
        .ns-authlight__shell {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .ns-authlight__hero {
            display: none;
        }

        .ns-authlight__form-side {
            min-height: calc(100vh - 120px);
            padding: 48px 22px;
        }
    }

    @@media (max-width: 760px) {
        .ns-authlight__topbar {
            padding: 10px 16px;
        }

        .ns-authlight__brand-logo {
            height: 34px;
        }

        .ns-authlight__top-pill {
            display: none;
        }

        .ns-authlight__footer {
            flex-direction: column;
            justify-content: center;
            gap: 6px;
            text-align: center;
            padding: 12px 18px;
        }
    }

    @@media (max-width: 430px) {
        .ns-authlight__demo-link {
            display: none;
        }
    }
</style>
